---
import { clsx } from 'clsx';
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
  sticky?: boolean;
  title?: string;
  collapsible?: boolean;
  defaultOpen?: boolean;
}

const { headings, sticky = true, title = 'On this page', collapsible = false, defaultOpen = false } = Astro.props;

// Filter out h1 (usually the title) and limit depth
const toc = headings.filter((h) => h.depth > 1 && h.depth <= 3);
---

{collapsible ? (
  <details open={defaultOpen} class="group">
    <summary class="cursor-pointer select-none list-none flex items-center justify-between gap-3 rounded-xl border border-black/10 dark:border-white/10 bg-black/[0.04] dark:bg-white/[0.06] px-4 py-3 transition-colors hover:bg-black/[0.07] dark:hover:bg-white/[0.10] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40">
      <span class="font-bold text-base text-foreground">{title}</span>
      <span class="text-base text-foreground/70 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <nav class={clsx(
      sticky && "sticky top-24 max-h-[calc(100vh-6rem)]",
      "overflow-auto pb-2 pt-4"
    )}>
      <ul class="text-base space-y-2.5 border-l border-foreground/10 pl-4">
        {toc.length === 0 && (
          <li class="pl-2 text-foreground/50 italic text-xs">No subheadings</li>
        )}
        {toc.map((heading) => (
          <li class={clsx(
            "transition-colors duration-200",
            heading.depth === 3 && "pl-4"
          )}>
            <a 
              href={`#${heading.slug}`}
              class="block text-foreground/70 hover:text-primary transition-colors"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </details>
) : (
  <nav class={clsx(
    sticky && "sticky top-24 max-h-[calc(100vh-6rem)]",
    "overflow-auto pb-10"
  )}>
    <h4 class="font-bold text-sm mb-4 text-foreground">{title}</h4>
    <ul class="text-sm space-y-2.5 border-l border-foreground/10 pl-4">
      {toc.length === 0 && (
        <li class="pl-2 text-foreground/50 italic text-xs">No subheadings</li>
      )}
      {toc.map((heading) => (
        <li class={clsx(
          "transition-colors duration-200",
          heading.depth === 3 && "pl-4"
        )}>
          <a 
            href={`#${heading.slug}`}
            class="block text-foreground/60 hover:text-primary transition-colors"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
    // Simple active state highlighter
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            const id = entry.target.getAttribute('id');
            const link = document.querySelector(`nav ul li a[href="#${id}"]`);
            if (entry.isIntersecting) {
                document.querySelectorAll('nav ul li a').forEach(a => {
                    a.classList.remove('text-primary', 'font-medium');
                    a.classList.add('text-foreground/60');
                });
                link?.classList.remove('text-foreground/60');
                link?.classList.add('text-primary', 'font-medium');
            }
        });
    }, { rootMargin: '0px 0px -80% 0px' });

    document.querySelectorAll('h2, h3').forEach(h => observer.observe(h));
</script>
