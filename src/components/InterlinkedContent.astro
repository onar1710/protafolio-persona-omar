---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection, type CollectionEntry } from 'astro:content';

type BlogEntry = CollectionEntry<'blog'>;

type Props = {
	minLinks?: number;
	maxLinks?: number;
	posts?: BlogEntry[];
	group?: string;
};

const { minLinks = 3, maxLinks = 7, posts: providedPosts, group } = Astro.props;

const pathname = Astro.url.pathname || '/';
const isEn = pathname.startsWith('/en/');
const lang = isEn ? 'en' : 'es';

const rawHtml = await Astro.slots.render('default');

const normalizePath = (p: string): string => {
	if (p === '/') return '/';
	return `/${p.replace(/^\/+/, '').replace(/\/+$/, '')}/`;
};

const currentPath = normalizePath(pathname);
const currentId = (() => {
	if (isEn) {
		const seoSlug = currentPath.replace(/^\/en\/seo\//, '').replace(/\/$/, '');
		if (seoSlug !== currentPath.replace(/\/$/, '')) return seoSlug ? `en/seo/${seoSlug}` : '';

		const webDesignSlug = currentPath.replace(/^\/en\/web-design\//, '').replace(/\/$/, '');
		if (webDesignSlug !== currentPath.replace(/\/$/, '')) return webDesignSlug ? `en/web-design/${webDesignSlug}` : '';

		const dmSlug = currentPath.replace(/^\/en\/digital-marketing\//, '').replace(/\/$/, '');
		if (dmSlug !== currentPath.replace(/\/$/, '')) return dmSlug ? `en/digital-marketing/${dmSlug}` : '';

		const smSlug = currentPath.replace(/^\/en\/social-media\//, '').replace(/\/$/, '');
		if (smSlug !== currentPath.replace(/\/$/, '')) return smSlug ? `en/social-media/${smSlug}` : '';

		const blogSlug = currentPath.replace(/^\/en\/blog\//, '').replace(/\/$/, '');
		return blogSlug ? `en/${blogSlug}` : '';
	}
	const seoSlug = currentPath.replace(/^\/seo\//, '').replace(/\/$/, '');
	if (seoSlug !== currentPath.replace(/\/$/, '')) return seoSlug ? `seo/${seoSlug}` : '';

	const disenowebSlug = currentPath.replace(/^\/disenoweb\//, '').replace(/\/$/, '');
	if (disenowebSlug !== currentPath.replace(/\/$/, '')) return disenowebSlug ? `disenoweb/${disenowebSlug}` : '';

	const marketingSlug = currentPath.replace(/^\/marketing-digital\//, '').replace(/\/$/, '');
	if (marketingSlug !== currentPath.replace(/\/$/, '')) return marketingSlug ? `marketing-digital/${marketingSlug}` : '';

	const socialSlug = currentPath.replace(/^\/social-media\//, '').replace(/\/$/, '');
	if (socialSlug !== currentPath.replace(/\/$/, '')) return socialSlug ? `social-media/${socialSlug}` : '';

	const blogSlug = currentPath.replace(/^\/blog\//, '').replace(/\/$/, '');
	return blogSlug || '';
})();

const hrefForPost = (post: BlogEntry): string => {
	if (post.id.startsWith('en/seo/')) return `/en/seo/${post.id.slice('en/seo/'.length)}/`;
	if (post.id.startsWith('en/web-design/')) return `/en/web-design/${post.id.slice('en/web-design/'.length)}/`;
	if (post.id.startsWith('en/digital-marketing/'))
		return `/en/digital-marketing/${post.id.slice('en/digital-marketing/'.length)}/`;
	if (post.id.startsWith('en/social-media/')) return `/en/social-media/${post.id.slice('en/social-media/'.length)}/`;
	if (post.id.startsWith('en/')) return `/en/blog/${post.id.replace(/^en\//, '')}/`;

	if (post.id.startsWith('seo/')) return `/seo/${post.id.slice('seo/'.length)}/`;
	if (post.id.startsWith('disenoweb/')) return `/disenoweb/${post.id.slice('disenoweb/'.length)}/`;
	if (post.id.startsWith('marketing-digital/'))
		return `/marketing-digital/${post.id.slice('marketing-digital/'.length)}/`;
	if (post.id.startsWith('social-media/')) return `/social-media/${post.id.slice('social-media/'.length)}/`;

	return `/blog/${post.id}/`;
};

const escapeHtml = (value: string): string =>
	String(value)
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/"/g, '&quot;')
		.replace(/'/g, '&#39;');

const stripTags = (value: string): string => String(value).replace(/<[^>]*>/g, ' ');

const countWords = (html: string): number => {
	const text = stripTags(html).replace(/\s+/g, ' ').trim();
	if (!text) return 0;
	return text.split(' ').length;
};

const clampInt = (n: number, min: number, max: number): number => Math.max(min, Math.min(max, Math.trunc(n)));

const decideLinkCount = (words: number): number => {
	if (words < 650) return clampInt(minLinks, 3, 7);
	if (words < 1100) return clampInt(4, minLinks, maxLinks);
	if (words < 1700) return clampInt(5, minLinks, maxLinks);
	if (words < 2300) return clampInt(6, minLinks, maxLinks);
	return clampInt(maxLinks, minLinks, 7);
};

const hashSeed = (value: string): number => {
	let h = 2166136261;
	for (let i = 0; i < value.length; i++) {
		h ^= value.charCodeAt(i);
		h = Math.imul(h, 16777619);
	}
	return h >>> 0;
};

const mulberry32 = (seed: number) => {
	let a = seed >>> 0;
	return () => {
		a += 0x6d2b79f5;
		let t = a;
		t = Math.imul(t ^ (t >>> 15), t | 1);
		t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
		return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
	};
};

const shuffleSeeded = <T,>(items: T[], seedText: string): T[] => {
	const rng = mulberry32(hashSeed(seedText));
	const arr = items.slice();
	for (let i = arr.length - 1; i > 0; i--) {
		const j = Math.floor(rng() * (i + 1));
		[arr[i], arr[j]] = [arr[j], arr[i]];
	}
	return arr;
};

const getDictionary = (): { es: string[]; en: string[] } => {
	const key = '__interlinkDictionary';
	const cached = (globalThis as unknown as Record<string, unknown>)[key];
	if (cached && typeof cached === 'object') return cached as { es: string[]; en: string[] };

	try {
		const filePath = path.join(process.cwd(), 'src', 'components', 'dicionario-interlink.txt');
		const content = fs.readFileSync(filePath, 'utf-8');
		const lines = content
			.split(/\r?\n/g)
			.map((l) => l.trim())
			.filter(Boolean);

		const es: string[] = [];
		const en: string[] = [];
		let section: 'es' | 'en' | null = null;
		for (const line of lines) {
			const low = line.toLowerCase();
			if (low === 'en español' || low === 'español' || low === 'espanol') {
				section = 'es';
				continue;
			}
			if (low === 'en ingles' || low === 'inglés' || low === 'ingles' || low === 'english') {
				section = 'en';
				continue;
			}
			if (section === 'es') es.push(line);
			if (section === 'en') en.push(line);
		}

		const dict = { es, en };
		(globalThis as unknown as Record<string, unknown>)[key] = dict;
		return dict;
	} catch {
		const dict = { es: [], en: [] };
		(globalThis as unknown as Record<string, unknown>)[key] = dict;
		return dict;
	}
};

const dictionary = getDictionary();
const phrases = lang === 'en' ? dictionary.en : dictionary.es;

const allPosts = Array.isArray(providedPosts) ? providedPosts : await getCollection('blog');
const candidates = allPosts
	.filter((p) => (lang === 'en' ? p.id.startsWith('en/') : !p.id.startsWith('en/')))
	.filter((p) => (currentId ? p.id !== currentId : normalizePath(hrefForPost(p)) !== currentPath))
	.filter((p) => (group ? p.data?.relatedGroup === group : true))
	.filter((p) => Boolean(p.data?.title && p.data?.description));

const words = countWords(rawHtml);
const linkCount = clampInt(decideLinkCount(words), minLinks, maxLinks);

const pickedPosts = shuffleSeeded(candidates, `${currentId || currentPath}-targets-${lang}`).slice(0, linkCount);
const pickedPhrases = shuffleSeeded(phrases, `${currentId || currentPath}-phrases-${lang}`).slice(0, linkCount);

const findFaqIndex = (html: string): number => {
	const lower = html.toLowerCase();
	const phrases = ['preguntas frecuentes', 'frequently asked questions', '>faq<', '>faq ', ' faq<', ' faq '];
	let idx = -1;
	for (const p of phrases) {
		const i = lower.indexOf(p);
		if (i >= 0 && (idx < 0 || i < idx)) idx = i;
	}
	return idx;
};

const faqIndex = findFaqIndex(rawHtml);
const beforeFaqHtml = faqIndex >= 0 ? rawHtml.slice(0, faqIndex) : rawHtml;
const afterFaqHtml = faqIndex >= 0 ? rawHtml.slice(faqIndex) : '';

type PMatch = { start: number; end: number; html: string; wordCount: number; hasLink: boolean };

const extractParagraphs = (html: string): PMatch[] => {
	const matches: PMatch[] = [];
	let cursor = 0;
	while (cursor < html.length) {
		const openIdx = html.indexOf('<p', cursor);
		if (openIdx < 0) break;
		const gtIdx = html.indexOf('>', openIdx);
		if (gtIdx < 0) break;
		const closeIdx = html.indexOf('</p>', gtIdx);
		if (closeIdx < 0) break;

		const pHtml = html.slice(openIdx, closeIdx + 4);
		const wc = countWords(pHtml);
		if (wc >= 10) {
			const hasLink = /<a\b/i.test(pHtml);
			matches.push({ start: openIdx, end: closeIdx + 4, html: pHtml, wordCount: wc, hasLink });
		}

		cursor = closeIdx + 4;
	}
	return matches;
};

const paragraphMatchesFallback = extractParagraphs(beforeFaqHtml);
const paragraphMatchesPrimary = paragraphMatchesFallback.filter((p) => !p.hasLink);
const paragraphMatches = paragraphMatchesPrimary.length >= 3 ? paragraphMatchesPrimary : paragraphMatchesFallback;

const buildAnchorHtml = (phrase: string, target: BlogEntry): string => {
	const phraseText = String(phrase || '').trim().replace(/\s+/g, ' ');
	const title = String(target.data.title || '').trim();
	const href = hrefForPost(target);
	if (!phraseText) {
		return `<a href="${escapeHtml(href)}" class="font-semibold text-primary-blue hover:underline">${escapeHtml(title)}</a>`;
	}
	return `${escapeHtml(phraseText)} <a href="${escapeHtml(href)}" class="font-semibold text-primary-blue hover:underline">${escapeHtml(title)}</a>`;
};

const buildInterlinkedHtml = (): string => {
	if (!paragraphMatches.length) return rawHtml;

	const maxInjectIndex = Math.max(0, paragraphMatches.length - 2);
	const usableCount = maxInjectIndex + 1;
	if (usableCount < 3) return rawHtml;

	const injectCount = Math.min(linkCount, usableCount, pickedPosts.length, pickedPhrases.length);
	if (injectCount < 3) return rawHtml;
	const anchors = Array.from({ length: injectCount }, (_, i) => buildAnchorHtml(pickedPhrases[i], pickedPosts[i]));

	const targetParagraphIndexes: number[] = [];
	for (let i = 1; i <= injectCount; i++) {
		const pos = i / (injectCount + 1);
		const idx = Math.min(maxInjectIndex, Math.max(0, Math.round(pos * (usableCount - 1))));
		targetParagraphIndexes.push(idx);
	}

	const uniqueIndexes = Array.from(new Set(targetParagraphIndexes)).sort((a, b) => a - b);
	while (uniqueIndexes.length < injectCount && uniqueIndexes.length < usableCount) {
		const seed = `${currentId || currentPath}-idx-${uniqueIndexes.length}`;
		const rng = mulberry32(hashSeed(seed));
		const candidate = Math.min(maxInjectIndex, Math.floor(rng() * usableCount));
		if (!uniqueIndexes.includes(candidate)) uniqueIndexes.push(candidate);
		uniqueIndexes.sort((a, b) => a - b);
	}

	const injectMap = new Map<number, string>();
	for (let i = 0; i < Math.min(injectCount, uniqueIndexes.length); i++) {
		injectMap.set(uniqueIndexes[i], anchors[i]);
	}

	let out = '';
	let cursor = 0;
	for (let i = 0; i < paragraphMatches.length; i++) {
		const p = paragraphMatches[i];
		out += beforeFaqHtml.slice(cursor, p.start);
		if (injectMap.has(i)) {
			const anchor = injectMap.get(i) as string;
			const injected = p.html.replace(/<\/p>\s*$/i, ` ${anchor}</p>`);
			out += injected;
		} else {
			out += p.html;
		}
		cursor = p.end;
	}
	out += beforeFaqHtml.slice(cursor);
	return out + afterFaqHtml;
};

const interlinkedHtml = buildInterlinkedHtml();
---

<div class="contents" set:html={interlinkedHtml} />
