---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection, type CollectionEntry } from 'astro:content';

type BlogEntry = CollectionEntry<'blog'>;

type Props = {
	minLinks?: number;
	maxLinks?: number;
	posts?: BlogEntry[];
	group?: string;
	tags?: string[];
};

const { minLinks = 2, maxLinks = 7, posts: providedPosts, group, tags: providedTags } = Astro.props;

const pathname = Astro.url.pathname || '/';
const isEn = pathname.startsWith('/en/');
const lang = isEn ? 'en' : 'es';

const normalizePath = (p: string): string => {
	if (p === '/') return '/';
	return `/${p.replace(/^\/+/, '').replace(/\/+$/, '')}/`;
};

const currentPath = normalizePath(pathname);
const currentId = (() => {
	if (isEn) {
		const seoSlug = currentPath.replace(/^\/en\/seo\//, '').replace(/\/$/, '');
		if (seoSlug !== currentPath.replace(/\/$/, '')) return seoSlug ? `en/seo/${seoSlug}` : '';

		const webDesignSlug = currentPath.replace(/^\/en\/web-design\//, '').replace(/\/$/, '');
		if (webDesignSlug !== currentPath.replace(/\/$/, '')) return webDesignSlug ? `en/web-design/${webDesignSlug}` : '';

		const dmSlug = currentPath.replace(/^\/en\/digital-marketing\//, '').replace(/\/$/, '');
		if (dmSlug !== currentPath.replace(/\/$/, '')) return dmSlug ? `en/digital-marketing/${dmSlug}` : '';

		const smSlug = currentPath.replace(/^\/en\/social-media\//, '').replace(/\/$/, '');
		if (smSlug !== currentPath.replace(/\/$/, '')) return smSlug ? `en/social-media/${smSlug}` : '';

		const blogSlug = currentPath.replace(/^\/en\/blog\//, '').replace(/\/$/, '');
		return blogSlug ? `en/${blogSlug}` : '';
	}
	const seoSlug = currentPath.replace(/^\/seo\//, '').replace(/\/$/, '');
	if (seoSlug !== currentPath.replace(/\/$/, '')) return seoSlug ? `seo/${seoSlug}` : '';

	const disenowebSlug = currentPath.replace(/^\/disenoweb\//, '').replace(/\/$/, '');
	if (disenowebSlug !== currentPath.replace(/\/$/, '')) return disenowebSlug ? `disenoweb/${disenowebSlug}` : '';

	const marketingSlug = currentPath.replace(/^\/marketing-digital\//, '').replace(/\/$/, '');
	if (marketingSlug !== currentPath.replace(/\/$/, '')) return marketingSlug ? `marketing-digital/${marketingSlug}` : '';

	const socialSlug = currentPath.replace(/^\/social-media\//, '').replace(/\/$/, '');
	if (socialSlug !== currentPath.replace(/\/$/, '')) return socialSlug ? `social-media/${socialSlug}` : '';

	const blogSlug = currentPath.replace(/^\/blog\//, '').replace(/\/$/, '');
	return blogSlug || '';
})();

const hrefForPost = (post: BlogEntry): string => {
	if (post.id.startsWith('en/seo/')) return `/en/seo/${post.id.slice('en/seo/'.length)}/`;
	if (post.id.startsWith('en/web-design/')) return `/en/web-design/${post.id.slice('en/web-design/'.length)}/`;
	if (post.id.startsWith('en/digital-marketing/'))
		return `/en/digital-marketing/${post.id.slice('en/digital-marketing/'.length)}/`;
	if (post.id.startsWith('en/social-media/')) return `/en/social-media/${post.id.slice('en/social-media/'.length)}/`;
	if (post.id.startsWith('en/')) return `/en/blog/${post.id.replace(/^en\//, '')}/`;

	if (post.id.startsWith('seo/')) return `/seo/${post.id.slice('seo/'.length)}/`;
	if (post.id.startsWith('disenoweb/')) return `/disenoweb/${post.id.slice('disenoweb/'.length)}/`;
	if (post.id.startsWith('marketing-digital/'))
		return `/marketing-digital/${post.id.slice('marketing-digital/'.length)}/`;
	if (post.id.startsWith('social-media/')) return `/social-media/${post.id.slice('social-media/'.length)}/`;

	return `/blog/${post.id}/`;
};

const escapeHtml = (value: string): string =>
	String(value)
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/"/g, '&quot;')
		.replace(/'/g, '&#39;');

const stripTags = (value: string): string => String(value).replace(/<[^>]*>/g, ' ');

const countWords = (html: string): number => {
	const text = stripTags(html).replace(/\s+/g, ' ').trim();
	if (!text) return 0;
	return text.split(' ').length;
};

const clampInt = (n: number, min: number, max: number): number => Math.max(min, Math.min(max, Math.trunc(n)));

const decideLinkCount = (words: number): number => {
	if (words < 650) return clampInt(minLinks, 1, 7);
	if (words < 1100) return clampInt(4, minLinks, maxLinks);
	if (words < 1700) return clampInt(5, minLinks, maxLinks);
	if (words < 2300) return clampInt(6, minLinks, maxLinks);
	return clampInt(maxLinks, minLinks, 7);
};

const hashSeed = (value: string): number => {
	let h = 2166136261;
	for (let i = 0; i < value.length; i++) {
		h ^= value.charCodeAt(i);
		h = Math.imul(h, 16777619);
	}
	return h >>> 0;
};

const mulberry32 = (seed: number) => {
	let a = seed >>> 0;
	return () => {
		a += 0x6d2b79f5;
		let t = a;
		t = Math.imul(t ^ (t >>> 15), t | 1);
		t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
		return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
	};
};

const shuffleSeeded = <T,>(items: T[], seedText: string): T[] => {
	const rng = mulberry32(hashSeed(seedText));
	const arr = items.slice();
	for (let i = arr.length - 1; i > 0; i--) {
		const j = Math.floor(rng() * (i + 1));
		[arr[i], arr[j]] = [arr[j], arr[i]];
	}
	return arr;
};

const getDictionary = (): { es: string[]; en: string[] } => {
	const key = '__interlinkDictionary';
	const cached = (globalThis as unknown as Record<string, unknown>)[key];
	if (cached && typeof cached === 'object') return cached as { es: string[]; en: string[] };

	try {
		const componentsDir = path.join(process.cwd(), 'src', 'components');
		const candidates = [
			'dicionario-interlink.txt',
			'DICIONARION-INTERLINK.txt',
			'DICIONARIO-INTERLINK.txt',
			'dicionario-interlink.TXT',
		];
		const fileName = candidates.find((name) => fs.existsSync(path.join(componentsDir, name)));
		if (!fileName) throw new Error('Interlink dictionary file not found');
		const filePath = path.join(componentsDir, fileName);
		const content = fs.readFileSync(filePath, 'utf-8');
		const lines = content
			.split(/\r?\n/g)
			.map((l) => l.trim())
			.filter(Boolean);

		const es: string[] = [];
		const en: string[] = [];
		let section: 'es' | 'en' | null = null;
		for (const line of lines) {
			const low = line.toLowerCase();
			if (low === 'en español' || low === 'español' || low === 'espanol') {
				section = 'es';
				continue;
			}
			if (low === 'en ingles' || low === 'inglés' || low === 'ingles' || low === 'english') {
				section = 'en';
				continue;
			}
			if (section === 'es') es.push(line);
			if (section === 'en') en.push(line);
		}

		const dict = { es, en };
		(globalThis as unknown as Record<string, unknown>)[key] = dict;
		return dict;
	} catch {
		const dict = { es: [], en: [] };
		(globalThis as unknown as Record<string, unknown>)[key] = dict;
		return dict;
	}
};

const normalizeTag = (tag: unknown): string => String(tag ?? '').trim().toLowerCase();
const getTagsArray = (value: unknown): string[] =>
	Array.isArray(value) ? value.map(normalizeTag).filter(Boolean) : [];

const currentTags = getTagsArray(providedTags);
const hasTagFilter = currentTags.length > 0;
const shouldInterlink = hasTagFilter || Boolean(group);

const dictionary = shouldInterlink ? getDictionary() : { es: [], en: [] };
const phrases = lang === 'en' && dictionary.en.length === 0 ? dictionary.es : lang === 'en' ? dictionary.en : dictionary.es;

const uniquePhrases = Array.from(new Set(phrases.map((p) => p.trim()).filter(Boolean)));

const demoteCtaHeading = (html: string): string => {
	const ctaStart =
		/^(Si\s+esto\s+te\s+interesa|Puedes\s+ver\s+m[aá]s\s+si\s+esto\s+te\s+interesa|Si\s+te\s+gusta\s+este\s+contenido|Puedes\s+profundizar\s+si\s+te\s+ha\s+gustado)\b/i;

	return html.replace(/<h([23])\b[^>]*>[\s\S]*?<\/h\1>/gi, (full) => {
		const plain = full
			.replace(/<[^>]+>/g, ' ')
			.replace(/\s+/g, ' ')
			.trim();
		const m = plain.match(ctaStart);
		if (!m) return full;

		const linkMatches = Array.from(full.matchAll(/<a\b[^>]*href\s*=\s*"([^"]+)"[^>]*>[\s\S]*?<\/a>/gi));
		const firstNonHash = linkMatches.find((m) => m[1] && !m[1].startsWith('#'));
		if (!firstNonHash) return full;

		const linkHtml = firstNonHash[0];
		const ctaText = m[1];
		return `<div class="pt-6 pb-6"><p class="text-base font-normal">${escapeHtml(ctaText)}. ${linkHtml}</p></div>`;
	});
};

const rawHtml = demoteCtaHeading(await Astro.slots.render('default'));

const sharesTag = (post: BlogEntry): boolean => {
	if (!hasTagFilter) return false;
	const t = new Set(getTagsArray(post?.data?.tags));
	for (const ct of currentTags) if (t.has(ct)) return true;
	return false;
};

const allPosts = shouldInterlink
	? Array.isArray(providedPosts)
		? providedPosts
		: await getCollection('blog')
	: [];

const candidates = allPosts
	.filter((p: BlogEntry) => (lang === 'en' ? p.id.startsWith('en/') : !p.id.startsWith('en/')))
	.filter((p: BlogEntry) => (currentId ? p.id !== currentId : normalizePath(hrefForPost(p)) !== currentPath))
	.filter((p: BlogEntry) => (hasTagFilter ? sharesTag(p) : group ? p.data?.relatedGroup === group : false))
	.filter((p: BlogEntry) => Boolean(p.data?.title && p.data?.description));

const words = countWords(rawHtml);
const linkCount = clampInt(decideLinkCount(words), minLinks, maxLinks);

const pickedPosts = shuffleSeeded(candidates, `${currentId || currentPath}-targets-${lang}`).slice(0, linkCount);
const pickedPhrases = shuffleSeeded(uniquePhrases, `${currentId || currentPath}-phrases-${lang}`).slice(0, linkCount);

const findFaqIndex = (html: string): number => {
	const lower = html.toLowerCase();
	const phrases = ['preguntas frecuentes', 'frequently asked questions', '>faq<', '>faq ', ' faq<', ' faq '];
	let idx = -1;
	for (const p of phrases) {
		const i = lower.indexOf(p);
		if (i >= 0 && (idx < 0 || i < idx)) idx = i;
	}
	return idx;
};

const faqIndex = findFaqIndex(rawHtml);
const beforeFaqHtml = faqIndex >= 0 ? rawHtml.slice(0, faqIndex) : rawHtml;
const afterFaqHtml = faqIndex >= 0 ? rawHtml.slice(faqIndex) : '';

type H2Section = { start: number; end: number; title: string };

const extractH2Sections = (html: string): H2Section[] => {
	const starts: number[] = [];
	let cursor = 0;
	while (cursor < html.length) {
		const idx = html.indexOf('<h2', cursor);
		if (idx < 0) break;
		starts.push(idx);
		cursor = idx + 3;
	}
	if (!starts.length) return [];

	const sections: H2Section[] = [];
	for (let i = 0; i < starts.length; i++) {
		const start = starts[i];
		const end = i + 1 < starts.length ? starts[i + 1] : html.length;
		const h2Close = html.indexOf('</h2>', start);
		const h2Html = h2Close >= 0 && h2Close < end ? html.slice(start, h2Close + 5) : html.slice(start, Math.min(start + 200, end));
		const title = stripTags(h2Html).replace(/\s+/g, ' ').trim();
		sections.push({ start, end, title });
	}
	return sections;
};

const buildAnchorHtml = (phrase: string, target: BlogEntry): string => {
	const phraseText = String(phrase || '').trim().replace(/\s+/g, ' ');
	const title = String(target.data.title || '').trim();
	const href = hrefForPost(target);
	if (!phraseText) {
		return `<a href="${escapeHtml(href)}" class="font-semibold text-primary-blue hover:underline">${escapeHtml(title)}</a>`;
	}
	return `${escapeHtml(phraseText)} <a href="${escapeHtml(href)}" class="font-semibold text-primary-blue hover:underline">${escapeHtml(title)}</a>`;
};

const buildInterlinkedHtml = (): string => {
	if (!shouldInterlink) return rawHtml;
	const sections = extractH2Sections(beforeFaqHtml);
	if (sections.length < 1) return rawHtml;

	const eligible = sections.filter((s) => {
		const t = s.title.toLowerCase();
		if (t.includes('preguntas frecuentes')) return false;
		if (t.includes('frequently asked')) return false;
		if (t.includes('conclusión') || t.includes('conclusion')) return false;
		return true;
	});

	if (eligible.length < 1) return rawHtml;

	const injectCount = Math.min(linkCount, eligible.length, pickedPosts.length, pickedPhrases.length);
	if (injectCount < 1) return rawHtml;

	const anchors = Array.from({ length: injectCount }, (_, i) => buildAnchorHtml(pickedPhrases[i], pickedPosts[i]));

	const hasLinkNearby = (pos: number): boolean => {
		const start = Math.max(0, pos - 500);
		const window = beforeFaqHtml.slice(start, pos);
		return /<a\s+[^>]*href=/i.test(window);
	};

	const targetSectionIndexes: number[] = [];
	const jump = 3;
	for (let i = 0; i < injectCount; i++) {
		let idx = Math.min(i * jump, eligible.length - 1);
		while (idx < eligible.length - 1 && hasLinkNearby(eligible[idx].end)) {
			idx = Math.min(idx + jump, eligible.length - 1);
		}
		targetSectionIndexes.push(idx);
	}

	const uniqueIndexes = Array.from(new Set(targetSectionIndexes)).sort((a, b) => a - b);
	if (uniqueIndexes.length < injectCount) {
		const all = Array.from({ length: eligible.length }, (_, i) => i);
		const missing = all.filter((i) => !uniqueIndexes.includes(i));
		const fill = shuffleSeeded(missing, `${currentId || currentPath}-h2-fill-${lang}`);
		uniqueIndexes.push(...fill.slice(0, Math.max(0, injectCount - uniqueIndexes.length)));
		uniqueIndexes.sort((a, b) => a - b);
	};

	const insertions = uniqueIndexes
		.slice(0, injectCount)
		.map((sectionIdx, i) => ({
			pos: eligible[sectionIdx].end,
			html: `<div class="pt-6 pb-6"><p class="text-base font-normal">${anchors[i]}</p></div>`,
		}))
		.sort((a, b) => a.pos - b.pos);

	let out = '';
	let cursor = 0;
	for (const ins of insertions) {
		out += beforeFaqHtml.slice(cursor, ins.pos);
		out += `\n${ins.html}\n`;
		cursor = ins.pos;
	}
	out += beforeFaqHtml.slice(cursor);
	return out + afterFaqHtml;
};

const interlinkedHtml = buildInterlinkedHtml();
---

{shouldInterlink ? <div class="contents" set:html={interlinkedHtml} /> : <div class="contents"><slot /></div>}
