---
export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const labels = lang === 'en' 
  ? {
      name: 'Name',
      email: 'Email',
      phone: 'Phone (optional)',
      message: 'Message',
      submit: 'Send Message',
      namePlaceholder: 'Your name',
      emailPlaceholder: 'your@email.com',
      phonePlaceholder: '+57 310 123 4567',
      messagePlaceholder: 'Tell me about your project...',
    }
  : {
      name: 'Nombre',
      email: 'Email',
      phone: 'Teléfono (opcional)',
      message: 'Mensaje',
      submit: 'Enviar Mensaje',
      namePlaceholder: 'Tu nombre',
      emailPlaceholder: 'tu@email.com',
      phonePlaceholder: '+57 310 123 4567',
      messagePlaceholder: 'Cuéntame sobre tu proyecto...',
    };
---

<form 
  id="contact-form" 
  class="space-y-6 mt-6"
  action="https://formspree.io/f/YOUR_FORM_ID"
  method="POST"
>
  <div>
    <label for="name" class="block text-sm font-bold mb-2">{labels.name}</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      placeholder={labels.namePlaceholder}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 outline-none transition-colors"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-bold mb-2">{labels.email}</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      placeholder={labels.emailPlaceholder}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 outline-none transition-colors"
    />
  </div>

  <div>
    <label for="phone" class="block text-sm font-bold mb-2">{labels.phone}</label>
    <input
      type="tel"
      id="phone"
      name="phone"
      placeholder={labels.phonePlaceholder}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 outline-none transition-colors"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-bold mb-2">{labels.message}</label>
    <textarea
      id="message"
      name="message"
      required
      rows="6"
      placeholder={labels.messagePlaceholder}
      class="w-full px-4 py-3 rounded-lg border border-gray-300 outline-none transition-colors resize-none"
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full btn-primary"
  >
    {labels.submit}
  </button>
</form>

<style>
  #contact-form input:focus,
  #contact-form textarea:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.18);
  }

  #contact-form button.btn-primary {
    width: 100%;
  }
</style>
