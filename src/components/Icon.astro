---
export interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'w-8 h-8' } = Astro.props;

const base = `inline-block ${className}`;

const icons: Record<string, string> = {
  rocket: '<path d="M14 3c3.5 2 6 5.5 7 9-3.5 1-7 1-10 0-1-3-1-6.5 3-9Z"/><path d="M7 14c-2.5.5-4 2-4 5 3 0 4.5-1.5 5-4"/><path d="M10 13l1 1"/><path d="M13 10l1 1"/><path d="M12 12l5-5"/>',
  atom: '<circle cx="12" cy="12" r="1.5"/><path d="M3 12c3-4 9-4 18 0"/><path d="M3 12c3 4 9 4 18 0"/><path d="M12 3c4 3 4 9 0 18"/><path d="M12 3c-4 3-4 9 0 18"/>',
  palette: '<path d="M12 3c5 0 9 3.6 9 8 0 2-1 3-3 3h-1.5a2.5 2.5 0 0 0 0 5H12c-5 0-9-3.6-9-8s4-8 9-8Z"/><circle cx="7.5" cy="10.5" r=".8"/><circle cx="10" cy="8" r=".8"/><circle cx="14" cy="8" r=".8"/><circle cx="16.5" cy="10.5" r=".8"/>',
  book: '<path d="M4 19a2 2 0 0 1 2-2h12"/><path d="M6 17V5a2 2 0 0 1 2-2h10v16"/><path d="M8 3v16"/>',
  cart: '<path d="M6 6h15l-2 8H7L6 6Z"/><path d="M6 6 5 3H2"/><circle cx="9" cy="19" r="1"/><circle cx="18" cy="19" r="1"/>',
  target: '<circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="4"/><path d="M12 12 19 5"/>',
  file: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/>',
  bolt: '<path d="M13 2 3 14h7l-1 8 10-12h-7l1-8Z"/>',
  shield: '<path d="M12 2 20 6v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4Z"/>',
  smartphone: '<rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/>',
  wrench: '<path d="M21 7a6 6 0 0 1-8.7 5.3L7 17.6a2 2 0 0 1-2.8 0l-.8-.8a2 2 0 0 1 0-2.8l5.3-5.3A6 6 0 0 1 17 3l-3 3 4 4 3-3Z"/>',
  map: '<path d="M9 18 3 21V6l6-3 6 3 6-3v15l-6 3-6-3Z"/><path d="M9 3v15"/><path d="M15 6v15"/>',
  message: '<path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8Z"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/>',
  chart: '<path d="M3 3v18h18"/><path d="M7 14v4"/><path d="M11 10v8"/><path d="M15 6v12"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
  trophy: '<path d="M8 4h8v3a4 4 0 0 1-8 0V4Z"/><path d="M6 7H4a2 2 0 0 0 2 2"/><path d="M18 7h2a2 2 0 0 1-2 2"/><path d="M12 11v4"/><path d="M8 21h8"/><path d="M9 15h6"/>',
  star: '<path d="M12 2l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1 3-7Z"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v6l4 2"/>',
  package: '<path d="M12 2 3 7l9 5 9-5-9-5Z"/><path d="M3 7v10l9 5 9-5V7"/><path d="M12 12v10"/>',
  building: '<path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 9h.01"/><path d="M9 13h.01"/><path d="M9 17h.01"/><path d="M15 9h.01"/><path d="M15 13h.01"/><path d="M15 17h.01"/>',
  scale: '<path d="M12 3v18"/><path d="M6 7h12"/><path d="M7 7 5 12a3 3 0 0 0 4 0L7 7Z"/><path d="M17 7l-2 5a3 3 0 0 0 4 0l-2-5Z"/>'
};

const content = icons[name] ?? icons.file;
---

<svg class={base} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <g set:html={content} />
</svg>
