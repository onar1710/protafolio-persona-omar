---
import Layout from '../layouts/Layout.astro';

export interface Props {
  title: string;
  description: string;
  h1: string;
  lastUpdated?: string;
}

const { title, description, h1, lastUpdated } = Astro.props;
---

<Layout title={title} description={description}>
  <main class="pt-24 pb-20" style="background: var(--white);">
    <div class="max-w-4xl mx-auto px-6 md:px-8 lg:px-12">
      <header class="mb-12">
        <h1 class="text-4xl md:text-5xl font-black text-black mb-4">{h1}</h1>
        {lastUpdated && <p class="text-black">{lastUpdated}</p>}
      </header>

      <article class="text-black">
        <slot />
      </article>
    </div>
  </main>
</Layout>
