---
export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const whatsappMessage =
  lang === 'en'
    ? 'Hi Omar, I saw your portfolio and I want to request a quote.'
    : 'Hola Omar, vi tu portafolio y quiero cotizar un proyecto';

const whatsappPhone = lang === 'en' ? '13239414865' : '573107851074';
const searchAction = lang === 'en' ? '/en/blog/' : '/blog/';
const searchLabel = lang === 'en' ? 'Search articles' : 'Buscar artículos';

const navLinks =
  lang === 'en'
    ? [
        { label: 'Home', href: '/en/' },
        { label: 'Services', href: '/en/services/' },
        { label: 'Blog', href: '/en/blog/' },
        { label: 'About', href: '/en/about/' },
        { label: 'Contact', href: '/en/contact/' },
      ]
    : [
        { label: 'Inicio', href: '/' },
        { label: 'Blog', href: '/blog/' },
        { label: 'Servicios', href: '/servicios/' },
        { label: 'Sobre mí', href: '/sobre-mi/' },
        { label: 'Contacto', href: '/contacto/' },
      ];
---

<nav
  class="fixed top-0 left-0 right-0 z-50"
  style="background: rgba(248, 250, 252, 0.95); backdrop-filter: blur(12px); border-bottom: 2px solid var(--primary-blue);"
>
  <div class="container container-padding flex items-center justify-between" style="height: 4rem;">
    <a href={lang === 'en' ? '/en/' : '/'} class="flex items-center gap-2" style="text-decoration: none; color: inherit;">
      <div
        style="width: 2rem; height: 2rem; background: linear-gradient(to right, var(--primary-blue), var(--primary-yellow)); border-radius: 0.5rem;"
      ></div>
      <span style="font-weight: 700; font-size: 1.25rem;">Omar Fuentes</span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-semibold text-base hover:text-primary-blue transition-colors"
          style="text-decoration: none; color: inherit;"
        >
          {link.label}
        </a>
      ))}
    </div>

    <form action={searchAction} method="get" class="hidden lg:flex items-center" style="border: 1px solid rgba(0,0,0,0.16); border-radius: 999px; padding: 0.25rem 0.5rem; background: white;">
      <svg aria-hidden="true" viewBox="0 0 24 24" style="width: 1.1rem; height: 1.1rem; color: var(--primary-blue); margin: 0 0.35rem;">
        <path fill="currentColor" d="M9.5 3a6.5 6.5 0 0 1 5.17 10.44l4.45 4.44-1.42 1.42-4.44-4.45A6.5 6.5 0 1 1 9.5 3Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" />
      </svg>
      <input
        type="search"
        name="q"
        aria-label={searchLabel}
        placeholder={lang === 'en' ? 'Search' : 'Buscar'}
        style="width: 8rem; border: 0; outline: 0; background: transparent; font-size: 0.95rem; color: var(--black);"
      />
    </form>

    <a
      href={`https://wa.me/${whatsappPhone}?text=${encodeURIComponent(whatsappMessage)}`}
      target="_blank"
      class="btn-primary hidden sm:inline-flex"
      style="padding: 0.5rem 1.5rem; font-size: 0.875rem; text-decoration: none;"
    >
      {lang === 'en' ? 'Get a Quote' : 'Contactar'}
    </a>

    <div class="md:hidden flex items-center gap-2">
      <button
        type="button"
        data-mobile-search-button
        aria-label={searchLabel}
        style="width: 2.75rem; height: 2.75rem; border: 1px solid rgba(0,0,0,0.16); border-radius: 0.75rem; background: white; display: flex; align-items: center; justify-content: center; color: var(--primary-blue); text-decoration: none;"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" style="width: 1.35rem; height: 1.35rem;">
          <path fill="currentColor" d="M9.5 3a6.5 6.5 0 0 1 5.17 10.44l4.45 4.44-1.42 1.42-4.44-4.45A6.5 6.5 0 1 1 9.5 3Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" />
        </svg>
      </button>

      <button
        type="button"
        data-mobile-menu-button
        aria-label={lang === 'en' ? 'Open menu' : 'Abrir menú'}
        aria-expanded="false"
        style="width: 2.75rem; height: 2.75rem; border: 1px solid rgba(0,0,0,0.16); border-radius: 0.75rem; background: white; display: flex; align-items: center; justify-content: center;"
      >
        <span data-mobile-menu-icon-open aria-hidden="true" style="display: block; width: 1.35rem; height: 2px; background: var(--primary-blue); box-shadow: 0 7px 0 var(--primary-blue), 0 -7px 0 var(--primary-blue);"></span>
        <span data-mobile-menu-icon-close aria-hidden="true" style="display: none; font-size: 1.75rem; line-height: 1; color: var(--black);">×</span>
      </button>
    </div>
  </div>

  <div data-mobile-search class="md:hidden hidden" style="background: white; border-top: 1px solid rgba(0,0,0,0.08); box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);">
    <div class="container container-padding py-4">
      <form action={searchAction} method="get" class="flex items-center gap-3" style="border: 1px solid rgba(0,0,0,0.16); border-radius: 999px; padding: 0.75rem 0.9rem; background: var(--gray-50);">
        <svg aria-hidden="true" viewBox="0 0 24 24" style="width: 1.2rem; height: 1.2rem; color: var(--primary-blue); flex: none;">
          <path fill="currentColor" d="M9.5 3a6.5 6.5 0 0 1 5.17 10.44l4.45 4.44-1.42 1.42-4.44-4.45A6.5 6.5 0 1 1 9.5 3Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" />
        </svg>
        <input
          data-mobile-search-input
          type="search"
          name="q"
          aria-label={searchLabel}
          placeholder={searchLabel}
          style="width: 100%; border: 0; outline: 0; background: transparent; font-size: 1rem; color: var(--black);"
        />
        <button type="submit" class="font-bold text-primary-blue" style="border: 0; background: transparent; cursor: pointer;">
          {lang === 'en' ? 'Go' : 'Ir'}
        </button>
      </form>
    </div>
  </div>

  <div data-mobile-menu class="md:hidden hidden" style="background: white; border-top: 1px solid rgba(0,0,0,0.08); box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);">
    <div class="container container-padding py-5">
      <form action={searchAction} method="get" class="flex items-center mb-5" style="border: 1px solid rgba(0,0,0,0.16); border-radius: 999px; padding: 0.65rem 0.8rem; background: var(--gray-50);">
        <svg aria-hidden="true" viewBox="0 0 24 24" style="width: 1.2rem; height: 1.2rem; color: var(--primary-blue); margin-right: 0.5rem;">
          <path fill="currentColor" d="M9.5 3a6.5 6.5 0 0 1 5.17 10.44l4.45 4.44-1.42 1.42-4.44-4.45A6.5 6.5 0 1 1 9.5 3Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" />
        </svg>
        <input
          type="search"
          name="q"
          aria-label={searchLabel}
          placeholder={searchLabel}
          style="width: 100%; border: 0; outline: 0; background: transparent; font-size: 1rem; color: var(--black);"
        />
      </form>

      <div class="grid gap-2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-bold text-lg"
            style="display: block; padding: 0.85rem 0; text-decoration: none; color: var(--black); border-bottom: 1px solid rgba(0,0,0,0.08);"
          >
            {link.label}
          </a>
        ))}
      </div>

      <a
        href={`https://wa.me/${whatsappPhone}?text=${encodeURIComponent(whatsappMessage)}`}
        target="_blank"
        class="btn-primary"
        style="display: flex; justify-content: center; margin-top: 1.25rem; padding: 0.85rem 1rem; text-decoration: none;"
      >
        {lang === 'en' ? 'Get a Quote' : 'Cotizar Proyecto'}
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (() => {
    const button = document.querySelector('[data-mobile-menu-button]');
    const menu = document.querySelector('[data-mobile-menu]');
    const searchButton = document.querySelector('[data-mobile-search-button]');
    const searchPanel = document.querySelector('[data-mobile-search]');
    const searchInput = document.querySelector('[data-mobile-search-input]');
    const openIcon = document.querySelector('[data-mobile-menu-icon-open]');
    const closeIcon = document.querySelector('[data-mobile-menu-icon-close]');

    if (!button || !menu) return;

    const closeMenu = () => {
      menu.classList.add('hidden');
      button.setAttribute('aria-expanded', 'false');
      if (openIcon) openIcon.style.display = 'block';
      if (closeIcon) closeIcon.style.display = 'none';
    };

    button.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      button.setAttribute('aria-expanded', String(!isOpen));
      if (openIcon) openIcon.style.display = isOpen ? 'block' : 'none';
      if (closeIcon) closeIcon.style.display = isOpen ? 'none' : 'block';
      if (!isOpen && searchPanel) searchPanel.classList.add('hidden');
    });

    if (searchButton && searchPanel) {
      searchButton.addEventListener('click', () => {
        const isOpen = !searchPanel.classList.contains('hidden');
        searchPanel.classList.toggle('hidden', isOpen);
        closeMenu();
        if (!isOpen && searchInput) setTimeout(() => searchInput.focus(), 50);
      });
    }
  })();
</script>
