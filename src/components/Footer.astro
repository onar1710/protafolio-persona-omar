---
export interface Props {
	lang?: 'es' | 'en';
}

const inferredLang: 'es' | 'en' = Astro.url.pathname.startsWith('/en') ? 'en' : 'es';
const lang: 'es' | 'en' = Astro.props.lang ?? inferredLang;
const year = new Date().getFullYear();

const isEn = lang === 'en';
const socialLinks = [
	{ label: 'LinkedIn', href: 'https://www.linkedin.com/in/omarfuentes052/' },
	{ label: 'X', href: 'https://twitter.com/omarfuentes052' },
	{ label: 'GitHub', href: 'https://github.com/onar1710' },
];

const copy = isEn
	? {
			description: 'Freelance web developer specialized in building modern, fast, and SEO-optimized websites.',
			servicesTitle: 'Services',
			services: [
				{ label: 'Web Design', href: '/en/services/' },
				{ label: 'Web Development', href: '/en/services/' },
				{ label: 'SEO Optimization', href: '/en/affordable-seo-services-for-small-business/' },
				{ label: 'Tools', href: '/en/tools/' },
			],
			linksTitle: 'Links',
			links: [
				{ label: 'Projects', href: '/en/portfolio/projects/' },
				{ label: 'Services', href: '/en/services/' },
				{ label: 'About', href: '/en/about/' },
				{ label: 'Blog', href: '/en/blog/' },
				{ label: 'Contact', href: '/en/contact/' },
			],
			contactTitle: 'Contact',
			contact: ['WhatsApp: +1 323 941 4865', 'Email: contacto@omarfuentes.com', 'Response time: under 1 hour'],
			rights: `© ${year} Omar Fuentes. All rights reserved.`,
			legal: [
				{ label: 'Legal Notice', href: '/en/legal-notice/' },
				{ label: 'Privacy Policy', href: '/en/privacy-policy/' },
				{ label: 'Cookies Policy', href: '/en/cookies-policy/' },
				{ label: 'Terms & Conditions', href: '/en/terms-conditions/' },
			],
		}
	: {
			description: 'Desarrollador web freelance especializado en crear sitios web modernos y optimizados para SEO.',
			servicesTitle: 'Servicios',
			services: [
				{ label: 'Diseño Web', href: '/servicios/' },
				{ label: 'Desarrollo Web', href: '/servicios/' },
				{ label: 'SEO y Posicionamiento', href: '/servicios/' },
				{ label: 'Herramientas', href: '/herramientas/' },
			],
			linksTitle: 'Enlaces',
			links: [
				{ label: 'Proyectos', href: '/portfolio/proyectos/' },
				{ label: 'Servicios', href: '/servicios/' },
				{ label: 'Sobre Mí', href: '/sobre-mi/' },
				{ label: 'Blog', href: '/blog/' },
				{ label: 'Contacto', href: '/contacto/' },
			],
			contactTitle: 'Contacto',
			contact: ['WhatsApp: +57 310 785 1074', 'Email: contacto@omarfuentes.com', 'Tiempo respuesta: menos de 1 hora'],
			rights: `© ${year} Omar Fuentes. Todos los derechos reservados.`,
			legal: [
				{ label: 'Aviso Legal', href: '/aviso-legal/' },
				{ label: 'Política de Privacidad', href: '/politica-privacidad/' },
				{ label: 'Política de Cookies', href: '/politicas-cookies/' },
				{ label: 'Términos y Condiciones', href: '/terminos-condiciones/' },
			],
		};

type FooterServiceItem = string | { label: string; href: string };
---
<footer class="bg-gray-50 border-t border-gray-200">
	<div class="px-6 md:px-8 lg:px-12 mx-auto py-12">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
			<div>
				<div class="flex items-center space-x-2 mb-4">
					<div class="w-8 h-8 bg-gradient-to-r from-primary-blue via-primary-yellow to-primary-green rounded-lg"></div>
					<span class="font-bold text-xl">Omar Fuentes</span>
				</div>
				<p class="text-black">{copy.description}</p>
				<div class="mt-5 flex items-center gap-4">
					{socialLinks.map((s) => (
						<a
							href={s.href}
							target="_blank"
							rel="noreferrer"
							aria-label={s.label}
							class="text-black/70 hover:text-primary-blue transition-colors"
						>
							{s.label === 'LinkedIn' ? (
								<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5ZM.5 8.5H4.5V24H.5V8.5ZM8.5 8.5H12.3V10.6H12.35C12.88 9.6 14.17 8.5 16.1 8.5 20.1 8.5 20.8 11.1 20.8 14.5V24H16.8V15.7C16.8 13.7 16.76 11.1 14.0 11.1 11.2 11.1 10.8 13.3 10.8 15.6V24H6.8V8.5H8.5Z" />
								</svg>
							) : s.label === 'GitHub' ? (
								<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M12 .5C5.73.5.5 5.86.5 12.47c0 5.28 3.44 9.76 8.2 11.34.6.12.82-.27.82-.6 0-.3-.01-1.08-.02-2.12-3.34.75-4.04-1.67-4.04-1.67-.54-1.43-1.33-1.81-1.33-1.81-1.08-.76.08-.74.08-.74 1.2.09 1.83 1.28 1.83 1.28 1.06 1.9 2.78 1.35 3.46 1.03.11-.8.41-1.35.75-1.66-2.66-.31-5.46-1.39-5.46-6.19 0-1.37.47-2.49 1.25-3.37-.13-.31-.54-1.55.12-3.23 0 0 1.02-.34 3.35 1.29a11.1 11.1 0 0 1 3.05-.43c1.03 0 2.07.15 3.04.43 2.33-1.63 3.35-1.29 3.35-1.29.66 1.68.25 2.92.12 3.23.78.88 1.25 2 1.25 3.37 0 4.81-2.8 5.87-5.47 6.18.42.39.8 1.15.8 2.33 0 1.68-.02 3.04-.02 3.45 0 .33.21.73.82.6 4.77-1.58 8.21-6.06 8.21-11.34C23.5 5.86 18.27.5 12 .5z" />
								</svg>
							) : (
								<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M18.24 2.25h3.67l-8.02 9.16L23.35 21.75h-7.41l-5.81-6.64-5.82 6.64H.65l8.58-9.8L.65 2.25h7.6l5.25 6L18.24 2.25Zm-1.29 17.3h2.03L7.14 4.34H4.97l11.98 15.21Z" />
								</svg>
							)}
						</a>
					))}
				</div>
			</div>
			
			<div>
				<h4 class="font-bold mb-4">{copy.servicesTitle}</h4>
				<ul class="space-y-2 text-black">
					{(copy.services as FooterServiceItem[]).map((service) => (
						<li>
							{typeof service === 'string' ? (
								service
							) : (
								<a href={service.href} class="hover:text-primary-blue">{service.label}</a>
							)}
						</li>
					))}
				</ul>
			</div>
			
			<div>
				<h4 class="font-bold mb-4">{copy.linksTitle}</h4>
				<ul class="space-y-2 text-black">
					{copy.links.map((link) => (
						<li><a href={link.href} class="hover:text-primary-blue">{link.label}</a></li>
					))}
				</ul>
			</div>
			
			<div>
				<h4 class="font-bold mb-4">{copy.contactTitle}</h4>
				<ul class="space-y-2 text-black">
					{copy.contact.map((item) => (
						<li>{item}</li>
					))}
				</ul>
			</div>
		</div>
		
		<div class="border-t border-gray-200 mt-8 pt-8 text-center text-black">
			<p>{copy.rights}</p>
			<div class="mt-4 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
				{copy.legal.map((link) => (
					<a href={link.href} class="hover:text-primary-blue">{link.label}</a>
				))}
			</div>
		</div>
	</div>
</footer>
