---
import { getCollection, type CollectionEntry } from 'astro:content';

type BlogEntry = CollectionEntry<'blog'>;

type Props = {
	limit?: number;
	posts?: BlogEntry[];
	group?: string;
	tags?: string[];
};

const { limit = 6, posts: providedPosts, group, tags: providedTags } = Astro.props;

const pathname = Astro.url.pathname || '/';
const isEn = pathname.startsWith('/en/');

const normalizePath = (p: string): string => {
	if (p === '/') return '/';
	return `/${p.replace(/^\/+/, '').replace(/\/+$/, '')}/`;
};

const currentPath = normalizePath(pathname);

const hrefForPost = (post: BlogEntry): string => {
	if (post.id.startsWith('en/seo/')) return `/en/seo/${post.id.slice('en/seo/'.length)}/`;
	if (post.id.startsWith('en/web-design/')) return `/en/web-design/${post.id.slice('en/web-design/'.length)}/`;
	if (post.id.startsWith('en/digital-marketing/'))
		return `/en/digital-marketing/${post.id.slice('en/digital-marketing/'.length)}/`;
	if (post.id.startsWith('en/social-media/')) return `/en/social-media/${post.id.slice('en/social-media/'.length)}/`;
	if (post.id.startsWith('en/')) return `/en/blog/${post.id.replace(/^en\//, '')}/`;

	if (post.id.startsWith('seo/')) return `/seo/${post.id.slice('seo/'.length)}/`;
	if (post.id.startsWith('disenoweb/')) return `/disenoweb/${post.id.slice('disenoweb/'.length)}/`;
	if (post.id.startsWith('marketing-digital/'))
		return `/marketing-digital/${post.id.slice('marketing-digital/'.length)}/`;
	if (post.id.startsWith('social-media/')) return `/social-media/${post.id.slice('social-media/'.length)}/`;

	return `/blog/${post.id}/`;
};

const currentId = (() => {
	if (isEn) {
		const seoSlug = currentPath.replace(/^\/en\/seo\//, '').replace(/\/$/, '');
		if (seoSlug !== currentPath.replace(/\/$/, '')) return seoSlug ? `en/seo/${seoSlug}` : '';

		const webDesignSlug = currentPath.replace(/^\/en\/web-design\//, '').replace(/\/$/, '');
		if (webDesignSlug !== currentPath.replace(/\/$/, '')) return webDesignSlug ? `en/web-design/${webDesignSlug}` : '';

		const dmSlug = currentPath.replace(/^\/en\/digital-marketing\//, '').replace(/\/$/, '');
		if (dmSlug !== currentPath.replace(/\/$/, '')) return dmSlug ? `en/digital-marketing/${dmSlug}` : '';

		const smSlug = currentPath.replace(/^\/en\/social-media\//, '').replace(/\/$/, '');
		if (smSlug !== currentPath.replace(/\/$/, '')) return smSlug ? `en/social-media/${smSlug}` : '';

		const blogSlug = currentPath.replace(/^\/en\/blog\//, '').replace(/\/$/, '');
		return blogSlug ? `en/${blogSlug}` : '';
	}
	const seoSlug = currentPath.replace(/^\/seo\//, '').replace(/\/$/, '');
	if (seoSlug !== currentPath.replace(/\/$/, '')) return seoSlug ? `seo/${seoSlug}` : '';

	const disenowebSlug = currentPath.replace(/^\/disenoweb\//, '').replace(/\/$/, '');
	if (disenowebSlug !== currentPath.replace(/\/$/, '')) return disenowebSlug ? `disenoweb/${disenowebSlug}` : '';

	const marketingSlug = currentPath.replace(/^\/marketing-digital\//, '').replace(/\/$/, '');
	if (marketingSlug !== currentPath.replace(/\/$/, '')) return marketingSlug ? `marketing-digital/${marketingSlug}` : '';

	const socialSlug = currentPath.replace(/^\/social-media\//, '').replace(/\/$/, '');
	if (socialSlug !== currentPath.replace(/\/$/, '')) return socialSlug ? `social-media/${socialSlug}` : '';

	const blogSlug = currentPath.replace(/^\/blog\//, '').replace(/\/$/, '');
	return blogSlug || '';
})();

const hashSeed = (value: string): number => {
	let h = 2166136261;
	for (let i = 0; i < value.length; i++) {
		h ^= value.charCodeAt(i);
		h = Math.imul(h, 16777619);
	}
	return h >>> 0;
};

const mulberry32 = (seed: number) => {
	let a = seed >>> 0;
	return () => {
		a += 0x6d2b79f5;
		let t = a;
		t = Math.imul(t ^ (t >>> 15), t | 1);
		t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
		return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
	};
};

const shuffleSeeded = <T,>(items: T[], seedText: string): T[] => {
	const rng = mulberry32(hashSeed(seedText));
	const arr = items.slice();
	for (let i = arr.length - 1; i > 0; i--) {
		const j = Math.floor(rng() * (i + 1));
		[arr[i], arr[j]] = [arr[j], arr[i]];
	}
	return arr;
};

const normalizeTag = (tag: unknown): string => String(tag ?? '').trim().toLowerCase();
const getTagsArray = (value: unknown): string[] =>
	Array.isArray(value) ? value.map(normalizeTag).filter(Boolean) : [];

const currentTags = getTagsArray(providedTags);
const hasTagFilter = currentTags.length > 0;
const shouldSelect = hasTagFilter || Boolean(group);

const allPosts = shouldSelect
	? Array.isArray(providedPosts)
		? providedPosts
		: await getCollection('blog')
	: [];

const sharedTagCount = (post: BlogEntry): number => {
	if (!hasTagFilter) return 0;
	const t = new Set(getTagsArray(post?.data?.tags));
	let count = 0;
	for (const ct of currentTags) if (t.has(ct)) count++;
	return count;
};

const candidates = allPosts
	.filter((p: BlogEntry) => (isEn ? p.id.startsWith('en/') : !p.id.startsWith('en/')))
	.filter((p: BlogEntry) => (currentId ? p.id !== currentId : normalizePath(hrefForPost(p)) !== currentPath))
	.filter((p: BlogEntry) => (hasTagFilter ? sharedTagCount(p) > 0 : group ? p.data?.relatedGroup === group : false))
	.filter((p: BlogEntry) => Boolean(p.data?.title && p.data?.description));

const selected =
	hasTagFilter
		? candidates
				.slice()
				.sort((a: BlogEntry, b: BlogEntry) => {
					const shared = sharedTagCount(b) - sharedTagCount(a);
					if (shared !== 0) return shared;
					const aDate = (a.data.updatedDate ?? a.data.pubDate).valueOf();
					const bDate = (b.data.updatedDate ?? b.data.pubDate).valueOf();
					return bDate - aDate;
				})
				.slice(0, limit)
		: shuffleSeeded(candidates, currentId || currentPath).slice(0, limit);

const heading = isEn ? 'Related Articles' : 'Artículos relacionados';
const cta = isEn ? 'Read article' : 'Leer artículo';
---

{selected.length ? (
	<section class="mt-16 border-t border-gray-200 pt-12">
		<div class="flex items-end justify-between gap-4 mb-8">
			<h2 class="text-2xl md:text-3xl font-black">{heading}</h2>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{selected.map((post: BlogEntry) => {
				const href = hrefForPost(post);
				const image = post.data.heroImageUrl || post.data.heroImage || '/PAGINAS-WEB-BUCARAMAGA.webp';
				return (
					<a
						href={href}
						class="group block rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden hover:shadow-lg transition-all"
					>
						<div class="relative aspect-video overflow-hidden bg-gray-50">
							<img
								src={image}
								alt={post.data.title}
								loading="lazy"
								decoding="async"
								class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
							/>
							<div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/0 to-black/0 opacity-70" />
						</div>
						<div class="p-7">
							<h3 class="text-xl font-black leading-snug text-black">{post.data.title}</h3>
							<p class="mt-2 text-sm text-gray-700 line-clamp-3">{post.data.description}</p>
							<div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary-blue group-hover:underline">
								{cta}
								<span aria-hidden="true">→</span>
							</div>
						</div>
					</a>
				);
			})}
		</div>
	</section>
) : null}
