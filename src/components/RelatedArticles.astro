---
import { getCollection, type CollectionEntry } from 'astro:content';

type BlogEntry = CollectionEntry<'blog'>;

type Props = {
	limit?: number;
	posts?: BlogEntry[];
};

const { limit = 3, posts: providedPosts } = Astro.props;

const pathname = Astro.url.pathname || '/';
const isEn = pathname.startsWith('/en/');

const normalizePath = (p: string): string => {
	if (p === '/') return '/';
	return `/${p.replace(/^\/+/, '').replace(/\/+$/, '')}/`;
};

const currentPath = normalizePath(pathname);

const hrefForPost = (post: BlogEntry): string => {
	if (post.id.startsWith('en/')) return `/en/blog/${post.id.replace(/^en\//, '')}/`;
	return `/blog/${post.id}/`;
};

const currentId = (() => {
	if (isEn) {
		const slug = currentPath.replace(/^\/en\/blog\//, '').replace(/\/$/, '');
		return slug ? `en/${slug}` : '';
	}
	const slug = currentPath.replace(/^\/blog\//, '').replace(/\/$/, '');
	return slug || '';
})();

const hashSeed = (value: string): number => {
	let h = 2166136261;
	for (let i = 0; i < value.length; i++) {
		h ^= value.charCodeAt(i);
		h = Math.imul(h, 16777619);
	}
	return h >>> 0;
};

const mulberry32 = (seed: number) => {
	let a = seed >>> 0;
	return () => {
		a += 0x6d2b79f5;
		let t = a;
		t = Math.imul(t ^ (t >>> 15), t | 1);
		t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
		return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
	};
};

const shuffleSeeded = <T,>(items: T[], seedText: string): T[] => {
	const rng = mulberry32(hashSeed(seedText));
	const arr = items.slice();
	for (let i = arr.length - 1; i > 0; i--) {
		const j = Math.floor(rng() * (i + 1));
		[arr[i], arr[j]] = [arr[j], arr[i]];
	}
	return arr;
};

const allPosts = Array.isArray(providedPosts) ? providedPosts : await getCollection('blog');
const candidates = allPosts
	.filter((p) => (isEn ? p.id.startsWith('en/') : !p.id.startsWith('en/')))
	.filter((p) => (currentId ? p.id !== currentId : normalizePath(hrefForPost(p)) !== currentPath))
	.filter((p) => Boolean(p.data?.title && p.data?.description));

const selected = shuffleSeeded(candidates, currentId || currentPath).slice(0, limit);

const heading = isEn ? 'Related Articles' : 'Artículos relacionados';
const cta = isEn ? 'Read article' : 'Leer artículo';
---

{selected.length ? (
	<section class="mt-16 border-t border-gray-200 pt-12">
		<div class="flex items-end justify-between gap-4 mb-8">
			<h2 class="text-2xl md:text-3xl font-black">{heading}</h2>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{selected.map((post) => {
				const href = hrefForPost(post);
				const image = post.data.heroImageUrl || post.data.heroImage || '/og-image.webp';
				return (
					<a
						href={href}
						class="group block rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden hover:shadow-lg transition-all"
					>
						<div class="relative aspect-video overflow-hidden bg-gray-50">
							<img
								src={image}
								alt={post.data.title}
								loading="lazy"
								decoding="async"
								class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
							/>
							<div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/0 to-black/0 opacity-70" />
						</div>
						<div class="p-6">
							<h3 class="text-lg font-bold leading-snug text-black line-clamp-2">{post.data.title}</h3>
							<p class="mt-2 text-sm text-gray-700 line-clamp-3">{post.data.description}</p>
							<div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary-blue group-hover:underline">
								{cta}
								<span aria-hidden="true">→</span>
							</div>
						</div>
					</a>
				);
			})}
		</div>
	</section>
) : null}
