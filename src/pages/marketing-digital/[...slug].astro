---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const includeDrafts = import.meta.env.DEV;
	const allPosts = (await getCollection('blog'))
		.filter((post: CollectionEntry<'blog'>) => !post.id.startsWith('en/'))
		.filter((post: CollectionEntry<'blog'>) => (includeDrafts ? true : !post.data?.draft));
	const posts = allPosts.filter((post: CollectionEntry<'blog'>) => post.id.startsWith('marketing-digital/'));
	return posts.map((post: CollectionEntry<'blog'>) => ({
		params: { slug: post.id.slice('marketing-digital/'.length) },
		props: { post, allPosts },
	}));
}

type Props = CollectionEntry<'blog'> | { post: CollectionEntry<'blog'>; allPosts: CollectionEntry<'blog'>[] };

const props = Astro.props as Props;
const post = 'post' in props ? props.post : props;
const allPosts = 'allPosts' in props ? props.allPosts : undefined;
const { Content } = await render(post);
---

<BlogPost {...post.data} posts={allPosts}>
	<Content />
</BlogPost>
