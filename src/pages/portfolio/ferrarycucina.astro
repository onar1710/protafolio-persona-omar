---
import Layout from '../../layouts/Layout.astro';
import { Clock, CheckCircle, ExternalLink, ArrowRight, Star, Users, TrendingUp, Target, Zap, Shield, Award, FileText } from 'lucide-react';

const project = {
  title: "Ferrary Cucinas - Mi Proyecto Estrella de Remodelaciones",
  description: "Este proyecto fue increíble: transformé la visión de Ferrary Cucinas en una plataforma digital que genera 4-5 cotizaciones semanales. Usé Next.js, Tailwind CSS y creé un portafolio visual que realmente vende sus servicios de remodelación en Bogotá.",
  cliente: "Ferrary Cucinas",
  fecha: "2024-2025",
  tipo: "Sitio Web Corporativo / Portafolio de Servicios",
  tecnologias: ["Next.js", "React", "Tailwind CSS", "Figma"],
  url: "https://ferrarycucina.co",
  imagen: "/images/proyecto-imagen-ferrarycucina.png",
  stats: {
    pages: "15+ páginas",
    images: "50+ imágenes", 
    videos: "4 videos",
    weeks: "3 semanas desarrollo"
  },
  results: [
    "✅ Sitio profesional que genera 4-5 cotizaciones semanales - ¡clientes reales!",
    "✅ +50 imágenes y videos optimizados que muestran la calidad de su trabajo",
    "✅ 6 proyectos destacados que convierten visitantes en clientes potenciales",
    "✅ Blog integrado con 3 artículos que posicionan en Google Bogotá",
    "✅ Sistema de cotización que pre-califica clientes antes de la llamada",
    "✅ 100% responsive - los clientes ven los proyectos desde su celular",
    "✅ Performance 95+ en Lighthouse - más rápido que la competencia",
    "✅ CTAs estratégicos que guían al cliente a contactar"
  ]
};

const techStack = [
  { name: "Next.js 14+", description: "Framework React con App Router para SSG", icon: "🚀" },
  { name: "React 18", description: "Biblioteca UI con componentes reutilizables", icon: "⚛️" },
  { name: "Tailwind CSS", description: "Framework CSS utility-first para diseño rápido", icon: "🎨" },
  { name: "TypeScript", description: "Tipado estático para mayor robustez", icon: "📘" },
  { name: "Figma", description: "Diseño UI/UX completo antes de código", icon: "🎯" }
];

const phases = [
  {
    title: "Mi Primera Semana: Entendiendo el Negocio de Remodelaciones",
    week: "Semana 1",
    tasks: [
      "Día 1-2: Me senté con Ferrary para entender su magia - cómo transforman espacios, qué hace únicos sus proyectos",
      "Día 3-4: Diseñé la arquitectura perfecta - quería que cada proyecto mostrara antes/después, el proceso completo",
      "Día 5-7: Creé el diseño en Figma - visualicé cómo los clientes recorrerían el sitio viendo la calidad de su trabajo"
    ]
  },
  {
    title: "Semanas 2-3: Desarrollo y Magia Visual",
    week: "Semanas 2-3",
    tasks: [
      "Día 8-12: Desarrollé el portafolio visual - cada imagen optimizada para mostrar la calidad de sus remodelaciones",
      "Día 13-15: Implementé el sistema de cotización inteligente - pre-califica clientes para ahorrar tiempo a Ferrary",
      "Día 16-18: Creé el blog con SEO local - artículos que posicionan para 'remodelación Bogotá'",
      "Día 19-21: Testing intensivo y deploy - optimicé cada imagen para velocidad máxima"
    ]
  }
];

const features = [
  {
    icon: "🎨",
    title: "Diseño que Vende Remodelaciones",
    description: "Creé una identidad visual que muestra la calidad artesanal de Ferrary. Quería que los visitantes sintieran la confianza de contratar a expertos con 25 años transformando espacios en Bogotá."
  },
  {
    icon: "📱",
    title: "100% Responsive para Clientes Móviles",
    description: "Los clientes buscan remodelaciones desde su celular. Diseñé una experiencia móvil perfecta donde cada proyecto se ve increíble y los CTAs están al alcance de un toque."
  },
  {
    icon: "🖼️",
    title: "Portafolio Visual que Impresiona",
    description: "Optimicé 50+ imágenes con Next.js Image para que carguen instantáneamente. Cada foto muestra la transformación real - eso es lo que convierte visitantes en clientes."
  },
  {
    icon: "🎬",
    title: "Videos que Cuentan Historias",
    description: "Integré 4 videos de transformaciones que muestran el proceso completo. Los clientes ven cómo Ferrary convierte espacios ordinarios en extraordinarios."
  },
  {
    icon: "📝",
    title: "Cotización Inteligente que Ahorra Tiempo",
    description: "Diseñé un formulario que pre-califica proyectos. Ferrary recibe solo clientes serios, ahorrando horas de llamadas innecesarias."
  },
  {
    icon: "🔍",
    title: "SEO Local para Bogotá",
    description: "Optimicé cada página para que aparezca cuando alguien busca 'remodelación de cocinas Bogotá' o 'baños modernos Bogotá'. Los clientes encuentran a Ferrary primero."
  }
];

const metrics = [
  {
    icon: "🚀",
    title: "Performance",
    value: "95+",
    description: "Lighthouse score en desktop y mobile"
  },
  {
    icon: "📄",
    title: "Páginas Creadas",
    value: "15+",
    description: "Sitio corporativo completo"
  },
  {
    icon: "🖼️",
    title: "Contenido Visual",
    value: "50+",
    description: "Imágenes y videos optimizados"
  },
  {
    icon: "⏱️",
    title: "Tiempo de Entrega",
    value: "3",
    description: "Semanas completas"
  }
];
---

<Layout title="Ferrary Cucinas - Remodelación Bogotá | Omar Fuentes" description="Caso de estudio completo del desarrollo de sitio web corporativo para empresa de remodelación con Next.js, Tailwind CSS y Figma.">
  <div class="min-h-screen bg-background">
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-primary/5"></div>
      <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-20">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex items-center gap-2 mb-6">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                <Clock class="w-4 h-4 mr-1" /> 3 semanas desarrollo
              </span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-500/10 text-green-700 dark:text-green-300 border border-green-500/20">
                <CheckCircle className="w-4 h-4 mr-1" /> Completado
              </span>
            </div>
            
            <h1 class="text-4xl md:text-6xl font-display font-bold mb-6">
              {project.title}
            </h1>
            
            <p class="text-xl text-muted-foreground mb-8">
              {project.description}
            </p>
            
            <div class="flex flex-wrap gap-3 mb-8">
              {project.tecnologias.map(tech => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-foreground/5 text-foreground border border-foreground/10">
                  {tech}
                </span>
              ))}
            </div>
            
            <div class="flex flex-col sm:flex-row gap-4">
              <a 
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-black rounded-xl hover:bg-primary/90 transition-all font-semibold shadow-lg shadow-primary/20"
              >
                <ExternalLink className="w-5 h-5" />
                Ver proyecto en vivo
              </a>
              <a 
                href="/portfolio/proyectos"
                class="inline-flex items-center gap-2 px-8 py-4 bg-foreground/10 text-foreground rounded-xl hover:bg-foreground/20 transition-all font-semibold"
              >
                <ArrowRight className="w-5 h-5" />
                Ver más proyectos
              </a>
            </div>
          </div>
          
          <div class="relative">
            <div class="aspect-[4/3] rounded-3xl overflow-hidden border border-foreground/10 bg-foreground/5">
              <img 
                src={project.imagen}
                alt={project.title}
                width="1200"
                height="900"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Project Stats -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {Object.entries(project.stats).map(([key, value]) => (
            <div key={key} class="text-center p-6 rounded-2xl border border-foreground/10 bg-background hover:border-primary/50 transition-all">
              <div class="text-3xl font-bold text-primary mb-2">{value}</div>
              <div class="text-muted-foreground capitalize">{key}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Stack Tecnológico</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Tecnologías modernas para desarrollo rápido y performance excepcional
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {techStack.map((tech, index) => (
            <div key={index} class="bg-background rounded-xl border p-6 hover:shadow-lg transition-shadow">
              <div class="flex items-start gap-4">
                <div class="text-2xl">{tech.icon}</div>
                <div>
                  <h3 class="font-semibold mb-2">{tech.name}</h3>
                  <p class="text-sm text-muted-foreground">{tech.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Key Features -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Características Principales</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Funcionalidades completas que hacen de este sitio una herramienta de negocio efectiva
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {features.map((feature, index) => (
            <div key={index} class="bg-background rounded-xl border p-8 hover:shadow-lg transition-shadow">
              <div class="text-3xl mb-4">{feature.icon}</div>
              <h3 class="text-xl font-semibold mb-3">{feature.title}</h3>
              <p class="text-muted-foreground leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Development Process -->
    <section id="proceso" class="py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Proceso de Desarrollo</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Metodología estructurada en 3 semanas para garantizar entrega exitosa y calidad excepcional.
          </p>
        </div>
        
        <div class="space-y-12">
          {phases.map((phase, index) => (
            <div key={index} class="relative">
              <div class="flex items-start gap-8">
                <div class="flex-shrink-0">
                  <div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary to-primary/80 text-white flex items-center justify-center font-bold text-xl shadow-lg shadow-primary/20">
                    {index + 1}
                  </div>
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-4 mb-6">
                    <h3 class="text-2xl font-bold text-foreground">{phase.title}</h3>
                    <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-primary/10 text-primary border border-primary/20">
                      {phase.week}
                    </span>
                  </div>
                  <div class="bg-background rounded-2xl border border-foreground/10 p-6">
                    <ul class="space-y-3">
                      {phase.tasks.map((task, taskIndex) => (
                        <li key={taskIndex} class="flex items-start gap-3 text-muted-foreground">
                          <div class="w-2 h-2 rounded-full bg-primary mt-2 flex-shrink-0"></div>
                          <span class="text-foreground">{task}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
              {index < phases.length - 1 && (
                <div class="absolute left-8 top-16 w-0.5 h-20 bg-gradient-to-b from-primary/20 to-transparent"></div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Performance Metrics -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Métricas de Performance</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Resultados excepcionales en velocidad, SEO y experiencia de usuario
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {metrics.map((metric, index) => (
            <div key={index} class="bg-background rounded-xl border p-8 text-center">
              <div class="text-4xl mb-4">{metric.icon}</div>
              <div class="text-3xl font-bold text-primary mb-2">{metric.value}</div>
              <div class="font-semibold mb-2">{metric.title}</div>
              <p class="text-sm text-muted-foreground">{metric.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Results -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Resultados del Proyecto</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Entrega completa con todas las funcionalidades corporativas implementadas
          </p>
        </div>
        
        <div class="bg-background rounded-2xl border p-8">
          <ul class="space-y-4">
            {project.results.map((result, index) => (
              <li key={index} class="flex items-start gap-3">
                <span class="text-green-500 mt-1">{result.split(' ')[0]}</span>
                <span class="text-foreground">{result.substring(result.indexOf(' ') + 1)}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- My Personal Experience -->
    <section class="py-20 bg-gradient-to-br from-primary/5 to-primary/10">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Mi Experiencia con Ferrary Cucinas</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Este proyecto me enseñó que el diseño web puede transformar completamente un negocio de servicios
          </p>
        </div>
        
        <div class="bg-background rounded-2xl border p-12">
          <div class="space-y-8 text-muted-foreground leading-relaxed">
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">🔨 El Desafío Real</h3>
              <p>Ferrary tenía un problema común: hacían un trabajo increíble transformando espacios, pero nadie lo sabía. Sus proyectos eran arte, pero su presencia digital era invisible. Mi misión era crear un portafolio que vendiera sus servicios antes de la primera llamada.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">💡 Mi Enfoque Diferente</h3>
              <p>En lugar de un sitio corporativo típico, creé una experiencia visual. Cada página muestra transformaciones reales con antes/después. Quería que los visitantes sintieran la calidad del trabajo de Ferrary a través de las fotos y videos.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">🎯 El Resultado Mágico</h3>
              <p>La llamada del cliente: 'Omar, estamos recibiendo 4-5 cotizaciones semanales solo del sitio web'. Los clientes llegan ya convencidos porque vieron la calidad del trabajo. Eso es transformación digital real.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">📚 Mi Gran Aprendizaje</h3>
              <p>Ferrary me enseñó que para negocios de servicios, el portafolio visual lo es todo. Los clientes no contratan palabras, contratan resultados que pueden ver. Un buen diseño web no solo muestra, sino que convierte.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div class="bg-background rounded-2xl border p-12">
          <div class="flex justify-center mb-6">
            <Star class="w-8 h-8 text-yellow-500 fill-current" />
          </div>
          <blockquote class="text-xl text-muted-foreground mb-8 leading-relaxed">
            "El sitio superó nuestras expectativas. Ahora los clientes nos encuentran por Google y llegan ya convencidos de la calidad de nuestro trabajo por las fotos. El formulario nos ayuda mucho a pre-calificar proyectos antes de hacer la visita."
          </blockquote>
          <div>
            <div class="font-semibold">Ferrary Cucinas</div>
            <div class="text-sm text-muted-foreground">Cliente Satisfecho</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-4">¿Tu Negocio de Servicios Necesita un Portafolio que Venda?</h2>
        <p class="text-xl text-muted-foreground mb-8">
          Como demostré con Ferrary, no se trata solo de mostrar tus trabajos - se trata de crear una experiencia que convierte visitantes en clientes antes de la primera llamada
        </p>
        
        <div class="bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl p-8 mb-8">
          <p class="text-lg text-muted-foreground mb-4">
            <strong>Mi enfoque:</strong> Creo portafolios visuales que hablan por ti. Tus clientes verán tu calidad y querrán contratarte antes de hablarte.
          </p>
          <p class="text-sm text-muted-foreground">
            4-5 cotizaciones semanales • 95+ PageSpeed • Clientes que llegan convencidos
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/573107851074?text=Hola%20Omar,%20vi%20el%20caso%20Ferrary%20y%20quiero%20un%20portafolio%20que%20venda" 
           target="_blank" 
           rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-black rounded-lg font-medium hover:bg-primary/90 transition-colors">
          <Shield class="w-5 h-5" />
          Crear Mi Portafolio Visual
        </a>
          <a href="/portfolio/proyectos" class="inline-flex items-center gap-2 px-8 py-4 border border-border rounded-lg font-medium hover:bg-accent transition-colors">
            <ArrowRight class="w-5 h-5" />
            Ver Más Transformaciones
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
