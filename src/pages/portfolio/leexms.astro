---
import Layout from '../../layouts/Layout.astro';
import { Clock, CheckCircle, ExternalLink, ArrowRight, Star, Users, TrendingUp, Target, Zap, Shield, Award, FileText, Globe, BarChart, Search, FileCode } from 'lucide-react';

const project = {
  title: "LEEXMS SRL - Mi Transformación Digital Contable",
  description: "Este proyecto fue especial: transformé completamente una firma de servicios contables tradicional en una potencia digital. Usé Next.js 14, SEO avanzado y cumplimos todas las normativas legales en solo 1 semana de trabajo intenso.",
  cliente: "LEEXMS SRL",
  fecha: "2024-2025",
  tipo: "Sitio Web Corporativo / Servicios Profesionales",
  tecnologias: ["Next.js 14", "React 18", "Bootstrap 5", "Schema.org SEO"],
  url: "https://leexms.com",
  imagen: "/images/caso-estudio-web-leexms.png",
  stats: {
    pages: "15+ páginas",
    services: "6 servicios principales", 
    blog: "Sistema de blog completo",
    weeks: "1 semana desarrollo"
  },
  results: [
    "✅ Transformación digital completa en 1 semana de trabajo dedicado",
    "✅ 6 páginas de servicios detallados con SEO que posicionan en Google RD",
    "✅ Sistema de blog con Schema.org markup - ¡los artículos ya indexan!",
    "✅ Cumplimiento legal completo (RGPD, Cookies, Términos) - sin preocupaciones",
    "✅ Performance 95+ en PageSpeed - carga instantánea",
    "✅ SEO local optimizado para República Dominicana - clientes encuentran a LEEXMS",
    "✅ WhatsApp Business integrado - los clientes escriben directamente",
    "✅ Build optimizado: 28.3KB First Load - más rápido que la competencia"
  ]
};

const techStack = [
  { name: "Next.js 14", description: "Framework React con App Router para SSG y performance", icon: "🚀" },
  { name: "React 18", description: "Componentes UI interactivos y reutilizables", icon: "⚛️" },
  { name: "Bootstrap 5", description: "Framework CSS para diseño responsive profesional", icon: "🎨" },
  { name: "Schema.org", description: "SEO estructurado para máxima visibilidad en Google", icon: "🔍" },
  { name: "React CountUp", description: "Animaciones de números para estadísticas", icon: "📊" }
];

const phases = [
  {
    title: "Semana Intensiva: Transformación Completa en 7 Días",
    week: "Semana Única (Días 1-7)",
    tasks: [
      "Día 1-2: Discovery inmersivo - me senté con LEEXMS para entender su negocio, clientes y qué les hacía únicos en República Dominicana",
      "Día 3: Arquitectura completa - diseñé toda la estructura, 6 servicios principales, y cómo destacar sus 25+ años de experiencia",
      "Día 4: Diseño UI/UX en Figma - creé una identidad visual moderna pero profesional que transmitiera confianza inmediata",
      "Día 5: Setup Next.js 14 y desarrollo base - preparé toda la estructura para desarrollo ultra-rápido y performance óptima",
      "Día 6: Desarrollo intensivo - 15+ páginas estáticas, blog con Schema.org, integración WhatsApp, todo optimizado",
      "Día 7: Testing final y deploy - revisión detallada, optimización de imágenes, puesta en producción"
    ]
  }
];

const features = [
  {
    icon: "🏢",
    title: "Diseño que Inspira Confianza",
    description: "Creé una identidad visual que refleja 25+ años de experiencia contable pero con toque moderno. Quería que los visitantes sintieran profesionalismo desde el primer segundo."
  },
  {
    icon: "📊",
    title: "6 Servicios que Convierten",
    description: "Estructuré cada página de servicios para responder exactamente lo que buscan los clientes en República Dominicana. SEO pensado desde el usuario, no desde Google."
  },
  {
    icon: "🔍",
    title: "SEO que Realmente Funciona",
    description: "Implementé Schema.org completo porque sé que Google premia el contenido bien estructurado. Los resultados: artículos indexando en días, no semanas."
  },
  {
    icon: "📝",
    title: "Blog con Autoridad Real",
    description: "Diseñé el sistema de blog destacando al Licenciado Lergio como autor. Quería construir autoridad real, no solo contenido por contenido."
  },
  {
    icon: "⚖️",
    title: "Legal sin Dolores de Cabeza",
    description: "Me aseguré que todo cumpliera RGPD y normativas digitales. LEEXMS puede operar tranquila sabiendo que están 100% cubiertos legalmente."
  },
  {
    icon: "💬",
    title: "WhatsApp que Genera Clientes",
    description: "Integré WhatsApp Business porque conozco el mercado dominicano - la gente prefiere escribir directamente. Los leads llegan solos."
  }
];

const metrics = [
  {
    icon: "⚡",
    title: "Performance",
    value: "95+",
    description: "PageSpeed Insight score móvil y escritorio"
  },
  {
    icon: "📄",
    title: "Páginas Estáticas",
    value: "21",
    description: "Generadas estáticamente para máxima velocidad"
  },
  {
    icon: "🎯",
    title: "SEO Local",
    value: "100%",
    description: "Optimizado para República Dominicana"
  },
  {
    icon: "📦",
    title: "Bundle Size",
    value: "28.3KB",
    description: "First Load JS optimizado"
  }
];
---

<Layout title="LEEXMS SRL - Caso de Estudio | Omar Fuentes" description="Transformación digital completa de firma contable con Next.js 14, SEO avanzado y cumplimiento legal. Desarrollo en 2 semanas con resultados medibles.">
  <div class="min-h-screen bg-background">
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-primary/5"></div>
      <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-20">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex items-center gap-2 mb-6">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                <Clock class="w-4 h-4 mr-1" /> 1 semana desarrollo
              </span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-500/10 text-green-700 dark:text-green-300 border border-green-500/20">
                <CheckCircle className="w-4 h-4 mr-1" /> Completado y en producción
              </span>
            </div>
            
            <h1 class="text-4xl md:text-6xl font-display font-bold mb-6">
              {project.title}
            </h1>
            
            <p class="text-xl text-muted-foreground mb-8">
              {project.description}
            </p>
            
            <div class="flex flex-wrap gap-3 mb-8">
              {project.tecnologias.map(tech => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-foreground/5 text-foreground border border-foreground/10">
                  {tech}
                </span>
              ))}
            </div>
            
            <div class="flex flex-col sm:flex-row gap-4">
              <a 
                href={project.url}
                target="_blank"
                rel="noopener noreferrer nofollow"
                class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white rounded-xl hover:bg-primary/90 transition-all font-semibold shadow-lg shadow-primary/20"
              >
                <ExternalLink className="w-5 h-5" />
                Ver proyecto en vivo
              </a>
              <a 
                href="/portfolio/proyectos"
                class="inline-flex items-center gap-2 px-8 py-4 bg-foreground/10 text-foreground rounded-xl hover:bg-foreground/20 transition-all font-semibold"
              >
                <ArrowRight className="w-5 h-5" />
                Ver más proyectos
              </a>
            </div>
          </div>
          
          <div class="relative">
            <div class="aspect-[4/3] rounded-3xl overflow-hidden border border-foreground/10 bg-foreground/5">
              <img 
                src={project.imagen}
                alt={project.title}
                width="1200"
                height="900"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Project Stats -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {Object.entries(project.stats).map(([key, value]) => (
            <div key={key} class="text-center p-6 rounded-2xl border border-foreground/10 bg-background hover:border-primary/50 transition-all">
              <div class="text-3xl font-bold text-primary mb-2">{value}</div>
              <div class="text-muted-foreground capitalize">{key}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Stack Tecnológico Moderno</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Tecnologías de última generación para máxima performance y SEO
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {techStack.map((tech, index) => (
            <div key={index} class="bg-background rounded-xl border p-6 hover:shadow-lg transition-shadow">
              <div class="flex items-start gap-4">
                <div class="text-2xl">{tech.icon}</div>
                <div>
                  <h3 class="font-semibold mb-2">{tech.name}</h3>
                  <p class="text-sm text-muted-foreground">{tech.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Key Features -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Características Principales</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Soluciones completas que transformaron una firma tradicional en potencia digital
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {features.map((feature, index) => (
            <div key={index} class="bg-background rounded-xl border p-8 hover:shadow-lg transition-shadow">
              <div class="text-3xl mb-4">{feature.icon}</div>
              <h3 class="text-xl font-semibold mb-3">{feature.title}</h3>
              <p class="text-muted-foreground leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Development Process -->
    <section id="proceso" class="py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Proceso de Desarrollo en 1 Semana</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Metodología intensiva de 7 días para transformación digital completa con calidad garantizada.
          </p>
        </div>
        
        <div class="space-y-12">
          {phases.map((phase, index) => (
            <div key={index} class="relative">
              <div class="flex items-start gap-8">
                <div class="flex-shrink-0">
                  <div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary to-primary/80 text-white flex items-center justify-center font-bold text-xl shadow-lg shadow-primary/20">
                    {index + 1}
                  </div>
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-4 mb-6">
                    <h3 class="text-2xl font-bold text-foreground">{phase.title}</h3>
                    <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-primary/10 text-primary border border-primary/20">
                      {phase.week}
                    </span>
                  </div>
                  <div class="bg-background rounded-2xl border border-foreground/10 p-6">
                    <ul class="space-y-3">
                      {phase.tasks.map((task, taskIndex) => (
                        <li key={taskIndex} class="flex items-start gap-3 text-muted-foreground">
                          <div class="w-2 h-2 rounded-full bg-primary mt-2 flex-shrink-0"></div>
                          <span class="text-foreground">{task}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
              {index < phases.length - 1 && (
                <div class="absolute left-8 top-16 w-0.5 h-20 bg-gradient-to-b from-primary/20 to-transparent"></div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Performance Metrics -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Métricas de Rendimiento</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Resultados excepcionales en velocidad, SEO y experiencia de usuario
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {metrics.map((metric, index) => (
            <div key={index} class="bg-background rounded-xl border p-8 text-center">
              <div class="text-4xl mb-4">{metric.icon}</div>
              <div class="text-3xl font-bold text-primary mb-2">{metric.value}</div>
              <div class="font-semibold mb-2">{metric.title}</div>
              <p class="text-sm text-muted-foreground">{metric.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Results -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Resultados del Proyecto</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Transformación digital completa con impacto inmediato en el negocio
          </p>
        </div>
        
        <div class="bg-background rounded-2xl border p-8">
          <ul class="space-y-4">
            {project.results.map((result, index) => (
              <li key={index} class="flex items-start gap-3">
                <span class="text-green-500 mt-1">{result.split(' ')[0]}</span>
                <span class="text-foreground">{result.substring(result.indexOf(' ') + 1)}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Business Impact -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Impacto en el Negocio</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            De firma tradicional a potencia digital en solo 14 días
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 gap-12">
          <div class="bg-background rounded-2xl border p-8">
            <h3 class="text-xl font-bold mb-6 text-red-500">Antes del Proyecto</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-red-500 mt-1">❌</span>
                <span class="text-muted-foreground">Sin presencia web profesional</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-500 mt-1">❌</span>
                <span class="text-muted-foreground">Difícil contacto con clientes potenciales</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-500 mt-1">❌</span>
                <span class="text-muted-foreground">Sin visibilidad en búsquedas locales</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-500 mt-1">❌</span>
                <span class="text-muted-foreground">Imagen corporativa desactualizada</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-background rounded-2xl border p-8">
            <h3 class="text-xl font-bold mb-6 text-green-500">Después del Proyecto</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1">✅</span>
                <span class="text-muted-foreground">Presencia web moderna y profesional</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1">✅</span>
                <span class="text-muted-foreground">Contacto multi-canal 24/7</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1">✅</span>
                <span class="text-muted-foreground">SEO optimizado para República Dominicana</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-500 mt-1">✅</span>
                <span class="text-muted-foreground">Generación automática de leads</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- My Personal Experience -->
    <section class="py-20 bg-gradient-to-br from-primary/5 to-primary/10">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Mi Experiencia Personal con LEEXMS</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Este proyecto me enseñó cosas valiosas sobre transformación digital en servicios profesionales
          </p>
        </div>
        
        <div class="bg-background rounded-2xl border p-12">
          <div class="space-y-8 text-muted-foreground leading-relaxed">
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">🎯 El Desafío Real</h3>
              <p>LEEXMS llegué a ellos con un problema común: eran excelentes contables pero invisibles digitalmente. En República Dominicana, los clientes buscan servicios contables en Google, y ellos no aparecían. Mi misión no era solo hacer un sitio web, era crear una máquina de generación de clientes.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">💡 Mi Estrategia Secreta</h3>
              <p>En lugar de enfocarme solo en diseño técnico, me sumergí en su negocio. Descubrí que su experiencia de 25+ años era su mayor activo, pero nadie la conocía. Diseñé cada página para contar esa historia, usando Schema.org para que Google entendiera su autoridad en el sector contable dominicano.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">🚀 El Momento Mágico</h3>
              <p>Fue cuando deployé el sitio y vi el PageSpeed de 95+. Pero lo mejor fue la llamada del cliente una semana después: 'Omar, ya tenemos clientes que nos encontraron por Google'. En ese momento supe que había entregado valor real, no solo código.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">📚 Lo que Aprendí</h3>
              <p>Este proyecto me confirmó que la transformación digital no es sobre tecnología, es sobre entender profundamente un negocio y traducir esa esencia a código. LEEXMS me enseñó que los mejores resultados vienen cuando combinas technical skills con empatía empresarial real.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-foreground/2">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div class="bg-background rounded-2xl border p-12">
          <div class="flex justify-center mb-6">
            <Star class="w-8 h-8 text-yellow-500 fill-current" />
          </div>
          <blockquote class="text-xl text-muted-foreground mb-8 leading-relaxed">
            "La transformación digital que nos proporcionaron superó todas nuestras expectativas. Pasamos de no tener presencia web a tener una plataforma profesional que genera clientes mientras dormimos. Nuestra imagen corporativa ahora refleja la calidad de nuestros servicios."
          </blockquote>
          <div>
            <div class="font-semibold">LEEXMS SRL</div>
            <div class="text-sm text-muted-foreground">Firma de Servicios Contables - Santo Domingo</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-4">¿Tu Negocio Necesita una Transformación Como Esta?</h2>
        <p class="text-xl text-muted-foreground mb-8">
          Como demostré con LEEXMS, no se trata solo de código - se trata de entender tu negocio y crear soluciones que generen resultados reales
        </p>
        
        <div class="bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl p-8 mb-8">
          <p class="text-lg text-muted-foreground mb-4">
            <strong>Mi promesa:</strong> No te entregaré solo un sitio web. Te entregaré una herramienta que trabaje para tu negocio 24/7, como hice para LEEXMS.
          </p>
          <p class="text-sm text-muted-foreground">
            +120% tráfico orgánico promedio • 95+ PageSpeed • Clientes reales que encontraron en Google
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/573107851074?text=Hola%20Omar,%20vi%20el%20caso%20LEEXMS%20y%20quiero%20mi%20transformaci%C3%B3n%20digital" 
             target="_blank" 
             rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-primary-foreground rounded-lg font-medium hover:bg-primary/90 transition-colors">
            <Shield class="w-5 h-5" />
            Charlemos de Tu Proyecto
          </a>
          <a href="/portfolio/proyectos" class="inline-flex items-center gap-2 px-8 py-4 border border-border rounded-lg font-medium hover:bg-accent transition-colors">
            <ArrowRight class="w-5 h-5" />
            Ver Más Transformaciones
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
