---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    title: 'LEEXMS SRL',
    description: 'Mi transformación digital contable en República Dominicana. Next.js 14, SEO avanzado y cumplimiento legal en 1 semana.',
    image: '/images-portfolio/caso-estudio-web-leexms.png',
    tags: ['Next.js 14', 'SEO Avanzado', 'Servicios Profesionales'],
    link: '/portfolio/leexms/',
    stats: ['15+ páginas', '95+ PageSpeed', '1 semana desarrollo'],
    url: 'https://leexms.com/',
    rel: 'noopener noreferrer nofollow',
  },
  {
    title: 'Ferrarycucina',
    description: 'Mi proyecto estrella de remodelaciones. Portafolio visual que genera 4-5 cotizaciones semanales en Bogotá.',
    image: '/images-portfolio/proyecto-imagen-ferrarycucina.png',
    tags: ['Diseño Web', 'Next.js', 'Local SEO'],
    link: '/portfolio/ferrarycucina/',
    stats: ['4-5 cotizaciones/semana', 'Primer página Google'],
  },
  {
    title: 'Productos Perros',
    description: 'Tienda eCommerce de mascotas con envíos rápidos y experiencia de compra optimizada.',
    image: '/images-portfolio/proyecto-imagen-productosperros.png',
    tags: ['eCommerce', 'Logística', 'Marketing'],
    link: '/portfolio/productos-para-perros/',
    stats: ['Envíos rápidos', 'Clientes satisfechos'],
  },
  {
    title: 'Mundo Gaming',
    description: 'Mi tienda gaming que convierte: 100+ productos, blog de reseñas y Amazon Associates.',
    image: '/images-portfolio/proyecto-imagen-omarytplay.png',
    tags: ['eCommerce', 'Next.js', 'Amazon Associates'],
    link: '/portfolio/mundo-gaming/',
    stats: ['100+ productos', '15 categorías', '95/100 Lighthouse'],
  },
  {
    title: 'Plomería Aqua Imperio',
    description: 'Servicios de plomería en Bogotá. Sitio especializado con SEO local y tecnología Ridgid.',
    image: '/images-portfolio/proyecto-imagen-plemria.png',
    tags: ['Servicios Locales', 'SEO Local', 'HTML5'],
    link: '/portfolio/plomeria/',
    stats: ['15+ páginas', 'SEO local completo', '1 semana desarrollo'],
  },
  {
    title: 'Mora Cleaning',
    description: 'Servicios de limpieza residencial en Tennessee con paquetes claros, garantía y CTAs para cotizar.',
    image: '/images-portfolio/caso-moracleaning.png',
    tags: ['SEO Local', 'Servicios', 'Conversión'],
    link: '/portfolio/moracleaning/',
    stats: ['3 paquetes', '5+ servicios', 'Tennessee, USA'],
    url: 'https://www.moracleaning.us/',
    rel: 'noopener noreferrer nofollow',
  },
  {
    title: 'BitcoinForWifi',
    description: 'Medio editorial sobre Bitcoin y tecnología con arquitectura por categorías y enfoque en SEO técnico.',
    image: '/images-portfolio/caso-bitcoinforwifi.png',
    tags: ['SEO Editorial', 'Contenido', 'Arquitectura'],
    link: '/portfolio/bitcoinforwifi/',
    stats: ['Categorías', 'Evergreen', 'Editorial'],
    url: 'https://bitcoinforwifi.com/',
    rel: 'noopener noreferrer nofollow',
  },
  {
    title: 'BG GREEK',
    description: 'Medio editorial de recetas, dieta y fitness con estructura por categorías, SEO técnico y enfoque evergreen.',
    image: '/images-portfolio/caso-bg-greek.png',
    tags: ['SEO Editorial', 'Contenido', 'Arquitectura'],
    link: '/portfolio/bggreek/',
    stats: ['4 categorías', 'Evergreen', 'Editorial'],
    url: 'https://bg-greek.vercel.app/',
    rel: 'noopener noreferrer nofollow',
  },
  {
    title: 'Akboheim Editorial',
    description: 'Medio editorial de literatura, educación y cultura con secciones temáticas, enfoque evergreen y SEO técnico.',
    image: '/images-portfolio/caso-akboheim.png',
    tags: ['SEO Editorial', 'Evergreen', 'Contenido'],
    link: '/portfolio/akboheim/',
    stats: ['4 secciones', 'Evergreen', 'Editorial'],
    url: 'https://akbohein-editorial.vercel.app/',
    rel: 'noopener noreferrer nofollow',
  },
];

const stats = [
  { label: 'Enfoque', value: 'SEO + UX' },
  { label: 'Prioridad', value: 'Velocidad' },
  { label: 'Soporte', value: 'Post-lanzamiento' },
];
---

<Layout
  title="Portafolio de Proyectos Web - Omar Fuentes | Diseño Web Colombia"
  description="Portafolio de proyectos web en Colombia: eCommerce, sitios corporativos y tiendas online. Enfoque en SEO técnico, velocidad y conversión."
  keywords="portafolio web colombia, proyectos web cali, ecommerce medellin, sitios web bogota, desarrollador web portfolio, casos de exito web, tiendas online colombia, diseño de paginas web, proyectos ecommerce colombia"
>
  <main class="py-16 md:py-24 lg:py-32 pt-24" style="background: var(--white);">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
      <div class="max-w-3xl mb-16">
        <h1 class="text-4xl md:text-6xl font-black mb-6 text-black">Mis Proyectos</h1>
        <p class="text-xl text-black">
          Como desarrollador web freelance, transformo ideas en productos digitales exitosos. Cada proyecto refleja mi compromiso con la excelencia técnica y el diseño centrado en el usuario.
        </p>
        <div class="mt-8">
          <a
            href="https://wa.me/573107851074?text=Hola%20Omar,%20quiero%20mi%20proyecto%20hoy.%20%C2%BFMe%20ayudas%20a%20cotizarlo%3F"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            style="text-decoration: none;"
          >
            Quiero mi proyecto hoy
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        {stats.map((stat) => (
          <div class="text-center p-8 rounded-2xl border" style="border-color: rgba(0,0,0,0.08); background: var(--white); box-shadow: 0 10px 30px rgba(0,0,0,0.06);">
            <div class="text-4xl font-black mb-2" style="color: var(--primary-blue);">{stat.value}</div>
            <div class="text-black font-bold">{stat.label}</div>
          </div>
        ))}
      </div>

      <section class="mb-16">
        <h2 class="text-3xl font-black mb-8 text-black">Proyectos Destacados</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {projects.map((project) => (
            <a href={project.link} class="group block relative overflow-hidden rounded-3xl border" style="border-color: rgba(0,0,0,0.08); background: var(--gray-50); transition: transform 300ms ease;">
              <div class="aspect-[4/3] w-full overflow-hidden">
                <img
                  src={project.image}
                  alt={project.title}
                  width="1200"
                  height="900"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.25) 55%, transparent 100%);"></div>
              </div>

              <div class="absolute bottom-0 left-0 w-full p-8" style="backdrop-filter: blur(10px);">
                <div class="flex flex-wrap gap-2 mb-3">
                  {project.tags.map((tag) => (
                    <span class="text-xs font-bold px-2 py-1 rounded-full" style="background: rgba(255,255,255,0.12); color: var(--white); border: 1px solid rgba(255,255,255,0.18);">
                      {tag}
                    </span>
                  ))}
                </div>

                <h3 class="text-2xl font-black text-white mb-2">{project.title}</h3>
                <p class="text-sm text-white mb-3">{project.description}</p>

                <div class="flex flex-wrap gap-2">
                  {project.stats.map((stat) => (
                    <span class="text-xs font-bold" style="color: var(--primary-yellow);">{stat}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="text-center p-12 rounded-2xl" style="background: linear-gradient(135deg, rgba(0, 102, 255, 0.08) 0%, rgba(255, 215, 0, 0.10) 50%, rgba(0, 200, 81, 0.08) 100%); border: 2px solid rgba(0,0,0,0.06);">
        <h2 class="text-3xl font-black mb-4 text-black">¿Listo para tu próximo proyecto?</h2>
        <p class="text-black max-w-2xl mx-auto mb-8">
          Como tu desarrollador web freelance, transformo tu visión en realidad con soluciones modernas, rápidas y escalables que impulsan tu negocio.
        </p>
        <a
          href="https://wa.me/573107851074?text=Hola%20Omar,%20vi%20tu%20portafolio%20y%20quiero%20desarrollar%20mi%20proyecto.%20¿Podemos%20hablar?"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
          style="text-decoration: none;"
        >
          Hablar por WhatsApp
        </a>
      </section>
    </div>
  </main>
</Layout>
