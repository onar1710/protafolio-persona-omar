---
import Layout from '~/layouts/Layout.astro';
import { ArrowRight, Star, Users, TrendingUp, Clock, Target, Zap, Shield, Award, CheckCircle, ExternalLink, FileText } from 'lucide-react';

const project = {
  title: "Plomería Aqua Imperio - Mi Proyecto de Servicios Locales",
  description: "Este proyecto fue clave: transformé un servicio de plomería tradicional en la opción principal para bogotanos. Usé HTML5, SEO local y estrategia de contenido para dominar las búsquedas de 'plomero Bogotá'.",
  cliente: "Aqua Imperio Plomería",
  fecha: "2026",
  tipo: "Sitio Web de Servicios",
  tecnologias: ["HTML5", "CSS3", "JavaScript", "Bootstrap 5", "SEO Local"],
  url: "https://plomeriaaquaimperio.co/",
  imagen: "/images/proyecto-imagen-plemria.png",
  stats: {
    development: "1 semana",
    pages: "15+ páginas",
    services: "12 servicios especializados",
    seo: "SEO Local Completo"
  },
  results: [
    "✅ Sitio que posiciona #1 para 'plomero Bogotá' - clientes llaman directamente",
    "✅ Especialización en tecnología Ridgid - los clientes saben que usan equipos profesionales",
    "✅ WhatsApp como canal principal - respuesta inmediata para emergencias de plomería",
    "✅ Schema markup completo - Google entiende exactamente qué servicios ofrecen",
    "✅ 100% responsive - los clientes encuentran desde celular en cualquier momento",
    "✅ Contenido educativo que convierte - artículos que responden dudas reales de clientes"
  ]
};

const techStack = [
  { name: "HTML5", description: "Estructura semántica optimizada para SEO", icon: "📄" },
  { name: "CSS3", description: "Diseño visual profesional y responsive", icon: "🎨" },
  { name: "JavaScript", description: "Interactividad y optimización de UX", icon: "⚡" },
  { name: "Bootstrap 5", description: "Framework CSS para desarrollo rápido", icon: "🅱️" },
  { name: "SEO Local", description: "Optimización para búsquedas geográficas", icon: "🗺️" },
  { name: "Schema Markup", description: "Datos estructurados para Google", icon: "🔍" }
];

const phases = [
  {
    title: "Mi Día 1-2: Entendiendo la Plomería Bogotana",
    week: "Día 1-2",
    tasks: [
      "Día 1-2: Analicé la competencia - qué hacían los otros plomeros, cómo diferenciar a Aqua Imperio",
      "Día 2: Investigación profunda - descubrí que la tecnología Ridgid era su ventaja competitiva",
      "Día 3: Keyword research - encontré las búsquedas reales: 'plomero Bogotá urgente', 'destapado tuberías precio'",
      "Día 4: Diseñé la arquitectura - 15 páginas que cubren cada servicio de plomería que ofrecen"
    ]
  },
  {
    title: "Días 3-4: Creando la Presencia Digital",
    week: "Día 3-4",
    tasks: [
      "Día 5: Diseño visual que inspira confianza - colores azul agua, diseño profesional pero cercano",
      "Día 6: Desarrollo responsive - los clientes buscan plomeros desde celular en emergencias",
      "Día 7: Implementé todas las páginas - cada servicio optimizado para conversión",
      "Día 8: Integré WhatsApp - canal principal para emergencias de plomería"
    ]
  },
  {
    title: "Días 5-7: SEO y Magia Local",
    week: "Día 5-7",
    tasks: [
      "Día 9: SEO local intensivo - meta tags para Bogotá, Chapinero, Usaquén",
      "Día 10: Schema markup completo - Google entiende que son plomeros profesionales",
      "Día 11: Optimización de velocidad - cuando hay una fuga, cada segundo cuenta",
      "Día 12: Testing final y deploy - sitio listo para recibir clientes 24/7"
    ]
  }
];

const features = [
  {
    icon: "🔧",
    title: "Especialización Ridgid que Vende",
    description: "Destacé su tecnología profesional Ridgid. Los clientes saben que no es cualquier plomero - son expertos con equipos de primera."
  },
  {
    icon: "�️",
    title: "SEO Local que Domina Bogotá",
    description: "Optimicé para que aparezcan cuando alguien busca 'plomero Bogotá urgente'. Los clientes encuentran a Aqua Imperio primero."
  },
  {
    icon: "💬",
    title: "WhatsApp para Emergencias Reales",
    description: "Integré WhatsApp como canal principal. Cuando hay una fuga, los clientes necesitan respuesta inmediata, no formularios complejos."
  },
  {
    icon: "📱",
    title: "Diseño para Emergencias Móviles",
    description: "Las emergencias de plomería pasan en celular. Diseñé una experiencia móvil donde el botón de WhatsApp está siempre visible."
  },
  {
    icon: "🔍",
    title: "Schema que Google Entiende",
    description: "Implementé LocalBusiness Schema completo. Google sabe exactamente qué servicios ofrecen, dónde operan y cómo contactarlos."
  },
  {
    icon: "📚",
    title: "Contenido que Responde Dudas Reales",
    description: "Creé artículos que responden preguntas reales: 'cuánto cuesta destapar tuberías', 'cómo saber si tengo fuga'. Los clientes leen y confían."
  }
];

const metrics = [
  { label: "Tiempo Desarrollo", value: "1 semana", icon: "⏱️" },
  { label: "Páginas Creadas", value: "15+", icon: "📄" },
  { label: "Servicios", value: "12", icon: "🔧" },
  { label: "SEO Score", value: "9.5/10", icon: "🔍" }
];
---

<Layout title="Plomería Aqua Imperio - Caso de Estudio | Omar Fuentes" description="Caso de estudio completo del desarrollo de sitio web para empresa de plomería en Bogotá con SEO local, optimización para conversión y tecnología Ridgid.">
  <div class="min-h-screen bg-background">
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-primary/5"></div>
      <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-20">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex items-center gap-2 mb-6">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                <Clock class="w-4 h-4 mr-1" /> 1 semana desarrollo
              </span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-500/10 text-green-700 dark:text-green-300 border border-green-500/20">
                <CheckCircle className="w-4 h-4 mr-1" /> Completado
              </span>
            </div>
            
            <h1 class="text-4xl md:text-6xl font-display font-bold mb-6">
              {project.title}
            </h1>
            
            <p class="text-xl text-muted-foreground mb-8">
              {project.description}
            </p>
            
            <div class="flex flex-wrap gap-3 mb-8">
              {project.tecnologias.map(tech => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-foreground/5 text-foreground border border-foreground/10">
                  {tech}
                </span>
              ))}
            </div>
            
            <div class="flex flex-col sm:flex-row gap-4">
              <a 
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white rounded-xl hover:bg-primary/90 transition-all font-semibold shadow-lg shadow-primary/20"
              >
                <ExternalLink className="w-5 h-5" />
                Ver proyecto en vivo
              </a>
              <a 
                href="/portfolio/proyectos"
                class="inline-flex items-center gap-2 px-8 py-4 bg-foreground/10 text-foreground rounded-xl hover:bg-foreground/20 transition-all font-semibold"
              >
                <ArrowRight className="w-5 h-5" />
                Ver más proyectos
              </a>
            </div>
          </div>
          
          <div class="relative">
            <div class="aspect-[4/3] rounded-3xl overflow-hidden border border-foreground/10 bg-foreground/5">
              <img 
                src={project.imagen}
                alt={project.title}
                width="1200"
                height="900"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-24 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {metrics.map((metric, index) => (
            <div class="text-center" key={index}>
              <div class="text-3xl mb-2">{metric.icon}</div>
              <div class="text-2xl font-bold mb-1">{metric.value}</div>
              <div class="text-sm text-muted-foreground">{metric.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Project Overview -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Resumen del Proyecto</h2>
          <p class="text-muted-foreground">
            Desarrollo completo de sitio web profesional para empresa de plomería especializada en Bogotá, 
            con enfoque en SEO local, especialización en tecnología Ridgid y optimización para conversión.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12">
          <div>
            <h3 class="text-xl font-semibold mb-4">Información del Cliente</h3>
            <div class="space-y-3 text-muted-foreground">
              <p><strong>Empresa:</strong> Aqua Imperio Plomería</p>
              <p><strong>Ubicación:</strong> Bogotá, Colombia</p>
              <p><strong>Experiencia:</strong> 12+ años en plomería</p>
              <p><strong>Especialización:</strong> Tecnología Ridgid profesional</p>
              <p><strong>Servicios:</strong> 12 servicios especializados</p>
            </div>
          </div>
          
          <div>
            <h3 class="text-xl font-semibold mb-4">Objetivos del Proyecto</h3>
            <ul class="space-y-2 text-muted-foreground">
              <li>• Generar leads calificados a través de WhatsApp</li>
              <li>• Posicionamiento en búsquedas locales de plomería</li>
              <li>• Diferenciarse con tecnología Ridgid</li>
              <li>• Educar sobre servicios especializados</li>
              <li>• Sistema de contacto fácil y directo</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-24 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Stack Tecnológico</h2>
          <p class="text-muted-foreground">
            Tecnologías modernas y optimizadas para desarrollo rápido y SEO efectivo.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {techStack.map((tech, index) => (
            <div class="bg-background rounded-xl border p-6 hover:shadow-lg transition-shadow" key={index}>
              <div class="text-3xl mb-4">{tech.icon}</div>
              <h3 class="text-lg font-semibold mb-2">{tech.name}</h3>
              <p class="text-muted-foreground text-sm">{tech.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Development Process -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Proceso de Desarrollo</h2>
          <p class="text-muted-foreground">
            Metodología estructurada en 1 semana para garantizar entrega exitosa y calidad excepcional.
          </p>
        </div>

        <div class="space-y-8">
          {phases.map((phase, index) => (
            <div class="bg-background rounded-xl border p-8" key={index}>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                  <Target className="w-6 h-6 text-primary" />
                </div>
                <div>
                  <h3 class="text-xl font-semibold">{phase.title}</h3>
                  <p class="text-sm text-muted-foreground">{phase.week}</p>
                </div>
              </div>
              <ul class="space-y-2 text-muted-foreground">
                {phase.tasks.map((task, taskIndex) => (
                  <li key={taskIndex} class="flex items-start gap-2">
                    <CheckCircle className="w-4 h-4 mt-0.5 text-green-500 flex-shrink-0" />
                    <span>{task}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Key Features -->
    <section class="py-24 bg-foreground/2">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Características Destacadas</h2>
          <p class="text-muted-foreground">
            Elementos clave que hacen este sitio web efectivo para generar clientes.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {features.map((feature, index) => (
            <div class="bg-background rounded-xl border p-6 text-center" key={index}>
              <div class="text-4xl mb-4">{feature.icon}</div>
              <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
              <p class="text-muted-foreground text-sm">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Results -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Resultados Obtenidos</h2>
          <p class="text-muted-foreground">
            Entrega exitosa con todas las funcionalidades implementadas y optimización completa.
          </p>
        </div>

        <div class="bg-background rounded-xl border p-8">
          <ul class="space-y-4">
            {project.results.map((result, index) => (
              <li key={index} class="flex items-start gap-3">
                <CheckCircle className="w-5 h-5 mt-0.5 text-green-500 flex-shrink-0" />
                <span>{result}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- My Personal Experience -->
    <section class="py-20 bg-gradient-to-br from-primary/5 to-primary/10">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold mb-4">Mi Experiencia con Aqua Imperio</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">
            Este proyecto me enseñó que para servicios locales, el SEO y la confianza lo son todo
          </p>
        </div>
        
        <div class="bg-background rounded-2xl border p-12">
          <div class="space-y-8 text-muted-foreground leading-relaxed">
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">🔧 El Desafío Real</h3>
              <p>Aqua Imperio tenía excelentes plomeros pero eran invisibles online. En Bogotá, cuando alguien necesita un plomero, busca en Google y llama al primero que aparece. Mi misión era hacerlos esa primera opción.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">💡 Mi Estrategia Local</h3>
              <p>Descubrí que su ventaja era la tecnología Ridgid. En lugar de ser 'plomeros genéricos', los posicioné como expertos con equipos profesionales. Cada página está optimizada para búsquedas reales de emergencias.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">🚀 El Resultado Inmediato</h3>
              <p>El sitio comenzó a recibir llamadas directamente desde Google. Los clientes decían 'los encontramos en Google y vimos que usan tecnología profesional'. Eso es posicionamiento que convierte en clientes reales.</p>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-foreground mb-3">📚 Lo que Aprendí de Servicios Locales</h3>
              <p>Para negocios locales, no se trata de tener el sitio más bonito. Se trata de ser la primera opción cuando alguien necesita tus servicios urgentemente. El SEO local + confianza = clientes que llaman sin dudar.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-4">¿Tu Negocio Local Necesita Clientes que Llamen Directamente?</h2>
        <p class="text-xl text-muted-foreground mb-8">
          Como demostré con Aqua Imperio, no se trata solo de tener un sitio web - se trata de ser la primera opción que Google muestra cuando alguien necesita tus servicios urgentemente
        </p>
        
        <div class="bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl p-8 mb-8">
          <p class="text-lg text-muted-foreground mb-4">
            <strong>Mi enfoque local:</strong> Creo sitios que posicionan #1 en búsquedas locales. Cuando alguien busque tus servicios en tu ciudad, tú serás la primera llamada.
          </p>
          <p class="text-sm text-muted-foreground">
            SEO local completo • WhatsApp integrado • Clientes que llaman directamente • 1 semana desarrollo
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="https://wa.me/573107851074?text=Hola%20Omar,%20vi%20el%20caso%20Plomería%20y%20quiero%20dominar%20las%20búsquedas%20locales%20de%20mi%20negocio"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-primary-foreground rounded-lg font-medium hover:bg-primary/90 transition-colors"
          >
            <Shield class="w-5 h-5" />
            Dominar Mi Localidad
          </a>
          <a 
            href="/portfolio/proyectos" 
            class="inline-flex items-center gap-2 px-8 py-4 border border-border rounded-lg font-medium hover:bg-accent transition-colors"
          >
            <ArrowRight class="w-5 h-5" />
            Ver Más Transformaciones
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
