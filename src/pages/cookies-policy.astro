---
import Layout from '~/layouts-en/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

---

<Layout title="Cookies Policy - Omar Fuentes" description="Cookies Policy of Jose Omar Fernandez Fuentes. Information about the use of cookies and similar technologies on our website.">
  
  <PageHeader 
      title="Cookies Policy"
      description="Last updated: January 28, 2026"
  />

  <Container as="main" class="max-w-4xl mx-auto">
      
      <!-- 1. What are Cookies? -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">1. What are Cookies?</h2>
          <p class="text-muted-foreground leading-8">
              Cookies are small text files that are stored on your device (computer, tablet, or mobile) when
              you visit a website. They allow the website to remember your actions and preferences for a period of time,
              improving your browsing experience.
          </p>
      </section>

      <!-- 2. How We Use Cookies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">2. How We Use Cookies</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              <span class="font-semibold text-foreground">Jose Omar Fernandez Fuentes</span> uses cookies on this website to:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Remember your preferences and settings</li>
              <li>Analyze website traffic and usage</li>
              <li>Improve functionality and user experience</li>
              <li>Understand how visitors interact with our site</li>
              <li>Optimize website performance</li>
          </ul>
      </section>

      <!-- 3. Types of Cookies We Use -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">3. Types of Cookies We Use</h2>

          <h3 class="text-xl font-semibold mb-4">3.1 Strictly Necessary Cookies</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              These cookies are essential for the website to function and cannot be disabled.
          </p>

          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6 mb-6 overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                  <thead class="bg-black/5 dark:bg-white/5">
                      <tr>
                          <th class="px-4 py-3 font-semibold text-foreground">Name</th>
                          <th class="px-4 py-3 font-semibold text-foreground">Purpose</th>
                          <th class="px-4 py-3 font-semibold text-foreground">Duration</th>
                      </tr>
                  </thead>
                  <tbody class="divide-y divide-black/10 dark:divide-white/10">
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">session_id</td>
                          <td class="px-4 py-3 text-muted-foreground">Maintain user session</td>
                          <td class="px-4 py-3 text-muted-foreground">Session</td>
                      </tr>
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">consent_cookie</td>
                          <td class="px-4 py-3 text-muted-foreground">Remember cookie preferences</td>
                          <td class="px-4 py-3 text-muted-foreground">1 year</td>
                      </tr>
                  </tbody>
              </table>
          </div>

          <h3 class="text-xl font-semibold mb-4 mt-8">3.2 Performance and Analytics Cookies</h3>
          <p class="text-muted-foreground leading-8 mb-4">They help us understand how visitors use our website.</p>

          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6 mb-6">
              <p class="font-semibold text-foreground mb-4">Google Analytics</p>
              <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
                  <li>
                      <span class="font-semibold text-foreground">Purpose:</span> Analyze website traffic
                  </li>
                  <li>
                      <span class="font-semibold text-foreground">Cookies:</span> _ga, _gid, _gat
                  </li>
                  <li>
                      <span class="font-semibold text-foreground">Duration:</span> Between session and 2 years
                  </li>
                  <li>
                      <span class="font-semibold text-foreground">Provider:</span> Google LLC
                  </li>
                  <li>
                      <span class="font-semibold text-foreground">More information:</span>{" "}
                      <a class="font-semibold text-primary hover:underline" href="https://policies.google.com/privacy" target="_blank" rel="noreferrer">
                          Google Analytics
                      </a>
                  </li>
              </ul>
          </div>

          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6 overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                  <thead class="bg-black/5 dark:bg-white/5">
                      <tr>
                          <th class="px-4 py-3 font-semibold text-foreground">Cookie</th>
                          <th class="px-4 py-3 font-semibold text-foreground">Purpose</th>
                          <th class="px-4 py-3 font-semibold text-foreground">Duration</th>
                      </tr>
                  </thead>
                  <tbody class="divide-y divide-black/10 dark:divide-white/10">
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">_ga</td>
                          <td class="px-4 py-3 text-muted-foreground">Distinguish unique users</td>
                          <td class="px-4 py-3 text-muted-foreground">2 years</td>
                      </tr>
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">_gid</td>
                          <td class="px-4 py-3 text-muted-foreground">Distinguish unique users</td>
                          <td class="px-4 py-3 text-muted-foreground">24 hours</td>
                      </tr>
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">_gat</td>
                          <td class="px-4 py-3 text-muted-foreground">Limit request rate</td>
                          <td class="px-4 py-3 text-muted-foreground">1 minute</td>
                      </tr>
                  </tbody>
              </table>
          </div>

          <h3 class="text-xl font-semibold mb-4 mt-8">3.3 Functionality Cookies</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              They allow the website to remember your choices and provide enhanced features.
          </p>

          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6 overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                  <thead class="bg-black/5 dark:bg-white/5">
                      <tr>
                          <th class="px-4 py-3 font-semibold text-foreground">Name</th>
                          <th class="px-4 py-3 font-semibold text-foreground">Purpose</th>
                          <th class="px-4 py-3 font-semibold text-foreground">Duration</th>
                      </tr>
                  </thead>
                  <tbody class="divide-y divide-black/10 dark:divide-white/10">
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">language_pref</td>
                          <td class="px-4 py-3 text-muted-foreground">Remember language preference</td>
                          <td class="px-4 py-3 text-muted-foreground">1 year</td>
                      </tr>
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">theme_mode</td>
                          <td class="px-4 py-3 text-muted-foreground">Remember light/dark mode</td>
                          <td class="px-4 py-3 text-muted-foreground">1 year</td>
                      </tr>
                  </tbody>
              </table>
          </div>

          <h3 class="text-xl font-semibold mb-4 mt-8">3.4 Marketing and Advertising Cookies</h3>
          <p class="text-muted-foreground leading-8">
              We currently <span class="font-semibold text-foreground">DO NOT</span> use third-party marketing or advertising cookies. If this changes in the future,
              we will update this policy and request your consent.
          </p>
      </section>

      <!-- 4. Third-Party Cookies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">4. Third-Party Cookies</h2>

          <h3 class="text-xl font-semibold mb-4">Google Analytics</h3>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Purpose:</span> Web traffic analysis</li>
              <li><span class="font-semibold text-foreground">Type:</span> Analytics cookies</li>
              <li>
                  <span class="font-semibold text-foreground">Privacy policy:</span>{" "}
                  <a class="font-semibold text-primary hover:underline" href="https://policies.google.com/privacy" target="_blank" rel="noreferrer">
                      https://policies.google.com/privacy
                  </a>
              </li>
              <li>
                  <span class="font-semibold text-foreground">Opt-out:</span>{" "}
                  <a class="font-semibold text-primary hover:underline" href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noreferrer">
                      https://tools.google.com/dlpage/gaoptout
                  </a>
              </li>
          </ul>

          <h3 class="text-xl font-semibold mb-4 mt-8">Google Fonts</h3>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Purpose:</span> Load web fonts</li>
              <li><span class="font-semibold text-foreground">Type:</span> Functionality cookies</li>
              <li>
                  <span class="font-semibold text-foreground">Privacy policy:</span>{" "}
                  <a class="font-semibold text-primary hover:underline" href="https://policies.google.com/privacy" target="_blank" rel="noreferrer">
                      https://policies.google.com/privacy
                  </a>
              </li>
          </ul>

          <p class="text-muted-foreground leading-8 mb-4">Other services that may set cookies:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Hosting services</li>
              <li>Contact form tools</li>
              <li>Social media integrations (if present)</li>
          </ul>
      </section>

      <!-- 5. Cookie Management and Control -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">5. Cookie Management and Control</h2>

          <h3 class="text-xl font-semibold mb-4">5.1 Cookie Consent</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              When you first visit our website, you will see a cookie banner where you can accept, reject, or customize your preferences.
          </p>

          <h3 class="text-xl font-semibold mb-4 mt-8">5.2 Changing Your Preferences</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              You can change your cookie preferences at any time using a settings panel (if available) or through your browser settings.
          </p>

          <h3 class="text-xl font-semibold mb-4 mt-8">5.3 Browser Settings</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              You can control and/or delete cookies as you wish. For details, please see{" "}
              <a class="font-semibold text-primary hover:underline" href="https://www.aboutcookies.org/" target="_blank" rel="noreferrer">
                  aboutcookies.org
              </a>
              .
          </p>

          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <p class="font-semibold text-foreground mb-4">Quick guides</p>
              <div class="grid gap-4 text-muted-foreground">
                  <div>
                      <p class="font-semibold text-foreground">Google Chrome</p>
                      <ol class="mt-2 grid gap-1 pl-6 list-decimal">
                          <li>Click menu (three dots) > Settings</li>
                          <li>Go to "Privacy and security" > "Cookies and other site data"</li>
                          <li>Select your preferences</li>
                      </ol>
                  </div>
                  <div>
                      <p class="font-semibold text-foreground">Mozilla Firefox</p>
                      <ol class="mt-2 grid gap-1 pl-6 list-decimal">
                          <li>Click menu (three lines) > Settings</li>
                          <li>Go to "Privacy & security"</li>
                          <li>Under "Cookies and site data", set your preferences</li>
                      </ol>
                  </div>
                  <div>
                      <p class="font-semibold text-foreground">Safari</p>
                      <ol class="mt-2 grid gap-1 pl-6 list-decimal">
                          <li>Go to Preferences > Privacy</li>
                          <li>Configure "Cookies and website data"</li>
                      </ol>
                  </div>
                  <div>
                      <p class="font-semibold text-foreground">Microsoft Edge</p>
                      <ol class="mt-2 grid gap-1 pl-6 list-decimal">
                          <li>Click menu (three dots) > Settings</li>
                          <li>Go to "Cookies and site permissions"</li>
                          <li>Configure "Cookies and site data"</li>
                      </ol>
                  </div>
              </div>

              <p class="mt-6 text-sm text-muted-foreground">
                  <span class="font-semibold text-foreground">Note:</span> Blocking or deleting cookies may affect website functionality.
              </p>
          </div>
      </section>

      <!-- 6. Mobile Device Cookies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">6. Mobile Device Cookies</h2>
          <p class="text-muted-foreground leading-8">
              To manage cookies on mobile devices, consult your mobile browser documentation: Safari (iOS), Chrome (Android/iOS), Firefox
              (Android/iOS), and Samsung Internet.
          </p>
      </section>

      <!-- 7. Do Not Track (DNT) -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">7. Do Not Track (DNT)</h2>
          <p class="text-muted-foreground leading-8">
              Some browsers include a "Do Not Track" feature. Currently, there is no universal standard for interpreting these signals.
              We respect your privacy and you can control cookies through the methods described above.
          </p>
      </section>

      <!-- 8. Local Storage and Other Technologies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">8. Local Storage and Other Technologies</h2>
          <p class="text-muted-foreground leading-8 mb-4">In addition to cookies, we may use other storage technologies such as:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Local Storage:</span> To store user preferences</li>
              <li><span class="font-semibold text-foreground">Session Storage:</span> For temporary data during your session</li>
              <li><span class="font-semibold text-foreground">Tracking pixels:</span> In emails (if applicable)</li>
          </ul>
      </section>

      <!-- 9. Cookie Duration -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">9. Cookie Duration</h2>
          <p class="text-muted-foreground leading-8 mb-4">Cookies can be:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Session cookies:</span> Deleted when you close your browser</li>
              <li><span class="font-semibold text-foreground">Persistent cookies:</span> Remain on your device until they expire or you delete them manually</li>
          </ul>

          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6 overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                  <thead class="bg-black/5 dark:bg-white/5">
                      <tr>
                          <th class="px-4 py-3 font-semibold text-foreground">Cookie Type</th>
                          <th class="px-4 py-3 font-semibold text-foreground">Typical Duration</th>
                      </tr>
                  </thead>
                  <tbody class="divide-y divide-black/10 dark:divide-white/10">
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">Strictly necessary</td>
                          <td class="px-4 py-3 text-muted-foreground">Session - 1 year</td>
                      </tr>
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">Analytics</td>
                          <td class="px-4 py-3 text-muted-foreground">1 day - 2 years</td>
                      </tr>
                      <tr>
                          <td class="px-4 py-3 text-muted-foreground">Functionality</td>
                          <td class="px-4 py-3 text-muted-foreground">1 month - 1 year</td>
                      </tr>
                  </tbody>
              </table>
          </div>
      </section>

      <!-- 10. Cookie Updates -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">10. Cookie Updates</h2>
          <p class="text-muted-foreground leading-8">
              We may occasionally update the types of cookies we use. When we make significant changes, we will update the
              "Last updated" date on this page.
          </p>
      </section>

      <!-- 11. Impact of Rejecting Cookies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">11. Impact of Rejecting Cookies</h2>
          <p class="text-muted-foreground leading-8 mb-4">If you decide to reject non-essential cookies:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>✅ The website will continue to function</li>
              <li>✅ You can browse and access content</li>
              <li>❌ We cannot remember your preferences</li>
              <li>❌ The experience may be less personalized</li>
              <li>❌ We cannot analyze how to improve the site</li>
          </ul>
      </section>

      <!-- 12. Cookies and Privacy -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">12. Cookies and Privacy</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              The use of cookies is covered by our{" "}
              <a class="font-semibold text-primary hover:underline" href="/privacy-policy">
                  Privacy Policy
              </a>
              .
          </p>
      </section>

      <!-- 13. Legal Framework -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">13. Legal Framework</h2>
          <p class="text-muted-foreground leading-8 mb-4">Our cookie policy complies with:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Colombian Law 1581 of 2012 (Personal Data Protection)</li>
              <li>Decree 1377 of 2013</li>
              <li>GDPR (EU General Data Protection Regulation) - best practices</li>
              <li>ePrivacy Directive</li>
          </ul>
      </section>

      <!-- 14. Frequently Asked Questions -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">14. Frequently Asked Questions</h2>

          <h3 class="text-xl font-semibold mb-4 mt-8">Do I have to accept all cookies?</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              No. You can reject non-essential cookies. Only strictly necessary cookies are mandatory for the site to function.
          </p>

          <h3 class="text-xl font-semibold mb-4 mt-8">How do I delete existing cookies?</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              You can delete cookies through your browser settings at any time.
          </p>

          <h3 class="text-xl font-semibold mb-4 mt-8">Do cookies contain personal information?</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              Cookies themselves do not contain personally identifiable information, but they can be associated with it when combined with other data.
          </p>

          <h3 class="text-xl font-semibold mb-4 mt-8">Can I change my consent later?</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              Yes, you can change your cookie preferences at any time using our settings panel or your browser settings.
          </p>
      </section>

      <!-- 15. Contact -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">15. Contact</h2>
          <p class="text-muted-foreground leading-8 mb-4">If you have questions about our Cookies Policy, you can contact us:</p>

          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6 mb-8">
              <p class="font-semibold text-foreground mb-4">Jose Omar Fernandez Fuentes</p>
              <div class="grid gap-2 text-muted-foreground">
                  <p>
                      <span class="font-semibold text-foreground">Address:</span> Floridablanca, Santander, Colombia
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Phone:</span> +57 310 785 1074
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Email:</span> joseomarfernandez747@gmail.com
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">NIT:</span> 3-1091452824
                  </p>
              </div>
          </div>
      </section>

      <!-- 16. Additional Resources -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">16. Additional Resources</h2>
          <p class="text-muted-foreground leading-8 mb-4">For more information about cookies:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>
                  <a class="font-semibold text-primary hover:underline" href="https://www.allaboutcookies.org/" target="_blank" rel="noreferrer">
                      All About Cookies
                  </a>
              </li>
              <li>
                  <a class="font-semibold text-primary hover:underline" href="https://www.youronlinechoices.com/" target="_blank" rel="noreferrer">
                      Your Online Choices
                  </a>
              </li>
              <li>
                  <a class="font-semibold text-primary hover:underline" href="https://www.networkadvertising.org/" target="_blank" rel="noreferrer">
                      Network Advertising Initiative
                  </a>
              </li>
          </ul>

          <p class="text-sm text-muted-foreground mt-8">
              <span class="font-semibold text-foreground">Last review:</span> January 28, 2026 · <span class="font-semibold text-foreground">Next scheduled review:</span> July 28, 2026
          </p>
      </section>
  </Container>
</Layout>
