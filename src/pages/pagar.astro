---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

export const prerender = false;

const nextUrl = `/pago${Astro.url.search || ''}`;
---

<Layout title="Pagar - Omar Fuentes" description="Contacto" >
  <PageHeader title="Contacto" description="Redirigiendo..." />

  <Container as="section" class="pb-24">
	<meta http-equiv="refresh" content={`0;url=${nextUrl}`} />
    <div class="max-w-2xl mx-auto rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
	  <p class="text-muted-foreground">Redirigiendo a pago...</p>
      <div class="mt-6">
		<a href={nextUrl} class="inline-flex justify-center rounded-full px-5 py-3 text-sm font-semibold bg-primary text-black hover:bg-primary/90 transition-colors">Ir a pago</a>
      </div>
    </div>
  </Container>
</Layout>
