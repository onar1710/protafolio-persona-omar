---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Generador de títulos SEO | Omar Fuentes"
  description="Crea títulos optimizados para SEO en segundos. Elige un tono, ingresa tu keyword y tema, y exporta al instante."
>
  <main class="pt-24 pb-20 bg-white">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-5xl">
      <a href="/herramientas/" class="text-primary-blue font-semibold hover:underline">Volver a herramientas</a>

      <header class="mt-6">
        <h1 class="text-4xl md:text-5xl font-black mb-4">Generador de títulos SEO</h1>
        <p class="text-black text-lg max-w-3xl">
          Genera 10 ideas de títulos que incluyan tu keyword y se adapten al tono de tu marca.
        </p>
      </header>

      <div class="mt-10 grid grid-cols-1 lg:grid-cols-2 gap-8">
        <form id="titleForm" class="card">
          <div class="grid grid-cols-1 gap-4">
            <label class="block">
              <span class="block text-sm font-semibold mb-2">Idioma de salida</span>
              <select id="lang" class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-white">
                <option value="es" selected>Español</option>
                <option value="en">Inglés</option>
              </select>
            </label>

            <label class="block">
              <span class="block text-sm font-semibold mb-2">Tono</span>
              <select id="tone" class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-white">
                <option value="Formal">Formal</option>
                <option value="Friendly">Amistoso</option>
                <option value="Informal">Informal</option>
                <option value="Professional" selected>Profesional</option>
                <option value="Diplomatic">Diplomático</option>
                <option value="Confident">Seguro</option>
                <option value="High school level">Educación secundaria</option>
                <option value="Academic">Académico</option>
                <option value="Simplified">Simplificado</option>
                <option value="Vivid">Vívido</option>
                <option value="Empathetic">Empático</option>
                <option value="Commercial">Comercial</option>
                <option value="Engaging">Atractivo</option>
                <option value="Direct">Directo</option>
                <option value="Persuasive">Persuasivo</option>
              </select>
            </label>

            <label class="block">
              <span class="block text-sm font-semibold mb-2">Keyword principal</span>
              <input id="keyword" class="w-full border border-gray-200 rounded-xl px-4 py-3" placeholder="Ej: diseño web" required />
            </label>

            <label class="block">
              <span class="block text-sm font-semibold mb-2">Tema (opcional)</span>
              <input id="topic" class="w-full border border-gray-200 rounded-xl px-4 py-3" placeholder="Ej: para negocios pequeños" />
            </label>
          </div>

          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <button type="submit" id="generateBtn" class="px-6 py-3 rounded-xl font-semibold text-white bg-gradient-to-r from-primary-blue to-accent-blue hover:shadow-glow-blue transition-all">
              Generar títulos (IA)
            </button>
            <button type="button" id="copyBtn" class="px-6 py-3 rounded-xl font-semibold border-2 border-primary-blue text-primary-blue hover:bg-primary-blue hover:text-white transition-all" disabled>
              Copiar
            </button>
            <button type="button" id="downloadBtn" class="px-6 py-3 rounded-xl font-semibold border-2 border-primary-green text-primary-green hover:bg-primary-green hover:text-white transition-all" disabled>
              Descargar .txt
            </button>
          </div>
        </form>

        <div class="card">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h2 class="text-xl font-bold">Resultados</h2>
            <span id="meta" class="text-xs text-gray-600"></span>
          </div>
          <ol id="results" class="space-y-3 text-black list-decimal pl-5"></ol>
          <p id="empty" class="text-gray-600">Completa el formulario y haz clic en “Generar títulos”.</p>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/tools/title-generator.js" data-default-lang="es"></script>
</Layout>
