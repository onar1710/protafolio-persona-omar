---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Generador de estructura de artículos | Omar Fuentes"
  description="Genera la estructura completa de un artículo optimizado para SEO (H2/H3, FAQ, tablas y más)."
>
  <main class="pt-24 pb-20 bg-white">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-5xl">
      <a href="/herramientas/" class="text-primary-blue font-semibold hover:underline">Volver a herramientas</a>

      <header class="mt-6 mb-10">
        <h1 class="text-4xl md:text-5xl font-black mb-4">Generador de estructura de artículos</h1>
        <p class="text-black text-lg max-w-3xl">
          Crea un esquema con H2/H3, preguntas frecuentes y secciones sugeridas.
        </p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <form id="outlineForm" class="card">
          <div class="grid grid-cols-1 gap-4">
            <label class="block">
              <span class="block text-sm font-semibold mb-2">Tema / título</span>
              <input id="topic" class="w-full border border-gray-200 rounded-xl px-4 py-3" placeholder="Ej: Cómo crear un sitio web" required />
            </label>

            <label class="block">
              <span class="block text-sm font-semibold mb-2">Keyword principal</span>
              <input id="primary" class="w-full border border-gray-200 rounded-xl px-4 py-3" placeholder="Ej: diseño web" required />
            </label>

            <label class="block">
              <span class="block text-sm font-semibold mb-2">Keywords secundarias (separadas por coma)</span>
              <input id="secondary" class="w-full border border-gray-200 rounded-xl px-4 py-3" placeholder="Ej: seo técnico, core web vitals, conversión" />
            </label>

            <label class="block">
              <span class="block text-sm font-semibold mb-2">Tipo de contenido</span>
              <select id="type" class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-white">
                <option value="blog" selected>Artículo de blog</option>
                <option value="guia">Guía paso a paso</option>
                <option value="comparacion">Comparativa</option>
                <option value="servicio">Página de servicio</option>
              </select>
            </label>

            <label class="block">
              <span class="block text-sm font-semibold mb-2">Datos de competencia (opcional)</span>
              <textarea id="competitorJson" class="w-full border border-gray-200 rounded-xl px-4 py-3 min-h-[120px]" placeholder="Pega aquí un JSON de SERP o notas (opcional)"></textarea>
            </label>
          </div>

          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <button type="submit" id="generateBtn" class="px-6 py-3 rounded-xl font-semibold text-white bg-gradient-to-r from-primary-blue to-accent-blue hover:shadow-glow-blue transition-all">
              Generar estructura (IA)
            </button>
            <button type="button" id="copyBtn" class="px-6 py-3 rounded-xl font-semibold border-2 border-primary-blue text-primary-blue hover:bg-primary-blue hover:text-white transition-all" disabled>
              Copiar
            </button>
            <button type="button" id="downloadBtn" class="px-6 py-3 rounded-xl font-semibold border-2 border-primary-green text-primary-green hover:bg-primary-green hover:text-white transition-all" disabled>
              Descargar .txt
            </button>
          </div>
        </form>

        <div class="card">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h2 class="text-xl font-bold">Estructura</h2>
            <span id="meta" class="text-xs text-gray-600"></span>
          </div>
          <pre id="output" class="whitespace-pre-wrap text-sm text-black"></pre>
          <p id="empty" class="text-gray-600">Completa el formulario y haz clic en “Generar estructura”.</p>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/tools/outline-generator.js" data-default-lang="es"></script>
</Layout>
