---
import Layout from '~/layouts/Layout.astro';
import { FileText, ArrowRight } from 'lucide-react';

const availableLangs = ['es'];
---

<Layout
  title="Herramientas | Omar Fuentes"
  description="Herramientas y utilidades para marketing, SEO y creación de contenido."
  availableLangs={availableLangs}
>
  <div class="max-w-5xl mx-auto px-6 pt-36 md:pt-40 pb-24">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Herramientas</h1>
      <p class="text-muted-foreground text-lg">Utilidades rápidas para ayudarte a crear contenido y mejorar tu SEO.</p>
    </div>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
      <a
        href="/herramientas/generador-estructura-articulos"
        class="group block rounded-2xl border border-black/10 bg-[#ffffff] text-black shadow-sm p-6 hover:shadow-md transition-all"
      >
        <div class="rounded-xl bg-[#2f30f7] text-white px-4 py-3 mb-4">
          <div class="text-xs font-semibold opacity-90">Herramienta</div>
          <div class="text-xl font-display font-bold">Generador de estructura de artículos SEO</div>
        </div>

        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-[#2f30f7]/10 flex items-center justify-center shrink-0">
            <FileText className="w-5 h-5 text-[#2f30f7]" />
          </div>
          <div class="text-sm text-black/70">
            Crea un esquema completo (H2/H3, FAQ, tablas y más) a partir de una palabra clave.
          </div>
        </div>

        <div class="mt-6">
          <span class="inline-flex items-center justify-center gap-2 rounded-full bg-[#2f30f7] text-white px-5 py-2.5 text-sm font-semibold hover:opacity-95 transition-opacity">
            Abrir herramienta
            <ArrowRight className="w-4 h-4" />
          </span>
        </div>
      </a>
    </div>
  </div>
</Layout>
