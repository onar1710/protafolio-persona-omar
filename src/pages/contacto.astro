---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';

const title = "Contacto - Omar Fuentes | Desarrollador Web Colombia";
const description = "Contacta a Omar Fuentes: +57 310 785 1074 | contacto@omarfuentes.com | Diseño web profesional en Colombia. Respuesta en menos de 1 hora. Cotiza tu proyecto web.";
const keywords = "contacto desarrollador web colombia, contacto diseño web cali, telefono desarrollador web, email freelance colombia, contacto web medellin, presupuesto pagina web, cotizar sitio web bogota, contacto seo colombia";
---

<Layout title={title} description={description} keywords={keywords}>
  <main class="py-16 md:py-24 lg:py-32 pt-24" style="background: var(--white);">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl">
      <!-- Header -->
      <div class="rounded-3xl p-10 md:p-14 mb-16 overflow-hidden" style="background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-yellow) 50%, var(--primary-green) 100%);">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6 text-white">Contacto</h1>
          <p class="text-lg md:text-xl text-white">
            Cuéntame tu idea y te respondo con un plan claro. Diseño web, desarrollo con Next.js y SEO técnico.
          </p>
        </div>
      </div>

      <!-- Contact Grid -->
      <div class="grid md:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <!-- Contact Info -->
        <div class="space-y-8">
          <h2 class="text-2xl font-bold mb-6">Datos de contacto</h2>
          
          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg" style="background: var(--primary-blue); color: var(--white);">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold mb-1">Email</h3>
              <a href="mailto:contacto@omarfuentes.com" class="contact-link">contacto@omarfuentes.com</a>
              <p class="text-black text-sm mt-1">Respuesta en menos de 1 hora</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg" style="background: var(--primary-yellow); color: var(--gray-900);">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold mb-1">Teléfono / WhatsApp</h3>
              <a href="tel:+573107851074" class="contact-link">+57 310 785 1074</a>
              <p class="text-black text-sm mt-1">Lun-Vie 9am-6pm (Colombia)</p>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg" style="background: var(--primary-green); color: var(--white);">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold mb-1">Ubicación</h3>
              <p class="text-black">Floridablanca, Santander</p>
              <p class="text-black">Colombia</p>
            </div>
          </div>
          
          <!-- Social Media -->
          <div class="p-6 rounded-2xl mt-8" style="background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-yellow) 50%, var(--primary-green) 100%); box-shadow: 0 20px 40px rgba(0, 102, 255, 0.18);">
            <h3 class="font-bold mb-4 text-white">Redes sociales</h3>
            <div class="grid grid-cols-2 gap-3">
              <a href="https://www.instagram.com/omarfuentes053/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-white hover:text-white transition-colors">
                <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none" />
                </svg>
                Instagram
              </a>
              <a href="https://www.tiktok.com/@omarfuentes052" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-white hover:text-white transition-colors">
                <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
                </svg>
                TikTok
              </a>
              <a href="https://www.youtube.com/@OmarFuentes052" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-white hover:text-white transition-colors">
                <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.376.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.376-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
                YouTube
              </a>
              <a href="https://x.com/omarfuentes052" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-white hover:text-white transition-colors">
                <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.017L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 5.471L19.5 2.25h-3.256l-6.324 7.218L18.244 2.25zm-1.19 18.13h-2.157L5.632 4.09h2.157l6.205 8.439 5.058-6.449 2.157 3.85z"/>
                </svg>
                X (Twitter)
              </a>
              <a href="https://www.linkedin.com/in/omarfuentes052/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-white hover:text-white transition-colors">
                <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .773 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .773 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <div class="p-8 rounded-2xl" style="background: var(--white); border: 2px solid var(--primary-blue); box-shadow: 0 20px 40px rgba(0, 102, 255, 0.18);">
            <h3 class="font-bold text-xl mb-2">Envíame un mensaje</h3>
            <p class="text-black mb-6">Completa el formulario y te responderé en menos de 1 hora</p>
            <ContactForm lang="es" />
          </div>
          
          <div class="mt-6 p-6 rounded-xl border" style="background: var(--gray-50); border-color: rgba(0, 102, 255, 0.18);">
            <h4 class="font-bold mb-3">Qué incluir para una respuesta rápida</h4>
            <div class="space-y-2 text-sm">
              <p class="text-black">→ Tipo de web: landing, catálogo, blog, ecommerce</p>
              <p class="text-black">→ Objetivo: ventas, leads, marca, SEO</p>
              <p class="text-black">→ Fecha ideal de entrega</p>
              <p class="text-black">→ Referencias: 2-3 webs que te gusten</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .contact-link {
    color: #000000;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  .contact-link:hover {
    color: var(--primary-blue);
  }
</style>
