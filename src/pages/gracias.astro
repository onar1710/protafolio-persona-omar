---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

const ref = Astro.url.searchParams.get('ref');
---

<Layout title="Gracias - Omar Fuentes" description="Confirmación de pago" >
  <PageHeader title="Gracias" description="Recibí tu solicitud de pago." />

  <Container as="section" class="pb-24">
    <div class="max-w-2xl mx-auto rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6 text-center">
      <h1 class="text-3xl font-bold">¡Gracias!</h1>
      <p class="mt-3 text-muted-foreground">Si completaste el pago, en unos instantes verás la confirmación en Wompi.</p>
      {ref && (
        <p class="mt-3 text-sm text-muted-foreground">Referencia: <span class="font-semibold text-foreground">{ref}</span></p>
      )}
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="inline-flex justify-center rounded-full px-5 py-3 text-sm font-semibold bg-primary text-black hover:bg-primary/90 transition-colors">Volver al inicio</a>
        <a href="/contacto" class="inline-flex justify-center rounded-full px-5 py-3 text-sm font-semibold border border-black/10 dark:border-white/10 text-foreground hover:bg-black/5 dark:hover:bg-white/5 transition-colors">Contactar por WhatsApp</a>
      </div>
    </div>
  </Container>
</Layout>
