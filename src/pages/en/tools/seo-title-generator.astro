---
import Layout from '../../../layouts/LayoutEN.astro';
---

<Layout
  title="Free SEO Title Generator | Omar Fuentes"
  description="Generate SEO-optimized titles in seconds. Choose a tone, enter your keyword and topic, and export instantly."
>
  <main class="pt-24 pb-20 bg-white">
    <section class="pb-10">
      <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-5xl">
        <a href="/en/tools/" class="text-primary-blue font-semibold hover:underline">Back to tools</a>

        <header class="mt-6">
          <h1 class="text-4xl md:text-5xl font-black mb-4">SEO Title Generator</h1>
          <p class="text-black text-lg max-w-3xl">
            Generate 10 title ideas that include your keyword and match your tone.
          </p>
        </header>

        <div class="mt-10 grid grid-cols-1 lg:grid-cols-2 gap-8">
          <form id="titleForm" class="card">
            <div class="grid grid-cols-1 gap-4">
              <label class="block">
                <span class="block text-sm font-semibold mb-2">Output language</span>
                <select id="lang" class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-white">
                  <option value="en" selected>English</option>
                  <option value="es">Spanish</option>
                </select>
              </label>

              <label class="block">
                <span class="block text-sm font-semibold mb-2">Tone</span>
                <select id="tone" class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-white">
                  <option value="Formal">Formal</option>
                  <option value="Friendly">Friendly</option>
                  <option value="Informal">Informal</option>
                  <option value="Professional" selected>Professional</option>
                  <option value="Diplomatic">Diplomatic</option>
                  <option value="Confident">Confident</option>
                  <option value="High school level">High school level</option>
                  <option value="Academic">Academic</option>
                  <option value="Simplified">Simplified</option>
                  <option value="Vivid">Vivid</option>
                  <option value="Empathetic">Empathetic</option>
                  <option value="Commercial">Commercial</option>
                  <option value="Engaging">Engaging</option>
                  <option value="Direct">Direct</option>
                  <option value="Persuasive">Persuasive</option>
                </select>
              </label>

              <label class="block">
                <span class="block text-sm font-semibold mb-2">Primary keyword</span>
                <input id="keyword" class="w-full border border-gray-200 rounded-xl px-4 py-3" placeholder="e.g. web design services" required />
              </label>

              <label class="block">
                <span class="block text-sm font-semibold mb-2">Topic (optional)</span>
                <input id="topic" class="w-full border border-gray-200 rounded-xl px-4 py-3" placeholder="e.g. for small businesses" />
              </label>
            </div>

            <div class="mt-6 flex flex-col sm:flex-row gap-3">
              <button type="submit" id="generateBtn" class="px-6 py-3 rounded-xl font-semibold text-white bg-gradient-to-r from-primary-blue to-accent-blue hover:shadow-glow-blue transition-all">
                Generate titles (AI)
              </button>
              <button type="button" id="copyBtn" class="px-6 py-3 rounded-xl font-semibold border-2 border-primary-blue text-primary-blue hover:bg-primary-blue hover:text-white transition-all" disabled>
                Copy
              </button>
              <button type="button" id="downloadBtn" class="px-6 py-3 rounded-xl font-semibold border-2 border-primary-green text-primary-green hover:bg-primary-green hover:text-white transition-all" disabled>
                Download .txt
              </button>
            </div>
          </form>

          <div class="card">
            <div class="flex items-center justify-between gap-4 mb-4">
              <h2 class="text-xl font-bold">Results</h2>
              <span id="meta" class="text-xs text-gray-600"></span>
            </div>
            <ol id="results" class="space-y-3 text-black list-decimal pl-5"></ol>
            <p id="empty" class="text-gray-600">Fill the form and click “Generate titles”.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script src="/js/tools/title-generator.js" data-default-lang="en"></script>
</Layout>
