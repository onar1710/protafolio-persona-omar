    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-bold text-primary-blue mb-2">200+</div>
          <div class="text-gray-600">Websites Optimized</div>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-bold text-primary-blue mb-2">#1</div>
          <div class="text-gray-600">Google Rankings Achieved</div>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-bold text-primary-blue mb-2">85%</div>
