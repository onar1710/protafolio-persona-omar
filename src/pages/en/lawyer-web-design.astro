          <div class="flex items-center space-x-4">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-blue-600" />
            </div>
            <span class="text-black font-bold text-lg">Attorney bio & credentials</span>
          </div>
          
          <div class="flex items-center space-x-4">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-blue-600" />
            </div>
            <span class="text-black font-bold text-lg">Practice area pages</span>
          </div>
          
          <div class="flex items-center space-x-4">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-blue-600" />
            </div>
            <span class="text-black font-bold text-lg">Client testimonials section</span>
