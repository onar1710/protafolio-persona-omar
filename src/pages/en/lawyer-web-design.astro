            <FileText className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Client Intake Forms</h3>
          <p class="text-black text-lg leading-relaxed">Integrated contact forms and consultation request systems that make it easy for potential clients to reach you.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-gray-50 p-8 rounded-2xl shadow-lg border border-gray-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-gray-600 to-gray-700 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Scale className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Practice Area Pages</h3>
          <p class="text-black text-lg leading-relaxed">SEO-optimized pages for each service you offer, helping you rank for the searches that matter.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-gray-50 p-8 rounded-2xl shadow-lg border border-gray-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-gray-600 to-gray-700 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Shield className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Secure & Compliant</h3>
          <p class="text-black text-lg leading-relaxed">SSL encryption and adherence to legal industry standards for client confidentiality.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-blue-50 p-8 rounded-2xl shadow-lg border border-blue-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Zap className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Fast Loading Speed</h3>
          <p class="text-black text-lg leading-relaxed">Sites built to load in under 3 seconds—because slow websites lose cases before you even get a chance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Work With Me Section -->
  <section class="py-24 bg-gradient-to-br from-blue-50 to-gray-50 relative overflow-hidden">
