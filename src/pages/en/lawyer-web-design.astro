---
import Layout from '../../layouts/LayoutEN.astro';

const services = [
  { title: 'Custom Lawyer Web Design', description: 'Tailored websites that reflect your practice area and expertise—whether you\'re a family lawyer, criminal defense attorney, or estate planning specialist.', icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Mobile-Optimized Design', description: 'Over 60% of legal searches happen on mobile. Your site looks flawless on every device.', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', bgClass: 'from-gray-500 to-gray-600' },
  { title: 'Client Intake Forms', description: 'Integrated contact forms and consultation request systems that make it easy for potential clients to reach you.', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Practice Area Pages', description: 'SEO-optimized pages for each service you offer, helping you rank for the searches that matter.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', bgClass: 'from-gray-500 to-gray-600' },
  { title: 'Secure & Compliant', description: 'SSL encryption and adherence to legal industry standards for client confidentiality.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016zM12 9v2m0 4h.01', bgClass: 'from-gray-500 to-gray-600' },
  { title: 'Fast Loading Speed', description: 'Sites built to load in under 3 seconds—because slow websites lose cases before you even get a chance.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-blue-500 to-blue-600' },
];

const whyChooseMe = [
  { title: 'Legal Industry Experience', description: 'I understand attorney-client privilege, compliance needs, and what converts legal prospects.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2a3 3 0 00-5.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v2a3 3 0 005.356 1.857m0 0a3 3 0 005.356 1.857m0 0a3 3 0 005.356 1.857M7 20h10', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Results-Driven Design', description: 'Every element is designed to build trust and generate consultation requests.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-gray-500 to-gray-600' },
  { title: 'Local SEO Expertise', description: 'I optimize for "lawyer near me" and practice-specific searches in your area.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', bgClass: 'from-gray-500 to-gray-600' },
  { title: 'Professional & Credible', description: 'Your website reflects your reputation and expertise.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Quick Turnaround', description: 'Most lawyer websites completed in 2-3 weeks.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', bgClass: 'from-gray-500 to-gray-600' },
];

const includes = [
  'Custom professional design',
  'Mobile-responsive layout',
  'Attorney bio & credentials',
  'Practice area pages',
  'Client testimonials section',
  'Contact & consultation forms',
  'Google Maps integration',
  'SSL security certificate',
  'Local SEO optimization',
  'Fast loading speed',
  'Easy content updates',
  '30 days post-launch support',
];

const steps = [
  { step: '1', title: 'Free Consultation', description: 'We discuss your practice, target clients, and goals. No pressure—just honest advice.' },
  { step: '2', title: 'Custom Proposal', description: 'Clear pricing and timeline. No hidden fees.' },
  { step: '3', title: 'Design & Development', description: 'I build your site while keeping you in the loop. You review and approve everything.' },
  { step: '4', title: 'Launch & Training', description: 'I handle all technical setup and show you how to manage basic updates.' },
  { step: '5', title: 'Ongoing Support', description: 'I\'m available whenever you need changes or technical help.' },
];

const testimonials = [
  { name: 'Michael Torres', role: 'Family Law Attorney', text: 'Professional, responsive, and delivered exactly what my practice needed. My consultation requests have doubled since launch.' },
  { name: 'Jennifer Park', role: 'Estate Planning Lawyer', text: 'Finally, a website that makes me look as credible as I am. Highly recommend for solo practitioners.' },
  { name: 'David Anderson', role: 'Criminal Defense Attorney', text: 'Great experience from start to finish. Fast turnaround and excellent communication throughout.' },
];

const faqs = [
  { question: 'How much does a lawyer website cost?', answer: 'Packages start at competitive rates depending on features needed. I provide custom quotes with transparent pricing—no surprises.' },
  { question: 'How long does it take?', answer: 'Most attorney websites are completed in 2-3 weeks.' },
  { question: 'Will my website be secure and compliant?', answer: 'Yes. Every site includes SSL encryption and follows industry best practices for client confidentiality.' },
  { question: 'Can I update content myself?', answer: 'Absolutely. I train you on easy updates, or I can handle them for you with a maintenance plan.' },
  { question: 'Do you handle SEO?', answer: 'Yes. Every site includes local SEO optimization. I also offer advanced SEO packages.' },
  { question: 'What if I need changes after launch?', answer: 'I include 30 days of free support, and ongoing maintenance packages are available.' },
];
---

<Layout
  title="Lawyer Web Design That Converts Visitors Into Clients | Omar Fuentes"
  description="I create professional, conversion-focused websites for law firms and solo practitioners. Your website should work as hard as you do—attracting clients and building trust from the first click."
  keywords="law firm web design, lawyer website, attorney web design, legal website design, lawyer SEO"
>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center pb-16 md:pb-24 lg:pb-32 bg-gradient-to-br from-blue-900 via-gray-800 to-blue-900 relative overflow-hidden pt-8">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-slide-in">
          <div class="flex items-center space-x-2 mb-6">
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-white/10 text-white border border-white/20">Small Business</span>
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-blue-500/20 text-blue-300 border border-blue-500/30">Lawyers</span>
          </div>

          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight text-white">
            Lawyer <br />
            <span class="bg-gradient-to-r from-blue-400 to-gray-400 bg-clip-text text-transparent">Web Design</span>
          </h1>

          <p class="text-xl text-white/90 mb-8 max-w-lg">
            I create professional, conversion-focused websites for law firms and solo practitioners. Your website should work as hard as you do—attracting clients and building trust from the first click.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://wa.me/13239414865?text=Hi%20Omar,%20I%20want%20a%20free%20lawyer%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 hover:shadow-xl bg-gradient-to-r from-blue-500 to-blue-600 text-white hover:shadow-xl">
              Schedule Your Free Consultation
            </a>
            <a href="/en/portfolio/projects/" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 border-2 border-white/30 text-white hover:bg-white/10">
              See Examples
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-4 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="text-yellow-400">★★★★★</span>
              <span class="font-semibold">Mobile-first design</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">Clear lead capture</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">Fast turnaround</span>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-blue-500 to-gray-500 rounded-3xl opacity-20 animate-float"></div>
          <div class="relative bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
            <p class="text-white/70 text-sm mb-4">Built for law firms</p>
            <p class="text-white text-2xl font-bold mb-2">Free consultation • No obligation • Clear next steps</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-gray-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Your Legal Expertise Deserves a Professional Online Presence</h2>
      </div>

      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-blue-100">
        <div class="space-y-6 text-center">
          <p class="text-xl text-gray-800 leading-relaxed">
            Here's the reality: <strong>96% of people seeking legal advice use search engines first</strong>.
          </p>
          <p class="text-xl text-gray-800 leading-relaxed">
            If your website looks outdated, loads slowly, or doesn't clearly communicate your value, potential clients will choose your competitor instead.
          </p>
          <p class="text-xl text-blue-800 font-bold">
            I specialize in designing high-converting websites for lawyers and small law firms. No generic templates. No tech jargon. Just a professional site that positions you as the trusted legal expert you are.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">What I Deliver for Legal Professionals</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Professional services designed specifically for law firms
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="card">
            <div class={`w-12 h-12 mb-4 bg-gradient-to-br ${service.bgClass} rounded-lg flex items-center justify-center`}>
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{service.title}</h3>
            <p class="text-gray-600">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Me Section -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-gray-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Why Lawyers Choose Me</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Experience and results that matter for legal professionals
        </p>
      </div>

      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-blue-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {whyChooseMe.map((item) => (
            <div class="flex items-start gap-4">
              <div class={`w-12 h-12 bg-gradient-to-br ${item.bgClass} rounded-lg flex items-center justify-center flex-shrink-0`}>
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">{item.title}</h3>
                <p class="text-gray-600 text-sm">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Every Lawyer Website I Build Includes:</h2>
      </div>

      <div class="max-w-4xl mx-auto bg-gradient-to-br from-blue-50 to-gray-50 rounded-3xl shadow-2xl p-12 border border-blue-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {includes.map((item) => (
            <div class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-md">
              <svg class="w-6 h-6 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-gray-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">How We Work Together</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 max-w-6xl mx-auto">
        {steps.map((step) => (
          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-4 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center">
              <span class="text-xl font-bold text-white">{step.step}</span>
            </div>
            <h3 class="text-base font-bold mb-2">{step.title}</h3>
            <p class="text-gray-600 text-xs">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">What Legal Professionals Say</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((testimonial) => (
          <div class="card">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class="w-4 h-4 fill-yellow-400 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
            </div>
            <p class="text-gray-600 mb-4 italic">"{testimonial.text}"</p>
            <div class="font-semibold">{testimonial.name}</div>
            <div class="text-sm text-gray-500">{testimonial.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-gray-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Frequently Asked Questions</h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-blue-100">
            <h3 class="text-lg font-bold mb-2">{faq.question}</h3>
            <p class="text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-blue-900 via-gray-800 to-blue-900">
    <div class="container text-center">
      <h2 class="text-section mb-4 text-white">Ready to Attract More Clients Online?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Your legal expertise deserves a website that converts. Let me build you a professional, high-converting site that positions you as the trusted attorney you are.
      </p>
      <a href="https://wa.me/13239414865?text=Hi%20Omar,%20I%20want%20a%20free%20lawyer%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 bg-white text-blue-900 hover:shadow-xl">
        Get Your Free Consultation
      </a>
      <div class="mt-8 text-white/70 text-sm">
        Conversion-focused web design • Trust-first layout • Technical SEO foundations
      </div>
    </div>
  </section>
</Layout>
