---
import Layout from '../../layouts/LayoutEN.astro';

const services = [
  { title: 'Custom Real Estate Web Design', description: 'Tailored websites for residential agents, commercial brokers, and luxury property specialists. Your brand, your market, your results.', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'IDX/MLS Integration', description: 'Seamless property search functionality. Your listings update automatically—no manual work required.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', bgClass: 'from-green-500 to-green-600' },
  { title: 'Mobile-Responsive Design', description: 'Over 75% of property searches happen on mobile. Your site looks perfect on every device.', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Lead Capture Systems', description: 'Strategic contact forms, property alerts, and home valuation tools that convert browsers into qualified leads.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-green-500 to-green-600' },
  { title: 'Neighborhood & Market Pages', description: 'SEO-optimized pages for every area you serve—rank for "homes for sale in [your city]" and dominate local search.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Virtual Tour Integration', description: 'Showcase properties with 3D tours, video walkthroughs, and photo galleries that sell homes faster.', icon: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z', bgClass: 'from-green-500 to-green-600' },
];

const whyChooseMe = [
  { title: 'Real Estate Industry Expertise', description: 'I understand MLS systems, lead generation, and what converts property shoppers.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2a3 3 0 00-5.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v2a3 3 0 005.356 1.857m0 0a3 3 0 005.356 1.857m0 0a3 3 0 005.356 1.857M7 20h10', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Proven Lead Generation', description: 'Every design element focuses on capturing and nurturing qualified leads.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-green-500 to-green-600' },
  { title: 'Local SEO Mastery', description: 'Optimize for neighborhood searches and "realtor near me" queries.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Fast & Scalable', description: 'Websites that handle high traffic during open houses and new listings.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-green-500 to-green-600' },
  { title: 'Quick Launch', description: 'Most real estate sites completed in 2-3 weeks.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', bgClass: 'from-blue-500 to-blue-600' },
];

const includes = [
  'Custom professional design',
  'Mobile-responsive layout',
  'IDX/MLS property search',
  'Agent bio & credentials',
  'Featured listings showcase',
  'Lead capture forms',
  'Home valuation calculator',
  'Neighborhood/market pages',
  'Google Maps integration',
  'SSL security certificate',
  'Local SEO optimization',
  '30 days post-launch support',
];

const steps = [
  { step: '1', title: 'Free Consultation', description: 'We discuss your market, ideal clients, and business goals. No sales pressure.' },
  { step: '2', title: 'Custom Proposal', description: 'Transparent pricing and timeline. No hidden costs.' },
  { step: '3', title: 'Design & Development', description: 'I build your site with regular check-ins. You approve everything before launch.' },
  { step: '4', title: 'Launch & Training', description: 'I handle technical setup and train you on managing listings and leads.' },
  { step: '5', title: 'Ongoing Support', description: 'Available for updates, new features, and technical assistance.' },
];

const testimonials = [
  { name: 'Rachel Martinez', role: 'Residential Real Estate Agent', text: 'My new site generates 3x more leads than my old template design. Professional, fast, and exactly what my business needed.' },
  { name: 'Brandon Cole', role: 'Luxury Property Specialist', text: 'Finally, a website that showcases luxury properties the way they deserve. Client inquiries have increased significantly.' },
  { name: 'Sophia Williams', role: 'Commercial Real Estate Broker', text: 'The IDX integration works flawlessly and the lead capture system is incredible. Best investment I\'ve made in my business.' },
];

const faqs = [
  { question: 'How much does a real estate website cost?', answer: 'Packages start at competitive rates depending on features and IDX requirements. Custom quotes provided—fully transparent pricing.' },
  { question: 'How long does it take?', answer: 'Most real estate websites are completed in 2-3 weeks.' },
  { question: 'Do you handle IDX/MLS integration?', answer: 'Yes. I integrate with all major IDX providers so your listings update automatically.' },
  { question: 'Will my site work on mobile?', answer: 'Absolutely. Responsive design is standard—looks perfect on phones, tablets, and desktops.' },
  { question: 'Can I update listings myself?', answer: 'Yes. Listings sync automatically through IDX. I train you on other content updates.' },
  { question: 'Do you offer SEO services?', answer: 'Every site includes local SEO optimization. Advanced SEO packages available for competitive markets.' },
  { question: 'What if I need changes after launch?', answer: '30 days of free support included. Ongoing maintenance plans available.' },
];
---

<Layout
  title="Real Estate Web Design That Generates Qualified Leads | Omar Fuentes"
  description="I create high-converting websites for real estate agents and brokers. Your site should showcase properties beautifully while turning visitors into serious buyers and sellers."
  keywords="real estate web design, realtor website, real estate agent website, property listings website, real estate SEO"
>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center pb-16 md:pb-24 lg:pb-32 bg-gradient-to-br from-blue-900 via-green-800 to-blue-900 relative overflow-hidden pt-8">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-slide-in">
          <div class="flex items-center space-x-2 mb-6">
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-white/10 text-white border border-white/20">Small Business</span>
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-green-500/20 text-green-300 border border-green-500/30">Real Estate</span>
          </div>

          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight text-white">
            Real Estate <br />
            <span class="bg-gradient-to-r from-green-400 to-blue-400 bg-clip-text text-transparent">Web Design</span>
          </h1>

          <p class="text-xl text-white/90 mb-8 max-w-lg">
            I create high-converting websites for real estate agents and brokers. Your site should showcase properties beautifully while turning visitors into serious buyers and sellers.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://wa.me/12025551234?text=Hi%20Omar,%20I%20want%20a%20free%20real%20estate%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 hover:shadow-xl bg-gradient-to-r from-green-500 to-green-600 text-white hover:shadow-xl">
              Get Your Free Consultation
            </a>
            <a href="/en/portfolio/projects/" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 border-2 border-white/30 text-white hover:bg-white/10">
              See Examples
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-4 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="text-yellow-400">★★★★★</span>
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">+300% More Leads</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">2-3 Week Delivery</span>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-green-500 to-blue-500 rounded-3xl opacity-20 animate-float"></div>
          <div class="relative bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
            <p class="text-white/70 text-sm mb-4">Trusted by 100+ Real Estate Professionals</p>
            <p class="text-white text-2xl font-bold mb-2">Free consultation • No obligation • Results guaranteed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-green-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Stand Out in a Competitive Real Estate Market</h2>
      </div>

      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-green-100">
        <div class="space-y-6 text-center">
          <p class="text-xl text-gray-800 leading-relaxed">
            <strong>90% of home buyers start their search online.</strong>
          </p>
          <p class="text-xl text-gray-800 leading-relaxed">
            If your website doesn't load fast, look professional, or showcase properties effectively, you're losing leads to competitors.
          </p>
          <p class="text-xl text-green-800 font-bold">
            I specialize in designing conversion-focused websites for real estate professionals. No cookie-cutter templates. No complicated tech. Just a stunning site that positions you as the go-to agent in your market.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">What I Deliver for Real Estate Professionals</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Professional services designed specifically for real estate success
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="card">
            <div class={`w-12 h-12 mb-4 bg-gradient-to-br ${service.bgClass} rounded-lg flex items-center justify-center`}>
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{service.title}</h3>
            <p class="text-gray-600">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Me Section -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-green-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Why Real Estate Agents Choose Me</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Industry expertise and proven results for real estate success
        </p>
      </div>

      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-green-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {whyChooseMe.map((item) => (
            <div class="flex items-start gap-4">
              <div class={`w-12 h-12 bg-gradient-to-br ${item.bgClass} rounded-lg flex items-center justify-center flex-shrink-0`}>
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">{item.title}</h3>
                <p class="text-gray-600 text-sm">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Every Real Estate Website I Build Includes:</h2>
      </div>

      <div class="max-w-4xl mx-auto bg-gradient-to-br from-green-50 to-blue-50 rounded-3xl shadow-2xl p-12 border border-green-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {includes.map((item) => (
            <div class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-md">
              <svg class="w-6 h-6 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-green-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">How We Work Together</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 max-w-6xl mx-auto">
        {steps.map((step) => (
          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-4 bg-gradient-to-br from-green-500 to-green-600 rounded-full flex items-center justify-center">
              <span class="text-xl font-bold text-white">{step.step}</span>
            </div>
            <h3 class="text-base font-bold mb-2">{step.title}</h3>
            <p class="text-gray-600 text-xs">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">What Real Estate Professionals Say</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((testimonial) => (
          <div class="card">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class="w-4 h-4 fill-yellow-400 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
            </div>
            <p class="text-gray-600 mb-4 italic">"{testimonial.text}"</p>
            <div class="font-semibold">{testimonial.name}</div>
            <div class="text-sm text-gray-500">{testimonial.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-blue-50 to-green-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Frequently Asked Questions</h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-green-100">
            <h3 class="text-lg font-bold mb-2">{faq.question}</h3>
            <p class="text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-blue-900 via-green-800 to-blue-900">
    <div class="container text-center">
      <h2 class="text-section mb-4 text-white">Ready to Generate More Real Estate Leads?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Stop losing potential clients to agents with better websites. Let me build you a professional, high-converting site that showcases properties and captures qualified leads.
      </p>
      <a href="https://wa.me/12025551234?text=Hi%20Omar,%20I%20want%20a%20free%20real%20estate%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 bg-white text-blue-900 hover:shadow-xl">
        Get Your Free Consultation
      </a>
      <div class="mt-8 text-white/70 text-sm">
        Serving Real Estate Professionals Since 2020 • 100+ Satisfied Agents • IDX/MLS Integration • 30-Day Support Included
      </div>
    </div>
  </section>
</Layout>
