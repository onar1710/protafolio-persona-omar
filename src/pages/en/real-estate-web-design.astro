---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, ArrowRight, Star, Clock, Award, Phone, MapPin, Target, Shield, Zap, Globe, TrendingUp, Calendar, Users, Briefcase, Home, Building, Search, Camera, MapPin as Pin } from 'lucide-react';
---

<Layout title="Real Estate Web Design That Generates Qualified Leads | Omar Fuentes" description="Professional real estate web design services for agents and brokers. Generate more qualified leads with conversion-focused websites that showcase properties beautifully and rank higher in property searches.">
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-blue-900 via-green-800 to-blue-900 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-6 py-24">
      <div class="text-center">
        <!-- Badge -->
        <div class="inline-flex items-center bg-white/10 backdrop-blur-md rounded-full px-6 py-3 mb-8 border border-white/20">
          <Building className="w-5 h-5 mr-2 text-green-400" />
          <span class="text-white text-sm font-semibold">Trusted by 100+ Real Estate Professionals</span>
        </div>
        
        <h1 class="text-6xl md:text-7xl font-bold mb-8 text-white leading-tight">
          Real Estate Web Design That Generates Qualified Leads
        </h1>
        
        <!-- Value Proposition -->
        <div class="max-w-3xl mx-auto mb-12">
          <p class="text-xl text-white/90 mb-8 leading-relaxed">I create high-converting websites for real estate agents and brokers. Your site should showcase properties beautifully while turning visitors into serious buyers and sellers.</p>
          
          <!-- Social Proof -->
          <div class="flex flex-wrap items-center justify-center gap-8 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Star className="w-5 h-5 text-green-400 fill-green-400" />
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <TrendingUp className="w-5 h-5 text-blue-400" />
              <span class="font-semibold">+300% More Leads</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Zap className="w-5 h-5 text-green-400" />
              <span class="font-semibold">2-3 Week Delivery</span>
            </div>
          </div>
        </div>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
          <a href="mailto:contact@omarfuentes.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-green-500 to-green-600 text-white px-10 py-5 font-semibold hover:from-green-600 hover:to-green-700 transition-all transform hover:scale-105 shadow-2xl text-lg">
            Get Your Free Consultation
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
          <a href="/en/portfolio" class="inline-flex items-center justify-center rounded-full border-2 border-white/30 text-white px-10 py-5 font-semibold hover:bg-white/10 transition-all text-lg backdrop-blur-sm">
            See Examples
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
        </div>
        
        <!-- Trust indicators -->
        <div class="text-white/70 text-sm flex items-center justify-center gap-2">
          <CheckCircle className="w-4 h-4" />
          <span>Free consultation • No obligation • Results guaranteed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-24 bg-gradient-to-br from-blue-50 to-green-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-blue-100 rounded-full blur-3xl opacity-30"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-green-100 rounded-full blur-3xl opacity-30"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-5xl mx-auto text-center mb-16">
        <h2 class="text-5xl font-bold mb-8 text-black">Stand Out in a Competitive Real Estate Market</h2>
      </div>
      
      <div class="max-w-5xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-green-100">
        <div class="text-center mb-8">
          <p class="text-xl text-gray-800 mb-6 leading-relaxed font-medium">
            <strong>90% of home buyers start their search online.</strong>
          </p>
          <p class="text-xl text-gray-800 mb-6 leading-relaxed font-medium">
            If your website doesn't load fast, look professional, or showcase properties effectively, you're losing leads to competitors.
          </p>
          <p class="text-xl text-green-800 leading-relaxed font-bold">
            I specialize in designing conversion-focused websites for real estate professionals. No cookie-cutter templates. No complicated tech. Just a stunning site that positions you as the go-to agent in your market.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-24 bg-white relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-20 left-20 w-72 h-72 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-20 right-20 w-72 h-72 bg-green-100 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-5xl font-bold mb-8 text-black">What I Deliver for Real Estate Professionals</h2>
        <p class="text-xl text-green-700 max-w-3xl mx-auto">Professional services designed specifically for real estate success</p>
