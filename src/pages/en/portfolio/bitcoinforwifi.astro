---
import LayoutEN from '../../../layouts/LayoutEN.astro';
import CaseStudyIcon from '../../../components/CaseStudyIcon.astro';
import CaseStudyHero from '../../../components/CaseStudyHero.astro';

const project = {
  title: 'BitcoinForWifi - Editorial Website about Bitcoin & Technology',
  description:
    'I designed and built BitcoinForWifi as an editorial website focused on speed and technical SEO: category-first architecture, clean article pages, lightweight images, and a Vercel deployment. The goal was to create a solid foundation for publishing evergreen content and scaling organic traffic without sacrificing performance.',
  cliente: 'BitcoinForWifi',
  fecha: '2026',
  tipo: 'Editorial Website / Blog',
  tecnologias: ['Astro', 'Tailwind CSS', 'Category Architecture', 'Technical SEO', 'Vercel'],
  url: 'https://bitcoinforwifi.com/',
  imagen: '/images-portfolio/caso-bitcoinforwifi.png',
  stats: {
    categories: '6 sections',
    stack: 'Astro + Tailwind',
    deploy: 'Vercel',
    focus: 'SEO + performance',
  },
  results: [
    '✅ Built with Astro (static HTML) for fast loads',
    '✅ Consistent UI with Tailwind CSS and reusable components',
    '✅ Clear architecture: primary categories with thematic routes',
    '✅ Article cards with featured image, date and reading time',
    '✅ Solid deployment on Vercel with global delivery and caching',
  ],
};

const techStack = [
  { name: 'Astro', description: 'Static generation for top performance and a simple DX', icon: '🚀' },
  { name: 'Tailwind CSS', description: 'Fast, consistent styling with utility-first design', icon: '🎨' },
  { name: 'Technical SEO', description: 'Content structure built for indexation and discovery', icon: '🔍' },
  { name: 'Vercel', description: 'CDN + caching for a fast global experience', icon: '⚡' },
  { name: 'Scalable Content', description: 'Ready to grow by categories and subtopics', icon: '📚' },
];

const phases = [
  {
    title: 'Editorial Strategy & Architecture',
    week: 'Phase 1',
    tasks: [
      'Defined the core categories to organize content from day one',
      'Designed category list templates with tags and internal links',
      'Structured clean, readable URLs that are easy to share',
    ],
  },
  {
    title: 'Implementation, SEO & Deployment',
    week: 'Phase 2',
    tasks: [
      'Built reusable components for article cards and sections',
      'Optimized assets and images to keep the site lightweight',
      'Deployed to Vercel for global delivery and caching',
    ],
  },
];

const features = [
  {
    icon: '🎯',
    title: 'Scalable editorial structure',
    description:
      'Category-driven organization that keeps navigation clear and supports consistent publishing.',
  },
  {
    icon: '⚡',
    title: 'Performance first',
    description:
      'Static generation with Astro and a lightweight UI so every page loads fast.',
  },
  {
    icon: '🔍',
    title: 'SEO built into the architecture',
    description:
      'Clean routes, internal linking, and topical structure so search engines understand the site.',
  },
  {
    icon: '📄',
    title: 'Clean article pages',
    description:
      'Cards and lists with useful metadata (date + reading time) to improve clicks and navigation.',
  },
  {
    icon: '📦',
    title: 'Solid Vercel deployment',
    description:
      'CDN delivery and caching to improve TTFB and site stability worldwide.',
  },
  {
    icon: '📚',
    title: 'Evergreen publishing foundation',
    description:
      'Ready to scale content volume without losing structure, speed, or consistency.',
  },
];

const metrics = [
  { icon: '📈', title: 'Goal', value: 'Organic SEO', description: 'Built to scale evergreen traffic' },
  { icon: '⚡', title: 'Delivery', value: 'SSG', description: 'Static HTML for fast loads' },
  { icon: '📚', title: 'Content', value: 'Evergreen', description: 'Long-term articles that keep ranking' },
  { icon: '🗺️', title: 'Structure', value: '6 categories', description: 'Clear topical organization' },
];

const experience = [
  {
    title: 'The approach',
    text: 'For editorial projects, the real challenge is building a structure that scales without becoming chaotic. I started with architecture: strong categories, clean routes, and repeatable components.',
  },
  {
    title: 'What I protected most',
    text: 'Speed. When visitors arrive from Google, the first impression is performance. Astro makes it easy to ship static HTML and keep the site fast across categories and list pages.',
  },
  {
    title: 'Why it works',
    text: 'The combination of content + technical SEO. BitcoinForWifi is designed as an internal linking network that reinforces topical authority and improves discovery.',
  },
];
---

<LayoutEN title="BitcoinForWifi - Case Study | Omar Fuentes" description="BitcoinForWifi case study: editorial site built with Astro and Tailwind, category architecture, technical SEO, and Vercel deployment for performance.">
  <main class="pt-24 pb-20" style="background: var(--white);">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
      <CaseStudyHero
        lang="en"
        title={project.title}
        description={project.description}
        image={project.imagen}
        liveUrl={project.url}
        backHref="/en/portfolio/projects/"
        technologies={project.tecnologias}
        badges={['Astro', 'Vercel', 'Editorial SEO']}
      />

      <section class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-14">
        {Object.entries(project.stats).map(([key, value]) => (
          <div class="text-center p-6 rounded-2xl" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08); box-shadow: 0 10px 30px rgba(0,0,0,0.06);">
            <div class="text-2xl font-black" style="color: var(--primary-blue);">{value}</div>
            <div class="text-black text-sm font-bold mt-2" style="text-transform: capitalize;">{key}</div>
          </div>
        ))}
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Tech Stack</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {techStack.map((tech) => (
            <div class="rounded-2xl p-6" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08);">
              <div class="text-2xl"><CaseStudyIcon icon={tech.icon} class="w-10 h-10" /></div>
              <div class="font-black text-black mt-3">{tech.name}</div>
              <div class="text-black mt-2">{tech.description}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Development Process</h2>
        <div class="space-y-6">
          {phases.map((phase) => (
            <div class="rounded-3xl p-8" style="background: var(--gray-50); border: 1px solid rgba(0,0,0,0.08);">
              <div class="flex flex-wrap items-center gap-3 mb-5">
                <h3 class="text-2xl font-black text-black">{phase.title}</h3>
                <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold" style="background: rgba(0, 102, 255, 0.12); color: var(--primary-blue); border: 1px solid rgba(0, 102, 255, 0.22);">{phase.week}</span>
              </div>
              <ul class="space-y-3">
                {phase.tasks.map((task) => (
                  <li class="flex items-start gap-3"><span style="color: var(--primary-green); font-weight: 900;">✓</span><span class="text-black">{task}</span></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Key Features</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {features.map((feature) => (
            <div class="rounded-3xl p-8" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08); box-shadow: 0 10px 30px rgba(0,0,0,0.06);">
              <div class="text-3xl"><CaseStudyIcon icon={feature.icon} class="w-12 h-12" /></div>
              <h3 class="text-xl font-black text-black mt-4">{feature.title}</h3>
              <p class="text-black mt-3">{feature.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Outcome Metrics</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {metrics.map((metric) => (
            <div class="rounded-3xl p-8 text-center" style="background: var(--gray-50); border: 1px solid rgba(0,0,0,0.08);">
              <div class="flex justify-center"><CaseStudyIcon icon={metric.icon} class="w-12 h-12" /></div>
              <div class="text-3xl font-black mt-3" style="color: var(--primary-blue);">{metric.value}</div>
              <div class="font-black text-black mt-2">{metric.title}</div>
              <div class="text-black mt-2">{metric.description}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Results</h2>
        <div class="rounded-3xl p-8" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08);">
          <ul class="space-y-4">
            {project.results.map((result) => (
              <li class="flex items-start gap-3">
                <span style="color: var(--primary-green); font-weight: 900;">✅</span>
                <span class="text-black">{result.replace(/^✅\s*/, '')}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">My Notes</h2>
        <div class="rounded-3xl p-10" style="background: linear-gradient(135deg, rgba(0, 102, 255, 0.08) 0%, rgba(255, 215, 0, 0.10) 50%, rgba(0, 200, 81, 0.08) 100%); border: 1px solid rgba(0,0,0,0.08);">
          <div class="space-y-8">
            {experience.map((item) => (
              <div>
                <h3 class="text-xl font-black text-black mb-3">{item.title}</h3>
                <p class="text-black">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section>
        <div class="rounded-3xl p-12 text-center" style="background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-yellow) 50%, var(--primary-green) 100%);">
          <h2 class="text-3xl font-black text-white mb-4">Want an editorial website built for SEO growth?</h2>
          <p class="text-white mb-8">If you want to scale with evergreen content without sacrificing speed, I can build an editorial foundation like BitcoinForWifi for your brand.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://wa.me/573107851074?text=Hello%20Omar,%20I%20want%20an%20editorial%20website%20like%20BitcoinForWifi%20for%20my%20brand" target="_blank" rel="noopener noreferrer" class="btn-primary" style="text-decoration: none;">
              Message on WhatsApp
            </a>
            <a href="/en/portfolio/projects/" class="btn-secondary" style="text-decoration: none; border-color: rgba(255,255,255,0.55); color: var(--white);">
              View More Projects
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>
</LayoutEN>
