---
import LayoutEN from '../../../layouts/LayoutEN.astro';
import CaseStudyIcon from '../../../components/CaseStudyIcon.astro';
import CaseStudyHero from '../../../components/CaseStudyHero.astro';

const project = {
  title: "Dog Products - My Pet eCommerce Store That Customers Love",
  description:
    "This project was fun and practical: I built a complete pet products eCommerce store with a functional cart and fast shipping experience. I used HTML5, CSS3 and vanilla JavaScript to deliver a smooth shopping experience pet owners enjoy.",
  cliente: "Dog Products",
  fecha: "2024-2025",
  tipo: "eCommerce / Online Store",
  tecnologias: ["HTML5", "CSS3", "JavaScript", "Responsive Design", "SEO"],
  url: "https://web-productos-para-perros.vercel.app/",
  imagen: "/images-portfolio/proyecto-imagen-productosperros.png",
  stats: {
    pages: "70+ pages",
    products: "50+ products",
    categories: "7 categories",
    weeks: "2 weeks development",
  },
  results: [
    "✅ Store with 50+ products pet owners actually buy",
    "✅ Functional cart with localStorage - items persist on refresh",
    "✅ Blog with tips for pet owners - builds trust and ranks in Google",
    "✅ 100% responsive - customers buy from phone, tablet or desktop",
    "✅ Local SEO optimized - appears for searches like 'buy dog food'",
    "✅ Wishlist system - customers save products to buy later",
  ],
};

const techStack = [
  { name: "HTML5", description: "Semantic markup for SEO and accessibility", icon: "📝" },
  { name: "CSS3", description: "Modern styles with Grid, Flexbox and animations", icon: "🎨" },
  { name: "JavaScript ES6+", description: "Vanilla functionality without frameworks", icon: "⚡" },
  { name: "LocalStorage", description: "Cart and wishlist persistence", icon: "💾" },
  { name: "Local SEO", description: "Optimization for local-intent searches", icon: "🎯" },
];

const phases = [
  {
    title: "Research and Planning",
    week: "Days 1-2",
    tasks: [
      "Day 1: Competitor research and primary keyword analysis",
      "Day 2: Information architecture for 70+ pages and technical plan (HTML5 + CSS3 + Vanilla JS)",
    ],
  },
  {
    title: "UI/UX Design",
    week: "Days 3-4",
    tasks: [
      "Day 3: Design system with a nature-inspired palette and reusable components",
      "Day 4: Homepage, categories, product pages and interactive prototypes",
    ],
  },
  {
    title: "Frontend Development",
    week: "Days 5-6",
    tasks: [
      "Day 5: Project setup and reusable components",
      "Day 6: Core pages, lightweight routing and functional JavaScript",
    ],
  },
  {
    title: "Content and SEO",
    week: "Days 7-8",
    tasks: [
      "Day 7: Creation of 50+ product pages with optimized descriptions",
      "Day 8: On-page SEO: meta tags, headings, URLs and local optimization",
    ],
  },
  {
    title: "Testing and Deploy",
    week: "Days 9-10",
    tasks: [
      "Day 9: Functional testing, cross-browser, responsive and Lighthouse optimization",
      "Day 10: Vercel deploy with CDN and performance checks",
    ],
  },
];

const features = [
  {
    icon: "🛒",
    title: "Complete Cart System",
    description:
      "Fully functional cart with localStorage persistence, header counter and automatic totals.",
  },
  {
    icon: "❤️",
    title: "Wishlist",
    description:
      "Favorites system with persistence, visual counter and the ability to move items between wishlist and cart.",
  },
  {
    icon: "📱",
    title: "Mobile-First Responsive Design",
    description:
      "Optimized breakpoints for mobile, tablet and desktop. Great UX on every device.",
  },
  {
    icon: "🔍",
    title: "Local SEO",
    description:
      "On-page structure and localized intent targeting to capture high-intent searches.",
  },
  {
    icon: "⚡",
    title: "Optimized Performance",
    description:
      "Fast pages with lazy loading and optimized assets for a smooth shopping experience.",
  },
  {
    icon: "📝",
    title: "Integrated Blog",
    description:
      "SEO-focused articles designed to attract organic traffic and build trust with pet owners.",
  },
];

const metrics = [
  { icon: "🚀", title: "Performance", value: "95+", description: "Lighthouse score on desktop and mobile" },
  { icon: "📄", title: "Pages", value: "70+", description: "Static pages optimized for SEO" },
  { icon: "🛍️", title: "Products", value: "50+", description: "Complete catalog across 7 categories" },
  { icon: "📊", title: "SEO", value: "100/100", description: "Strong on-page SEO foundation" },
];
---

<LayoutEN title="Dog Products - Pet eCommerce Case Study | Omar Fuentes" description="Case study: pet eCommerce store built with HTML5, CSS3 and vanilla JavaScript. Fast, responsive and SEO-friendly.">
  <main class="pt-24 pb-20" style="background: var(--white);">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
      <CaseStudyHero
        lang="en"
        title={project.title}
        description={project.description}
        image={project.imagen}
        liveUrl={project.url}
        backHref="/en/portfolio/projects/"
        technologies={project.tecnologias}
        badges={["2 weeks development", "Completed"]}
      />

      <section class="mb-14">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6" style="background: var(--gray-50); border: 1px solid rgba(0,0,0,0.08); border-radius: 1.5rem; padding: 2rem;">
          {Object.entries(project.stats).map(([key, value]) => (
            <div class="text-center">
              <div class="text-2xl font-black" style="color: var(--primary-blue);">{value}</div>
              <div class="text-black font-bold mt-2" style="text-transform: capitalize;">{key}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Tech Stack</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {techStack.map((tech) => (
            <div class="rounded-2xl p-6" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08);">
              <div class="text-2xl"><CaseStudyIcon icon={tech.icon} class="w-10 h-10" /></div>
              <div class="font-black text-black mt-3">{tech.name}</div>
              <div class="text-black mt-2">{tech.description}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Key Features</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {features.map((feature) => (
            <div class="rounded-3xl p-8" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08); box-shadow: 0 10px 30px rgba(0,0,0,0.06);">
              <div class="text-3xl"><CaseStudyIcon icon={feature.icon} class="w-12 h-12" /></div>
              <h3 class="text-xl font-black text-black mt-4">{feature.title}</h3>
              <p class="text-black mt-3">{feature.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Development Process</h2>
        <div class="space-y-6">
          {phases.map((phase) => (
            <div class="rounded-3xl p-8" style="background: var(--gray-50); border: 1px solid rgba(0,0,0,0.08);">
              <div class="flex flex-wrap items-center gap-3 mb-5">
                <h3 class="text-2xl font-black text-black">{phase.title}</h3>
                <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold" style="background: rgba(0, 102, 255, 0.12); color: var(--primary-blue); border: 1px solid rgba(0, 102, 255, 0.22);">{phase.week}</span>
              </div>
              <ul class="space-y-3">
                {phase.tasks.map((task) => (
                  <li class="flex items-start gap-3"><span style="color: var(--primary-green); font-weight: 900;">✓</span><span class="text-black">{task}</span></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Performance Metrics</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {metrics.map((m) => (
            <div class="rounded-3xl p-8 text-center" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08);">
              <div class="flex justify-center"><CaseStudyIcon icon={m.icon} class="w-12 h-12" /></div>
              <div class="text-3xl font-black mt-3" style="color: var(--primary-blue);">{m.value}</div>
              <div class="font-black text-black mt-2">{m.title}</div>
              <div class="text-black mt-2">{m.description}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Project Results</h2>
        <div class="rounded-3xl p-8" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08);">
          <ul class="space-y-4">
            {project.results.map((result) => (
              <li class="flex items-start gap-3">
                <span style="color: var(--primary-green); font-weight: 900;">✅</span>
                <span class="text-black">{result.replace(/^✅\s*/, '')}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section>
        <div class="rounded-3xl p-12 text-center" style="background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-yellow) 50%, var(--primary-green) 100%);">
          <h2 class="text-3xl font-black text-white mb-4">Need an eCommerce store that converts?</h2>
          <p class="text-white mb-8">I can build a fast, SEO-friendly store with a great user experience.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://wa.me/573107851074?text=Hello%20Omar,%20I%20saw%20your%20Dog%20Products%20case%20study%20and%20I%20want%20to%20build%20an%20online%20store" target="_blank" rel="noopener noreferrer" class="btn-primary" style="text-decoration: none;">Start my project</a>
            <a href="/en/portfolio/projects/" class="btn-secondary" style="text-decoration: none; border-color: rgba(255,255,255,0.55); color: var(--white);">View more projects</a>
          </div>
        </div>
      </section>
    </div>
  </main>
</LayoutEN>
