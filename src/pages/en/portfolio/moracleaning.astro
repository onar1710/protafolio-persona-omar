---
import LayoutEN from '../../../layouts/LayoutEN.astro';
import CaseStudyIcon from '../../../components/CaseStudyIcon.astro';
import CaseStudyHero from '../../../components/CaseStudyHero.astro';

const project = {
  title: 'Mora Cleaning - House Cleaning Services Website (Tennessee)',
  description:
    'This case study shows how I structure a high-converting local service website: clear offer, defined cleaning packages, trust elements, and strong CTAs to turn local traffic into quote requests. Built to scale with local SEO in Tennessee.',
  cliente: 'Mora Cleaning',
  fecha: '2026',
  tipo: 'Local Service Website',
  tecnologias: ['Landing Architecture', 'Local SEO', 'Conversion Copy', 'Performance Optimization'],
  url: 'https://www.moracleaning.us/',
  imagen: '/images-portfolio/caso-moracleaning.png',
  stats: {
    location: 'Tennessee, USA',
    packages: '3 tiers',
    services: '5+ services',
    focus: 'SEO + Leads',
  },
  results: [
    '✅ Clear value proposition: reliable and detailed residential cleaning with flexible scheduling',
    '✅ Three packages (Basic, Standard, Deep) to reduce friction and speed up decisions',
    '✅ Trust section (verified staff, safe products, satisfaction guarantee) to increase confidence',
    '✅ Strong, repeated CTAs to request a quote without losing the visitor',
    '✅ Structure ready to expand by city/service for local SEO growth',
  ],
};

const techStack = [
  { name: 'Local SEO', description: 'Built around local intent (city/state + service)', icon: '🗺️' },
  { name: 'Conversion Copy', description: 'Benefits + guarantee + trust signals to drive leads', icon: '🎯' },
  { name: 'Clear Packages', description: 'Comparable offers so visitors choose faster', icon: '📦' },
  { name: 'CTA Strategy', description: 'Quote requests placed where intent is highest', icon: '💬' },
  { name: 'Performance', description: 'Lightweight layout for a fast mobile experience', icon: '⚡' },
];

const phases = [
  {
    title: 'Offer, Structure and Trust',
    week: 'Phase 1',
    tasks: [
      'Defined the offer: detailed residential cleaning with flexible scheduling in TN',
      'Organized core services (general, kitchen & bath, dusting, move-in/out, deep cleaning)',
      'Built trust elements: verified staff, safe products, satisfaction guarantee',
    ],
  },
  {
    title: 'Packages, CTAs and Local SEO',
    week: 'Phase 2',
    tasks: [
      'Created three tiers (Basic, Standard, Deep) with clear scope to reduce confusion',
      'Reinforced CTAs to turn visits into quote requests',
      'Prepared a structure that scales by city/service to capture high-intent local searches',
    ],
  },
];

const features = [
  {
    icon: '🧼',
    title: 'Clear offer in seconds',
    description: 'Visitors instantly understand what the business does, where it operates, and the next step to book.',
  },
  {
    icon: '📦',
    title: 'Packages that close',
    description: 'Three comparable options that cover maintenance, standard, and deep cleaning, with add-ons available.',
  },
  {
    icon: '🛡️',
    title: 'Trust and safety',
    description: 'Verified staff, safe products for families and pets, plus a satisfaction guarantee.',
  },
  {
    icon: '🗺️',
    title: 'Local SEO-ready',
    description: 'A structure designed to expand by Tennessee cities and service keywords that convert.',
  },
  {
    icon: '💬',
    title: 'CTAs without friction',
    description: 'Clear actions to request a quote placed in the most effective sections.',
  },
  {
    icon: '⚡',
    title: 'Fast mobile experience',
    description: 'Mobile-first layout with clean sections and readable content.',
  },
];

const metrics = [
  { icon: '🎯', title: 'Goal', value: 'Leads', description: 'Turn local visits into quote requests' },
  { icon: '🗺️', title: 'Market', value: 'TN', description: 'Focused on Tennessee local intent' },
  { icon: '📦', title: 'Offer', value: '3 packages', description: 'Simple and comparable pricing tiers' },
  { icon: '🛡️', title: 'Trust', value: 'Guarantee', description: 'Confidence-driven conversion elements' },
];

const experience = [
  {
    title: 'What I focused on',
    text: 'For local services, conversion happens when the offer is clear and the site feels trustworthy. This layout is built around clarity, packages, and guarantee-first messaging.',
  },
  {
    title: 'Why packages matter',
    text: 'Packages remove uncertainty. When visitors instantly understand what they get, more of them take action and request a quote.',
  },
  {
    title: 'How I designed for SEO',
    text: 'The structure is ready to scale by city and service terms in Tennessee, capturing high-intent searches and pushing users to a clear CTA.',
  },
];
---

<LayoutEN title="Mora Cleaning - Case Study | Omar Fuentes" description="Mora Cleaning case study: local cleaning service website for Tennessee with clear packages, trust signals, local SEO and strong CTAs to generate leads.">
  <main class="pt-24 pb-20" style="background: var(--white);">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
      <CaseStudyHero
        lang="en"
        title={project.title}
        description={project.description}
        image={project.imagen}
        liveUrl={project.url}
        backHref="/en/portfolio/projects/"
        technologies={project.tecnologias}
        badges={['Local SEO', 'Lead gen', 'Services']}
      />

      <section class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-14">
        {Object.entries(project.stats).map(([key, value]) => (
          <div class="text-center p-6 rounded-2xl" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08); box-shadow: 0 10px 30px rgba(0,0,0,0.06);">
            <div class="text-2xl font-black" style="color: var(--primary-blue);">{value}</div>
            <div class="text-black text-sm font-bold mt-2" style="text-transform: capitalize;">{key}</div>
          </div>
        ))}
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Stack & Strategy</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {techStack.map((tech) => (
            <div class="rounded-2xl p-6" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08);">
              <div class="text-2xl"><CaseStudyIcon icon={tech.icon} class="w-10 h-10" /></div>
              <div class="font-black text-black mt-3">{tech.name}</div>
              <div class="text-black mt-2">{tech.description}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Process</h2>
        <div class="space-y-6">
          {phases.map((phase) => (
            <div class="rounded-3xl p-8" style="background: var(--gray-50); border: 1px solid rgba(0,0,0,0.08);">
              <div class="flex flex-wrap items-center gap-3 mb-5">
                <h3 class="text-2xl font-black text-black">{phase.title}</h3>
                <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold" style="background: rgba(0, 102, 255, 0.12); color: var(--primary-blue); border: 1px solid rgba(0, 102, 255, 0.22);">{phase.week}</span>
              </div>
              <ul class="space-y-3">
                {phase.tasks.map((task) => (
                  <li class="flex items-start gap-3"><span style="color: var(--primary-green); font-weight: 900;">✓</span><span class="text-black">{task}</span></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Key Features</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {features.map((feature) => (
            <div class="rounded-3xl p-8" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08); box-shadow: 0 10px 30px rgba(0,0,0,0.06);">
              <div class="text-3xl"><CaseStudyIcon icon={feature.icon} class="w-12 h-12" /></div>
              <h3 class="text-xl font-black text-black mt-4">{feature.title}</h3>
              <p class="text-black mt-3">{feature.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Outcome Metrics</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {metrics.map((metric) => (
            <div class="rounded-3xl p-8 text-center" style="background: var(--gray-50); border: 1px solid rgba(0,0,0,0.08);">
              <div class="flex justify-center"><CaseStudyIcon icon={metric.icon} class="w-12 h-12" /></div>
              <div class="text-3xl font-black mt-3" style="color: var(--primary-blue);">{metric.value}</div>
              <div class="font-black text-black mt-2">{metric.title}</div>
              <div class="text-black mt-2">{metric.description}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">Results</h2>
        <div class="rounded-3xl p-8" style="background: var(--white); border: 1px solid rgba(0,0,0,0.08);">
          <ul class="space-y-4">
            {project.results.map((result) => (
              <li class="flex items-start gap-3">
                <span style="color: var(--primary-green); font-weight: 900;">✅</span>
                <span class="text-black">{result.replace(/^✅\s*/, '')}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-3xl font-black text-black mb-8">My Notes</h2>
        <div class="rounded-3xl p-10" style="background: linear-gradient(135deg, rgba(0, 102, 255, 0.08) 0%, rgba(255, 215, 0, 0.10) 50%, rgba(0, 200, 81, 0.08) 100%); border: 1px solid rgba(0,0,0,0.08);">
          <div class="space-y-8">
            {experience.map((item) => (
              <div>
                <h3 class="text-xl font-black text-black mb-3">{item.title}</h3>
                <p class="text-black">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section>
        <div class="rounded-3xl p-12 text-center" style="background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-yellow) 50%, var(--primary-green) 100%);">
          <h2 class="text-3xl font-black text-white mb-4">Want a service website that generates leads?</h2>
          <p class="text-white mb-8">If you run a local service business, I can build a website with clear packages, trust signals, and local SEO to turn traffic into real quote requests.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://wa.me/573107851074?text=Hello%20Omar,%20I%20want%20a%20local%20service%20website%20like%20Mora%20Cleaning" target="_blank" rel="noopener noreferrer" class="btn-primary" style="text-decoration: none;">
              Message on WhatsApp
            </a>
            <a href="/en/portfolio/projects/" class="btn-secondary" style="text-decoration: none; border-color: rgba(255,255,255,0.55); color: var(--white);">
              View More Projects
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>
</LayoutEN>
