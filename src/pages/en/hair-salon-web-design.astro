---
import Layout from '../../layouts/LayoutEN.astro';

const services = [
  { title: 'Online booking system for appointments', description: 'Easy-to-use booking system for your clients to schedule appointments', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', bgClass: 'from-pink-500 to-pink-600' },
  { title: 'Photo gallery to showcase your work', description: 'Beautiful gallery to display your hairstyles and transformations', icon: 'M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z', bgClass: 'from-purple-500 to-purple-600' },
  { title: 'Service pages (haircuts, coloring, styling, etc.)', description: 'Dedicated pages for each service you offer', icon: 'M6 10H4a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 002 2h8a2 2 0 002-2v-2h2a2 2 0 002-2v-4a2 2 0 00-2-2h-2V8a2 2 0 00-2-2H8a2 2 0 00-2 2v2z', bgClass: 'from-purple-500 to-purple-600' },
  { title: 'Contact forms and quick call buttons', description: 'Multiple ways for clients to reach you instantly', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 2.493A1 1 0 008.618 7h6.764a1 1 0 01.948-.684L17.28 3a2 2 0 012 2h3.28a1 1 0 01.948.684l1.498 2.493A1 1 0 0018.618 7h-6.764a1 1 0 01-.948-.684L9.72 3.684A1 1 0 008.772 3H6a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7', bgClass: 'from-purple-500 to-purple-600' },
  { title: 'Mobile-optimized design', description: 'Perfect experience on smartphones and tablets', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', bgClass: 'from-pink-500 to-pink-600' },
  { title: 'Local SEO structure', description: 'Optimized to attract local clients searching for hair services', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', bgClass: 'from-purple-500 to-purple-600' },
];

const whyChooseMe = [
  { title: 'Affordable hair salon web design', description: 'You don\'t need to spend thousands to have a professional website.', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1', bgClass: 'from-pink-500 to-pink-600' },
  { title: 'Responsive design that works on all devices', description: 'Most of your clients are on their phone — your site will look perfect there.', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', bgClass: 'from-purple-500 to-purple-600' },
  { title: 'Fast and reliable performance', description: 'Nobody waits for a slow website. Yours will load fast and run smoothly.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-pink-500 to-pink-600' },
  { title: 'Built to get more bookings', description: 'Everything is designed to turn visitors into real appointments.', icon: 'M3 21h18', bgClass: 'from-purple-500 to-purple-600' },
  { title: 'SEO-friendly structure', description: 'Your salon can appear on Google when people search for services near them.', icon: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z', bgClass: 'from-purple-500 to-purple-600' },
  { title: 'Clean and modern design that builds trust', description: 'Show your style, your work, and your professionalism from the first second.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', bgClass: 'from-pink-500 to-pink-600' },
];

const results = [
  'Get more appointment bookings',
  'Attract new local clients',
  'Show your work professionally',
  'Build trust before the client even contacts you',
];

const steps = [
  { step: '1', title: 'You tell me about your salon and what you need', description: 'Share your goals, services, and style preferences' },
  { step: '2', title: 'I design and build your website', description: 'Professional design optimized for bookings and showcasing your work' },
  { step: '3', title: 'You start getting more bookings', description: 'Watch your salon grow with new clients and appointments' },
];
---

<Layout
  title="Hair Salon Web Design for Small Businesses | Omar Fuentes"
  description="If you run a hair salon, you already know how important it is to look professional online. I build websites that help you get more bookings, show your work, and turn visitors into real clients."
  keywords="hair salon web design, salon website, online booking, salon SEO, beauty website design"
>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center pb-16 md:pb-24 lg:pb-32 bg-gradient-to-br from-purple-900 via-pink-900 to-purple-900 relative overflow-hidden pt-8">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-slide-in">
          <div class="flex items-center space-x-2 mb-6">
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-white/10 text-white border border-white/20">Small Business</span>
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-pink-500/20 text-pink-300 border border-pink-500/30">Hair Salons</span>
          </div>

          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight text-white">
            Hair Salon <br />
            <span class="bg-gradient-to-r from-pink-400 to-purple-400 bg-clip-text text-transparent">Web Design</span>
          </h1>

          <p class="text-xl text-white/90 mb-8 max-w-lg">
            If you run a hair salon, you already know how important it is to look professional online. I build websites that help you get more bookings, show your work, and turn visitors into real clients.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://wa.me/12025551234?text=Hi%20Omar,%20I%20want%20a%20free%20hair%20salon%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 hover:shadow-xl bg-gradient-to-r from-pink-500 to-pink-600 text-white hover:shadow-xl">
              Get a Quote
            </a>
            <a href="/en/portfolio/projects/" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 border-2 border-white/30 text-white hover:bg-white/10">
              View Portfolio
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-4 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="text-yellow-400">★★★★★</span>
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">+200% More Bookings</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">3-7 Day Delivery</span>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-pink-500 to-purple-500 rounded-3xl opacity-20 animate-float"></div>
          <div class="relative bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
            <p class="text-white/70 text-sm mb-4">Trusted by 50+ Hair Salons</p>
            <p class="text-white text-2xl font-bold mb-2">Free consultation • No obligation • Results guaranteed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Connection Section -->
  <section class="py-20 bg-gradient-to-br from-purple-50 to-pink-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">A Website That Brings You More Clients, Not Just Looks Good</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Your salon website shouldn't just look nice — it should help you get more appointments.
        </p>
      </div>

      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-pink-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">Book appointments</h3>
              <p class="text-gray-600">Easy online booking system for your clients</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">See your work</h3>
              <p class="text-gray-600">Beautiful photo gallery to showcase your styles</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016zM12 9v2m0 4h.01" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">Trust your brand</h3>
              <p class="text-gray-600">Professional design that builds credibility</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">Quick call buttons and contact</h3>
              <p class="text-gray-600">One-tap call buttons and fast contact forms</p>
            </div>
          </div>
        </div>

        <div class="text-center mt-8">
          <p class="text-lg text-purple-800 font-semibold">Because at the end of the day, what matters is getting more clients in your chair.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">What Your Hair Salon Website Will Include</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          I build websites with everything your salon actually needs
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="card">
            <div class={`w-12 h-12 mb-4 bg-gradient-to-br ${service.bgClass} rounded-lg flex items-center justify-center`}>
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{service.title}</h3>
            <p class="text-gray-600">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Me Section -->
  <section class="py-20 bg-gray-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Why Hair Salons Choose This Web Design</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Professional features designed specifically for hair salons
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {whyChooseMe.map((item) => (
          <div class="card">
            <div class={`w-12 h-12 mb-4 bg-gradient-to-br ${item.bgClass} rounded-lg flex items-center justify-center`}>
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{item.title}</h3>
            <p class="text-gray-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Turn Visitors Into Paying Clients</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          A good hair salon website helps you:
        </p>
      </div>

      <div class="max-w-4xl mx-auto bg-gradient-to-br from-purple-50 to-pink-50 rounded-3xl shadow-2xl p-12 border border-purple-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {results.map((result) => (
            <div class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-md">
              <svg class="w-6 h-6 text-purple-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold text-lg">{result}</span>
            </div>
          ))}
        </div>

        <div class="text-center mt-8">
          <p class="text-lg text-purple-800 font-semibold">
            Your website works for you 24/7, bringing new clients even when you're busy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Authority Section -->
  <section class="py-20 bg-gradient-to-br from-purple-50 to-pink-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">I Understand How Hair Salon Businesses Work</h2>
      </div>

      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-pink-100">
        <div class="space-y-6 text-center">
          <p class="text-xl text-gray-700 leading-relaxed">
            You don't need something complicated.
          </p>
          <p class="text-xl text-gray-700 leading-relaxed">
            You need something simple, clean, and effective — something that helps people book fast and trust your work.
          </p>
          <p class="text-xl text-gray-900 font-bold">
            That's exactly what I build.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Simple Process</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {steps.map((step) => (
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-br from-purple-500 to-purple-600 rounded-full flex items-center justify-center">
              <span class="text-2xl font-bold text-white">{step.step}</span>
            </div>
            <h3 class="text-lg font-bold mb-2">{step.title}</h3>
            <p class="text-gray-600 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-purple-900 via-pink-900 to-purple-900">
    <div class="container text-center">
      <h2 class="text-section mb-4 text-white">Ready to Get More Clients for Your Salon?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Let's build a website that actually helps your business grow.
      </p>
      <a href="https://wa.me/12025551234?text=Hi%20Omar,%20I%20want%20a%20free%20hair%20salon%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 bg-white text-purple-900 hover:shadow-xl">
        Get a Quote
      </a>
      <div class="mt-8 text-white/70 text-sm">
        30-day satisfaction guarantee • Dedicated support • Proven results
      </div>
    </div>
  </section>
</Layout>
