---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, ArrowRight, Star, Clock, Award, Phone, MapPin, Wrench, Target, Shield, Zap, Globe, TrendingUp, Calendar, Scissors, Users, Camera } from 'lucide-react';
---

<Layout title="Hair Salon Web Design for Small Businesses | Omar Fuentes" description="Professional hair salon web design services for small businesses. Get more bookings, showcase your work, and turn visitors into real clients with fast, SEO-optimized websites.">
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-purple-900 via-pink-900 to-purple-900 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-6 py-24">
      <div class="text-center">
        <!-- Badge -->
        <div class="inline-flex items-center bg-white/10 backdrop-blur-md rounded-full px-6 py-3 mb-8 border border-white/20">
          <Scissors className="w-5 h-5 mr-2 text-pink-400" />
          <span class="text-white text-sm font-semibold">Trusted by 50+ Hair Salons</span>
        </div>
        
        <h1 class="text-6xl md:text-7xl font-bold mb-8 text-white leading-tight">
          Hair Salon Web Design for Small Businesses
        </h1>
        
        <!-- Value Proposition -->
        <div class="max-w-3xl mx-auto mb-12">
          <p class="text-xl text-white/90 mb-8 leading-relaxed">If you run a hair salon, you already know how important it is to look professional online. I build websites that help you get more bookings, show your work, and turn visitors into real clients.</p>
          
          <!-- Social Proof -->
          <div class="flex flex-wrap items-center justify-center gap-8 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Star className="w-5 h-5 text-pink-400 fill-pink-400" />
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <TrendingUp className="w-5 h-5 text-green-400" />
              <span class="font-semibold">+200% More Bookings</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Zap className="w-5 h-5 text-pink-400" />
              <span class="font-semibold">3-7 Day Delivery</span>
            </div>
          </div>
        </div>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
          <a href="mailto:contact@omarfuentes.com" class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-pink-500 to-pink-600 text-white px-10 py-5 font-semibold hover:from-pink-600 hover:to-pink-700 transition-all transform hover:scale-105 shadow-2xl text-lg">
            Get a Quote
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
          <a href="/en/portfolio" class="inline-flex items-center justify-center rounded-full border-2 border-white/30 text-white px-10 py-5 font-semibold hover:bg-white/10 transition-all text-lg backdrop-blur-sm">
            View Portfolio
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
        </div>
        
        <!-- Trust indicators -->
        <div class="text-white/70 text-sm flex items-center justify-center gap-2">
          <CheckCircle className="w-4 h-4" />
          <span>Free consultation • No obligation • Results guaranteed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Connection Section -->
  <section class="py-24 bg-gradient-to-br from-purple-50 to-pink-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-pink-100 rounded-full blur-3xl opacity-30"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-100 rounded-full blur-3xl opacity-30"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-5xl mx-auto text-center mb-16">
        <h2 class="text-5xl font-bold mb-8 text-black">A Website That Brings You More Clients, Not Just Looks Good</h2>
      </div>
      
      <div class="max-w-5xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-pink-100">
        <div class="text-center mb-8">
          <p class="text-xl text-gray-800 mb-6 font-semibold">Your salon website shouldn't just look nice — it should help you get more appointments.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <Calendar className="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Book appointments</h3>
              <p class="text-black font-medium">Easy online booking system for your clients</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-purple-700 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <Camera className="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">See your work</h3>
              <p class="text-black font-medium">Beautiful photo gallery to showcase your styles</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-purple-700 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <Shield className="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Trust your brand</h3>
              <p class="text-black font-medium">Professional design that builds credibility</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <Phone className="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Contact you instantly</h3>
              <p class="text-black font-medium">Quick call buttons and contact forms</p>
            </div>
          </div>
        </div>
        
        <div class="text-center mt-8">
          <p class="text-lg text-purple-800 font-semibold">Because at the end of the day, what matters is getting more clients in your chair.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-24 bg-white relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-20 left-20 w-72 h-72 bg-pink-100 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-20 right-20 w-72 h-72 bg-purple-100 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-5xl font-bold mb-8 text-black">Why Hair Salons Choose This Web Design</h2>
        <p class="text-xl text-purple-700 max-w-3xl mx-auto">Professional features designed specifically for hair salons</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group bg-gradient-to-br from-white to-pink-50 p-8 rounded-2xl shadow-lg border border-pink-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Target className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Affordable hair salon web design</h3>
          <p class="text-black text-lg leading-relaxed">You don't need to spend thousands to have a professional website.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-purple-50 p-8 rounded-2xl shadow-lg border border-purple-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-purple-600 to-purple-700 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22 16.92V19a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 3 4.18 2 2 0 0 1 5 2h2.09a2 2 0 0 1 2 1.72c.12.86.3 1.7.54 2.5a2 2 0 0 1-.45 2.11L8.09 9.41a16 16 0 0 0 6.5 6.5l1.08-1.09a2 2 0 0 1 2.11-.45c.8.24 1.64.42 2.5.54A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Responsive design that works on all devices</h3>
          <p class="text-black text-lg leading-relaxed">Most of your clients are on their phone — your site will look perfect there.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-pink-50 p-8 rounded-2xl shadow-lg border border-pink-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Zap className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Fast and reliable performance</h3>
          <p class="text-black text-lg leading-relaxed">Nobody waits for a slow website. Yours will load fast and run smoothly.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-purple-50 p-8 rounded-2xl shadow-lg border border-purple-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-purple-600 to-purple-700 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 21h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M5 21V7a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M9 21v-6a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M8 9h.01M12 9h.01M16 9h.01" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Built to get more bookings</h3>
          <p class="text-black text-lg leading-relaxed">Everything is designed to turn visitors into real appointments.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-purple-50 p-8 rounded-2xl shadow-lg border border-purple-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-purple-600 to-purple-700 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
              <path d="M2 12h20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M12 2c3 3 4.5 6.5 4.5 10S15 19 12 22c-3-3-4.5-6.5-4.5-10S9 5 12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">SEO-friendly structure</h3>
          <p class="text-black text-lg leading-relaxed">Your salon can appear on Google when people search for services near them.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-pink-50 p-8 rounded-2xl shadow-lg border border-pink-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Award className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Clean and modern design that builds trust</h3>
          <p class="text-black text-lg leading-relaxed">Show your style, your work, and your professionalism from the first second.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-24 bg-gradient-to-br from-purple-50 to-pink-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-10 right-10 w-80 h-80 bg-pink-100 rounded-full blur-3xl opacity-30"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-5xl font-bold mb-8 text-black">What Your Hair Salon Website Will Include</h2>
        <p class="text-xl text-purple-700 max-w-3xl mx-auto font-medium">I build websites with everything your salon actually needs:</p>
      </div>
      
      <div class="max-w-5xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-pink-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <Calendar className="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Online booking system for appointments</h3>
              <p class="text-black font-medium">Easy-to-use booking system for your clients to schedule appointments</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-purple-700 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <Camera className="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Photo gallery to showcase your work</h3>
              <p class="text-black font-medium">Beautiful gallery to display your hairstyles and transformations</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-purple-700 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <Scissors className="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Service pages (haircuts, coloring, styling, etc.)</h3>
              <p class="text-black font-medium">Dedicated pages for each service you offer</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-purple-700 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <Phone className="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Contact forms and quick call buttons</h3>
              <p class="text-black font-medium">Multiple ways for clients to reach you instantly</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M22 16.92V19a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 3 4.18 2 2 0 0 1 5 2h2.09a2 2 0 0 1 2 1.72c.12.86.3 1.7.54 2.5a2 2 0 0 1-.45 2.11L8.09 9.41a16 16 0 0 0 6.5 6.5l1.08-1.09a2 2 0 0 1 2.11-.45c.8.24 1.64.42 2.5.54A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Mobile-optimized design</h3>
              <p class="text-black font-medium">Perfect experience on smartphones and tablets</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-pink-50 p-6 rounded-2xl transition-all duration-300">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-purple-700 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
                <path d="M2 12h20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <path d="M12 2c3 3 4.5 6.5 4.5 10S15 19 12 22c-3-3-4.5-6.5-4.5-10S9 5 12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-black">Local SEO structure</h3>
              <p class="text-black font-medium">Optimized to attract local clients searching for hair services</p>
            </div>
          </div>
        </div>
        
        <div class="text-center mt-8">
          <p class="text-lg text-purple-800 font-semibold">This is not just web design for hair salons — it's a system to help you grow.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="py-24 bg-gradient-to-br from-white to-purple-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-100 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-5xl mx-auto text-center mb-16">
        <h2 class="text-5xl font-bold mb-8 text-black">Turn Visitors Into Paying Clients</h2>
        <p class="text-xl text-purple-700 mb-8 leading-relaxed max-w-3xl mx-auto font-medium">
          A good hair salon website helps you:
        </p>
      </div>
        
      <div class="max-w-5xl mx-auto bg-gradient-to-br from-white to-purple-50 rounded-3xl shadow-2xl p-12 border border-purple-100">
        <p class="text-xl text-purple-800 mb-10 text-center font-bold">Your hair salon website will help you:</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex items-center space-x-4 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300">
            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-purple-600" />
            </div>
            <span class="text-black font-bold text-lg">Get more appointment bookings</span>
          </div>
          
          <div class="flex items-center space-x-4 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300">
            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-purple-600" />
            </div>
            <span class="text-black font-bold text-lg">Attract new local clients</span>
          </div>
          
          <div class="flex items-center space-x-4 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300">
            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-purple-600" />
            </div>
            <span class="text-black font-bold text-lg">Show your work professionally</span>
          </div>
          
          <div class="flex items-center space-x-4 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300">
            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-purple-600" />
            </div>
            <span class="text-black font-bold text-lg">Build trust before the client even contacts you</span>
          </div>
        </div>
        
        <p class="text-lg text-purple-800 mt-10 text-center font-semibold">
          Your website works for you 24/7, bringing new clients even when you're busy.
        </p>
      </div>
    </div>
  </section>

  <!-- Authority Section -->
  <section class="py-24 bg-gradient-to-br from-purple-50 to-pink-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-20 right-20 w-80 h-80 bg-pink-100 rounded-full blur-3xl opacity-30"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-5xl font-bold mb-8 text-black">I Understand How Hair Salon Businesses Work</h2>
        </div>
        
        <div class="bg-white rounded-3xl shadow-2xl p-12 border border-pink-100">
          <div class="space-y-8 text-center">
            <p class="text-xl text-black leading-relaxed max-w-4xl mx-auto font-medium">
              You don't need something complicated.
            </p>
            <p class="text-xl text-black leading-relaxed max-w-4xl mx-auto font-medium">
              You need something simple, clean, and effective — something that helps people book fast and trust your work.
            </p>
            <p class="text-xl text-black leading-relaxed max-w-4xl mx-auto font-bold">
              That's exactly what I build.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

