---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const allPosts = (await getCollection('blog')).filter((post) => post.id.startsWith('en/'));
	return allPosts.map((post) => ({
		params: { slug: post.id.replace(/^en\//, '') },
		props: { post, allPosts },
	}));
}

type Props = CollectionEntry<'blog'> | { post: CollectionEntry<'blog'>; allPosts: CollectionEntry<'blog'>[] };

const props = Astro.props as Props;
const post = 'post' in props ? props.post : props;
const allPosts = 'allPosts' in props ? props.allPosts : undefined;
const { Content } = await render(post);
---

<BlogPost {...post.data} posts={allPosts}>
	<Content />
</BlogPost>
