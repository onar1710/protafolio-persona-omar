---
import { getCollection } from 'astro:content';
import FormattedDate from '../../../components/FormattedDate.astro';
import Layout from '../../../layouts/LayoutEN.astro';

const posts = (await getCollection('blog'))
	.filter((post) => post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const toEnSlug = (id: string) => id.replace(/^en\//, '');

const seoPosts = new Set(['avoid-algorithmic-penalties-penguin', 'what-are-cloaking-and-keywords-stuffing-in-seo']);
const webDesignPosts = new Set([
	'responsive-web-design-with-html-5',
	'web-design-services-for-small-businesses-the-affordable-and-reliable-guide',
]);

const postCategory = (id: string): 'web-design' | 'seo' | 'digital-marketing' | 'social-media' => {
	if (id.startsWith('en/seo/')) return 'seo';
	if (id.startsWith('en/web-design/')) return 'web-design';
	if (id.startsWith('en/digital-marketing/')) return 'digital-marketing';
	if (id.startsWith('en/social-media/')) return 'social-media';

	const slug = toEnSlug(id);
	if (seoPosts.has(slug)) return 'seo';
	if (webDesignPosts.has(slug)) return 'web-design';
	return 'web-design';
};

const postUrl = (id: string) => {
	if (id.startsWith('en/seo/')) return `/en/seo/${id.slice('en/seo/'.length)}/`;
	if (id.startsWith('en/web-design/')) return `/en/web-design/${id.slice('en/web-design/'.length)}/`;
	if (id.startsWith('en/digital-marketing/'))
		return `/en/digital-marketing/${id.slice('en/digital-marketing/'.length)}/`;
	if (id.startsWith('en/social-media/')) return `/en/social-media/${id.slice('en/social-media/'.length)}/`;
	return `/en/blog/${toEnSlug(id)}/`;
};

---

<Layout
  title="Blog | Omar Fuentes"
  description="Guides and articles about web design, development, SEO, and performance for small businesses in USA."
  keywords="web design blog, web development blog, SEO blog, small business web design"
>
  <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl pt-24">
  <div class="mb-12">
    <a href="/en/" class="text-primary-blue font-semibold hover:underline">Back to home</a>
    <h1 class="text-3xl md:text-5xl font-black mt-4 mb-4">Blog</h1>
    <p class="text-black max-w-3xl">
      Practical notes about web design, development, SEO, and performance.
    </p>
  </div>

  <div class="flex flex-wrap gap-3 mb-10">
    <a
      href="/en/blog/?cat=web-design"
      data-blog-tab="web-design"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      Web design
    </a>
    <a
      href="/en/blog/?cat=seo"
      data-blog-tab="seo"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      SEO
    </a>
    <a
      href="/en/blog/?cat=digital-marketing"
      data-blog-tab="digital-marketing"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      Digital marketing
    </a>
    <a
      href="/en/blog/?cat=social-media"
      data-blog-tab="social-media"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      Social media
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {posts.map((post) => (
      <a
        href={postUrl(post.id)}
        data-blog-card
        data-blog-category={postCategory(post.id)}
        class="bg-white rounded-2xl overflow-hidden transition-all duration-500 border border-gray-100 shadow-lg hover:shadow-2xl hover:-translate-y-2 block"
        style="text-decoration: none;"
      >
        {post.data.heroImage && (
          <div class="relative aspect-video overflow-hidden">
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        )}

        <div class="p-6">
          <div class="text-sm text-black mb-3">
            <FormattedDate date={post.data.pubDate} />
          </div>
          <h2 class="text-2xl font-black mb-3">{post.data.title}</h2>
          <p class="text-black">{post.data.description}</p>
          <div class="mt-6 text-primary-blue font-semibold">Read article</div>
        </div>
      </a>
    ))}
  </div>
</div>

<script is:inline>
  (() => {
    const params = new URLSearchParams(window.location.search);
    const cat = params.get('cat');

    const cards = Array.from(document.querySelectorAll('[data-blog-card]'));
    if (!cat) return;

    for (const card of cards) {
      const cardCat = card.getAttribute('data-blog-category');
      (card).style.display = cardCat === cat ? '' : 'none';
    }

    const tabs = Array.from(document.querySelectorAll('[data-blog-tab]'));
    for (const tab of tabs) {
      const tabCat = tab.getAttribute('data-blog-tab');
      if (tabCat === cat) {
        tab.style.background = 'var(--primary-blue)';
        tab.style.borderColor = 'var(--primary-blue)';
        tab.style.color = 'var(--white)';
      }
    }
  })();
</script>
</Layout>
