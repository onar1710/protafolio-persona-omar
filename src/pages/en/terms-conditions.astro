---
import Layout from '~/layouts-en/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

---

<Layout title="Terms & Conditions - Omar Fuentes" description="Comprehensive Terms and Conditions for Omar Fuentes web design, development and SEO services. Legal agreement for clients across the United States.">
  
  <PageHeader 
      title="Terms & Conditions"
      description="Last updated: January 28, 2026"
  />

  <Container as="main" class="max-w-4xl mx-auto">
      
      <!-- Agreement Overview -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Agreement Overview</h2>
          <p class="text-muted-foreground leading-8 mb-6">
              These Terms & Conditions ("Terms") govern your use of the website omarfuentes.com and the web design, 
              development, and SEO services provided by <span class="font-semibold text-foreground">Omar Fuentes</span> 
              ("we," "us," or "our") throughout the United States.
          </p>
          <p class="text-muted-foreground leading-8 mb-4">
              By accessing our website, requesting a quote, or engaging our services, you agree to be bound by these Terms.
              If you do not agree to these Terms, please do not use our website or services.
          </p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <p class="font-semibold text-foreground mb-2">Key Points:</p>
              <ul class="space-y-1 text-sm text-muted-foreground">
                  <li>• These Terms constitute a legally binding agreement</li>
                  <li>• Services are provided to clients throughout the United States</li>
                  <li>• All projects require signed agreement before commencement</li>
                  <li>• Payment terms are strictly enforced</li>
              </ul>
          </div>
      </section>

      <!-- Services Description -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Services Description</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Omar Fuentes provides professional web design, development, and digital marketing services to businesses across the United States:
          </p>
          
          <div class="grid gap-4 md:grid-cols-2">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Web Design Services</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Custom responsive website design</li>
                      <li>• User experience (UX) design</li>
                      <li>• User interface (UI) design</li>
                      <li>• Mobile-first design approach</li>
                      <li>• Brand identity integration</li>
                      <li>• Wireframing and prototyping</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Web Development Services</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• HTML5, CSS3, JavaScript development</li>
                      <li>• React, Next.js, Vue.js development</li>
                      <li>• WordPress theme development</li>
                      <li>• E-commerce solutions</li>
                      <li>• Database integration</li>
                      <li>• API development and integration</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">SEO Services</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• On-page SEO optimization</li>
                      <li>• Technical SEO audits</li>
                      <li>• Local SEO for small businesses</li>
                      <li>• Content optimization</li>
                      <li>• Keyword research and strategy</li>
                      <li>• Performance tracking and reporting</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Support Services</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Website maintenance and updates</li>
                      <li>• Security monitoring</li>
                      <li>• Performance optimization</li>
                      <li>• Content management training</li>
                      <li>• Technical support</li>
                      <li>• Hosting consultation</li>
                  </ul>
              </div>
          </div>
      </section>

      <!-- Client Responsibilities -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Client Responsibilities</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              As a client, you agree to fulfill the following responsibilities to ensure project success:
          </p>
          
          <div class="space-y-6">
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">1</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Provide Accurate Information</h3>
                      <p class="text-muted-foreground text-sm">Supply complete, accurate, and timely information about your business, goals, and project requirements.</p>
                  </div>
              </div>
              
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">2</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Content and Materials</h3>
                      <p class="text-muted-foreground text-sm">Provide all necessary content, images, logos, and materials within agreed timeframes. Ensure you have legal rights to use all provided materials.</p>
                  </div>
              </div>
              
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">3</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Timely Feedback</h3>
                      <p class="text-muted-foreground text-sm">Review deliverables and provide feedback within specified timeframes to avoid project delays.</p>
                  </div>
              </div>
              
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">4</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Technical Access</h3>
                      <p class="text-muted-foreground text-sm">Provide necessary access to hosting accounts, domains, and other technical systems as required for project completion.</p>
                  </div>
              </div>
              
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">5</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Payment Obligations</h3>
                      <p class="text-muted-foreground text-sm">Make all payments according to agreed schedules and terms. Late payments may result in project suspension.</p>
                  </div>
              </div>
          </div>
      </section>

      <!-- Payment Terms -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Payment Terms</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Our payment structure is designed to be fair and transparent while ensuring project continuity:
          </p>
          
          <div class="space-y-6">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Payment Structure</h3>
                  <div class="space-y-4">
                      <div class="flex justify-between items-center pb-3 border-b border-black/10">
                          <span class="text-muted-foreground">Initial Deposit</span>
                          <span class="font-semibold">50% of total project value</span>
                      </div>
                      <div class="flex justify-between items-center pb-3 border-b border-black/10">
                          <span class="text-muted-foreground">Final Payment</span>
                          <span class="font-semibold">50% upon project completion</span>
                      </div>
                      <div class="flex justify-between items-center">
                          <span class="text-muted-foreground">Monthly Services</span>
                          <span class="font-semibold">Due on the 1st of each month</span>
                      </div>
                  </div>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Payment Methods</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• <strong>Bank Transfer (ACH):</strong> Preferred method for U.S. clients</li>
                      <li>• <strong>PayPal:</strong> Available for all clients</li>
                      <li>• <strong>Wire Transfer:</strong> For international clients</li>
                      <li>• <strong>Zelle:</strong> Available for U.S. bank transfers</li>
                      <li>• <strong>Credit/Debit Cards:</strong> Via PayPal processing</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Late Payment Policy</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Late fee: 1.5% per month on overdue amounts</li>
                      <li>• Projects may be suspended after 7 days of non-payment</li>
                      <li>• Final deliverables released only after full payment</li>
                      <li>• Collection costs may be charged for delinquent accounts</li>
                  </ul>
              </div>
          </div>
      </section>

      <!-- Project Timeline and Delivery -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Project Timeline and Delivery</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Project timelines are estimates based on scope and client cooperation:
          </p>
          
          <div class="grid gap-4 md:grid-cols-2">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Timeline Factors</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Client response time affects overall timeline</li>
                      <li>• Additional scope extends delivery dates</li>
                      <li>• Technical complexity may require additional time</li>
                      <li>• Third-party dependencies can impact schedule</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Delivery Process</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Initial design concepts within 5-7 business days</li>
                      <li>• Development begins after design approval</li>
                      <li>• Review periods built into each phase</li>
                      <li>• Final delivery includes all project files</li>
                  </ul>
              </div>
          </div>
          
          <div class="mt-6 p-4 bg-yellow-50 dark:bg-yellow-950 rounded-xl">
              <p class="text-sm text-yellow-800 dark:text-yellow-200">
                  <strong>Important:</strong> Timelines are estimates and not guarantees. We will communicate any delays promptly and propose solutions.
              </p>
          </div>
      </section>

      <!-- Intellectual Property Rights -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Intellectual Property Rights</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Intellectual property ownership is clearly defined to protect both parties:
          </p>
          
          <div class="space-y-6">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Client Ownership</h3>
                  <p class="text-muted-foreground mb-3 text-sm">Upon full payment, you own:</p>
                  <ul class="space-y-2 text-muted-foreground text-sm">
                      <li>• Final website design and layout</li>
                      <li>• Custom code developed for your project</li>
                      <li>• Graphics and visual elements created</li>
                      <li>• Content optimization and SEO work</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Our Retained Rights</h3>
                  <p class="text-muted-foreground mb-3 text-sm">We retain rights to:</p>
                  <ul class="space-y-2 text-muted-foreground text-sm">
                      <li>• Proprietary code and frameworks</li>
                      <li>• Development methodologies and processes</li>
                      <li>• Pre-existing tools and libraries</li>
                      <li>• Portfolio display rights (with permission)</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Third-Party Assets</h3>
                  <p class="text-muted-foreground mb-3 text-sm">Regarding third-party resources:</p>
                  <ul class="space-y-2 text-muted-foreground text-sm">
                      <li>• Stock photos require separate licensing</li>
                      <li>• Premium plugins/fonts may need ongoing subscriptions</li>
                      <li>• Open-source licenses must be respected</li>
                      <li>• Client responsible for third-party license compliance</li>
                  </ul>
              </div>
          </div>
      </section>

      <!-- Confidentiality -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Confidentiality</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Both parties agree to maintain strict confidentiality regarding sensitive information:
          </p>
          
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <h3 class="text-lg font-semibold mb-3">Confidential Information Includes</h3>
              <div class="grid gap-3 text-sm text-muted-foreground">
                  <div class="flex items-start gap-2">
                      <span class="text-primary mt-1">•</span>
                      <div>Business strategies, financial information, and customer data</div>
                  </div>
                  <div class="flex items-start gap-2">
                      <span class="text-primary mt-1">•</span>
                      <div>Technical specifications, code, and development processes</div>
                  </div>
                  <div class="flex items-start gap-2">
                      <span class="text-primary mt-1">•</span>
                      <div>Marketing strategies and proprietary business methods</div>
                  </div>
                  <div class="flex items-start gap-2">
                      <span class="text-primary mt-1">•</span>
                      <div>Any information marked as "confidential" or "proprietary"</div>
                  </div>
              </div>
              <p class="text-muted-foreground text-xs mt-4">
                  Confidentiality obligation survives termination of the business relationship for a period of 3 years.
              </p>
          </div>
      </section>

      <!-- Warranty and Support -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Warranty and Support</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We stand behind our work with comprehensive warranties and support:
          </p>
          
          <div class="grid gap-4 md:grid-cols-2">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3 text-primary">Warranty Coverage</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• 30-day bug fix warranty post-launch</li>
                      <li>• Code quality and performance guarantees</li>
                      <li>• Cross-browser compatibility testing</li>
                      <li>• Mobile responsiveness verification</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3 text-primary">Support Services</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Email support during business hours</li>
                      <li>• Emergency support for critical issues</li>
                      <li>• Training sessions for website management</li>
                      <li>• Documentation and user guides provided</li>
                  </ul>
              </div>
          </div>
          
          <div class="mt-6 p-4 bg-red-50 dark:bg-red-950 rounded-xl">
              <p class="text-sm text-red-800 dark:text-red-200">
                  <strong>SEO Disclaimer:</strong> We do not guarantee specific search engine rankings. SEO results depend on numerous factors including competition, algorithm changes, and market conditions.
              </p>
          </div>
      </section>

      <!-- Limitation of Liability -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Limitation of Liability</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Our liability is limited to the maximum extent permitted by U.S. law:
          </p>
          
          <div class="space-y-4">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Liability Cap</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Total liability limited to project value</li>
                      <li>• No liability for lost profits or revenue</li>
                      <li>• No liability for consequential damages</li>
                      <li>• No liability for third-party service failures</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Force Majeure</h3>
                  <p class="text-muted-foreground text-sm">
                      We are not liable for delays or failures caused by circumstances beyond our reasonable control, 
                      including natural disasters, war, terrorism, strikes, government actions, or internet infrastructure failures.
                  </p>
              </div>
          </div>
      </section>

      <!-- Termination -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Termination</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Either party may terminate the agreement under specific conditions:
          </p>
          
          <div class="space-y-4">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Client Termination</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• 7-day written notice required</li>
                      <li>• Deposit forfeited if work has begun</li>
                      <li>• Payment for work completed up to termination date</li>
                      <li>• Paid deliverables transferred upon final payment</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Our Termination Rights</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Non-payment or breach of terms</li>
                      <li>• Client provides false or misleading information</li>
                      <li>• Unreasonable delays or lack of cooperation</li>
                      <li>• Illegal or unethical project requirements</li>
                  </ul>
              </div>
          </div>
      </section>

      <!-- Governing Law -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Governing Law and Dispute Resolution</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Legal framework for resolving disputes:
          </p>
          
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <ul class="space-y-3 text-sm text-muted-foreground">
                  <li class="flex items-start gap-2">
                      <span class="text-primary mt-1">•</span>
                      <div><strong>Governing Law:</strong> These Terms are governed by U.S. federal law and applicable state laws</div>
                  </li>
                  <li class="flex items-start gap-2">
                      <span class="text-primary mt-1">•</span>
                      <div><strong>Dispute Resolution:</strong> Parties agree to first attempt good faith negotiation to resolve disputes</div>
                  </li>
                  <li class="flex items-start gap-2">
                      <span class="text-primary mt-1">•</span>
                      <div><strong>Legal Venue:</strong> Any legal proceedings shall be conducted in appropriate U.S. federal or state courts</div>
                  </li>
                  <li class="flex items-start gap-2">
                      <span class="text-primary mt-1">•</span>
                      <div><strong>Attorney's Fees:</strong> Prevailing party in legal disputes may be entitled to reasonable attorney's fees</div>
                  </li>
              </ul>
          </div>
      </section>

      <!-- Contact Information -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Contact Information</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              For questions about these Terms & Conditions or to discuss your project:
          </p>
          
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <div class="grid gap-4 md:grid-cols-2">
                  <div>
                      <h3 class="font-semibold mb-3">Business Contact</h3>
                      <div class="space-y-2 text-sm text-muted-foreground">
                          <p><strong>Business:</strong> Omar Fuentes</p>
                          <p><strong>Service Area:</strong> United States (Remote)</p>
                          <p><strong>Phone:</strong> +57 310 785 1074</p>
                          <p><strong>Email:</strong> <a href="mailto:contact@omarfuentes.com" class="text-primary hover:underline">contact@omarfuentes.com</a></p>
                      </div>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-3">Business Hours</h3>
                      <div class="space-y-2 text-sm text-muted-foreground">
                          <p><strong>Monday - Friday:</strong> 9:00 AM - 6:00 PM EST</p>
                          <p><strong>Saturday:</strong> 10:00 AM - 2:00 PM EST</p>
                          <p><strong>Sunday:</strong> Closed</p>
                          <p><strong>Emergency:</strong> Available for existing clients</p>
                      </div>
                  </div>
              </div>
          </div>
      </section>
  </Container>
</Layout>
