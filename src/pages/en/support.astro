---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, Shield, Clock, Mail, MessageCircle, Star, Zap, AlertTriangle, AlertCircle, Wrench, Crown, Phone, ArrowRight, Activity, Users, X } from 'lucide-react';
---

<Layout title="Website Support & Maintenance Services USA | Omar Fuentes" description="Professional website support and maintenance services for USA businesses. 24/7 technical support, 30-day guarantee, and affordable maintenance plans. Keep your website running perfectly." keywords="website support USA, web maintenance services USA, technical support USA, website warranty, 24/7 website support, web developer support USA, ecommerce maintenance USA, small business website support">
  <style>
    .support-text-gray-600 { color: #4b5563 !important; }
    .support-text-gray-700 { color: #374151 !important; }
    .support-text-white { color: #ffffff !important; }
  </style>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800 text-white pt-32">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full text-sm font-medium mb-6 backdrop-blur">
          <Activity className="w-3 h-3 text-white animate-pulse" />
          24/7 Professional Support
        </div>
        <h1 class="text-5xl font-bold mb-6 text-white">Website Support & Maintenance Services</h1>
        <p class="text-xl mb-8 opacity-90 max-w-3xl mx-auto text-white">
          Your peace of mind after project delivery. I provide comprehensive website support 
          and maintenance services for USA businesses, ensuring your online presence runs smoothly 24/7.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13125551234" class="inline-flex items-center justify-center rounded-full bg-white text-blue-600 px-8 py-4 font-semibold hover:bg-gray-100 transition-colors">
            <Phone className="w-5 h-5 mr-2" />
            Call Now: (312) 555-1234
          </a>
          <a href="mailto:contact@omarfuentes.com" class="inline-flex items-center justify-center rounded-full border-2 border-white text-white px-8 py-4 font-semibold hover:bg-white hover:text-blue-600 transition-colors">
            <Mail className="w-5 h-5 mr-2" />
            Email Support
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl font-bold text-blue-600 mb-2">500+</div>
          <div class="support-text-gray-600">Websites Supported</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-green-600 mb-2">99.9%</div>
          <div class="support-text-gray-600">Uptime Guaranteed</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-purple-600 mb-2">&lt;1hr</div>
          <div class="support-text-gray-600">Response Time</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-orange-600 mb-2">30</div>
          <div class="support-text-gray-600">Days Warranty</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Warranty Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div class="bg-gradient-to-r from-blue-50 to-indigo-100 rounded-3xl p-8 border border-blue-200">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center">
              <Shield className="w-6 h-6 text-white" />
            </div>
            <h2 class="text-3xl font-bold text-gray-800">Included Warranty (30 Days)</h2>
          </div>
          
          <h3 class="text-xl font-semibold mb-4 text-gray-700">What does the warranty cover?</h3>
          <p class="text-gray-600 mb-6">All my projects include 30 days warranty from final delivery date. During this period, I fix at no additional cost:</p>
          
          <div class="grid md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 transition-all group">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center group-hover:bg-red-200 transition-colors">
                  <AlertTriangle className="w-5 h-5 text-red-600" />
                </div>
                <h4 class="font-semibold text-gray-800">Functionality Errors</h4>
              </div>
              <ul class="space-y-2 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Programming bugs or errors</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Broken or non-functional links</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Contact form issues</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Elements not loading correctly</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Responsive design issues on specific devices</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Features not working as agreed</span>
                </li>
              </ul>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 transition-all group">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center group-hover:bg-blue-200 transition-colors">
                  <Zap className="w-5 h-5 text-blue-600" />
                </div>
                <h4 class="font-semibold text-gray-800">Performance & SEO</h4>
              </div>
              <ul class="space-y-2 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Loading speed issues not initially detected</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Technical SEO implementation errors</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Metadata or schema markup problems</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Basic accessibility corrections</span>
                </li>
              </ul>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 transition-all group">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center group-hover:bg-purple-200 transition-colors">
                  <Star className="w-5 h-5 text-purple-600" />
                </div>
                <h4 class="font-semibold text-gray-800">Minor Design Adjustments</h4>
              </div>
              <ul class="space-y-2 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Incorrect spacing or alignment fixes</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Color adjustments not matching agreement</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Text readability issues</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Overlapping visual elements</span>
                </li>
              </ul>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 transition-all group">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center group-hover:bg-green-200 transition-colors">
                  <Wrench className="w-5 h-5 text-green-600" />
                </div>
                <h4 class="font-semibold text-gray-800">Browser Compatibility</h4>
              </div>
              <ul class="space-y-2 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Modern browser compatibility issues</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Mobile device display problems</span>
                </li>
                <li class="flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                  <span>Browser update related errors</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Response Times -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="text-xl font-semibold mb-4 text-gray-800">Warranty Response Times</h3>
            <div class="grid md:grid-cols-3 gap-4">
              <div class="text-center p-4 rounded-lg bg-red-50 border border-red-200">
                <AlertCircle className="w-8 h-8 text-red-600 mx-auto mb-2" />
                <div class="font-semibold text-red-600">Critical Errors</div>
                <div class="text-sm text-gray-600">Site down, not working</div>
                <div class="text-lg font-bold text-red-600">12 hours</div>
              </div>
              <div class="text-center p-4 rounded-lg bg-yellow-50 border border-yellow-200">
                <AlertTriangle className="w-8 h-8 text-yellow-600 mx-auto mb-2" />
                <div class="font-semibold text-yellow-600">Major Issues</div>
                <div class="text-sm text-gray-600">Broken functionality</div>
                <div class="text-lg font-bold text-yellow-600">24 hours</div>
              </div>
              <div class="text-center p-4 rounded-lg bg-blue-50 border border-blue-200">
                <Wrench className="w-8 h-8 text-blue-600 mx-auto mb-2" />
                <div class="font-semibold text-blue-600">Minor Adjustments</div>
                <div class="text-sm text-gray-600">Small corrections</div>
                <div class="text-lg font-bold text-blue-600">48 hours</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's NOT Covered -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div class="bg-red-50 rounded-3xl p-8 border border-red-200">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center">
              <AlertTriangle className="w-6 h-6 text-red-600" />
            </div>
            <h2 class="text-2xl font-bold text-red-800">What's NOT Covered by Warranty</h2>
          </div>
          <p class="text-red-700 mb-6">It's important to be clear. The warranty does not include:</p>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="space-y-2">
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Content changes (texts, new images)</span>
              </div>
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">New features not originally planned</span>
              </div>
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Redesigns or visual style changes</span>
              </div>
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Modifications made by third parties</span>
              </div>
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Issues caused by client's hosting</span>
              </div>
            </div>
            <div class="space-y-2">
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Third-party plugin/theme updates</span>
              </div>
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Issues from external API changes</span>
              </div>
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Outdated browser incompatibility</span>
              </div>
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Original scope modifications</span>
              </div>
              <div class="flex items-start gap-2">
                <X className="w-4 h-4 text-red-500 mt-0.5 flex-shrink-0" />
                <span class="text-red-700">Damage from malware or hacking</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Support Channels -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-8 text-center text-gray-800">Support Channels</h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-8 border border-blue-200 hover:shadow-lg transition-all group">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center group-hover:bg-blue-200 transition-colors">
              <Mail className="w-6 h-6 text-blue-600" />
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2 text-gray-800">Email (Preferred)</h3>
              <p class="text-sm text-gray-600">For detailed technical issues</p>
            </div>
          </div>
          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <span class="text-blue-500">→</span>
              <a href="mailto:contact@omarfuentes.com" class="font-mono text-blue-600 hover:text-blue-700">contact@omarfuentes.com</a>
            </div>
            <div class="text-sm text-gray-600 space-y-1">
              <div class="flex items-start gap-2">
                <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                <span>Detailed problem description</span>
              </div>
              <div class="flex items-start gap-2">
                <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                <span>Screenshots if possible</span>
              </div>
              <div class="flex items-start gap-2">
                <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                <span>Browser, device, and OS details</span>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-2xl p-8 border border-green-200 hover:shadow-lg transition-all group">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center group-hover:bg-green-200 transition-colors">
              <MessageCircle className="w-6 h-6 text-green-600" />
            </div>
            <div>
              <h3 class="text-xl font-semibold mb-2 text-gray-800">Phone Support</h3>
              <p class="text-sm text-gray-600">For quick consultations</p>
            </div>
          </div>
          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <span class="text-green-500">→</span>
              <a href="tel:+13125551234" class="font-mono text-green-600 hover:text-green-700">(312) 555-1234</a>
            </div>
            <div class="text-sm text-gray-600 space-y-1">
              <div class="flex items-start gap-2">
                <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                <span>Ideal for simple questions</span>
              </div>
              <div class="flex items-start gap-2">
                <CheckCircle className="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" />
                <span>Business hours response</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Business Hours -->
      <div class="mt-8 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-full text-sm">
          <Clock className="w-4 h-4" />
          <span>Monday to Friday: 9:00 AM - 6:00 PM (EST)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Support Plans -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-8 text-center text-gray-800">Extended Support Plans</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">After the 30-day warranty period, I offer ongoing support options:</p>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Basic Plan -->
        <div class="bg-white rounded-2xl border border-gray-200 hover:border-blue-300 transition-all group">
          <div class="p-8">
            <div class="text-center mb-6">
              <div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-200 transition-colors">
                <Wrench className="w-8 h-8 text-blue-600" />
              </div>
              <h3 class="text-xl font-bold mb-2 text-gray-800">Basic Plan</h3>
              <p class="text-sm text-gray-600 mb-4">Per incident</p>
              <div class="text-3xl font-bold text-blue-600 mb-1">$25–$50</div>
              <p class="text-sm text-gray-600">USD per incident</p>
            </div>
            
            <div class="space-y-3 mb-6">
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Technical error fixes</span>
              </div>
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Minor content updates</span>
              </div>
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Technical consultations</span>
              </div>
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Response time: 24–48 hours</span>
              </div>
            </div>
            
            <div class="text-center">
              <a href="tel:+13125551234" class="inline-block w-full px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-semibold">
                Request Support
              </a>
            </div>
          </div>
        </div>

        <!-- Monthly Plan -->
        <div class="bg-gradient-to-b from-blue-50 to-blue-100 rounded-2xl border border-blue-300 hover:border-blue-400 transition-all group relative overflow-hidden">
          <div class="absolute top-4 right-4">
            <span class="px-3 py-1 bg-blue-600 text-white rounded-full text-xs font-semibold">POPULAR</span>
          </div>
          <div class="p-8">
            <div class="text-center mb-6">
              <div class="w-16 h-16 bg-blue-200 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-300 transition-colors">
                <Clock className="w-8 h-8 text-blue-700" />
              </div>
              <h3 class="text-xl font-bold mb-2 text-gray-800">Monthly Plan</h3>
              <p class="text-sm text-gray-600 mb-4">For regular support</p>
              <div class="text-3xl font-bold text-blue-700 mb-1">$99</div>
              <p class="text-sm text-gray-600">USD/month</p>
            </div>
            
            <div class="space-y-3 mb-6">
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Up to 4 hours monthly work</span>
              </div>
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Content updates</span>
              </div>
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Monthly site backup</span>
              </div>
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Basic monitoring</span>
              </div>
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Priority support (12–24 hours)</span>
              </div>
            </div>
            
            <div class="text-center">
              <a href="tel:+13125551234" class="inline-block w-full px-6 py-3 bg-blue-700 text-white rounded-lg hover:bg-blue-800 transition-colors font-semibold shadow-lg">
                Get Monthly Plan
              </a>
            </div>
          </div>
        </div>

        <!-- Premium Plan -->
        <div class="bg-gradient-to-b from-purple-50 to-purple-100 rounded-2xl border border-purple-300 hover:border-purple-400 transition-all group">
          <div class="p-8">
            <div class="text-center mb-6">
              <div class="w-16 h-16 bg-purple-200 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:bg-purple-300 transition-colors">
                <Crown className="w-8 h-8 text-purple-700" />
              </div>
              <h3 class="text-xl font-bold mb-2 text-gray-800">Premium Plan</h3>
              <p class="text-sm text-gray-600 mb-4">Complete proactive support</p>
              <div class="text-3xl font-bold text-purple-700 mb-1">$199</div>
              <p class="text-sm text-gray-600">USD/month</p>
            </div>
            
            <div class="space-y-3 mb-6">
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Up to 8 hours monthly work</span>
              </div>
              <div class="flex items-center gap-2">
                <CheckCircle className="w-4 h-4 text-green-600" />
                <span class="text-sm text-gray-700">Everything in Monthly Plan</span>
              </div>
