---
import Layout from '~/layouts-en/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

---

<Layout title="Cookies Policy - Omar Fuentes" description="Cookies Policy for Omar Fuentes website. Information about cookies and tracking technologies used in compliance with U.S. regulations.">
  
  <PageHeader 
      title="Cookies Policy"
      description="Last updated: January 28, 2026"
  />

  <Container as="main" class="max-w-4xl mx-auto">
      
      <!-- 1. What Are Cookies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">1. What Are Cookies</h2>
          <p class="text-muted-foreground leading-8 mb-6">
              Cookies are small text files that are stored on your device (computer, tablet, or mobile) when you visit a website.
              They help the website remember information about your visit, which can make it easier to visit the site again
              and make the site more useful to you.
          </p>
          <p class="text-muted-foreground leading-8">
              At <span class="font-semibold text-foreground">Omar Fuentes</span>, we use cookies to enhance your experience
              on our website and to analyze how our site is used.
          </p>
      </section>

      <!-- 2. How We Use Cookies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">2. How We Use Cookies</h2>
          <p class="text-muted-foreground leading-8 mb-4">We use cookies for the following purposes:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Essential Cookies:</span> Required for the website to function properly</li>
              <li><span class="font-semibold text-foreground">Performance Cookies:</span> Help us understand how visitors interact with our site</li>
              <li><span class="font-semibold text-foreground">Functional Cookies:</span> Remember your preferences and settings</li>
              <li><span class="font-semibold text-foreground">Marketing Cookies:</span> Used to deliver relevant advertisements</li>
              <li><span class="font-semibold text-foreground">Analytics Cookies:</span> Help us analyze website traffic and usage</li>
          </ul>
      </section>

      <!-- 3. Types of Cookies We Use -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">3. Types of Cookies We Use</h2>
          
          <h3 class="text-xl font-semibold mb-4">3.1 Essential Cookies</h3>
          <p class="text-muted-foreground leading-8 mb-4">These cookies are necessary for the website to function and cannot be switched off:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Session management</li>
              <li>Security tokens</li>
              <li>Load balancing</li>
              <li>Basic site functionality</li>
          </ul>

          <h3 class="text-xl font-semibold mb-4 mt-8">3.2 Performance Cookies</h3>
          <p class="text-muted-foreground leading-8 mb-4">These cookies help us understand how our website is performing:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Page load times</li>
              <li>Error reporting</li>
              <li>Response times</li>
              <li>Site performance metrics</li>
          </ul>

          <h3 class="text-xl font-semibold mb-4 mt-8">3.3 Analytics Cookies</h3>
          <p class="text-muted-foreground leading-8 mb-4">These cookies help us analyze website traffic and usage:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Google Analytics</li>
              <li>Visitor behavior tracking</li>
              <li>Popular pages identification</li>
              <li>Traffic sources analysis</li>
          </ul>

          <h3 class="text-xl font-semibold mb-4 mt-8">3.4 Marketing Cookies</h3>
          <p class="text-muted-foreground leading-8 mb-4">These cookies are used for marketing purposes:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Ad personalization</li>
              <li>Campaign tracking</li>
              <li>Conversion tracking</li>
              <li>Remarketing</li>
          </ul>
      </section>

      <!-- 4. Third-Party Cookies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">4. Third-Party Cookies</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We use third-party services that may place cookies on your device:
          </p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <div class="space-y-4">
                  <div>
                      <h4 class="font-semibold text-foreground mb-2">Google Analytics</h4>
                      <p class="text-sm text-muted-foreground">Used for website analytics and user behavior tracking</p>
                  </div>
                  <div>
                      <h4 class="font-semibold text-foreground mb-2">Google Ads</h4>
                      <p class="text-sm text-muted-foreground">Used for advertising and conversion tracking</p>
                  </div>
                  <div>
                      <h4 class="font-semibold text-foreground mb-2">Meta (Facebook/Instagram)</h4>
                      <p class="text-sm text-muted-foreground">Used for social media marketing and analytics</p>
                  </div>
                  <div>
                      <h4 class="font-semibold text-foreground mb-2">LinkedIn</h4>
                      <p class="text-sm text-muted-foreground">Used for professional networking and marketing</p>
                  </div>
              </div>
          </div>
      </section>

      <!-- 5. Managing Cookies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">5. Managing Cookies</h2>
          <p class="text-muted-foreground leading-8 mb-4">You can control and manage cookies in several ways:</p>
          
          <h3 class="text-xl font-semibold mb-4">5.1 Browser Settings</h3>
          <p class="text-muted-foreground leading-8 mb-4">Most browsers allow you to:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>View what cookies are stored</li>
              <li>Delete existing cookies</li>
              <li>Block third-party cookies</li>
              <li>Block cookies from specific sites</li>
              <li>Disable all cookies</li>
          </ul>

          <h3 class="text-xl font-semibold mb-4 mt-8">5.2 Cookie Consent Banner</h3>
          <p class="text-muted-foreground leading-8 mb-4">
              Our website uses a cookie consent banner that allows you to:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Accept all cookies</li>
              <li>Accept only essential cookies</li>
              <li>Customize your cookie preferences</li>
              <li>Withdraw consent at any time</li>
          </ul>
      </section>

      <!-- 6. Cookie Duration -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">6. Cookie Duration</h2>
          <p class="text-muted-foreground leading-8 mb-4">Different cookies have different lifespans:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Session Cookies:</span> Deleted when you close your browser</li>
              <li><span class="font-semibold text-foreground">Persistent Cookies:</span> Remain on your device for a set period</li>
              <li><span class="font-semibold text-foreground">Analytics Cookies:</span> Typically 2 years</li>
              <li><span class="font-semibold text-foreground">Marketing Cookies:</span> Typically 30 days to 1 year</li>
          </ul>
      </section>

      <!-- 7. Your Rights (CCPA Compliance) -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">7. Your Rights (CCPA Compliance)</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Under the California Consumer Privacy Act (CCPA), you have the right to:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Know what personal information is collected</li>
              <li>Delete personal information collected through cookies</li>
              <li>Opt-out of the sale of personal information</li>
              <li>Non-discrimination for exercising privacy rights</li>
          </ul>
          <p class="text-muted-foreground leading-8">
              To exercise these rights, please contact us at <a href="mailto:contact@omarfuentes.com" class="text-primary hover:underline">contact@omarfuentes.com</a>
          </p>
      </section>

      <!-- 8. International Data Transfers -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">8. International Data Transfers</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Some cookies may transfer data to countries outside the United States:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Google services may process data in various countries</li>
              <li>Social media platforms may transfer data internationally</li>
              <li>We ensure appropriate safeguards are in place</li>
              <li>All transfers comply with applicable privacy laws</li>
          </ul>
      </section>

      <!-- 9. Do Not Track -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">9. Do Not Track</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Our website currently does not respond to Do Not Track (DNT) signals. However, you can:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Use browser settings to block tracking cookies</li>
              <li>Opt out of advertising through industry programs</li>
              <li>Contact us directly to opt out of tracking</li>
          </ul>
      </section>

      <!-- 10. Updates to This Policy -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">10. Updates to This Policy</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We may update this Cookies Policy from time to time to reflect changes in:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>The cookies we use</li>
              <li>How we use cookies</li>
              <li>Legal requirements</li>
              <li>Industry best practices</li>
          </ul>
          <p class="text-muted-foreground leading-8">
              The "Last updated" date at the top of this page indicates when this policy was last modified.
          </p>
      </section>

      <!-- 11. Contact Information -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">11. Contact Information</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              If you have questions about our use of cookies or this policy, please contact us:
          </p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <div class="grid gap-2 text-muted-foreground">
                  <p>
                      <span class="font-semibold text-foreground">Business:</span> Omar Fuentes
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Service Area:</span> United States
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Phone:</span> +57 310 785 1074
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Email:</span> <a href="mailto:contact@omarfuentes.com" class="text-primary hover:underline">contact@omarfuentes.com</a>
                  </p>
              </div>
          </div>
      </section>
  </Container>
</Layout>
