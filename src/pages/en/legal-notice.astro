---
import Layout from '~/layouts-en/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

---

<Layout title="Legal Notice - Omar Fuentes" description="Legal Notice and company information for Omar Fuentes web design and SEO services in the United States.">
  
  <PageHeader 
      title="Legal Notice"
      description="Company information and legal details"
  />

  <Container as="main" class="max-w-4xl mx-auto">
      
      <!-- Company Information -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Company Information</h2>
          <p class="text-muted-foreground leading-8 mb-6">
              This legal notice provides information about <span class="font-semibold text-foreground">Omar Fuentes</span>,
              a web design, development, and SEO service provider operating in the United States.
          </p>

          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <dl class="grid gap-4 text-muted-foreground">
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Business Name</dt>
                      <dd>Omar Fuentes</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Business Type</dt>
                      <dd>Web Design, Development & SEO Services</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Service Area</dt>
                      <dd>United States (Remote Services)</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Contact Phone</dt>
                      <dd>+57 310 785 1074</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Email</dt>
                      <dd>contact@omarfuentes.com</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Website</dt>
                      <dd>www.omarfuentes.com</dd>
                  </div>
              </dl>
          </div>
      </section>

      <!-- Services Provided -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Services Provided</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Omar Fuentes provides professional web design, development, and SEO services to businesses across the United States.
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Custom Website Design and Development</li>
              <li>Search Engine Optimization (SEO)</li>
              <li>WordPress Development and Customization</li>
              <li>E-commerce Website Solutions</li>
              <li>Local SEO Services for Small Businesses</li>
              <li>Website Maintenance and Support</li>
              <li>Responsive Web Design</li>
              <li>Website Performance Optimization</li>
          </ul>
      </section>

      <!-- Service Area -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Service Area</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We provide services to clients throughout the United States, including but not limited to:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Houston, Texas</li>
              <li>Los Angeles, California</li>
              <li>Miami, Florida</li>
              <li>New York City, New York</li>
              <li>Chicago, Illinois</li>
              <li>San Antonio, Texas</li>
              <li>Orange County, California</li>
              <li>Salt Lake City, Utah</li>
              <li>Washington, D.C.</li>
              <li>Long Island, New York</li>
              <li>All other U.S. states (remote services)</li>
          </ul>
      </section>

      <!-- Business Hours -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Business Hours</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Our standard business hours are:
          </p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <div class="grid gap-2 text-muted-foreground">
                  <p><span class="font-semibold text-foreground">Monday - Friday:</span> 9:00 AM - 6:00 PM EST</p>
                  <p><span class="font-semibold text-foreground">Saturday:</span> 10:00 AM - 2:00 PM EST</p>
                  <p><span class="font-semibold text-foreground">Sunday:</span> Closed</p>
                  <p><span class="font-semibold text-foreground">Emergency Support:</span> Available for existing clients</p>
              </div>
          </div>
      </section>

      <!-- Payment Methods -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Payment Methods</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We accept the following payment methods:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Bank Transfer (ACH)</li>
              <li>PayPal</li>
              <li>Credit/Debit Cards (via PayPal)</li>
              <li>Zelle</li>
              <li>Wire Transfer</li>
          </ul>
      </section>

      <!-- Tax Information -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Tax Information</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Important tax information for U.S. clients:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>All services are subject to applicable U.S. taxes</li>
              <li>International service provider - tax compliance per U.S. regulations</li>
              <li>Clients may receive 1099 forms for services rendered</li>
              <li>Tax documentation available upon request</li>
          </ul>
      </section>

      <!-- Disclaimers -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Disclaimers</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Important disclaimers regarding our services:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">SEO Results:</span> Search engine rankings cannot be guaranteed</li>
              <li><span class="font-semibold text-foreground">Timeline Estimates:</span> Project timelines are estimates and may vary</li>
              <li><span class="font-semibold text-foreground">Third-Party Services:</span> Not responsible for hosting, domain, or third-party service issues</li>
              <li><span class="font-semibold text-foreground">Content Responsibility:</span> Clients are responsible for content accuracy and legality</li>
          </ul>
      </section>

      <!-- Intellectual Property -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Intellectual Property</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Intellectual property information:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Website design and content © 2026 Omar Fuentes</li>
              <li>All rights reserved</li>
              <li>Custom code becomes client property upon full payment</li>
              <li>We retain rights to proprietary tools and methodologies</li>
          </ul>
      </section>

      <!-- Complaints Procedure -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Complaints Procedure</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              If you have any complaints about our services:
          </p>
          <ol class="grid gap-2 pl-6 text-muted-foreground list-decimal">
              <li>Contact us directly at contact@omarfuentes.com</li>
              <li>We will acknowledge your complaint within 24 hours</li>
              <li>We will investigate and respond within 5 business days</li>
              <li>If unresolved, we will propose alternative solutions</li>
          </ol>
      </section>

      <!-- Legal Compliance -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Legal Compliance</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We comply with applicable U.S. laws and regulations:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>California Consumer Privacy Act (CCPA)</li>
              <li>General Data Protection Regulation (GDPR) for EU clients</li>
              <li>Children's Online Privacy Protection Act (COPPA)</li>
              <li>Americans with Disabilities Act (ADA) compliance</li>
              <li>Federal Trade Commission (FTC) guidelines</li>
          </ul>
      </section>

      <!-- Contact -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Contact</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              For legal inquiries or questions about this notice, please contact:
          </p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <div class="grid gap-2 text-muted-foreground">
                  <p>
                      <span class="font-semibold text-foreground">Business:</span> Omar Fuentes
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Service Area:</span> United States
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Phone:</span> +57 310 785 1074
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Email:</span> contact@omarfuentes.com
                  </p>
              </div>
          </div>
      </section>
  </Container>
</Layout>
