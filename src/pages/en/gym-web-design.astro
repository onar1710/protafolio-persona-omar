---
import Layout from '../../layouts/LayoutEN.astro';

const services = [
  { title: 'A Site That Looks as Serious as Your Gym', description: 'Custom design that matches your brand — whether you run a hardcore CrossFit box, a boutique studio, or a full-service fitness center. Not a generic fitness template everyone\'s seen before.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-teal-500 to-teal-600' },
  { title: 'Show Up When People Search for a Gym Near Them', description: '"Gym near me." "CrossFit gym in [your city]." "Personal training in [your neighborhood]." I optimize your site so those searches lead to you, not your competitor.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', bgClass: 'from-green-500 to-green-600' },
  { title: 'Class Schedules and Memberships Front and Center', description: 'Your hours, your classes, your pricing — easy to find, easy to read, easy to act on. No one should have to hunt for how to sign up.', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z', bgClass: 'from-teal-500 to-teal-600' },
  { title: 'A Site That Looks Good on Every Phone', description: 'Most people search for gyms on their phone. If your site is a mess on mobile, you\'re losing them before they even read a word.', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 2.493A1 1 0 008.618 7h6.764a1 1 0 01.948-.684L17.28 3a2 2 0 012 2h3.28a1 1 0 01.948.684l1.498 2.493A1 1 0 0018.618 7h-6.764a1 1 0 01-.948-.684L9.72 3.684A1 1 0 008.772 3H6a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7', bgClass: 'from-green-500 to-green-600' },
];

const whyChooseMe = [
  'Done in 2–3 weeks, not months',
  'You own everything — no monthly ransom fees',
  'Built for local Google search from day one',
  'Custom design, not a template your competitor already has',
  'I respond when you message me',
  'No confusing contracts or hidden costs',
];

const includes = [
  'Custom design built around your gym\'s brand and personality',
  'Works perfectly on phones and tablets',
  'Pages for each membership type or program you offer',
  'Class schedule integration',
  'Contact and signup forms',
  'Google Maps so people can find you',
  'SSL certificate',
  'Local SEO setup so you rank in your city',
  'Photo gallery of your space and classes',
  'One month of free fixes after launch',
];

const steps = [
  { step: '1', title: 'We Talk', description: 'Quick call. I learn about your gym, your members, your goals. You figure out if I\'m the right fit.' },
  { step: '2', title: 'I Send You a Price', description: 'One number. No "starting at" games. You know exactly what you\'re paying before we touch anything.' },
  { step: '3', title: 'I Build Your Site', description: 'You see it as it comes together. Something doesn\'t feel right? I change it.' },
  { step: '4', title: 'We Launch', description: 'I handle everything technical. I show you how to update things yourself if you want to.' },
  { step: '5', title: 'I Stick Around', description: 'Need to update your schedule, add a new class, change your pricing? I\'m here.' },
];

const testimonials = [
  { name: 'Carlos Mendez', role: 'CrossFit Gym Owner', text: 'We were getting maybe two or three new member inquiries a month online. Now we\'re getting twelve, fifteen. The site paid for itself in the first two months.' },
  { name: 'Jasmine Obi', role: 'Boutique Fitness Studio', text: 'I\'d been using the same website for four years. I knew it was hurting us but kept putting it off. Easiest process I\'ve been through — and the results speak for themselves.' },
  { name: 'Tom Reyes', role: 'Personal Training Gym', text: 'Every other designer wanted to sell me a template. This was actually built for my gym. My members have commented on it. New people mention it when they walk in.' },
];

const faqs = [
  { question: 'What\'s this going to cost me?', answer: 'Depends on what your gym needs. I\'ll give you a clear, exact number upfront — no surprises and no hidden fees after the fact.' },
  { question: 'How fast can you get this done?', answer: '2–3 weeks for most gym websites. If you need it faster, tell me and we\'ll make it work.' },
  { question: 'Will my gym show up on Google?', answer: 'That\'s built into everything I do. Every site I build is optimized so people searching for a gym in your area can actually find you.' },
  { question: 'Can I add my own class schedule?', answer: 'Yes. I\'ll set it up so you can update it yourself without needing to call me every time something changes.' },
  { question: 'What if I already have a website?', answer: 'I can redesign what you have or build something new from scratch. Either way works.' },
  { question: 'Do I have to sign a long contract?', answer: 'No. You pay for the website, it\'s yours. No monthly fees unless you want ongoing support.' },
];
---

<Layout
  title="Gym Web Design That Turns Website Visitors Into Paying Members | Omar Fuentes"
  description="You built your gym to change lives. But if your website looks like it was made in 2015, you're losing signups to the place down the street — and you don't even know it."
  keywords="gym web design, fitness website, gym website, class schedule website, local SEO gym"
>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center pb-16 md:pb-24 lg:pb-32 bg-gradient-to-br from-teal-900 via-green-800 to-teal-900 relative overflow-hidden pt-8">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-slide-in">
          <div class="flex items-center space-x-2 mb-6">
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-white/10 text-white border border-white/20">Small Business</span>
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-teal-500/20 text-teal-300 border border-teal-500/30">Gyms</span>
          </div>

          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight text-white">
            Gym <br />
            <span class="bg-gradient-to-r from-teal-400 to-green-400 bg-clip-text text-transparent">Web Design</span>
          </h1>

          <p class="text-xl text-white/90 mb-8 max-w-lg">
            You built your gym to change lives. But if your website looks like it was made in 2015, you're losing signups to the place down the street — and you don't even know it.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://wa.me/12025551234?text=Hi%20Omar,%20I%20want%20a%20free%20gym%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 hover:shadow-xl bg-gradient-to-r from-teal-500 to-teal-600 text-white hover:shadow-xl">
              Let's Talk About Your Gym's Website
            </a>
            <a href="/en/portfolio/projects/" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 border-2 border-white/30 text-white hover:bg-white/10">
              See Examples
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-4 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="text-yellow-400">★★★★★</span>
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">+230% More Signups</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">2-3 Week Delivery</span>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-teal-500 to-green-500 rounded-3xl opacity-20 animate-float"></div>
          <div class="relative bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
            <p class="text-white/70 text-sm mb-4">Trusted by 50+ Fitness Businesses</p>
            <p class="text-white text-2xl font-bold mb-2">Free consultation • No obligation • Results guaranteed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">People Judge Your Gym By Your Website Before They Ever Walk In</h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-6 text-center">
        <p class="text-xl text-gray-700 leading-relaxed">
          Someone's looking for a gym in your area. They Google it. They land on your site. In about eight seconds they've already decided if you're worth their time or not.
        </p>
        <p class="text-xl text-gray-700 leading-relaxed">
          If your site is slow, hard to navigate, or doesn't show your space, your classes, and your vibe — they click back and sign up somewhere else.
        </p>
        <p class="text-2xl text-teal-600 font-bold">
          I build websites for gym owners and fitness studios that make people want to walk through your door.
        </p>
      </div>
    </div>
  </section>

  <!-- What You Get Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">A Website That Works as Hard as Your Members Do</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {services.map((service) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
            <div class={`w-12 h-12 mb-4 bg-gradient-to-br ${service.bgClass} rounded-lg flex items-center justify-center`}>
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{service.title}</h3>
            <p class="text-gray-600">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Me Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Why Work With Me Instead of a Generic Web Agency</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto mb-8">
          Generic agencies build generic websites. They'll hand you something that could belong to any gym in any city, slap your logo on it, and call it done.
        </p>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          I focus on gyms and fitness businesses. I know how people decide where to train, what makes them trust a gym before they visit, and what gets them to actually fill out that contact form.
        </p>
      </div>

      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4">
        {whyChooseMe.map((item) => (
          <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-xl">
            <svg class="w-6 h-6 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="font-semibold">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">What's Included</h2>
      </div>

      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4">
        {includes.map((item) => (
          <div class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-md">
            <svg class="w-6 h-6 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="font-semibold">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">How This Works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 max-w-6xl mx-auto">
        {steps.map((step) => (
          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-4 bg-gradient-to-br from-teal-500 to-teal-600 rounded-full flex items-center justify-center">
              <span class="text-xl font-bold text-white">{step.step}</span>
            </div>
            <h3 class="text-base font-bold mb-2">{step.title}</h3>
            <p class="text-gray-600 text-xs">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Real Feedback</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((testimonial) => (
          <div class="card">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class="w-4 h-4 fill-teal-400 text-teal-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
            </div>
            <p class="text-gray-600 mb-4 italic">"{testimonial.text}"</p>
            <div class="font-semibold">{testimonial.name}</div>
            <div class="text-sm text-gray-500">{testimonial.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Questions</h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
            <h3 class="text-lg font-bold mb-2">{faq.question}</h3>
            <p class="text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-teal-900 via-green-800 to-teal-900">
    <div class="container text-center">
      <h2 class="text-section mb-4 text-white">Your Competitors Are Signing Up Members You Should Be Getting</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Let's fix your website situation. Quick call, no pressure, honest advice.
      </p>
      <a href="https://wa.me/12025551234?text=Hi%20Omar,%20I%20want%20a%20free%20gym%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 bg-white text-teal-900 hover:shadow-xl">
        Book a Call
      </a>
      <div class="mt-8 text-white/70 text-sm">
        Building websites for gym owners since 2020 • 50+ fitness businesses now converting more visitors into members • Working remotely with clients across the US and Latin America
      </div>
    </div>
  </section>
</Layout>
