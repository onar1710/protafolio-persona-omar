        <div class="flex items-start gap-4">
          <CheckCircle className="w-6 h-6 text-teal-500 flex-shrink-0 mt-1" />
          <p class="text-gray-900 font-medium">Contact and signup forms</p>
        </div>
        <div class="flex items-start gap-4">
          <CheckCircle className="w-6 h-6 text-teal-500 flex-shrink-0 mt-1" />
