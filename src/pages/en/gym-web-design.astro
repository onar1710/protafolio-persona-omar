              <Star className="w-5 h-5 fill-teal-500" />
              <Star className="w-5 h-5 fill-teal-500" />
              <Star className="w-5 h-5 fill-teal-500" />
            </div>
          </div>
          <p class="text-gray-700 mb-6 italic">"I'd been using the same website for four years. I knew it was hurting us but kept putting it off. Easiest process I've been through — and the results speak for themselves."</p>
          <div class="flex items-center">
            <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-green-600 rounded-full flex items-center justify-center text-white font-bold mr-4">
              JO
            </div>
            <div>
              <p class="font-bold text-gray-900">Jasmine Obi</p>
              <p class="text-gray-600 text-sm">Boutique Fitness Studio</p>
