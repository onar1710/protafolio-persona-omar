---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, ArrowRight, Star, Clock, Award, Phone, MapPin, Target, Shield, Zap, Globe, TrendingUp, Calendar, Users, Briefcase, Home, Dumbbell, Activity, CreditCard } from 'lucide-react';
---

<Layout title="Gym Web Design That Turns Website Visitors Into Paying Members | Omar Fuentes" description="Professional gym web design services. Get more signups and members with fitness websites that showcase your gym and rank higher in local searches.">
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-teal-900 via-green-800 to-teal-900 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    
    <!-- Decorative circles -->
    <div class="absolute top-20 right-20 w-72 h-72 bg-teal-500 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-20 left-20 w-96 h-96 bg-green-500 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6 py-24">
      <div class="text-center">
        <!-- Badge -->
        <div class="inline-flex items-center bg-white/10 backdrop-blur-md rounded-full px-6 py-3 mb-8 border border-white/20">
          <Dumbbell className="w-5 h-5 mr-2 text-teal-400" />
          <span class="text-white text-sm font-semibold">Trusted by 50+ Fitness Businesses</span>
        </div>
        
        <h1 class="text-6xl md:text-7xl font-bold mb-8 text-white leading-tight">
          Gym Web Design That Turns Website Visitors Into Paying Members
        </h1>
        
        <!-- Value Proposition -->
        <div class="max-w-3xl mx-auto mb-12">
          <p class="text-xl text-white/90 mb-8 leading-relaxed">You built your gym to change lives. But if your website looks like it was made in 2015, you're losing signups to the place down the street — and you don't even know it.</p>
          
          <!-- Social Proof -->
          <div class="flex flex-wrap items-center justify-center gap-8 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Star className="w-5 h-5 text-teal-400 fill-teal-400" />
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <TrendingUp className="w-5 h-5 text-teal-400" />
              <span class="font-semibold">+230% More Signups</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Zap className="w-5 h-5 text-teal-400" />
              <span class="font-semibold">2-3 Week Delivery</span>
            </div>
          </div>
        </div>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
          <a href="mailto:contact@omarfuentes.com" class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-teal-500 to-teal-600 text-white px-10 py-5 font-semibold hover:from-teal-600 hover:to-teal-700 transition-all transform hover:scale-105 shadow-2xl text-lg">
            Let's Talk About Your Gym's Website
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
          <a href="/en/portfolio" class="inline-flex items-center justify-center rounded-full border-2 border-white/30 text-white px-10 py-5 font-semibold hover:bg-white/10 transition-all text-lg backdrop-blur-sm">
            See Examples
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
        </div>
        
        <!-- Trust indicators -->
        <div class="text-white/70 text-sm flex items-center justify-center gap-2">
          <CheckCircle className="w-4 h-4" />
          <span>Free consultation • No obligation • Results guaranteed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-8 text-gray-900 leading-tight">
          People Judge Your Gym By Your Website Before They Ever Walk In
        </h2>
        <p class="text-xl text-gray-700 mb-12 leading-relaxed">
          Someone's looking for a gym in your area. They Google it. They land on your site. In about eight seconds they've already decided if you're worth their time or not.
        </p>
        <p class="text-xl text-gray-700 mb-12 leading-relaxed">
          If your site is slow, hard to navigate, or doesn't show your space, your classes, and your vibe — they click back and sign up somewhere else.
        </p>
        <p class="text-2xl text-teal-600 font-bold mb-12">
          I build websites for gym owners and fitness studios that make people want to walk through your door.
        </p>
      </div>
    </div>
  </section>

  <!-- What You Get Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-8 text-gray-900">
          A Website That Works as Hard as Your Members Do
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Feature 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-16 h-16 bg-gradient-to-br from-teal-500 to-teal-600 rounded-2xl flex items-center justify-center mb-6">
            <Activity className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">A Site That Looks as Serious as Your Gym</h3>
          <p class="text-gray-700 leading-relaxed">Custom design that matches your brand — whether you run a hardcore CrossFit box, a boutique studio, or a full-service fitness center. Not a generic fitness template everyone's seen before.</p>
        </div>
        
        <!-- Feature 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-16 h-16 bg-gradient-to-br from-green-500 to-green-600 rounded-2xl flex items-center justify-center mb-6">
            <Target className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Show Up When People Search for a Gym Near Them</h3>
          <p class="text-gray-700 leading-relaxed">"Gym near me." "CrossFit gym in [your city]." "Personal training in [your neighborhood]." I optimize your site so those searches lead to you, not your competitor.</p>
