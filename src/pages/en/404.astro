---
import LayoutEN from '../../layouts/LayoutEN.astro';
---

<LayoutEN title="Page not found (404) | Omar Fuentes" description="The page you’re looking for doesn’t exist or was moved. Go back to the homepage to continue browsing.">
	<Fragment slot="head">
		<meta name="robots" content="noindex, nofollow" />
	</Fragment>
	<main class="pt-48 pb-24" style="background: var(--white);">
		<div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
			<section class="py-10 md:py-14">
				<div class="max-w-3xl">
					<p class="text-sm font-black mb-3" style="color: var(--primary-blue);">Error 404</p>
					<h1 class="text-4xl md:text-6xl font-black mb-4 text-black">Page not found</h1>
					<p class="text-lg md:text-xl text-black mb-8">
						The link may be incorrect, or the page might have a new URL.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href="/en/" class="btn-primary" style="text-decoration: none;">Go to Home</a>
						<a href="/en/portfolio/projects/" class="btn-secondary" style="text-decoration: none;">View Projects</a>
					</div>
				</div>
			</section>
		</div>
	</main>
</LayoutEN>
