---
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/LayoutEN.astro';

type BlogEntry = CollectionEntry<'blog'>;

const allEnPosts = (await getCollection('blog'))
  .filter((post: BlogEntry) => post.id.startsWith('en/'))
  .filter((post: BlogEntry) => !post.data?.draft)
  .sort((a: BlogEntry, b: BlogEntry) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Agrupar artículos por etiqueta y tomar el más reciente de cada una
const postsByTag = new Map();
allEnPosts.forEach((post) => {
  if (post.data.tags && post.data.tags.length > 0) {
    const mainTag = post.data.tags[0]; // Primera etiqueta del artículo
    if (!postsByTag.has(mainTag)) {
      postsByTag.set(mainTag, post);
    }
  }
});

// Convertir a array y limitar a 6 artículos únicos por etiqueta
const enPosts = Array.from(postsByTag.values()).slice(0, 6);

const postUrl = (id: string) => `/en/blog/${id.slice('en/'.length)}/`;

const howItWorks = [
  { step: '1', title: 'Contact & Free Consultation', description: 'Tell us about your business, goals, and what you need. We\'ll guide you and recommend the best solution.' },
  { step: '2', title: 'Design & Development', description: 'We create your website with a modern design, optimized for performance, SEO, and conversions.' },
  { step: '3', title: 'Review & Launch', description: 'You review the site, request changes if needed, and once approved, we launch your website.' },
];

const whatToExpect = [
  { title: 'Project Timeline', description: 'Most websites are completed in 3 to 7 days, depending on your needs and revisions.' },
  { title: 'Communication', description: 'We stay in contact throughout the process via chat or email to ensure everything meets your expectations.' },
  { title: 'Secure Payment', description: 'We accept secure payments via PayPal, so your investment is protected at all times.' },
  { title: 'Revisions Included', description: 'We include revisions to make sure your website looks and works exactly how you want.' },
];

const industries = [
  { name: 'Restaurants', description: 'Online menus, reservations, delivery systems', href: '/en/restaurant-web-design/', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', bgClass: 'from-orange-500 to-orange-600' },
  { name: 'Hair Salons', description: 'Online bookings, gallery, appointments', href: '/en/hair-salon-web-design/', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', bgClass: 'from-purple-500 to-purple-600' },
  { name: 'Cleaning Services', description: 'Service scheduling, quotes, testimonials', href: '/en/cleaning-web-design/', icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16', bgClass: 'from-blue-500 to-blue-600' },
  { name: 'Construction', description: 'Project galleries, service areas, quotes', href: '/en/construction-web-design/', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', bgClass: 'from-yellow-500 to-yellow-600' },
  { name: 'Lawyers', description: 'Case studies, consultations, attorney profiles', href: '/en/lawyer-web-design/', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', bgClass: 'from-indigo-500 to-indigo-600' },
  { name: 'Real Estate', description: 'Property listings, virtual tours, agent profiles', href: '/en/real-estate-web-design/', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', bgClass: 'from-green-500 to-green-600' },
  { name: 'Electricians', description: 'Service requests, emergency calls, work areas', href: '/en/electrician-web-design/', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-red-500 to-red-600' },
  { name: 'Photographers', description: 'Portfolio galleries, booking systems, pricing', href: '/en/photographer-web-design/', icon: 'M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z', bgClass: 'from-pink-500 to-pink-600' },
  { name: 'Gyms', description: 'Class schedules, memberships, sign-ups', href: '/en/gym-web-design/', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', bgClass: 'from-teal-500 to-teal-600' },
];

const benefits = [
  { title: 'Affordable web design services tailored for small businesses', description: 'Get a professional website without overpaying, designed to fit your budget and business goals.', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1', color: 'blue' },
  { title: 'Responsive web design that works on all devices', description: 'Your website will look and perform perfectly on mobile, tablet, and desktop.', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', color: 'green' },
  { title: 'Reliable web design focused on performance', description: 'Fast-loading, secure, and stable websites that your customers can trust.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', color: 'purple' },
  { title: 'Complete web design and management solutions', description: 'From design to maintenance, everything is handled so you can focus on your business.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', color: 'orange' },
  { title: 'Comprehensive web design built for growth', description: 'A scalable website structure that grows with your business and supports long-term success.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', color: 'red' },
  { title: 'SEO-friendly web design that helps you rank on Google', description: 'Built with a solid structure and best practices to improve your visibility and attract organic traffic from search engines.', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', color: 'teal' },
];

const whatYouGet = [
  { title: 'A system that generates leads', description: 'Your website will be designed to capture visitor information and turn them into potential customers.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'A professional online presence', description: 'Modern design that builds trust and credibility with your potential customers.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', bgClass: 'from-indigo-500 to-indigo-600' },
  { title: 'Better visibility on Google', description: 'SEO-optimized structure that helps your website rank higher in search results.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'A website designed to grow with your business', description: 'Scalable solution that can expand as your business needs evolve.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', bgClass: 'from-indigo-500 to-indigo-600' },
];

const technologies = [
  { name: 'Next.js', label: 'JS', color: 'blue', icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5', bgClass: 'from-blue-500 to-blue-600' },
  { name: 'Astro.js', label: 'A', color: 'purple', icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5', bgClass: 'from-purple-500 to-purple-600' },
  { name: 'Bootstrap', label: 'B', color: 'indigo', icon: 'M4 6h16v12H4z', bgClass: 'from-indigo-500 to-indigo-600' },
  { name: 'HTML5', label: '5', color: 'orange', icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5', bgClass: 'from-orange-500 to-orange-600' },
  { name: 'WordPress', label: 'W', color: 'blue', icon: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z', bgClass: 'from-blue-600 to-blue-700' },
  { name: 'eCommerce', label: 'E', color: 'green', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', bgClass: 'from-green-500 to-green-600' },
  { name: 'Shopify', label: 'S', color: 'emerald', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', bgClass: 'from-emerald-500 to-emerald-600' },
  { name: 'Colorful Design', label: 'CD', color: 'pink', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', bgClass: 'from-pink-500 to-pink-600' },
];

const whyWorkWithMe = [
  { title: 'You work directly with me — no middlemen or delays', description: 'Direct communication means faster decisions and better results for your project.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2a3 3 0 00-5.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v2a3 3 0 005.356 1.857m0 0a3 3 0 005.356 1.857m0 0a3 3 0 005.356 1.857M7 20h10', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Faster delivery compared to traditional agencies', description: 'No bureaucracy means your website gets done in days, not months.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', bgClass: 'from-indigo-500 to-indigo-600' },
  { title: 'Focused on results, not just design', description: 'Every decision is made to help you get more customers and grow your business.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Clear and direct communication', description: 'No corporate jargon or confusing processes — just straight talk about your needs.', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 2.493A1 1 0 008.618 7h6.764a1 1 0 01.948-.684L17.28 3a2 2 0 012 2h3.28a1 1 0 01.948.684l1.498 2.493A1 1 0 0018.618 7h-6.764a1 1 0 01-.948-.684L9.72 3.684A1 1 0 008.772 3H6a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7', bgClass: 'from-indigo-500 to-indigo-600' },
  { title: 'Built specifically for small businesses', description: 'I understand small business challenges and build solutions that work for your budget and goals.', icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0V6a2 2 0 00-2-2h-4a2 2 0 00-2 2v2', bgClass: 'from-blue-500 to-blue-600' },
];

const testimonials = [
  { name: 'Ayeuri Melo Sanchez', text: 'One of the best developers I have ever met. He built a consulting website for the Dominican Republic and it turned out amazing. Highly recommend!' },
  { name: 'Plomeria Aquaimperio', text: 'Omar, thank you for your services. I really liked the website, highly recommended, he does his job very well and pays close attention to detail.' },
  { name: 'Jorge Capacho', text: 'Omar thank you for your support. The website turned out exactly how I wanted. Thanks to you I can continue with my business.' },
  { name: 'Jaime Mantilla', text: 'Very professional, excellent for creating websites. He helped with my business and I highly recommend him.' },
  { name: 'Gladys Hernández', text: 'I hired Omar to build my pet products website. I needed something professional and the result was excellent work.' },
  { name: 'David', text: 'Very professional and dedicated. I was surprised that in 4 days my business website was almost ready. I recommend him openly.' },
];

const faqs = [
  { question: 'How long does it take for a website to rank on Google?', answer: 'It depends on the niche, competition and content quality. Generally, a new website needs between 3 and 6 months to see consistent organic results. Sites with solid SEO technical structure from day one shorten that time considerably.' },
  { question: 'What is technical SEO and why does it matter for my business?', answer: 'Technical SEO is the set of configurations that allow Google to crawl, understand and index your site correctly. It includes loading speed, URL structure, structured data, sitemap, robots.txt and Core Web Vitals. Without a solid technical foundation, even the best content can remain invisible in search results.' },
  { question: 'What is the difference between local SEO and organic SEO?', answer: 'Organic SEO focuses on ranking web pages in general Google results regardless of user location. Local SEO is designed for businesses with a physical presence or that serve specific geographic areas. It appears on Google Maps (Local Pack) when someone searches for "service near me" or "service + city".' },
  { question: 'What makes a website design convert visitors into customers?', answer: 'A website that converts has three pillars: speed (loads in under 2 seconds), clarity (the visitor understands in 5 seconds what you offer and why to trust you) and a visible call to action. Good design helps, but without a structure designed to guide the user toward contact or purchase, visits simply bounce.' },
  { question: 'Do I need a blog on my website to improve my SEO?', answer: 'It is not mandatory, but it is one of the most effective long-term strategies. A well-managed blog generates indexable content, attracts traffic from informational searches and builds topical authority. Businesses that consistently publish relevant content receive up to 3 times more organic traffic than those with only static service pages.' },
];
---

<Layout
  title="SEO and Web Design Blog for Small Businesses in USA | Omar Fuentes"
  description="Free guides and practical strategies on SEO, web design and digital marketing for small businesses in the USA. Learn how to rank on Google and get more customers."
  keywords="seo blog usa, web design blog, small business seo, web design for small business, freelance web developer usa, digital marketing guides"
>
  <section id="home" class="min-h-screen flex items-center justify-center pb-4 md:pb-8 lg:pb-4 bg-white relative overflow-hidden pt-8">
    <!-- Subtle background shapes -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-20 right-0 w-96 h-96 bg-blue-50 rounded-full opacity-60 translate-x-1/2 -translate-y-1/4"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-yellow-50 rounded-full opacity-50 -translate-x-1/3 translate-y-1/4"></div>
    </div>

    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <!-- Editorial badge -->
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-50 border border-blue-100 mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-blue animate-pulse"></span>
            <span class="text-sm font-semibold text-primary-blue">SEO & Web Design Blog · Free Resources</span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6 leading-tight tracking-tight text-gray-900">
            SEO and Web Design for small businesses that want to
            <span class="bg-gradient-to-r from-primary-blue via-primary-yellow to-primary-green bg-clip-text text-transparent"> grow on Google</span>
          </h1>

          <p class="text-lg md:text-xl text-gray-600 mb-4 max-w-xl leading-relaxed">
            I'm <strong class="text-gray-900">Omar Fuentes</strong>, an SEO and web development specialist since 2018. Here I share practical guides and real strategies to help your business get more visibility on Google.
          </p>

          <p class="text-lg md:text-xl text-gray-600 mb-10 max-w-xl leading-relaxed">
            If you need someone to apply it for you, I also offer web design and SEO services for small businesses in the USA.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/en/blog/" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl font-semibold text-base bg-primary-blue text-white hover:bg-blue-700 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
              Read the blog
            </a>
            <a href="/en/contact/" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl font-semibold text-base border-2 border-gray-200 text-gray-700 hover:border-primary-blue hover:text-primary-blue transition-colors">
              Talk with Omar
            </a>
          </div>
        </div>

        <div class="relative flex justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-lg p-4 border border-gray-100 z-10 max-w-xs">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-gray-900">50+ businesses helped</p>
                  <p class="text-xs text-gray-500">Colombia & Latin America</p>
                </div>
              </div>
            </div>
            <img
              src="/mi-foto-frelance-Photoroom.png"
              alt="Omar Fuentes - SEO Specialist and Web Developer"
              class="w-4/5 lg:w-full h-auto max-w-sm relative z-0"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Featured Section -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-gray-50 to-white">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
        <div>
          <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-blue-500/10 text-primary-blue border border-blue-500/20 mb-3">SEO & Web Design Blog</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-black">
            Learn how to rank your website
            <span class="bg-gradient-to-r from-primary-blue via-primary-yellow to-primary-green bg-clip-text text-transparent"> and get more clients</span>
          </h2>
          <p class="text-xl text-gray-700 mt-3 max-w-2xl">Practical guides, SEO strategies and web design tips I use with my clients every day.</p>
        </div>
        <a href="/en/blog/" class="flex-shrink-0 inline-flex items-center gap-2 text-primary-blue font-semibold hover:underline text-lg">
          View all articles
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>

      {enPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {enPosts.map((post: BlogEntry) => (
            <a href={postUrl(post.id)} class="group bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-md hover:shadow-xl hover:-translate-y-2 transition-all duration-300 block" style="text-decoration: none;">
              <div class="relative aspect-video overflow-hidden bg-gray-50">
                <img
                  src={post.data.heroImage || '/PAGINAS-WEB-BUCARAMAGA.webp'}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-6">
                <div class="text-sm text-gray-500 mb-2">
                  <FormattedDate date={post.data.updatedDate ?? post.data.pubDate} />
                </div>
                <h3 class="text-xl font-black leading-snug text-black mb-3 group-hover:text-primary-blue transition-colors">{post.data.title}</h3>
                <p class="text-gray-600 text-base line-clamp-2">{post.data.description}</p>
                <div class="mt-4 text-primary-blue font-semibold text-sm flex items-center gap-1">
                  Read article
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </div>
              </div>
            </a>
          ))}

          <!-- 3 static featured articles on Web Design & SEO -->
          <a href="/en/blog/responsive-web-design-with-html-5/" class="group bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-md hover:shadow-xl hover:-translate-y-2 transition-all duration-300 block" style="text-decoration: none;">
            <div class="relative aspect-video overflow-hidden bg-gray-50">
              <img src="/images/images-en/responsive-web-design-with-HTML5.png" alt="Responsive Web Design with HTML5" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-black leading-snug text-black mb-3 group-hover:text-primary-blue transition-colors">Responsive Web Design with HTML5: From Mobile-First to Adaptive</h3>
              <p class="text-gray-600 text-base line-clamp-2">A comprehensive guide to building responsive websites with HTML5, covering mobile-first design, fluid layouts and CSS3 techniques.</p>
              <div class="mt-4 text-primary-blue font-semibold text-sm flex items-center gap-1">Read article <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg></div>
