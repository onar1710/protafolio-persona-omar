        </div>
        <div class="flex items-start gap-4">
          <CheckCircle className="w-6 h-6 text-pink-500 flex-shrink-0 mt-1" />
          <p class="text-gray-700 font-medium">Built for Google local search from day one</p>
        </div>
        <div class="flex items-start gap-4">
          <CheckCircle className="w-6 h-6 text-pink-500 flex-shrink-0 mt-1" />
          <p class="text-gray-700 font-medium">Custom, not a template your competitor already has</p>
        </div>
        <div class="flex items-start gap-4">
          <CheckCircle className="w-6 h-6 text-pink-500 flex-shrink-0 mt-1" />
          <p class="text-gray-700 font-medium">I actually respond when you message me</p>
        </div>
        <div class="flex items-start gap-4">
          <CheckCircle className="w-6 h-6 text-pink-500 flex-shrink-0 mt-1" />
          <p class="text-gray-700 font-medium">No confusing contracts</p>
        </div>
