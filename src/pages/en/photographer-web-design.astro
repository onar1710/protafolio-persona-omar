---
import Layout from '../../layouts/LayoutEN.astro';

const services = [
  { title: 'A Website That Loads Fast and Looks the Part', description: 'No clunky templates everyone\'s seen before. Clean, custom design that loads fast and makes your work the star.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-pink-500 to-pink-600' },
  { title: 'Show Up When People Search', description: 'When someone types "wedding photographer in [your city]," you should be right there. I optimize your site so Google actually sends you traffic.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', bgClass: 'from-purple-500 to-purple-600' },
  { title: 'A Gallery That Wows Without Slowing Everything Down', description: 'High-res images displayed beautifully, optimized so they don\'t tank your load time. Your photos deserve to be seen properly.', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', bgClass: 'from-pink-500 to-pink-600' },
  { title: 'Booking Forms That Actually Convert', description: 'Clear calls to action, simple contact forms, easy ways for people to reach you. No friction between "I love this" and "I\'m hiring them."', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', bgClass: 'from-purple-500 to-purple-600' },
];

const whyChooseMe = [
  'Clear timeline agreed up front',
  'You own everything — no monthly hostage fees',
  'Built for Google local search from day one',
  'Custom, not a template your competitor already has',
  'I actually respond when you message me',
  'No confusing contracts',
];

const includes = [
  'Custom design (not a template everyone else uses)',
  'Optimized photo gallery that loads fast',
  'Works perfectly on phones',
  'Pages for each type of session you offer (weddings, portraits, events, etc.)',
  'Pages for each city or area you cover',
  'Contact and booking forms',
  'Google Maps integration',
  'SSL certificate',
  'Local SEO setup so you rank in your area',
  'One month of free fixes after launch',
];

const steps = [
  { step: '1', title: 'We Talk', description: 'Quick call. I learn about your style, your clients, your goals. You decide if we\'re a good fit.' },
  { step: '2', title: 'I Send You a Price', description: 'One number. No "starting at" nonsense. You know exactly what you\'re paying before anything starts.' },
  { step: '3', title: 'I Build Your Site', description: 'You\'ll see it come together. Don\'t like something? I change it. Simple.' },
  { step: '4', title: 'We Launch', description: 'I handle the technical side. I\'ll show you how to update things if you ever want to.' },
  { step: '5', title: 'I Stick Around', description: 'Need to swap a photo, update your prices, add a new service? I\'m here.' },
];

const testimonials = [
  { name: 'Valentina Cruz', role: 'Wedding Photographer', text: 'I used to get maybe one or two inquiries a month from my website. Now I\'m getting five or six. The difference was night and day.' },
  { name: 'Ryan Okafor', role: 'Portrait Photographer', text: 'I\'d been putting off redoing my site for two years because I didn\'t want the hassle. Honestly the easiest process I\'ve been through. Worth every penny.' },
  { name: 'Priya Nair', role: 'Brand Photographer', text: 'Other designers wanted to give me a Squarespace template with my logo on it. This was actually custom. My clients notice.' },
];

const faqs = [
  { question: 'What\'s this going to cost me?', answer: 'Depends on what you need. Most photographer sites fall into a clear range. I\'ll give you an exact number upfront — no surprises later.' },
  { question: 'How fast can you do this?', answer: '2–3 weeks for most projects. Need it faster? Tell me and we\'ll figure it out.' },
  { question: 'Will I show up on Google?', answer: 'That\'s the whole point. Every site I build is optimized for local search so potential clients can actually find you.' },
  { question: 'Can I use my own photos?', answer: 'Yes, and I\'ll make sure they\'re displayed in a way that does them justice without slowing your site down.' },
  { question: 'Can I update the site myself later?', answer: 'Yes. I\'ll show you how. Or I can handle updates for you if you\'d rather not deal with it.' },
  { question: 'Do I have to sign a long contract?', answer: 'No. You pay for the website, it\'s yours. No monthly fees unless you want ongoing support.' },
];
---

<Layout
  title="Photographer Web Design That Actually Books Sessions | Omar Fuentes"
  description="I build portfolio websites for photographers who are tired of losing clients to people with a prettier online presence. Let me help you attract the right clients, show up on Google, and fill your calendar."
  keywords="photographer web design, photography portfolio website, photographer website, booking website, photography SEO"
>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center pb-16 md:pb-24 lg:pb-32 bg-gradient-to-br from-pink-900 via-purple-800 to-pink-900 relative overflow-hidden pt-8">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-slide-in">
          <div class="flex items-center space-x-2 mb-6">
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-white/10 text-white border border-white/20">Small Business</span>
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-pink-500/20 text-pink-300 border border-pink-500/30">Photographers</span>
          </div>

          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight text-white">
            Photographer <br />
            <span class="bg-gradient-to-r from-pink-400 to-purple-400 bg-clip-text text-transparent">Web Design</span>
          </h1>

          <p class="text-xl text-white/90 mb-8 max-w-lg">
            I build portfolio websites for photographers who are tired of losing clients to people with a prettier online presence. Let me help you attract the right clients, show up on Google, and fill your calendar.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://wa.me/13239414865?text=Hi%20Omar,%20I%20want%20a%20free%20photographer%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 hover:shadow-xl bg-gradient-to-r from-pink-500 to-pink-600 text-white hover:shadow-xl">
              Let's Talk About Your Website
            </a>
            <a href="/en/portfolio/projects/" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 border-2 border-white/30 text-white hover:bg-white/10">
              See Examples
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-4 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="text-yellow-400">★★★★★</span>
              <span class="font-semibold">Mobile-first design</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">Clear lead capture</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">Fast turnaround</span>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-pink-500 to-purple-500 rounded-3xl opacity-20 animate-float"></div>
          <div class="relative bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
            <p class="text-white/70 text-sm mb-4">Built for photographers</p>
            <p class="text-white text-2xl font-bold mb-2">Free consultation • No obligation • Clear next steps</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Your Work Is Beautiful. Your Website Shouldn't Be the Reason They Hire Someone Else.</h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-6 text-center">
        <p class="text-xl text-gray-700 leading-relaxed">
          When someone's looking for a photographer for their wedding, their brand, their family — they're scrolling fast. They make a decision in seconds.
        </p>
        <p class="text-xl text-gray-700 leading-relaxed">
          If your site loads slow, looks outdated, or doesn't show your best work upfront, they're gone. They found someone else. And you never knew they were there.
        </p>
        <p class="text-2xl text-pink-600 font-bold">
          I build websites specifically for photographers — the kind that make people stop scrolling and hit "Book a Session."
        </p>
      </div>
    </div>
  </section>

  <!-- What You Get Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">A Portfolio That Does the Selling For You</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {services.map((service) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
            <div class={`w-12 h-12 mb-4 bg-gradient-to-br ${service.bgClass} rounded-lg flex items-center justify-center`}>
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{service.title}</h3>
            <p class="text-gray-600">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Me Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Why Work With Me Instead of a Generic Web Agency</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto mb-8">
          I don't build websites for everyone. I focus on creative professionals who need their work to speak first and their site to back it up.
        </p>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Most web designers hand you something generic and call it a day. I'll give you something built around how photographers actually get hired.
        </p>
      </div>

      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4">
        {whyChooseMe.map((item) => (
          <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-xl">
            <svg class="w-6 h-6 text-pink-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="font-semibold">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">What's Included</h2>
      </div>

      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4">
        {includes.map((item) => (
          <div class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-md">
            <svg class="w-6 h-6 text-pink-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="font-semibold">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">How This Works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 max-w-6xl mx-auto">
        {steps.map((step) => (
          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-4 bg-gradient-to-br from-pink-500 to-pink-600 rounded-full flex items-center justify-center">
              <span class="text-xl font-bold text-white">{step.step}</span>
            </div>
            <h3 class="text-base font-bold mb-2">{step.title}</h3>
            <p class="text-gray-600 text-xs">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Real Feedback</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((testimonial) => (
          <div class="card">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class="w-4 h-4 fill-pink-400 text-pink-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
            </div>
            <p class="text-gray-600 mb-4 italic">"{testimonial.text}"</p>
            <div class="font-semibold">{testimonial.name}</div>
            <div class="text-sm text-gray-500">{testimonial.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Questions</h2>
      </div>

      <div class="max-w-4xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
            <h3 class="text-lg font-bold mb-2">{faq.question}</h3>
            <p class="text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-pink-900 via-purple-800 to-pink-900">
    <div class="container text-center">
      <h2 class="text-section mb-4 text-white">Tired of Losing Clients to Photographers With a Better Website?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Let's fix that. Quick call, honest advice, no pressure.
      </p>
      <a href="https://wa.me/13239414865?text=Hi%20Omar,%20I%20want%20a%20free%20photographer%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 bg-white text-pink-900 hover:shadow-xl">
        Book a Call
      </a>
      <div class="mt-8 text-white/70 text-sm">
        Conversion-focused web design • Portfolio-first layout • Technical SEO foundations
      </div>
    </div>
  </section>
</Layout>
