---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, ArrowRight, Star, Clock, Award, Phone, MapPin, Target, Shield, Zap, Globe, TrendingUp, Calendar, Users, Briefcase, Home, Camera, Image, Mail, Search } from 'lucide-react';
---

<Layout title="Photographer Web Design That Actually Books Sessions | Omar Fuentes" description="Professional photographer web design services. Get more bookings and inquiries with portfolio websites that showcase your work and rank higher in local searches.">
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-pink-900 via-purple-800 to-pink-900 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    
    <!-- Decorative circles -->
    <div class="absolute top-20 right-20 w-72 h-72 bg-pink-500 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-20 left-20 w-96 h-96 bg-purple-500 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6 py-24">
      <div class="text-center">
        <!-- Badge -->
        <div class="inline-flex items-center bg-white/10 backdrop-blur-md rounded-full px-6 py-3 mb-8 border border-white/20">
          <Camera className="w-5 h-5 mr-2 text-pink-400" />
          <span class="text-white text-sm font-semibold">Trusted by 50+ Creative Professionals</span>
        </div>
        
        <h1 class="text-6xl md:text-7xl font-bold mb-8 text-white leading-tight">
          Web Design for Photographers That Actually Books Sessions
        </h1>
        
        <!-- Value Proposition -->
        <div class="max-w-3xl mx-auto mb-12">
          <p class="text-xl text-white/90 mb-8 leading-relaxed">I build portfolio websites for photographers who are tired of losing clients to people with a prettier online presence. Let me help you attract the right clients, show up on Google, and fill your calendar.</p>
          
          <!-- Social Proof -->
          <div class="flex flex-wrap items-center justify-center gap-8 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Star className="w-5 h-5 text-pink-400 fill-pink-400" />
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <TrendingUp className="w-5 h-5 text-pink-400" />
              <span class="font-semibold">+200% More Inquiries</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Camera className="w-5 h-5 text-pink-400" />
              <span class="font-semibold">2-3 Week Delivery</span>
            </div>
          </div>
        </div>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
          <a href="mailto:contact@omarfuentes.com" class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-pink-500 to-pink-600 text-white px-10 py-5 font-semibold hover:from-pink-600 hover:to-pink-700 transition-all transform hover:scale-105 shadow-2xl text-lg">
            Let's Talk About Your Website
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
          <a href="/en/portfolio" class="inline-flex items-center justify-center rounded-full border-2 border-white/30 text-white px-10 py-5 font-semibold hover:bg-white/10 transition-all text-lg backdrop-blur-sm">
            See Examples
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
        </div>
        
        <!-- Trust indicators -->
        <div class="text-white/70 text-sm flex items-center justify-center gap-2">
          <CheckCircle className="w-4 h-4" />
          <span>Free consultation • No obligation • Results guaranteed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-8 text-gray-900 leading-tight">
          Your Work Is Beautiful. Your Website Shouldn't Be the Reason They Hire Someone Else.
        </h2>
        <p class="text-xl text-gray-700 mb-12 leading-relaxed">
          When someone's looking for a photographer for their wedding, their brand, their family — they're scrolling fast. They make a decision in seconds.
        </p>
        <p class="text-xl text-gray-700 mb-12 leading-relaxed">
          If your site loads slow, looks outdated, or doesn't show your best work upfront, they're gone. They found someone else. And you never knew they were there.
        </p>
        <p class="text-2xl text-pink-600 font-bold mb-12">
          I build websites specifically for photographers — the kind that make people stop scrolling and hit "Book a Session."
        </p>
      </div>
    </div>
  </section>

  <!-- What You Get Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-8 text-gray-900">
          A Portfolio That Does the Selling For You
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Feature 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl flex items-center justify-center mb-6">
            <Zap className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">A Website That Loads Fast and Looks the Part</h3>
          <p class="text-gray-700 leading-relaxed">No clunky templates everyone's seen before. Clean, custom design that loads in under 2 seconds and makes your work the star.</p>
        </div>
        
        <!-- Feature 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6">
            <Search className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Show Up When People Search</h3>
          <p class="text-gray-700 leading-relaxed">When someone types "wedding photographer in [your city]," you should be right there. I optimize your site so Google actually sends you traffic.</p>
        </div>
        
        <!-- Feature 3 -->
