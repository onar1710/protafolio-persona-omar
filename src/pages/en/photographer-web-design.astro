          <p class="text-gray-700">You'll see it come together. Don't like something? I change it. Simple.</p>
        </div>
        
        <!-- Step 4 -->
        <div class="text-center group">
          <div class="w-20 h-20 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform shadow-xl">
            <span class="text-3xl font-bold text-white">4</span>
          </div>
