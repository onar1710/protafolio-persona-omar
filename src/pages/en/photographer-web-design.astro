            <Image className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">A Gallery That Wows Without Slowing Everything Down</h3>
          <p class="text-gray-700 leading-relaxed">High-res images displayed beautifully, optimized so they don't tank your load time. Your photos deserve to be seen properly.</p>
        </div>
        
        <!-- Feature 4 -->
        <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
          <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6">
            <Mail className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Booking Forms That Actually Convert</h3>
          <p class="text-gray-700 leading-relaxed">Clear calls to action, simple contact forms, easy ways for people to reach you. No friction between "I love this" and "I'm hiring them."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Me Section -->
