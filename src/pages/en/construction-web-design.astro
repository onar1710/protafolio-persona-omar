            <Shield className="w-8 h-8 text-white" />
          </div>
          <h3 class="text-2xl font-bold mb-4 text-black">Professional design that builds trust</h3>
          <p class="text-gray-700 text-lg leading-relaxed">Showcase your work, credibility, and experience to win more projects.</p>
        </div>

        <div class="group bg-gradient-to-br from-white to-purple-50 p-8 rounded-2xl shadow-lg border border-purple-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
