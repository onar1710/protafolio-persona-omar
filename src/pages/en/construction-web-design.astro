              <p class="text-gray-700 font-medium">Dedicated pages for remodeling, new construction, and specialized services</p>
            </div>
          </div>

          <div class="flex items-start space-x-6 group hover:bg-orange-50 p-6 rounded-2xl transition-all duration-300">
