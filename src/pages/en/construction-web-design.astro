---
import Layout from '../../layouts/LayoutEN.astro';

const features = [
  { title: 'Project galleries to showcase your work', description: 'Display your best projects with high-quality images and detailed descriptions', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', bgClass: 'from-orange-500 to-orange-600' },
  { title: 'Service pages for each type of construction service', description: 'Dedicated pages for remodeling, new construction, and specialized services', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', bgClass: 'from-slate-500 to-slate-600' },
  { title: 'Quote request forms to generate leads', description: 'Easy-to-use forms that capture all essential project information', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01', bgClass: 'from-green-500 to-green-600' },
  { title: 'Service area targeting for local SEO', description: 'Optimized to attract customers in your specific service locations', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Testimonials to build trust', description: 'Show customer reviews and success stories to establish credibility', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', bgClass: 'from-purple-500 to-purple-600' },
  { title: 'Clear call-to-actions to increase conversions', description: 'Strategic placement of contact forms and phone numbers', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 2.493A1 1 0 008.618 7h6.764a1 1 0 01.948-.684L17.28 3a2 2 0 012 2h3.28a1 1 0 01.948.684l1.498 2.493A1 1 0 0018.618 7h-6.764a1 1 0 01-.948-.684L9.72 3.684A1 1 0 008.772 3H6a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7', bgClass: 'from-yellow-500 to-orange-500' },
];

const benefits = [
  { title: 'Built to generate leads for construction companies', description: 'Turn visitors into real inquiries and project requests.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-orange-500 to-orange-600' },
  { title: 'Mobile-friendly and responsive web design', description: 'Perfect performance on all devices, especially mobile users searching for local services.', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', bgClass: 'from-slate-500 to-slate-600' },
  { title: 'Fast-loading and reliable websites', description: 'Speed matters for both SEO rankings and user experience.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', bgClass: 'from-yellow-500 to-orange-500' },
  { title: 'SEO-optimized structure for construction services', description: 'Designed to help your business rank on Google and attract local clients.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', bgClass: 'from-green-500 to-green-600' },
  { title: 'Professional design that builds trust', description: 'Showcase your work, credibility, and experience to win more projects.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', bgClass: 'from-blue-500 to-blue-600' },
  { title: 'Local SEO optimization', description: 'Get found by customers in your service area looking for construction services.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z', bgClass: 'from-purple-500 to-purple-600' },
];

const results = [
  'Get more calls from potential clients',
  'Increase quote requests',
  'Attract local customers searching for construction services',
  'Grow your business consistently',
];

const steps = [
  { step: '1', title: 'Tell us about your construction business', description: 'Share your goals, services, and target audience' },
  { step: '2', title: 'We design and build your website', description: 'Professional design optimized for conversions and SEO' },
  { step: '3', title: 'You start getting leads and new projects', description: 'Watch your business grow with qualified inquiries' },
];
---

<Layout
  title="Construction Web Design Services for Small Businesses | Omar Fuentes"
  description="Get a professional website built for construction companies that want more leads, more projects, and consistent growth."
  keywords="construction web design, contractor website, construction company website, local SEO contractor, project gallery"
>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center pb-16 md:pb-24 lg:pb-32 bg-gradient-to-br from-slate-900 via-orange-900 to-slate-900 relative overflow-hidden pt-8">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-slide-in">
          <div class="flex items-center space-x-2 mb-6">
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-white/10 text-white border border-white/20">Small Business</span>
            <span class="px-3 py-1 rounded-full text-sm font-medium bg-orange-500/20 text-orange-300 border border-orange-500/30">Construction</span>
          </div>

          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight text-white">
            Construction <br />
            <span class="bg-gradient-to-r from-orange-400 to-slate-400 bg-clip-text text-transparent">Web Design</span>
          </h1>

          <p class="text-xl text-white/90 mb-8 max-w-lg">
            Get a professional website built for construction companies that want more leads, more projects, and consistent growth.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://wa.me/12025551234?text=Hi%20Omar,%20I%20want%20a%20free%20construction%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 hover:shadow-xl bg-gradient-to-r from-orange-500 to-orange-600 text-white hover:shadow-xl">
              Get Your Free Quote
            </a>
            <a href="/en/portfolio/projects/" class="px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 border-2 border-white/30 text-white hover:bg-white/10">
              See Examples
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-4 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="text-yellow-400">★★★★★</span>
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">+200% More Leads</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <span class="font-semibold">3-7 Day Delivery</span>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-orange-500 to-slate-500 rounded-3xl opacity-20 animate-float"></div>
          <div class="relative bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
            <p class="text-white/70 text-sm mb-4">Trusted by 50+ Construction Companies</p>
            <p class="text-white text-2xl font-bold mb-2">Free consultation • No obligation • Results guaranteed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="py-20 bg-gradient-to-br from-slate-50 to-orange-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Web Design for Construction Companies That Want More Clients</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-xl border border-red-100">
          <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 2.502-3.546V7.546c0-1.879-.962-3.546-2.502-3.546H5.502C3.962 4 3 5.667 3 7.546v8.908c0 1.879.962 3.546 2.502 3.546z" />
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-red-900">The Problem:</h3>
          </div>
          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start">
              <span class="text-red-600 mr-3 mt-1">•</span>
              <span>No online visibility → missing potential clients</span>
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-3 mt-1">•</span>
              <span>Competitors ranking higher on Google</span>
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-3 mt-1">•</span>
              <span>Website doesn't convert visitors to leads</span>
            </li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-xl border border-green-100">
          <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-green-900">Our Solution:</h3>
          </div>
          <div class="space-y-4 text-gray-700">
            <p class="text-lg leading-relaxed">Construction businesses need more than just a website. You need a platform that showcases your projects, builds trust, and turns visitors into qualified leads.</p>
            <p class="text-lg leading-relaxed font-semibold">We create construction company web design solutions focused on generating calls, quote requests, and new project opportunities.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Why Construction Businesses Choose Our Web Design</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Professional features designed specifically for the construction industry
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map((benefit) => (
          <div class="card">
            <div class={`w-12 h-12 mb-4 bg-gradient-to-br ${benefit.bgClass} rounded-lg flex items-center justify-center`}>
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={benefit.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-gradient-to-br from-slate-50 to-orange-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Features Every Construction Website Needs</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          We build websites with the exact functionality construction companies need
        </p>
      </div>

      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-orange-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {features.map((feature) => (
            <div class="flex items-start gap-4">
              <div class={`w-12 h-12 bg-gradient-to-br ${feature.bgClass} rounded-lg flex items-center justify-center flex-shrink-0`}>
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={feature.icon} />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">{feature.title}</h3>
                <p class="text-gray-600 text-sm">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Get More Leads and Construction Projects</h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          A well-designed construction website is more than an online presence — it's a lead generation tool.
        </p>
      </div>

      <div class="max-w-4xl mx-auto bg-gradient-to-br from-green-50 to-slate-50 rounded-3xl shadow-2xl p-12 border border-green-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {results.map((result) => (
            <div class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-md">
              <svg class="w-6 h-6 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold text-lg">{result}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Authority Section -->
  <section class="py-20 bg-gradient-to-br from-slate-50 to-orange-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Why Choose Our Construction Web Design Services</h2>
      </div>

      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-12 border border-orange-100">
        <div class="space-y-6 text-center">
          <p class="text-xl text-gray-700 leading-relaxed">
            We understand how construction businesses operate. Your website needs to clearly show your services, past projects, and why clients should trust you.
          </p>
          <p class="text-xl text-gray-900 font-bold">
            We combine web design, SEO, and conversion strategies to help construction companies stand out and win more jobs online.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-section mb-4">Simple Process, Real Results</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {steps.map((step) => (
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-br from-orange-500 to-orange-600 rounded-full flex items-center justify-center">
              <span class="text-2xl font-bold text-white">{step.step}</span>
            </div>
            <h3 class="text-lg font-bold mb-2">{step.title}</h3>
            <p class="text-gray-600 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-slate-900 via-orange-900 to-slate-900">
    <div class="container text-center">
      <h2 class="text-section mb-4 text-white">Ready to Get More Construction Clients?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Let's build a website that brings you more leads, more calls, and more projects.
      </p>
      <a href="https://wa.me/12025551234?text=Hi%20Omar,%20I%20want%20a%20free%20construction%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 transform hover:scale-105 bg-white text-slate-900 hover:shadow-xl">
        Get a Quote
      </a>
      <div class="mt-8 text-white/70 text-sm">
        30-day satisfaction guarantee • Dedicated support • Proven results
      </div>
    </div>
  </section>
</Layout>
