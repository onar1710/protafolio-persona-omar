        </div>

        <div class="group bg-gradient-to-br from-white to-yellow-50 p-8 rounded-2xl shadow-lg border border-yellow-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-yellow-500 to-orange-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Zap className="w-8 h-8 text-white" />
