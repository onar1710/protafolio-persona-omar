---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, ArrowRight, Star, Clock, Award, Phone, MapPin, Wrench, Hammer, Building, Users, Target, Shield, Zap, Globe, TrendingUp } from 'lucide-react';
---

<Layout title="Construction Web Design Services for Small Businesses | Omar Fuentes" description="Professional construction web design services for small businesses. Get more leads, projects, and growth with fast, SEO-optimized websites that convert visitors into real clients.">
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-orange-900 to-slate-900 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
