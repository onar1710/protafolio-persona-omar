---
import Layout from '~/layouts-en/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

---

<Layout title="Privacy Policy - Omar Fuentes" description="Privacy Policy of Omar Fuentes. Comprehensive data protection policy compliant with CCPA, GDPR, and U.S. privacy laws for web design and SEO services.">
  
  <PageHeader 
      title="Privacy Policy"
      description="Last updated: January 28, 2026"
  />

  <Container as="main" class="max-w-4xl mx-auto">
      
      <!-- Introduction -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Introduction</h2>
          <p class="text-muted-foreground leading-8 mb-6">
              <span class="font-semibold text-foreground">Omar Fuentes</span> ("we," "us," or "our") is committed to protecting your privacy and personal information.
              This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website
              omarfuentes.com and use our web design, development, and SEO services throughout the United States.
          </p>
          <p class="text-muted-foreground leading-8 mb-4">
              By using our website and services, you consent to the collection and use of information as described in this policy.
              This policy complies with the California Consumer Privacy Act (CCPA), General Data Protection Regulation (GDPR) for EU clients,
              and other applicable U.S. privacy laws.
          </p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <p class="font-semibold text-foreground mb-2">Quick Links:</p>
              <div class="space-y-1 text-sm">
                  <a href="#information-we-collect" class="text-primary hover:underline block">What Information We Collect</a>
                  <a href="#how-we-use-information" class="text-primary hover:underline block">How We Use Your Information</a>
                  <a href="#your-rights" class="text-primary hover:underline block">Your Privacy Rights</a>
                  <a href="#contact" class="text-primary hover:underline block">Contact Information</a>
              </div>
          </div>
      </section>

      <!-- Information We Collect -->
      <section id="information-we-collect" class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Information We Collect</h2>
          
          <h3 class="text-xl font-semibold mb-4">Personal Information You Provide</h3>
          <p class="text-muted-foreground leading-8 mb-4">When you contact us, request services, or interact with our website, we may collect:</p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <ul class="grid gap-3 text-muted-foreground">
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Contact Information:</strong> Full name, email address, phone number, company name, job title</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Business Information:</strong> Company website URL, industry type, business size, target market</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Project Details:</strong> Service requirements, budget range, timeline, technical specifications</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Payment Information:</strong> Billing address, payment method details, invoice preferences</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Communication:</strong> Messages, emails, phone call recordings (with consent), meeting notes</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Marketing Preferences:</strong> Consent for newsletters, promotional materials, service updates</div></li>
              </ul>
          </div>

          <h3 class="text-xl font-semibold mb-4 mt-8">Automatically Collected Information</h3>
          <p class="text-muted-foreground leading-8 mb-4">We automatically collect certain technical information when you visit our website:</p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <ul class="grid gap-3 text-muted-foreground">
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Device & Browser Data:</strong> Browser type, version, operating system, device type, screen resolution</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Network Information:</strong> IP address, ISP, general geographic location (city/state level)</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Usage Data:</strong> Pages visited, time spent on pages, click patterns, navigation paths</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Session Data:</strong> Session duration, referral source, search terms used to find our site</div></li>
                  <li class="flex items-start"><span class="text-primary mr-2">•</span> <div><strong>Cookies & Tracking:</strong> Cookie identifiers, unique device identifiers, analytics tracking data</div></li>
              </ul>
          </div>
      </section>

      <!-- How We Use Your Information -->
      <section id="how-we-use-information" class="mb-16">
          <h2 class="text-2xl font-bold mb-6">How We Use Your Information</h2>
          <p class="text-muted-foreground leading-8 mb-6">We use your information for specific business purposes as outlined below:</p>
          
          <div class="grid gap-6 md:grid-cols-2">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3 text-primary">Service Delivery</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Process service requests and quotes</li>
                      <li>• Develop and deliver web design projects</li>
                      <li>• Implement SEO strategies</li>
                      <li>• Provide technical support</li>
                      <li>• Manage project timelines</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3 text-primary">Communication</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Respond to inquiries and questions</li>
                      <li>• Send project updates</li>
                      <li>• Schedule meetings and calls</li>
                      <li>• Provide customer support</li>
                      <li>• Share relevant resources</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3 text-primary">Business Operations</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Process payments and invoicing</li>
                      <li>• Maintain client records</li>
                      <li>• Conduct analytics and research</li>
                      <li>• Improve our services</li>
                      <li>• Ensure website security</li>
                  </ul>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3 text-primary">Marketing (with consent)</h3>
                  <ul class="space-y-2 text-sm text-muted-foreground">
                      <li>• Send newsletters and updates</li>
                      <li>• Share service promotions</li>
                      <li>• Provide industry insights</li>
                      <li>• Invite to webinars/events</li>
                      <li>• Request testimonials</li>
                  </ul>
              </div>
          </div>
      </section>

      <!-- Legal Basis for Processing -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Legal Basis for Processing</h2>
          <p class="text-muted-foreground leading-8 mb-4">We process your personal information based on the following legal foundations:</p>
          <div class="space-y-4">
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">1</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Contract Performance</h3>
                      <p class="text-muted-foreground text-sm">Processing necessary to fulfill our service agreements and deliver requested web design, development, and SEO services.</p>
                  </div>
              </div>
              
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">2</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Legitimate Business Interest</h3>
                      <p class="text-muted-foreground text-sm">Processing for legitimate business purposes including marketing analytics, service improvement, and fraud prevention.</p>
                  </div>
              </div>
              
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">3</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Consent</h3>
                      <p class="text-muted-foreground text-sm">Processing based on your explicit consent for marketing communications, analytics, and non-essential cookies.</p>
                  </div>
              </div>
              
              <div class="flex items-start gap-4">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-primary font-semibold text-sm">4</span>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-2">Legal Obligation</h3>
                      <p class="text-muted-foreground text-sm">Processing required by U.S. federal and state laws, tax regulations, and industry compliance requirements.</p>
                  </div>
              </div>
          </div>
      </section>

      <!-- Information Sharing -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Information Sharing and Disclosure</h2>
          <p class="text-muted-foreground leading-8 mb-4">We do not sell your personal information. We only share your data in limited circumstances:</p>
          
          <div class="space-y-6">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Service Providers</h3>
                  <p class="text-muted-foreground mb-3 text-sm">We share information with trusted third-party service providers:</p>
                  <ul class="space-y-2 text-muted-foreground text-sm">
                      <li>• <strong>Web Hosting:</strong> Cloudflare, Vercel (for website hosting and CDN)</li>
                      <li>• <strong>Analytics:</strong> Google Analytics (for website traffic analysis)</li>
                      <li>• <strong>Communication:</strong> Mailchimp (for email marketing)</li>
                      <li>• <strong>Payment Processing:</strong> PayPal, Stripe (for payment processing)</li>
                      <li>• <strong>Project Management:</strong> Notion, Trello (for project organization)</li>
                  </ul>
                  <p class="text-muted-foreground text-xs mt-3">All providers undergo strict security vetting and are bound by confidentiality agreements.</p>
              </div>
              
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h3 class="text-lg font-semibold mb-3">Legal Requirements</h3>
                  <p class="text-muted-foreground mb-3 text-sm">We may disclose information when required by law:</p>
                  <ul class="space-y-2 text-muted-foreground text-sm">
                      <li>• Court orders, subpoenas, or legal processes</li>
                      <li>• Government agency requests (FBI, FTC, etc.)</li>
                      <li>• Law enforcement investigations</li>
                      <li>• Regulatory compliance requirements</li>
                  </ul>
              </div>
          </div>
      </section>

      <!-- Your Rights -->
      <section id="your-rights" class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Your Privacy Rights</h2>
          
          <h3 class="text-xl font-semibold mb-4">CCPA Rights (California Residents)</h3>
          <p class="text-muted-foreground leading-8 mb-4">If you are a California resident, you have the following rights under the CCPA:</p>
          <div class="grid gap-4 md:grid-cols-2">
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h4 class="font-semibold mb-2">Right to Know</h4>
                  <p class="text-muted-foreground text-sm">Request details about personal information we collect, use, and share about you.</p>
              </div>
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h4 class="font-semibold mb-2">Right to Delete</h4>
                  <p class="text-muted-foreground text-sm">Request deletion of your personal information, with certain exceptions.</p>
              </div>
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h4 class="font-semibold mb-2">Right to Opt-Out</h4>
                  <p class="text-muted-foreground text-sm">Opt-out of sale or sharing of your personal information for marketing purposes.</p>
              </div>
              <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
                  <h4 class="font-semibold mb-2">Right to Non-Discrimination</h4>
                  <p class="text-muted-foreground text-sm">We will not discriminate against you for exercising your privacy rights.</p>
              </div>
          </div>

          <h3 class="text-xl font-semibold mb-4 mt-8">How to Exercise Your Rights</h3>
          <p class="text-muted-foreground leading-8 mb-4">To exercise your privacy rights, please:</p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <ol class="space-y-3 text-muted-foreground">
                  <li class="flex items-start"><span class="font-semibold mr-2">1.</span> <div>Email us at <a href="mailto:contact@omarfuentes.com" class="text-primary hover:underline">contact@omarfuentes.com</a> with "Privacy Rights Request" in the subject line</div></li>
                  <li class="flex items-start"><span class="font-semibold mr-2">2.</span> <div>Provide your name, email address, and specify which right you want to exercise</div></li>
                  <li class="flex items-start"><span class="font-semibold mr-2">3.</span> <div>Include verification information (such as previous project details) to confirm your identity</div></li>
                  <li class="flex items-start"><span class="font-semibold mr-2">4.</span> <div>We will respond within 45 days as required by CCPA</div></li>
              </ol>
          </div>
      </section>

      <!-- Data Security -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Data Security Measures</h2>
          <p class="text-muted-foreground leading-8 mb-4">We implement comprehensive security measures to protect your information:</p>
          <div class="grid gap-4 md:grid-cols-2">
              <div class="space-y-4">
                  <div class="flex items-start gap-3">
                      <div class="w-6 h-6 bg-green-500/10 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                          <span class="text-green-600 text-xs">✓</span>
                      </div>
                      <div>
                          <h4 class="font-semibold text-sm">Encryption</h4>
                          <p class="text-muted-foreground text-xs">SSL/TLS encryption for all data transmission and AES-256 encryption for stored data</p>
                      </div>
                  </div>
                  <div class="flex items-start gap-3">
                      <div class="w-6 h-6 bg-green-500/10 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                          <span class="text-green-600 text-xs">✓</span>
                      </div>
                      <div>
                          <h4 class="font-semibold text-sm">Access Control</h4>
                          <p class="text-muted-foreground text-xs">Role-based access control and multi-factor authentication for all systems</p>
                      </div>
                  </div>
                  <div class="flex items-start gap-3">
                      <div class="w-6 h-6 bg-green-500/10 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                          <span class="text-green-600 text-xs">✓</span>
                      </div>
                      <div>
                          <h4 class="font-semibold text-sm">Regular Backups</h4>
                          <p class="text-muted-foreground text-xs">Automated daily backups with secure storage and disaster recovery protocols</p>
                      </div>
                  </div>
              </div>
              <div class="space-y-4">
                  <div class="flex items-start gap-3">
                      <div class="w-6 h-6 bg-green-500/10 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                          <span class="text-green-600 text-xs">✓</span>
                      </div>
                      <div>
                          <h4 class="font-semibold text-sm">Security Monitoring</h4>
                          <p class="text-muted-foreground text-xs">24/7 security monitoring and intrusion detection systems</p>
                      </div>
                  </div>
                  <div class="flex items-start gap-3">
                      <div class="w-6 h-6 bg-green-500/10 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                          <span class="text-green-600 text-xs">✓</span>
                      </div>
                      <div>
                          <h4 class="font-semibold text-sm">Employee Training</h4>
                          <p class="text-muted-foreground text-xs">Regular security training and confidentiality agreements for all team members</p>
                      </div>
                  </div>
                  <div class="flex items-start gap-3">
                      <div class="w-6 h-6 bg-green-500/10 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                          <span class="text-green-600 text-xs">✓</span>
                      </div>
                  <div>
                          <h4 class="font-semibold text-sm">Compliance Audits</h4>
                          <p class="text-muted-foreground text-xs">Regular security audits and vulnerability assessments</p>
                      </div>
                  </div>
              </div>
          </div>
      </section>

      <!-- Contact Information -->
      <section id="contact" class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Contact Information</h2>
          <p class="text-muted-foreground leading-8 mb-4">If you have questions about this Privacy Policy or need to exercise your privacy rights, please contact us:</p>
          
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <div class="grid gap-4 md:grid-cols-2">
                  <div>
                      <h3 class="font-semibold mb-3">Privacy Contact</h3>
                      <div class="space-y-2 text-sm text-muted-foreground">
                          <p><strong>Email:</strong> <a href="mailto:contact@omarfuentes.com" class="text-primary hover:underline">contact@omarfuentes.com</a></p>
                          <p><strong>Phone:</strong> +57 310 785 1074</p>
                          <p><strong>Response Time:</strong> Within 24 hours for privacy inquiries</p>
                      </div>
                  </div>
                  <div>
                      <h3 class="font-semibold mb-3">Business Information</h3>
                      <div class="space-y-2 text-sm text-muted-foreground">
                          <p><strong>Business:</strong> Omar Fuentes</p>
                          <p><strong>Service:</strong> Web Design, Development & SEO</p>
                          <p><strong>Service Area:</strong> United States (Remote)</p>
                      </div>
                  </div>
              </div>
          </div>
          
          <div class="mt-6 p-4 bg-blue-50 dark:bg-blue-950 rounded-xl">
              <p class="text-sm text-blue-800 dark:text-blue-200">
                  <strong>California Residents:</strong> If you are unsatisfied with our response to your privacy rights request, 
                  you can contact the California Privacy Protection Agency at <a href="https://cppa.ca.gov" class="text-blue-600 dark:text-blue-400 hover:underline" target="_blank">cppa.ca.gov</a>
              </p>
          </div>
      </section>

      <!-- Policy Updates -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">Policy Updates</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We may update this Privacy Policy periodically to reflect changes in our practices, legal requirements, 
              or business operations. Significant changes will be communicated through:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Email notifications to existing clients</li>
              <li>Website banners and announcements</li>
              <li>Direct communication for active projects</li>
          </ul>
          <p class="text-muted-foreground leading-8 mt-4">
              The "Last updated" date at the top of this page indicates when this policy was most recently modified.
          </p>
      </section>
  </Container>
</Layout>
