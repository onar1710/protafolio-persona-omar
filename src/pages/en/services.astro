---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, ArrowRight, Star, Clock, Award, Phone, MapPin, Target, Shield, Zap, Globe, TrendingUp, Calendar, Users, Briefcase, Home, Code, Smartphone, Search, BarChart, Hammer, Sparkles, Wrench, ShoppingCart, Palette, Camera, Dumbbell } from 'lucide-react';
---

<Layout title="Web Design Services | Omar Fuentes" description="Complete web design services for small businesses. Custom website design, responsive development, SEO optimization, and industry-specific solutions to help you grow your business online.">
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-blue-900 via-indigo-800 to-blue-900 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    
    <!-- Decorative circles -->
    <div class="absolute top-20 right-20 w-72 h-72 bg-blue-500 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-20 left-20 w-96 h-96 bg-indigo-500 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6 py-24">
      <div class="text-center">
        <h1 class="text-6xl md:text-7xl font-bold mb-8 text-white leading-tight">
          Web Design Services & Solutions
        </h1>
        
        <p class="text-xl text-white/90 max-w-3xl mx-auto mb-12">
          My web design services for small businesses are built to compete in today's market and help you stand out from your competitors.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <a href="mailto:contact@omarfuentes.com" class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-blue-500 to-blue-600 text-white px-10 py-5 font-semibold hover:from-blue-600 hover:to-blue-700 transition-all transform hover:scale-105 shadow-2xl text-lg">
            Get a Quote
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
          <a href="/en/contact" class="inline-flex items-center justify-center rounded-full border-2 border-white/30 text-white px-10 py-5 font-semibold hover:bg-white/10 transition-all text-lg backdrop-blur-sm">
            Contact Me
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed Services Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-8 text-gray-900">
          Complete Web Design Solutions
        </h2>
        <p class="text-xl text-gray-700 mb-12 max-w-3xl mx-auto">
          Professional web services covering every aspect of modern web development
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Custom Web Design Details -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-6">
            <Code className="w-6 h-6 text-white" />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Custom Web Design</h3>
          <p class="text-gray-700 mb-4">Creation of 100% personalized sites according to brand identity.</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2">
              <div class="w-5 h-5 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-2 h-2 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-gray-700 text-sm">UI/UX Design (Interface and User Experience)</span>
            </li>
            <li class="flex items-start gap-2">
              <div class="w-5 h-5 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-2 h-2 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-gray-700 text-sm">Wireframes and interactive prototypes</span>
            </li>
            <li class="flex items-start gap-2">
              <div class="w-5 h-5 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-2 h-2 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-gray-700 text-sm">User flows and journey maps</span>
            </li>
            <li class="flex items-start gap-2">
              <div class="w-5 h-5 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-2 h-2 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-gray-700 text-sm">Intuitive and user-centered interface design</span>
            </li>
          </ul>
        </div>

        <!-- Responsive Design -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
          <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-xl flex items-center justify-center mb-6">
            <Smartphone className="w-6 h-6 text-white" />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Responsive Web Design / Mobile First</h3>
