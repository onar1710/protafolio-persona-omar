        </div>
        
        <div class="group text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-yellow-600 to-yellow-700 rounded-2xl flex items-center justify-center mx-auto mb-8 group-hover:scale-110 transition-transform shadow-xl">
            <span class="text-3xl font-bold text-white">2</span>
