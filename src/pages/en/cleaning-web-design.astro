---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, ArrowRight, Star, Clock, Award, Phone, MapPin, Wrench, Droplets, Home, Wind, Calendar, Target, TrendingUp, Zap, Shield } from 'lucide-react';
---

<Layout title="Cleaning Company Web Design Services for Small Businesses | Omar Fuentes" description="Professional cleaning web design services for small businesses. Get more bookings, calls, and growth with fast, SEO-optimized websites that convert visitors into real clients.">
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-blue-900 via-blue-700 to-yellow-800 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-6 py-24">
      <div class="text-center">
        <!-- Badge -->
        <div class="inline-flex items-center bg-white/10 backdrop-blur-md rounded-full px-6 py-3 mb-8 border border-white/20">
          <Shield className="w-5 h-5 mr-2 text-yellow-400" />
          <span class="text-white text-sm font-semibold">Trusted by 50+ Cleaning Companies</span>
        </div>
        
        <h1 class="text-6xl md:text-7xl font-bold mb-8 text-white leading-tight">
          Cleaning Company Web Design Services for Small Businesses
        </h1>
        
        <!-- Value Proposition -->
        <div class="max-w-3xl mx-auto mb-12">
          <p class="text-xl text-white/90 mb-8 leading-relaxed">Get a professional website built for cleaning businesses that want more bookings, more calls, and consistent growth.</p>
          
          <!-- Social Proof -->
          <div class="flex flex-wrap items-center justify-center gap-8 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Star className="w-5 h-5 text-yellow-400 fill-yellow-400" />
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <TrendingUp className="w-5 h-5 text-green-400" />
              <span class="font-semibold">+200% More Leads</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Zap className="w-5 h-5 text-yellow-400" />
              <span class="font-semibold">3-7 Day Delivery</span>
            </div>
          </div>
        </div>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
          <a href="mailto:contact@omarfuentes.com" class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-yellow-500 to-yellow-600 text-white px-10 py-5 font-semibold hover:from-yellow-600 hover:to-yellow-700 transition-all transform hover:scale-105 shadow-2xl text-lg">
            Get Your Free Quote
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
          <a href="/en/portfolio" class="inline-flex items-center justify-center rounded-full border-2 border-white/30 text-white px-10 py-5 font-semibold hover:bg-white/10 transition-all text-lg backdrop-blur-sm">
            See Examples
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
        </div>
        
        <!-- Trust indicators -->
        <div class="text-white/70 text-sm flex items-center justify-center gap-2">
          <CheckCircle className="w-4 h-4" />
          <span>Free consultation • No obligation • Results guaranteed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry-Specific Section -->
  <section class="py-24 bg-gradient-to-br from-blue-50 to-yellow-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-yellow-100 rounded-full blur-3xl opacity-30"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-100 rounded-full blur-3xl opacity-30"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-5xl mx-auto text-center mb-16">
        <h2 class="text-5xl font-bold mb-8 text-black">Web Design for Cleaning Services That Generate Bookings</h2>
      </div>
      
      <!-- Problem/Solution Grid -->
      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Problem Card -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-xl border border-yellow-100 hover:shadow-2xl transition-all duration-300">
          <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center mr-4">
              <Target className="w-6 h-6 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-yellow-900">The Problem Most Cleaning Businesses Face:</h3>
          </div>
          <ul class="space-y-4 text-yellow-900">
            <li class="flex items-start">
              <span class="text-yellow-700 mr-3 mt-1 font-bold">•</span>
              <span class="text-lg font-medium text-black">No online visibility → missing potential clients</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-700 mr-3 mt-1 font-bold">•</span>
              <span class="text-lg font-medium text-black">Competitors ranking higher on Google</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-700 mr-3 mt-1 font-bold">•</span>
              <span class="text-lg font-medium text-black">Website doesn't convert visitors to bookings</span>
            </li>
          </ul>
        </div>
        
        <!-- Solution Card -->
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 shadow-xl border border-blue-100 hover:shadow-2xl transition-all duration-300">
          <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mr-4">
              <CheckCircle className="w-6 h-6 text-blue-600" />
            </div>
            <h3 class="text-2xl font-bold text-blue-900">Our Solution:</h3>
          </div>
          <div class="space-y-4 text-black">
            <p class="text-lg leading-relaxed font-medium">Your cleaning business needs more than just a website. You need a system that brings in new clients consistently.</p>
            <p class="text-lg leading-relaxed font-semibold">We create cleaning company web design solutions focused on generating quote requests, phone calls, and recurring customers for your business.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-24 bg-white relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-20 left-20 w-72 h-72 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-20 right-20 w-72 h-72 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-5xl font-bold mb-8 text-black">Why Cleaning Businesses Choose Our Web Design Services</h2>
        <p class="text-xl text-yellow-700 max-w-3xl mx-auto">Professional features designed specifically for the cleaning industry</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group bg-gradient-to-br from-white to-yellow-50 p-8 rounded-2xl shadow-lg border border-yellow-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
          <div class="w-16 h-16 bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <Target className="w-8 h-8 text-white" />
          </div>
