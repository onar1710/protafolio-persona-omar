  <!-- Results Section -->
  <section class="py-24 bg-gradient-to-br from-white to-blue-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-5xl mx-auto text-center mb-16">
        <h2 class="text-5xl font-bold mb-8 text-black">Get More Cleaning Clients Every Week</h2>
        <p class="text-xl text-blue-700 mb-8 leading-relaxed max-w-3xl mx-auto font-medium">
          A well-designed cleaning website helps you:
        </p>
      </div>
        
      <div class="max-w-5xl mx-auto bg-gradient-to-br from-white to-blue-50 rounded-3xl shadow-2xl p-12 border border-blue-100">
        <p class="text-xl text-blue-800 mb-10 text-center font-bold">Our cleaning web design services are focused on helping you:</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex items-center space-x-4 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-blue-600" />
            </div>
            <span class="text-black font-bold text-lg">Get more calls and quote requests</span>
          </div>
          
          <div class="flex items-center space-x-4 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-blue-600" />
            </div>
            <span class="text-black font-bold text-lg">Increase recurring customers</span>
          </div>
          
          <div class="flex items-center space-x-4 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-blue-600" />
            </div>
            <span class="text-black font-bold text-lg">Rank higher for local cleaning services</span>
          </div>
          
          <div class="flex items-center space-x-4 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
              <CheckCircle className="w-5 h-5 text-blue-600" />
            </div>
            <span class="text-black font-bold text-lg">Build trust with potential clients</span>
          </div>
        </div>
        
        <p class="text-lg text-blue-800 mt-10 text-center font-semibold">
          Your website becomes a 24/7 client acquisition system.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Section -->
  <section class="py-24 bg-gradient-to-br from-blue-50 to-yellow-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-20 right-20 w-80 h-80 bg-yellow-100 rounded-full blur-3xl opacity-30"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-5xl font-bold mb-8 text-black">Cleaning Company Web Design That Understands Your Business</h2>
        </div>
        
        <div class="bg-white rounded-3xl shadow-2xl p-12 border border-yellow-100">
          <div class="space-y-8 text-center">
            <p class="text-xl text-blue-800 leading-relaxed max-w-4xl mx-auto font-medium">
              We understand how cleaning businesses work. Whether you offer residential, commercial, carpet, or window cleaning, your website must clearly show your services and make it easy for customers to contact you.
            </p>
            <p class="text-xl text-blue-800 leading-relaxed max-w-4xl mx-auto font-bold">
              That's exactly what we build.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-24 bg-white relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
