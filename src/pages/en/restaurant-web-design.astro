            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-24 bg-gradient-to-br from-red-50 to-orange-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-10 right-10 w-80 h-80 bg-orange-100 rounded-full blur-3xl opacity-30"></div>
    
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
