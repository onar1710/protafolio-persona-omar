---
import Layout from '~/layouts-en/Layout.astro';
import { CheckCircle, ArrowRight, Star, Clock, Award, Phone, MapPin, Target, Shield, Zap, Globe, TrendingUp, Calendar, Utensils, ChefHat, Pizza, Coffee } from 'lucide-react';
---

<Layout title="Small Business Restaurant Web Design That Fills Tables & Boosts Online Orders | Omar Fuentes" description="Professional restaurant web design services for small businesses. Get more customers, online orders, and compete with big chains with fast, SEO-optimized websites.">
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-red-900 via-orange-900 to-red-900 text-white overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-6 py-24">
      <div class="text-center">
        <!-- Badge -->
        <div class="inline-flex items-center bg-white/10 backdrop-blur-md rounded-full px-6 py-3 mb-8 border border-white/20">
          <Utensils className="w-5 h-5 mr-2 text-orange-400" />
          <span class="text-white text-sm font-semibold">Trusted by 100+ Small Business Restaurants</span>
        </div>
        
        <h1 class="text-6xl md:text-7xl font-bold mb-8 text-white leading-tight">
          Small Business Restaurant Web Design That Fills Tables & Boosts Online Orders
        </h1>
        
        <!-- Value Proposition -->
        <div class="max-w-3xl mx-auto mb-12">
          <p class="text-xl text-white/90 mb-8 leading-relaxed">I design conversion-focused websites for small business restaurants that don't just look amazing—they turn visitors into paying customers. Let me help you compete with the big chains and grow your local restaurant business online.</p>
          
          <!-- Social Proof -->
          <div class="flex flex-wrap items-center justify-center gap-8 text-white/80">
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Star className="w-5 h-5 text-orange-400 fill-orange-400" />
              <span class="font-semibold">4.9/5 Rating</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <TrendingUp className="w-5 h-5 text-green-400" />
              <span class="font-semibold">+300% More Orders</span>
            </div>
            <div class="flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full">
              <Zap className="w-5 h-5 text-orange-400" />
              <span class="font-semibold">2-3 Week Delivery</span>
            </div>
          </div>
        </div>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-6 justify-center mb-12">
          <a href="https://wa.me/+1 (555) 123-4567?text=Hi%20Omar,%20I%20want%20a%20restaurant%20web%20design%20quote" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-orange-500 to-orange-600 text-white px-10 py-5 font-semibold hover:from-orange-600 hover:to-orange-700 transition-all transform hover:scale-105 shadow-2xl text-lg">
            Get Your Free Consultation
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
          <a href="mailto:contact@omarfuentes.com" class="inline-flex items-center justify-center rounded-full border-2 border-white/30 text-white px-10 py-5 font-semibold hover:bg-white/10 transition-all text-lg backdrop-blur-sm">
            See Examples
            <ArrowRight className="w-6 h-6 ml-3" />
          </a>
        </div>
        
        <!-- Trust indicators -->
        <div class="text-white/70 text-sm flex items-center justify-center gap-2">
          <CheckCircle className="w-4 h-4" />
          <span>Free consultation • No obligation • Results guaranteed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-24 bg-gradient-to-br from-red-50 to-orange-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-orange-100 rounded-full blur-3xl opacity-30"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-red-100 rounded-full blur-3xl opacity-30"></div>
    
