---
import Layout from '~/layouts-en/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

---

<Layout title="Refund Policy - Omar Fuentes" description="Refund Policy for Omar Fuentes web design and SEO services in the United States. Terms for refunds and cancellations.">
  
  <PageHeader 
      title="Refund Policy"
      description="Last updated: January 28, 2026"
  />

  <Container as="main" class="max-w-4xl mx-auto">
      
      <!-- 1. General Refund Policy -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">1. General Refund Policy</h2>
          <p class="text-muted-foreground leading-8 mb-6">
              At <span class="font-semibold text-foreground">Omar Fuentes</span>, we strive to provide exceptional web design,
              development, and SEO services. This refund policy outlines the conditions under which refunds may be issued
              for our services in the United States.
          </p>
          <p class="text-muted-foreground leading-8">
              Due to the custom nature of our services, refunds are only available under specific circumstances outlined below.
          </p>
      </section>

      <!-- 2. Deposit and Initial Payments -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">2. Deposit and Initial Payments</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Regarding deposits and initial payments:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">50% Deposit:</span> Required to begin all projects</li>
              <li><span class="font-semibold text-foreground">Non-refundable:</span> Deposits are non-refundable once work has begun</li>
              <li><span class="font-semibold text-foreground">Work Initiation:</span> Work begins within 2 business days of deposit receipt</li>
              <li><span class="font-semibold text-foreground">Project Cancellation:</span> Client may cancel within 24 hours for full deposit refund</li>
          </ul>
      </section>

      <!-- 3. Web Design and Development Services -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">3. Web Design and Development Services</h2>
          <p class="text-muted-foreground leading-8 mb-4">Refund policy for web design and development:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Design Phase:</span> Refunds available before development begins</li>
              <li><span class="font-semibold text-foreground">Development Phase:</span> No refunds once development has started</li>
              <li><span class="font-semibold text-foreground">Revisions:</span> Up to 3 major revisions included at no additional cost</li>
              <li><span class="font-semibold text-foreground">Deliverables:</span> Final payment required before delivery of completed website</li>
          </ul>
      </section>

      <!-- 4. SEO Services -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">4. SEO Services</h2>
          <p class="text-muted-foreground leading-8 mb-4">Refund policy for SEO services:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">No Ranking Guarantees:</span> SEO results cannot be guaranteed</li>
              <li><span class="font-semibold text-foreground">Monthly Services:</span> No refunds for monthly SEO services already rendered</li>
              <li><span class="font-semibold text-foreground">Service Delivery:</span> Refunds only if services are not delivered as specified</li>
              <li><span class="font-semibold text-foreground">Performance-Based:</span> No refunds based on ranking performance</li>
          </ul>
      </section>

      <!-- 5. Website Maintenance and Support -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">5. Website Maintenance and Support</h2>
          <p class="text-muted-foreground leading-8 mb-4">Refund policy for maintenance and support:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Monthly Plans:</span> Pro-rata refunds for unused months if service is cancelled</li>
              <li><span class="font-semibold text-foreground">Support Tickets:</span> No refunds for support tickets already addressed</li>
              <li><span class="font-semibold text-foreground">Service Level:</span> Refunds if service level agreements are not met</li>
          </ul>
      </section>

      <!-- 6. Refund Request Process -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">6. Refund Request Process</h2>
          <p class="text-muted-foreground leading-8 mb-4">To request a refund, please follow these steps:</p>
          <ol class="grid gap-2 pl-6 text-muted-foreground list-decimal">
              <li>Send a written request to <a href="mailto:contact@omarfuentes.com" class="text-primary hover:underline">contact@omarfuentes.com</a></li>
              <li>Include your project name, invoice number, and reason for refund</li>
              <li>Provide any supporting documentation</li>
              <li>Allow 5-7 business days for review and response</li>
          </ol>
      </section>

      <!-- 7. Valid Refund Reasons -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">7. Valid Refund Reasons</h2>
          <p class="text-muted-foreground leading-8 mb-4">Refunds may be issued for the following reasons:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Service Not Delivered:</span> If agreed services are not provided</li>
              <li><span class="font-semibold text-foreground">Significant Delay:</span> Projects delayed by more than 30 days without cause</li>
              <li><span class="font-semibold text-foreground">Quality Issues:</span> Deliverables that don't meet agreed specifications</li>
              <li><span class="font-semibold text-foreground">Cancellation Window:</span> Within 24 hours of deposit payment</li>
          </ul>
      </section>

      <!-- 8. Non-Refundable Items -->
      <section class="mb-16">
          <h2 class="text-2- font-bold mb-6">8. Non-Refundable Items</h2>
          <p class="text-muted-foreground leading-8 mb-4">The following items are non-refundable:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Deposits after work has begun</li>
              <li>Third-party costs (domains, hosting, premium plugins)</li>
              <li>SEO services already rendered</li>
              <li>Consultation hours already used</li>
              <li>Training sessions already conducted</li>
          </ul>
      </section>

      <!-- 9. Partial Refunds -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">9. Partial Refunds</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Partial refunds may be issued in the following circumstances:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Project Scope Reduction:</span> If client reduces project scope mid-project</li>
              <li><span class="font-semibold text-foreground">Partial Delivery:</span> If only some deliverables are completed</li>
              <li><span class="font-semibold text-foreground">Service Modifications:</span> If services are modified by mutual agreement</li>
          </ul>
      </section>

      <!-- 10. Refund Method -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">10. Refund Method</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Approved refunds will be processed as follows:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Original Payment Method:</span> Refunds issued to original payment method</li>
              <li><span class="font-semibold text-foreground">Processing Time:</span> 5-10 business days to appear in your account</li>
              <li><span class="font-semibold text-foreground">Fees:</span> Transaction fees may apply for certain payment methods</li>
          </ul>
      </section>

      <!-- 11. Dispute Resolution -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">11. Dispute Resolution</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              If you disagree with a refund decision:
          </p>
          <ol class="grid gap-2 pl-6 text-muted-foreground list-decimal">
              <li>First, contact us directly to resolve the issue</li>
              <li>We will review your case within 5 business days</li>
              <li>If unresolved, we may propose alternative solutions</li>
              <li>Final decision rests with Omar Fuentes management</li>
          </ol>
      </section>

      <!-- 12. State-Specific Requirements -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">12. State-Specific Requirements</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              Certain states have specific refund requirements:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">California:</span> Complies with California Consumer Protection Act</li>
              <li><span class="font-semibold text-foreground">Florida:</span> Follows Florida Deceptive and Unfair Trade Practices Act</li>
              <li><span class="font-semibold text-foreground">New York:</span> Adheres to New York General Business Law</li>
              <li><span class="font-semibold text-foreground">All States:</span> Complies with federal consumer protection laws</li>
          </ul>
      </section>

      <!-- 13. Policy Changes -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">13. Policy Changes</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We reserve the right to modify this refund policy:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Changes will be posted on our website</li>
              <li>Effective immediately upon posting</li>
              <li>Existing contracts governed by policy in effect at signing</li>
          </ul>
      </section>

      <!-- 14. Contact Information -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">14. Contact Information</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              For refund requests or questions about this policy, please contact us:
          </p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <div class="grid gap-2 text-muted-foreground">
                  <p>
                      <span class="font-semibold text-foreground">Business:</span> Omar Fuentes
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Service Area:</span> United States
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Phone:</span> +57 310 785 1074
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Email:</span> <a href="mailto:contact@omarfuentes.com" class="text-primary hover:underline">contact@omarfuentes.com</a>
                  </p>
              </div>
          </div>
      </section>
  </Container>
</Layout>
