---
import Layout from '../../layouts/LayoutEN.astro';

const timelineItems = [
  {
    date: '2018',
    title: 'Started in Development',
    description:
      'I began my journey learning HTML, CSS, and JavaScript. My first projects were personal sites to understand the fundamentals of web development.',
  },
  {
    date: '2019',
    title: 'First Professional Projects',
    description:
      'I started building sites for local businesses in Colombia, focusing on speed, structure, and clarity. I learned the importance of basic SEO and performance.',
  },
  {
    date: '2020',
    title: 'Frontend Specialization',
    description:
      'I deepened my knowledge in React and modern JavaScript. I developed more complex applications and understood the importance of component architecture.',
  },
  {
    date: '2021',
    title: 'SEO + Performance Focus',
    description:
      'I specialized in technical SEO, Core Web Vitals, and fast mobile experiences. Certifications in Google Analytics and performance optimization.',
  },
  {
    date: '2022',
    title: 'Full Stack Expansion',
    description:
      'I incorporated Node.js and backend into my skills. I could offer complete solutions and better understand the full web development cycle.',
  },
  {
    date: '2023',
    title: 'Websites That Convert',
    description:
      'I focused on landing pages and sites designed to convert visitors into leads and sales. I learned about user psychology and conversion rate optimization.',
  },
  {
    date: '2024',
    title: 'Design Systems',
    description:
      'I developed complete design systems to maintain consistency and scalability. Implemented design tokens and reusable components.',
  },
  {
    date: 'Today',
    title: 'Direct Work With You',
    description:
      'Freelance: clear communication, defined deliverables, and post-launch support. I specialize in projects that need measurable results.',
  },
];

const howIWork = [
  {
    title: 'Speed and Performance',
    description:
      'I optimize Core Web Vitals so your site loads in under 2 seconds. I implement lazy loading, code splitting, and image optimization to guarantee maximum speed.',
  },
  {
    title: 'Clean and Maintainable Code',
    description:
      'No patches or temporary solutions. Organized structure with reusable components and a professional approach so the project is easy to maintain.',
  },
  {
    title: 'Real Responsive Design',
    description:
      'I don\'t just adapt: I optimize the experience for each device. Mobile-first approach with layouts that adapt perfectly to mobiles, tablets, and desktop.',
  },
  {
    title: 'Advanced Technical SEO',
    description:
      'I implement metadata, basic schema when applicable, structure, and performance best practices so your site can compete and capture organic traffic.',
  },
  {
    title: 'Custom Development',
    description:
      'I choose the perfect technology for your project: Next.js for applications, Astro for ultra-fast sites, or WordPress to manage content easily.',
  },
  {
    title: 'Direct Communication',
    description:
      'I work directly with you, no intermediaries. Clear progress, quick decisions, and support after launch.',
  },
];

const expectations: Array<{ name: ExpectationName; role: string }> = [
  {
    name: 'Design & UX',
    role:
      'Clean, modern interfaces focused on conversion. Every element is designed to guide the user toward the desired action.',
  },
  {
    name: 'Development',
    role:
      'Fast implementation, clean code, and scalable architecture. I use best practices to guarantee optimal performance.',
  },
  {
    name: 'SEO & Performance',
    role:
      'Complete technical optimization: from Core Web Vitals to structure. Your site is prepared to compete and rank.',
  },
  {
    name: 'Continuous Support',
    role:
      'Post-launch accompaniment with maintenance, updates, and technical support. I don\'t leave you alone after launch.',
  },
];

type SkillItem = { name: string; levelLabel: string; pct: number; color: SkillBarColor };
type SkillGroup = { title: string; items: SkillItem[] };

const skillGroups: SkillGroup[] = [
  {
    title: 'Frontend',
    items: [
      { name: 'React/Next.js', levelLabel: 'Expert', pct: 95, color: 'blue' },
      { name: 'TypeScript', levelLabel: 'Advanced', pct: 85, color: 'blue' },
      { name: 'Tailwind CSS', levelLabel: 'Expert', pct: 90, color: 'blue' },
      { name: 'Astro', levelLabel: 'Advanced', pct: 80, color: 'blue' },
    ],
  },
  {
    title: 'Backend',
    items: [
      { name: 'Node.js', levelLabel: 'Advanced', pct: 80, color: 'green' },
      { name: 'REST APIs', levelLabel: 'Expert', pct: 85, color: 'green' },
      { name: 'WordPress', levelLabel: 'Advanced', pct: 75, color: 'green' },
      { name: 'Databases', levelLabel: 'Intermediate', pct: 70, color: 'green' },
    ],
  },
  {
    title: 'SEO & Performance',
    items: [
      { name: 'Technical SEO', levelLabel: 'Expert', pct: 95, color: 'purple' },
      { name: 'Core Web Vitals', levelLabel: 'Expert', pct: 90, color: 'purple' },
      { name: 'Schema Markup', levelLabel: 'Advanced', pct: 85, color: 'purple' },
      { name: 'Analytics', levelLabel: 'Advanced', pct: 80, color: 'purple' },
    ],
  },
];

const values = [
  {
    title: 'Transparency',
    description:
      'Honest communication about timelines, costs, and possibilities. No surprises or unrealistic promises.',
  },
  {
    title: 'Excellence',
    description:
      'I commit to quality in every detail. Every project should exceed expectations.',
  },
  {
    title: 'Responsibility',
    description:
      'I take full commitment with every project. Your success is my success and my reputation is at stake.',
  },
  {
    title: 'Innovation',
    description:
      'Always learning and applying the latest technologies to give you a real competitive advantage.',
  },
];

const achievements = [
  {
    title: '50+ Completed Projects',
    description: 'Websites launched and running for clients in Colombia and Latin America.',
    metaLeft: '2018-2024',
    metaRight: '95% satisfaction',
  },
  {
    title: 'Perfect Core Web Vitals',
    description: 'Multiple projects with 100/100 score on Google PageSpeed Insights.',
    metaLeft: '2023-2024',
    metaRight: 'Optimal performance',
  },
  {
    title: 'Top 3 on Google',
    description: 'Clients ranked in top positions for competitive keywords.',
    metaLeft: 'SEO',
    metaRight: 'Measurable results',
  },
  {
    title: 'Google Certifications',
    description: 'Certified in Analytics, SEO, and Performance Optimization by Google.',
    metaLeft: '2021',
    metaRight: 'Continuous learning',
  },
  {
    title: 'Design Systems',
    description: 'Development of complete design systems for companies and startups.',
    metaLeft: '2024',
    metaRight: 'Scalability',
  },
  {
    title: 'Mobile-First Apps',
    description: 'Progressive web applications with native experience on mobile.',
    metaLeft: 'PWA',
    metaRight: 'Advanced responsive',
  },
];

type SkillBarColor = 'blue' | 'green' | 'purple';

const barClass = (color: SkillBarColor): string =>
  color === 'green'
    ? 'from-primary-green to-accent-green'
    : color === 'purple'
      ? 'from-primary-blue via-primary-yellow to-primary-green'
      : 'from-primary-blue to-accent-blue';

type ExpectationName = 'Design & UX' | 'Development' | 'SEO & Performance' | 'Continuous Support';

const expectationIcon = (name: ExpectationName): string => {
  if (name === 'Design & UX') {
    return `
      <svg viewBox="0 0 64 64" aria-hidden="true" class="w-14 h-14">
        <defs>
          <linearGradient id="uxg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="var(--primary-blue)" />
            <stop offset="1" stop-color="var(--primary-yellow)" />
          </linearGradient>
        </defs>
        <rect x="10" y="12" width="44" height="32" rx="8" fill="url(#uxg)" opacity="0.25" />
        <rect x="14" y="16" width="36" height="24" rx="6" fill="none" stroke="var(--primary-blue)" stroke-width="3" />
        <circle cx="24" cy="28" r="3" fill="var(--primary-blue)" />
        <circle cx="32" cy="28" r="3" fill="var(--primary-blue)" />
        <path d="M38 30c2.5 2.5 6.5 2.5 9 0" fill="none" stroke="var(--primary-blue)" stroke-width="3" stroke-linecap="round" />
        <path d="M18 52h28" stroke="var(--primary-blue)" stroke-width="3" stroke-linecap="round" />
      </svg>
    `;
  }

  if (name === 'Development') {
    return `
      <svg viewBox="0 0 64 64" aria-hidden="true" class="w-14 h-14">
        <defs>
          <linearGradient id="devg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="var(--primary-green)" />
            <stop offset="1" stop-color="var(--primary-blue)" />
          </linearGradient>
        </defs>
        <rect x="10" y="12" width="44" height="40" rx="10" fill="url(#devg)" opacity="0.2" />
        <path d="M24 26l-8 6 8 6" fill="none" stroke="var(--primary-blue)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M40 26l8 6-8 6" fill="none" stroke="var(--primary-blue)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M34 24l-4 16" fill="none" stroke="var(--primary-green)" stroke-width="3" stroke-linecap="round" />
      </svg>
    `;
  }

  if (name === 'SEO & Performance') {
    return `
      <svg viewBox="0 0 64 64" aria-hidden="true" class="w-14 h-14">
        <defs>
          <linearGradient id="seog" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="var(--primary-blue)" />
            <stop offset="1" stop-color="var(--primary-green)" />
          </linearGradient>
        </defs>
        <circle cx="28" cy="28" r="14" fill="url(#seog)" opacity="0.2" />
        <circle cx="28" cy="28" r="10" fill="none" stroke="var(--primary-blue)" stroke-width="3" />
        <path d="M38 38l10 10" stroke="var(--primary-green)" stroke-width="4" stroke-linecap="round" />
        <path d="M20 30l4 4 10-12" fill="none" stroke="var(--primary-blue)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    `;
  }

  return `
    <svg viewBox="0 0 64 64" aria-hidden="true" class="w-14 h-14">
      <defs>
        <linearGradient id="supg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="var(--primary-yellow)" />
          <stop offset="1" stop-color="var(--primary-blue)" />
        </linearGradient>
      </defs>
      <path d="M32 12a16 16 0 1016 16A16 16 0 0032 12z" fill="url(#supg)" opacity="0.2" />
      <path d="M24 34l4 4 12-14" fill="none" stroke="var(--primary-green)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M20 50h24" stroke="var(--primary-blue)" stroke-width="3" stroke-linecap="round" />
      <path d="M26 50v-6m12 6v-6" stroke="var(--primary-blue)" stroke-width="3" stroke-linecap="round" />
    </svg>
  `;
};

const heroProfileSvg = `
  <svg viewBox="0 0 1200 750" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Omar Fuentes - Web Developer" class="w-full h-auto">
    <defs>
      <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#ffffff" />
        <stop offset="1" stop-color="#ffffff" />
      </linearGradient>
      <linearGradient id="ring" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="var(--primary-blue)" />
        <stop offset="0.5" stop-color="var(--primary-yellow)" />
        <stop offset="1" stop-color="var(--primary-green)" />
      </linearGradient>
      <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="18" stdDeviation="24" flood-color="#000" flood-opacity="0.12"/>
      </filter>

	  <clipPath id="avatarClip">
		<circle cx="360" cy="360" r="136" />
	  </clipPath>
    </defs>

    <rect width="1200" height="750" fill="url(#bg)"/>

    <circle cx="980" cy="140" r="220" fill="url(#ring)" opacity="0.10"/>
    <circle cx="180" cy="620" r="260" fill="url(#ring)" opacity="0.08"/>

    <g filter="url(#shadow)">
      <rect x="120" y="120" width="960" height="510" rx="40" fill="#ffffff"/>
    </g>

    <g transform="translate(0,0)">
      <circle cx="360" cy="360" r="160" fill="url(#ring)"/>
      <circle cx="360" cy="360" r="146" fill="#ffffff"/>
	  <image
		href="/foto-perfil-omar-fuentes.jpeg"
		x="224"
		y="224"
		width="272"
		height="272"
		clip-path="url(#avatarClip)"
		preserveAspectRatio="xMidYMid slice"
	  />
    </g>

    <text x="560" y="320" font-family="Inter, system-ui, -apple-system, sans-serif" font-size="56" font-weight="900" fill="#0F172A">Omar Fuentes</text>
    <text x="560" y="380" font-family="Inter, system-ui, -apple-system, sans-serif" font-size="30" font-weight="700" fill="#334155">Web Developer</text>
    <text x="560" y="430" font-family="Inter, system-ui, -apple-system, sans-serif" font-size="22" font-weight="600" fill="#475569">SEO • Performance • Conversion Design</text>

    <g transform="translate(560, 470)">
      <rect x="0" y="0" width="520" height="14" rx="7" fill="var(--gray-100)"/>
      <rect x="0" y="0" width="320" height="14" rx="7" fill="url(#ring)"/>
    </g>
  </svg>
`;

---

<Layout
  title="About | Omar Fuentes - Web Development Professional"
  description="Learn about Omar Fuentes, a professional web developer specializing in modern, fast, and SEO-optimized websites for small businesses in USA."
  keywords="about Omar Fuentes, web developer profile, professional web development, small business web services"
>
  <main class="py-16 md:py-24 lg:py-32 bg-white pt-24">
    <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-6xl">
      <a href="/en/" class="text-primary-blue font-semibold hover:underline">Back to home</a>

      <header class="mt-6 mb-12">
        <h1 class="text-4xl md:text-5xl font-black mb-4">About Me</h1>
        <p class="text-xl text-black max-w-3xl">
          Freelance web developer based in Colombia specializing in creating fast, SEO-optimized websites designed to convert.
        </p>
      </header>

      <section class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-black mb-4">Hi, I'm Omar</h2>
          <p class="text-black">
            I'm a passionate web developer based in Colombia, specializing in creating digital experiences that actually work. My journey began in 2018 and since then I've helped dozens of businesses and entrepreneurs establish their online presence with measurable results.
          </p>
          <p class="text-black mt-4">
            My philosophy is simple: <strong>no complications, no fluff, just results</strong>. I specialize in transforming ideas into fast websites, optimized for SEO from day one and designed to convert visitors into customers.
          </p>
          <p class="text-black mt-4">
            What sets me apart is my comprehensive approach: I don't just build websites, I understand your business, your market, and your goals. I work directly with you (no agencies or intermediaries) to ensure every line of code and every pixel is aligned with your objectives.
          </p>
          <p class="text-black mt-4">
            When I'm not coding, I'm probably learning about new technologies, optimizing the performance of some project, or enjoying a good coffee while planning the next great digital idea.
          </p>
        </div>

        <div class="bg-white rounded-3xl p-6 border border-gray-100 shadow-lg">
          <div class="rounded-2xl overflow-hidden">
            <div set:html={heroProfileSvg} />
          </div>
        </div>
      </section>

      <section class="mt-20">
        <h2 class="text-3xl md:text-4xl font-black mb-10 text-center">My Journey</h2>
        <div class="space-y-6">
          {timelineItems.map((item) => (
            <div class="card">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-14 text-primary-blue font-black">{item.date}</div>
                <div>
                  <h3 class="text-xl font-bold mb-2">{item.title}</h3>
                  <p class="text-black">{item.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-20">
        <h2 class="text-3xl md:text-4xl font-black mb-6 text-center">How I Work</h2>
        <p class="text-black text-center max-w-3xl mx-auto">
          My methodology is based on transparent communication, clear deliverables, and measurable results. Every project is unique, but the process follows these fundamental principles.
        </p>
        <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {howIWork.map((item) => (
            <div class="card">
              <h3 class="text-xl font-bold mb-2">{item.title}</h3>
              <p class="text-black">{item.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-20">
        <h2 class="text-3xl md:text-4xl font-black mb-6 text-center">What You Can Expect</h2>
        <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {expectations.map((m) => (
            <div class="bg-white rounded-2xl overflow-hidden transition-all duration-500 border border-gray-100 shadow-lg hover:shadow-2xl hover:-translate-y-2">
              <div class="relative aspect-video overflow-hidden">
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-green-50">
                  <div class="w-16 h-16 rounded-2xl bg-white shadow-lg flex items-center justify-center">
                    <div set:html={expectationIcon(m.name)} />
                  </div>
                </div>
              </div>
              <div class="p-6">
                <div class="font-bold text-lg mb-2">{m.name}</div>
                <p class="text-black text-sm">{m.role}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-20">
        <h2 class="text-3xl md:text-4xl font-black mb-6 text-center">My Technical Skills</h2>
        <p class="text-black text-center max-w-3xl mx-auto">
          Technologies and tools I master to create complete, high-performance web solutions.
        </p>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {skillGroups.map((group) => (
            <div class="card">
              <h3 class="text-xl font-bold mb-6">{group.title}</h3>
              <div class="space-y-4">
                {group.items.map((s) => (
                  <div>
                    <div class="flex justify-between mb-2">
                      <span class="text-sm font-semibold">{s.name}</span>
                      <span class="text-sm text-gray-600">{s.levelLabel}</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-3">
                      <div
                        class={`bg-gradient-to-r ${barClass(s.color)} h-3 rounded-full`}
                        style={`width: ${s.pct}%`}
                      ></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-20">
        <h2 class="text-3xl md:text-4xl font-black mb-6 text-center">My Values and Philosophy</h2>
        <p class="text-black text-center max-w-3xl mx-auto">
          These are the principles that guide every project and every line of code I write.
        </p>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {values.map((v) => (
            <div class="card text-center">
              <h3 class="text-lg font-bold mb-2">{v.title}</h3>
              <p class="text-black text-sm">{v.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-20">
        <h2 class="text-3xl md:text-4xl font-black mb-6 text-center">Achievements and Recognition</h2>
        <p class="text-black text-center max-w-3xl mx-auto">
          Some important milestones that mark my journey and the impact I've generated.
        </p>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {achievements.map((a) => (
            <div class="card">
              <h3 class="text-lg font-bold mb-2">{a.title}</h3>
              <p class="text-black text-sm mb-4">{a.description}</p>
              <div class="flex items-center gap-2 text-xs text-gray-600">
                <span class="px-2 py-1 rounded-full border border-gray-200">{a.metaLeft}</span>
                <span>•</span>
                <span>{a.metaRight}</span>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>
