---
import Layout from '~/layouts-en/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

---

<Layout title="Privacy Policy - Omar Fuentes" description="Privacy Policy of Jose Omar Fernandez Fuentes. Personal data protection according to applicable regulations.">
  
  <PageHeader 
      title="Privacy Policy"
      description="Last updated: January 28, 2026"
  />

  <Container as="main" class="max-w-4xl mx-auto">
      
      <!-- 1. General Information -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">1. General Information</h2>
          <p class="text-muted-foreground leading-8 mb-6">
              This Privacy Policy describes how <span class="font-semibold text-foreground">Jose Omar Fernandez Fuentes</span>{" "}
              (hereinafter "we", "our" or "the website") collects, uses, and protects the personal information
              you provide when using our website and web design, SEO, and programming services.
          </p>

          <p class="font-semibold text-foreground mb-4">Data Controller:</p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <dl class="grid gap-4 text-muted-foreground">
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Name</dt>
                      <dd>Jose Omar Fernandez Fuentes</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">NIT</dt>
                      <dd>3-1091452824</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Address</dt>
                      <dd>Floridablanca, Santander, Colombia</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Phone</dt>
                      <dd>+57 310 785 1074</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Email</dt>
                      <dd>joseomarfernandez747@gmail.com</dd>
                  </div>
              </dl>
          </div>
      </section>

      <!-- 2. Information We Collect -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">2. Information We Collect</h2>

          <h3 class="text-xl font-semibold mb-4">2.1 Voluntarily Provided Information</h3>
          <p class="text-muted-foreground leading-8 mb-4">When you contact us or request our services, we may collect:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Full name</li>
              <li>Email address</li>
              <li>Phone number</li>
              <li>Company or organization name</li>
              <li>Information about your project or service needs</li>
              <li>Any other information you decide to share voluntarily</li>
          </ul>

          <h3 class="text-xl font-semibold mb-4 mt-8">2.2 Automatically Collected Information</h3>
          <p class="text-muted-foreground leading-8 mb-4">When you visit our website, we may automatically collect:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>IP address</li>
              <li>Browser and device type</li>
              <li>Pages visited and browsing time</li>
              <li>Referral source (how you found our site)</li>
              <li>Cookie data and similar technologies</li>
          </ul>
      </section>

      <!-- 3. How We Use Your Information -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">3. How We Use Your Information</h2>
          <p class="text-muted-foreground leading-8 mb-4">We use the collected information to:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Respond to your inquiries and service requests</li>
              <li>Provide quotes and business proposals</li>
              <li>Communicate about ongoing projects</li>
              <li>Improve our services and user experience</li>
              <li>Send relevant information about our services (only with your consent)</li>
              <li>Comply with legal and tax obligations</li>
              <li>Perform statistical analysis and website improvements</li>
          </ul>
      </section>

      <!-- 4. Legal Basis for Data Processing -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">4. Legal Basis for Data Processing</h2>
          <p class="text-muted-foreground leading-8 mb-4">We process your personal data under the following legal bases:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Consent:</span> When you voluntarily provide your information</li>
              <li><span class="font-semibold text-foreground">Contract execution:</span> For the provision of requested services</li>
              <li><span class="font-semibold text-foreground">Legitimate interest:</span> To improve our services and commercial communication</li>
              <li><span class="font-semibold text-foreground">Legal obligation:</span> To comply with tax and legal requirements in Colombia</li>
          </ul>
      </section>

      <!-- 5. Sharing Information with Third Parties -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">5. Sharing Information with Third Parties</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              We do not sell, rent, or share your personal information with third parties, except in the following cases:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>
                  <span class="font-semibold text-foreground">Service providers:</span> We may share information with providers who help us operate
                  our business (hosting services, email marketing, payment processing), always under confidentiality agreements.
              </li>
              <li><span class="font-semibold text-foreground">Legal requirements:</span> When required by law or competent authorities.</li>
              <li><span class="font-semibold text-foreground">With your consent:</span> When you expressly authorize sharing your information.</li>
          </ul>
      </section>

      <!-- 6. Cookies and Similar Technologies -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">6. Cookies and Similar Technologies</h2>
          <p class="text-muted-foreground leading-8">
              Our website uses cookies and similar technologies. For more information, please see our{" "}
              <a class="font-semibold text-primary hover:underline" href="/cookies-policy">
                  Cookies Policy
              </a>
              .
          </p>
      </section>

      <!-- 7. Information Security -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">7. Information Security</h2>
          <p class="text-muted-foreground leading-8 mb-6">
              We implement appropriate technical and organizational security measures to protect your personal information against unauthorized access,
              loss, destruction, or alteration. However, no method of transmission over the Internet is 100% secure.
          </p>
          <p class="font-semibold text-foreground mb-4">Security measures include:</p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>Encrypted SSL/TLS connections</li>
              <li>Restricted access to personal data</li>
              <li>Regular backups</li>
              <li>Constant security system updates</li>
          </ul>
      </section>

      <!-- 8. Data Retention -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">8. Data Retention</h2>
          <p class="text-muted-foreground leading-8">
              We retain your personal information only as long as necessary for the purposes described in this policy or as required by Colombian law.
              Client data is retained during the business relationship and up to 5 years afterward for tax and legal purposes.
          </p>
      </section>

      <!-- 9. Your Rights -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">9. Your Rights</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              In accordance with applicable regulations, you have the right to:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Access</span> your personal data we hold</li>
              <li><span class="font-semibold text-foreground">Rectify</span> inaccurate or incomplete information</li>
              <li><span class="font-semibold text-foreground">Update</span> your personal data</li>
              <li><span class="font-semibold text-foreground">Erase</span> your data when appropriate</li>
              <li><span class="font-semibold text-foreground">Withdraw</span> consent for data processing</li>
              <li><span class="font-semibold text-foreground">Inquire</span> what personal data we have about you</li>
              <li><span class="font-semibold text-foreground">File complaints</span> with the relevant authority</li>
          </ul>
          <p class="text-muted-foreground leading-8 mb-4">
              To exercise these rights, you can contact us through:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Email:</span> joseomarfernandez747@gmail.com</li>
              <li><span class="font-semibold text-foreground">Phone:</span> +57 310 785 1074</li>
          </ul>
          <p class="text-muted-foreground leading-8">We will respond to your request within a maximum of 15 business days.</p>
      </section>

      <!-- 10. International Transfers -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">10. International Transfers</h2>
          <p class="text-muted-foreground leading-8">
              Some of our service providers (such as hosting services or email tools) may be located outside Colombia.
              We ensure that these providers comply with adequate data protection standards.
          </p>
      </section>

      <!-- 11. Minors -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">11. Minors</h2>
          <p class="text-muted-foreground leading-8">
              Our services are not directed to persons under 18 years of age. We do not intentionally collect personal information from minors.
              If you are a parent and believe your child has provided us with personal information, please contact us immediately.
          </p>
      </section>

      <!-- 12. Links to Third-Party Sites -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">12. Links to Third-Party Sites</h2>
          <p class="text-muted-foreground leading-8">
              Our website may contain links to third-party sites. We are not responsible for the privacy practices of these sites.
              We recommend reviewing their privacy policies.
          </p>
      </section>

      <!-- 13. Changes to This Policy -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">13. Changes to This Policy</h2>
          <p class="text-muted-foreground leading-8">
              We may update this Privacy Policy occasionally. The "Last updated" date at the beginning of this page indicates when the last
              modification was made. Significant changes will be notified on our website.
          </p>
      </section>

      <!-- 14. Marketing and Communications -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">14. Marketing and Communications</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              If you have given consent to receive marketing communications, you can withdraw it at any time:
          </p>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li>By clicking "Unsubscribe" in our emails</li>
              <li>By contacting us directly at joseomarfernandez747@gmail.com</li>
          </ul>
      </section>

      <!-- 15. Contact -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">15. Contact</h2>
          <p class="text-muted-foreground leading-8 mb-4">
              If you have questions, concerns, or requests related to this Privacy Policy or the processing of your personal data, you can contact us:
          </p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6 mb-8">
              <p class="font-semibold text-foreground mb-4">Jose Omar Fernandez Fuentes</p>
              <div class="grid gap-2 text-muted-foreground">
                  <p>
                      <span class="font-semibold text-foreground">Address:</span> Floridablanca, Santander, Colombia
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Phone:</span> +57 310 785 1074
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">Email:</span> joseomarfernandez747@gmail.com
                  </p>
                  <p>
                      <span class="font-semibold text-foreground">NIT:</span> 3-1091452824
                  </p>
              </div>
          </div>
      </section>
  </Container>
</Layout>
