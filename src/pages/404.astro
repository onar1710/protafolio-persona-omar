---
import LayoutEs from '~/layouts/Layout.astro';
import LayoutEn from '~/layouts-en/Layout.astro';
import { getLangFromUrl, useTranslations } from '~/i18n/utils';

Astro.response.status = 404;

const lang = getLangFromUrl(new URL(Astro.request.url));
const t = useTranslations(lang);

const Layout = lang === 'en' ? LayoutEn : LayoutEs;
---

<Layout title={t['404.title']} description={t['404.description']}>
  <div class="min-h-[100vh] flex flex-col items-center justify-center text-center relative overflow-hidden pt-0">
      <!-- Background Effect -->
      <div class="absolute inset-0 z-0 flex items-center justify-center opacity-20 pointer-events-none">
          <div class="w-[600px] h-[600px] bg-red-500/20 rounded-full blur-[120px]"></div>
      </div>

      <div class="relative z-10 px-6">
        <h1 class="text-9xl font-display font-bold text-black/10 dark:text-white/10 mb-4 select-none">404</h1>
        <h2 class="text-4xl md:text-5xl font-display font-bold mb-6">{t['404.heading']}</h2>
        <p class="text-xl text-muted-foreground max-w-lg mx-auto mb-10">
            {t['404.description']}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href={lang === 'en' ? '/en' : '/'}
              class="px-8 py-3 bg-primary text-black font-medium rounded-full hover:bg-primary/90 transition-all hover:scale-105"
            >
              {t['404.backHome']}
            </a>
            <a 
              href="https://wa.me/573107851074?text=Hola%20Omar,%20encontré%20un%20enlace%20roto%20en%20tu%20sitio%20web"
              target="_blank"
              rel="noopener noreferrer"
              class="px-8 py-3 bg-foreground/5 text-foreground font-medium rounded-full hover:bg-foreground/10 transition-all border border-foreground/10 dark:text-white dark:border-white/10 dark:hover:bg-white/10"
            >
              {t['404.reportIssue']}
            </a>
        </div>
      </div>
  </div>
</Layout>
