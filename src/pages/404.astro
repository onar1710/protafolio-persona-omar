---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada (404) | Omar Fuentes" description="La página que buscas no existe o fue movida. Vuelve al inicio para seguir navegando.">
	<Fragment slot="head">
		<meta name="robots" content="noindex, nofollow" />
	</Fragment>
	<main class="pt-48 pb-24" style="background: var(--white);">
		<div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12">
			<section class="py-10 md:py-14">
				<div class="max-w-3xl">
					<p class="text-sm font-black mb-3" style="color: var(--primary-blue);">Error 404</p>
					<h1 class="text-4xl md:text-6xl font-black mb-4 text-black">Página no encontrada</h1>
					<p class="text-lg md:text-xl text-black mb-8">
						Es posible que el enlace esté mal escrito o que la página haya cambiado de URL.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href="/" class="btn-primary" style="text-decoration: none;">Ir a la Home</a>
						<a href="/portfolio/proyectos/" class="btn-secondary" style="text-decoration: none;">Ver Proyectos</a>
					</div>
				</div>
			</section>
		</div>
	</main>
</Layout>
