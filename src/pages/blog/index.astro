---
import { getCollection, type CollectionEntry } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';

type BlogEntry = CollectionEntry<'blog'>;

const posts = (await getCollection('blog'))
	.filter((post: BlogEntry) => !post.id.startsWith('en/'))
	.sort((a: BlogEntry, b: BlogEntry) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const seoPosts = new Set([
	'que-es-page-rank',
	'que-son-los-enlaces-nofollow-funcion-uso-estrategia-seo',
	'como-escribir-articulos-seo-guia-completa',
	'sitios-web-que-crean-backlinks-para-ti',
	'como-conseguir-backlinks-para-tu-sitio-web',
	'autoridad-de-dominio',
	'algoritmo-de-google',
	'mejores-agencias-servicio-seo-organico-colombia',
	'diseno-web-seo',
]);

const disenoWebPosts = new Set([
	'optimizar-imagenes-para-web',
	'como-posicionar-mi-web-en-los-primeros-lugares-de-google',
]);

const postCategory = (id: string): 'disenoweb' | 'seo' | 'marketing' | 'social' => {
	if (id.startsWith('seo/')) return 'seo';
	if (id.startsWith('disenoweb/')) return 'disenoweb';
	if (id.startsWith('marketing-digital/')) return 'marketing';
	if (id.startsWith('social-media/')) return 'social';
	if (seoPosts.has(id)) return 'seo';
	if (disenoWebPosts.has(id)) return 'disenoweb';
	return 'disenoweb';
};

const postUrl = (id: string) => {
	if (id.startsWith('seo/')) return `/seo/${id.slice('seo/'.length)}/`;
	if (id.startsWith('disenoweb/')) return `/disenoweb/${id.slice('disenoweb/'.length)}/`;
	if (id.startsWith('marketing-digital/'))
		return `/marketing-digital/${id.slice('marketing-digital/'.length)}/`;
	if (id.startsWith('social-media/')) return `/social-media/${id.slice('social-media/'.length)}/`;
	return `/blog/${id}/`;
};

---

<Layout
  title="Blog | Omar Fuentes"
  description="Artículos y guías sobre diseño y desarrollo web, SEO y rendimiento para negocios en Colombia."
  keywords="blog diseño web, blog desarrollo web, blog SEO, páginas web Colombia"
>
  <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl pt-24">
  <div class="mb-12">
    <a href="/" class="text-primary-blue font-semibold hover:underline">Volver al inicio</a>
    <h1 class="text-3xl md:text-5xl font-black mt-4 mb-4">Blog</h1>
    <p class="text-black max-w-3xl">
      Ideas y guías prácticas sobre diseño y desarrollo de páginas web, SEO y velocidad para hacer crecer negocios reales.
    </p>
  </div>

  <div class="flex flex-wrap gap-3 mb-10">
    <a
      href="/blog/?cat=disenoweb"
      data-blog-tab="disenoweb"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      Diseño web
    </a>
    <a
      href="/blog/?cat=seo"
      data-blog-tab="seo"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      SEO
    </a>
    <a
      href="/blog/?cat=marketing"
      data-blog-tab="marketing"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      Marketing digital
    </a>
    <a
      href="/blog/?cat=social"
      data-blog-tab="social"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      Social media
    </a>
    <a
      href="/blog/"
      data-blog-tab="all"
      class="px-4 py-2 rounded-full border font-bold text-sm"
      style="border-color: rgba(0,0,0,0.12); background: var(--white); color: var(--black); text-decoration: none;"
    >
      Ver todo
    </a>
  </div>

  <div data-search-status class="hidden mb-8 rounded-2xl border border-blue-100 bg-blue-50 p-5 text-black"></div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {posts.map((post: BlogEntry) => (
      <a
        href={postUrl(post.id)}
        data-blog-card
        data-blog-category={postCategory(post.id)}
        data-blog-search={`${post.data.title} ${post.data.description} ${post.data.tags?.join(' ') ?? ''} ${postCategory(post.id)}`.toLowerCase()}
        data-blog-tags={`${post.data.tags?.join(' ') ?? ''}`.toLowerCase()}
        class="bg-white rounded-2xl overflow-hidden transition-all duration-500 border border-gray-100 shadow-lg hover:shadow-2xl hover:-translate-y-2 block"
        style="text-decoration: none;"
      >
        {post.data.heroImage && (
          <div class="relative aspect-video overflow-hidden">
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        )}

        <div class="p-6">
          <div class="text-sm text-black mb-3">
            <FormattedDate date={post.data.pubDate} />
          </div>
          <h2 class="text-2xl font-black mb-3">{post.data.title}</h2>
          <p class="text-black">{post.data.description}</p>
          <div class="mt-6 text-primary-blue font-semibold">Leer artículo</div>
        </div>
      </a>
    ))}
  </div>
</div>

<script is:inline>
  (() => {
    const normalize = (value) =>
      String(value || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .trim();

    const params = new URLSearchParams(window.location.search);
    const cat = params.get('cat');
    const q = normalize(params.get('q') || '');
    const words = q.split(/\s+/).filter(Boolean);

    const cards = Array.from(document.querySelectorAll('[data-blog-card]'));
    const status = document.querySelector('[data-search-status]');
    let visibleCount = 0;

    for (const card of cards) {
      const cardCat = card.getAttribute('data-blog-category');
      const cardText = normalize(card.getAttribute('data-blog-search') || '');
      const cardTags = normalize(card.getAttribute('data-blog-tags') || '');
      const matchesCat = !cat || cat === 'all' || cardCat === cat;
      const matchesSearch =
        !q ||
        cardText.includes(q) ||
        cardTags.includes(q) ||
        words.some((word) => word.length > 2 && (cardText.includes(word) || cardTags.includes(word)));
      const shouldShow = matchesCat && matchesSearch;
      (card).style.display = shouldShow ? '' : 'none';
      if (shouldShow) visibleCount += 1;
    }

    if (status && q) {
      status.classList.remove('hidden');
      status.innerHTML = visibleCount
        ? `<strong>Resultados relacionados:</strong> encontré ${visibleCount} artículo${visibleCount === 1 ? '' : 's'} para tu búsqueda.`
        : `<strong>No encontré coincidencias exactas.</strong> Prueba con otra palabra relacionada como SEO, backlinks, diseño web o rendimiento.`;
    }

    const tabs = Array.from(document.querySelectorAll('[data-blog-tab]'));
    for (const tab of tabs) {
      const tabCat = tab.getAttribute('data-blog-tab');
      if (tabCat === cat) {
        tab.style.background = 'var(--primary-blue)';
        tab.style.borderColor = 'var(--primary-blue)';
        tab.style.color = 'var(--white)';
      }
    }
  })();
</script>

  </Layout>
