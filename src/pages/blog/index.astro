---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

---

<Layout
  title="Blog | Omar Fuentes"
  description="Artículos y guías sobre diseño y desarrollo web, SEO y rendimiento para negocios en Colombia."
  keywords="blog diseño web, blog desarrollo web, blog SEO, páginas web Colombia"
>
  <div class="px-6 md:px-8 lg:px-12 mx-auto max-w-7xl pt-24">
  <div class="mb-12">
    <a href="/" class="text-primary-blue font-semibold hover:underline">Volver al inicio</a>
    <h1 class="text-3xl md:text-5xl font-black mt-4 mb-4">Blog</h1>
    <p class="text-black max-w-3xl">
      Ideas y guías prácticas sobre diseño y desarrollo de páginas web, SEO y velocidad para hacer crecer negocios reales.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {posts.map((post) => (
      <a
        href={`/blog/${post.id}/`}
        class="bg-white rounded-2xl overflow-hidden transition-all duration-500 border border-gray-100 shadow-lg hover:shadow-2xl hover:-translate-y-2 block"
        style="text-decoration: none;"
      >
        {post.data.heroImage && (
          <div class="relative aspect-video overflow-hidden">
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        )}

        <div class="p-6">
          <div class="text-sm text-black mb-3">
            <FormattedDate date={post.data.pubDate} />
          </div>
          <h2 class="text-2xl font-black mb-3">{post.data.title}</h2>
          <p class="text-black">{post.data.description}</p>
          <div class="mt-6 text-primary-blue font-semibold">Leer artículo</div>
        </div>
      </a>
    ))}
  </div>
</div>

  </Layout>
