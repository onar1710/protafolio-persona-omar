import menosTiempoCargaImage from '~/assets/images/resultados/menos-tiempo-carga-web.jpg';
import primeraPaginaGoogleImage from '~/assets/images/resultados/primera-pagina-google.jpg';
import googleLogoImage from '~/assets/images/logo-google.png';
import BlogCard from '~/components/blog/BlogCard.astro';
import Layout from '~/layouts/Layout.astro';
import Schema from '~/components/layout/Schema.astro';
import Hero from '~/components/sections/Hero.astro';
import Section from '~/components/layout/Section.astro';
// posts execution moved to LatestPosts component
import LatestPosts from '~/components/sections/LatestPosts.astro';
import BentoGrid from '~/components/sections/BentoGrid.astro';
import BentoItem from '~/components/ui/BentoItem.astro';
import { Cpu, Globe, Zap, BarChart, ShieldCheck, Settings, FileCode, Search, Moon, Eye, ArrowRight, Mail, Phone, MessageCircle, CheckCircle, Clock, Lock, Rocket, Star } from 'lucide-react';
import FeaturesList from '~/components/sections/FeaturesList.astro';
import FeatureItem from '~/components/ui/FeatureItem.astro';
import Container from '~/components/ui/Container.astro';

import Testimonials from '~/components/sections/Testimonials.astro';
import Testimonial from '~/components/ui/Testimonial.astro';
import Stats from '~/components/sections/Stats.astro';
import StatItem from '~/components/ui/StatItem.astro';
import CTA from '~/components/sections/CTA.astro';
import FAQ from '~/components/sections/FAQ.astro';
import LogoCloud from '~/components/sections/LogoCloud.astro';
import TechStack from '~/components/sections/TechStack.astro';
import OpenSourceNotification from '~/components/common/OpenSourceNotification.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang = defaultLang } = Astro.params;
const t = useTranslations(lang);

const latestBlogPosts = (await getCollection('blog'))
  .filter((post) => !post.id.includes('/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const logos = [
  { name: 'Vite', src: 'https://vitejs.dev/logo.svg', description: t['logo.vite.desc'] },
  { name: 'Cloudflare', src: '/cloudflare-logo.svg', description: t['logo.cloudflare.desc'] },
  { name: 'Astro', src: 'https://astro.build/assets/press/astro-logo-dark.svg', description: t['logo.astro.desc'] },
  { name: 'React', src: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg', width: 512, height: 512, description: t['logo.react.desc'] },
  { name: 'Tailwind CSS', src: '/tailwind-logo.svg', description: t['logo.tailwind.desc'] },
  { name: 'Framer Motion', src: '/framer-motion.png', description: t['logo.framer.desc'] },
];

const googleReviewsUrl = 'https://share.google/URJBIY6tzhrTMEJXL';

const googleReviews = [
  {
    author: 'Ayeuri Melo Sanchez',
    rating: 5,
    text: 'De los mejores desarrolladores que he conocido, me hizo una página web de consultoría para Republica Dominicana y quedo fenomenal, lo recomiendo al 100%'
  },
  {
    author: 'Plomeria Aquaimperio',
    rating: 5,
    text: 'Omar muchas gracias por su servicios me gusto mucho la página, recomedadicimo, sabe hacer muy bien su trabajo y muy atento a los detalles, gracias omar por ese gran trabajo'
  },
  {
    author: 'Jorge Capacho',
    rating: 5,
    text: 'Omar parcero le quiero dar las gracias por su apoyo su trabajo la página web quedó como la quería gracias a usted puedo seguir con mi Emprendimiento lleno éxitos y bendiciones, recomiendo su trabajo'
  },
  {
    author: 'Jaime Mantilla',
    rating: 5,
    text: 'Muy profesionales son excelentes para la creación de páginas me ayudó con mi emprendimiento de venta de cuentas de Indrive recomendado'
  },
  {
    author: 'Gladys Hernández',
    rating: 5,
    text: 'Contraté a Omar para armar mi sitio web de productos para perros. Necesitaba algo profesional para vender collares,...'
  },
  {
    author: 'David',
    rating: 5,
    text: 'Hola me pareció muy profesional, es muy dedicado me sorprendió que en 4 días ya tenía mi web de negocios casi lista lo recomiendo abiertamente'
  },
