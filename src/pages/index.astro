	                <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center mb-4">
	                    <Cpu className="w-6 h-6 text-white" />
	                </div>
	                <h3 class="text-2xl font-bold mb-2">Sitios rápidos y listos para SEO</h3>
	                <p class="text-muted-foreground text-sm">Core Web Vitals, arquitectura limpia y enfoque en conversión.</p>
	                </div>
	        </BentoItem>

	        <!-- Small Item 1 -->
	        <BentoItem class="relative overflow-hidden flex flex-col justify-center text-center hover:bg-white/10 transition-colors">
	            <Image
	                src={traficoOrganicoImage}
	                alt="+120% Tráfico Orgánico"
	                class="absolute inset-0 w-full h-full object-cover opacity-25"
	                loading="lazy"
	                decoding="async"
	                widths={[447, 894]}
	                sizes="447px"
	            />
	            <div class="absolute inset-0 bg-black/40"></div>
	            <div class="relative z-10">
	                <div class="w-12 h-12 rounded-full bg-blue-500/20 text-blue-400 flex items-center justify-center mx-auto mb-4">
	                    <Zap className="w-6 h-6" />
	                </div>
	                <h3 class="text-lg font-bold">+120% Tráfico Orgánico</h3>
	                <p class="text-sm text-muted-foreground mt-2">Promedio en 1-2 meses</p>
	            </div>
	        </BentoItem>

	        <!-- Small Item 2 -->
	        <BentoItem class="relative overflow-hidden flex flex-col justify-center text-center hover:bg-white/10 transition-colors">
