
---
import { languages, defaultLang } from '~/i18n/ui';
import { isRtl, useTranslations } from '~/i18n/utils';
import { Image } from 'astro:assets';
import bentoCode from '~/assets/bento-code.jpg';
import searchImage from '~/assets/blog/search.jpg';
import resultadosMediblesImage from '~/assets/images/resultados/resultados-medibles.jpg';
