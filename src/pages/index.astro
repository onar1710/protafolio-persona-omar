	                <div class="absolute bottom-0 left-0 w-full h-1/2 bg-linear-to-t from-black/50 to-transparent z-10"></div>
	                <Image
	                    src={sitiosRapidosImage}
	                    alt="Sitios rápidos y listos para SEO"
	                    class="absolute inset-0 w-full h-full object-cover object-center opacity-55 group-hover:scale-105 transition-transform duration-700"
	                    loading="lazy"
	                    decoding="async"
	                    widths={[447, 894]}
	                    sizes="447px"
	                />
	                
