---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from '../layouts/Layout.astro';

// Datos de proyectos del portafolio
const featuredProjects = [
  {
    title: "LEEXMS SRL",
    description: "Transformación digital contable con Next.js 14 y SEO avanzado",
    image: "/images-portfolio/caso-estudio-web-leexms.png",
    tags: ["Next.js", "SEO", "Servicios Profesionales"],
    url: "/portfolio/leexms",
    stats: ["15+ páginas", "95+ PageSpeed", "1 semana"]
  },
  {
    title: "Ferrarycucina",
    description: "Portafolio visual de remodelaciones que genera 4-5 cotizaciones semanales",
    image: "/images-portfolio/proyecto-imagen-ferrarycucina.png",
    tags: ["Diseño Web", "Next.js", "Local SEO"],
    url: "/portfolio/ferrarycucina",
    stats: ["4-5 cotizaciones/semana", "Primer página Google"]
  },
  {
    title: "Productos Perros",
    description: "Tienda eCommerce de mascotas con experiencia de compra optimizada",
    image: "/images-portfolio/proyecto-imagen-productosperros.png",
    tags: ["eCommerce", "Logística", "Marketing"],
    url: "/portfolio/productos-para-perros",
    stats: ["Envíos rápidos", "Clientes satisfechos"]
  },
  {
    title: "Mundo Gaming",
    description: "Tienda gaming con 100+ productos, blog de reseñas y Amazon Associates",
    image: "/images-portfolio/proyecto-imagen-omarytplay.png",
    tags: ["eCommerce", "Next.js", "Amazon Associates"],
    url: "/portfolio/mundo-gaming",
    stats: ["100+ productos", "15 categorías", "95/100 Lighthouse"]
  },
  {
    title: "Plomería Aqua Imperio",
    description: "Servicios de plomería en Bogotá con SEO local y tecnología Ridgid",
    image: "/images-portfolio/proyecto-imagen-plemria.png",
    tags: ["Servicios Locales", "SEO Local", "HTML5"],
    url: "/portfolio/plomeria",
    stats: ["15+ páginas", "SEO local completo", "1 semana desarrollo"]
  },
  {
    title: "BitcoinForWifi",
    description: "Medio editorial sobre Bitcoin y tecnología construido con Astro, categorías y SEO técnico",
    image: "/images-portfolio/caso-bitcoinforwifi.png",
    tags: ["Astro", "Tailwind CSS", "SEO Editorial"],
    url: "/portfolio/bitcoinforwifi",
    stats: ["6 categorías", "Vercel", "SSG ultra rápido"]
  },
  {
    title: "Akboheim Editorial",
    description: "Medio editorial de literatura y cultura con arquitectura por secciones, newsletter y base legal completa",
    image: "/images-portfolio/caso-akboheim.png",
    tags: ["Astro", "SEO Editorial", "Contenido"],
    url: "/portfolio/akboheim",
    stats: ["6 secciones", "Newsletter", "Vercel"]
  },
  {
    title: "BG GREEK",
    description: "Medio editorial de recetas, dieta y fitness con Astro, Tailwind, SEO técnico y búsqueda integrada",
    image: "/images-portfolio/caso-bg-greek.png",
    tags: ["Astro", "Tailwind CSS", "SEO Editorial"],
    url: "/portfolio/bggreek",
    stats: ["4 secciones", "Búsqueda", "Vercel"]
  },
  {
    title: "Mora Cleaning",
    description: "Servicios de limpieza residencial en Tennessee con paquetes claros, SEO local y CTAs para cotizar",
    image: "/images-portfolio/caso-moracleaning.png",
    tags: ["SEO Local", "Servicios", "Astro"],
    url: "/portfolio/moracleaning",
    stats: ["3 paquetes", "5+ servicios", "TN, USA"]
  },
  ];

// Servicios principales basados en la experiencia real
const services = [
  {
    title: "Diseño y Desarrollo Web con SEO",
    description: "Sitios web profesionales optimizados para Google desde el día 1",
    features: ["Diseño responsive (móvil, tablet, desktop)", "SEO técnico completo", "Velocidad optimizada (Core Web Vitals)", "Arquitectura de contenido para ranking", "Schema markup y metadatos", "Google Analytics configurado"],
    color: "blue",
    ideal: "Negocios locales en Cali, Medellín y Bogotá que necesitan visibilidad online"
  },
  {
    title: "Tiendas eCommerce optimizadas",
    description: "Tiendas online diseñadas para vender con experiencia de compra que convierte",
    features: ["Catálogo de productos optimizado", "Carrito y checkout fluido", "Pasarelas de pago integradas", "Diseño que genera confianza", "Velocidad extrema de carga", "SEO para productos"],
    color: "yellow",
    ideal: "Emprendedores y empresas que venden productos online"
  },
  {
    title: "Rediseño Web + Optimización SEO",
    description: "¿Tu sitio actual es lento, anticuado o no aparece en Google? Lo transformo completamente",
    features: ["Auditoría completa del sitio actual", "Rediseño moderno y profesional", "Mejora de velocidad (60-80% más rápido)", "Optimización SEO técnico", "Migración sin perder posiciones", "Mantenimiento y soporte incluido"],
    color: "green",
    ideal: "Empresas con sitio actual que no genera resultados"
  }
];

const posts = (await getCollection('blog')).filter((post) => !post.id.startsWith('en/') && post.data.draft !== true);

// Filtrar solo artículos con fecha <= hoy
const today = new Date();
today.setHours(23, 59, 59, 999); // Incluir todo el día de hoy

const publishedPosts = posts.filter((post) => {
	const postDate = new Date(post.data.pubDate);
	return postDate <= today;
});

// Agrupar artículos por etiqueta y tomar el más reciente de cada una
const postsByTag = new Map();
publishedPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.forEach((post) => {
		if (post.data.tags && post.data.tags.length > 0) {
			const mainTag = post.data.tags[0]; // Primera etiqueta del artículo
			if (!postsByTag.has(mainTag)) {
				postsByTag.set(mainTag, post);
			}
		}
	});

// Convertir a array y limitar a 9 artículos únicos por etiqueta
const latestPosts = Array.from(postsByTag.values()).slice(0, 9);

const postUrl = (id: string) => {
	if (id.startsWith('seo/')) return `/seo/${id.slice('seo/'.length)}/`;
	if (id.startsWith('disenoweb/')) return `/disenoweb/${id.slice('disenoweb/'.length)}/`;
	if (id.startsWith('marketing-digital/')) return `/marketing-digital/${id.slice('marketing-digital/'.length)}/`;
	if (id.startsWith('social-media/')) return `/social-media/${id.slice('social-media/'.length)}/`;
	return `/blog/${id}/`;
};
---

<Layout 
  title="Blog de SEO y Diseño Web en Colombia | Omar Fuentes" 
  description="Guías prácticas de SEO, diseño web y marketing digital para negocios en Colombia. Aprende a posicionar tu web en Google y conseguir más clientes. Freelancer SEO y desarrollador web."
  keywords="blog seo colombia, diseño web colombia, posicionar web google, seo para negocios, freelancer seo, desarrollador web colombia, marketing digital, guias seo gratis"
>
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "url": "https://www.omarfuentes.com/",
      "name": "Blog de SEO y Diseño Web en Colombia | Omar Fuentes",
