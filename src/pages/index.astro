---

<Layout title="Diseño y Desarrollo Web en Colombia | Omar Fuentes" description="Diseño y desarrollo de páginas web. Creo sitios web modernos, responsivos, profesionales que rankean en Google y con SEO incluido. Cargan rápido y convierten visitantes en clientes reales. Para negocios en Colombia. +120% tráfico orgánico comprobado. Cotiza gratis." keywords="diseño y desarrollo web, diseño web colombia, diseño web cali, diseño web medellin, diseño web bogota, paginas web colombia, desarrollador web freelance, seo tecnico, optimizacion web, landing page, tienda online, ecommerce, desarrollo web colombia, posicionamiento google, sitios web rapidos, web design colombia, freelancer colombia">
    <Fragment slot="head">
    </Fragment>
    <Schema item={{
            "@context": "https://schema.org",
            "@type": "WebSite",
            "@id": `${Astro.site}#website`,
            "url": Astro.site,
            "name": "Omar Fuentes - Diseño y Desarrollo Web en Colombia",
            "description": "Ayudo a negocios en Colombia a tener sitios web profesionales que rankean en Google y convierten visitantes en clientes. Servicios de diseño y desarrollo web modernos.",
            "inLanguage": "es-CO",
            "isAccessibleForFree": true,
            "potentialAction": {
                "@type": "SearchAction",
                "target": {
                    "@type": "EntryPoint",
                    "urlTemplate": `${Astro.site}/search?q={search_term_string}`
                },
                "query-input": "required name=search_term_string"
            },
            "publisher": {
                "@id": `${Astro.site}#organization`
            }
        }} />
    <Schema item={{
            "@context": "https://schema.org",
