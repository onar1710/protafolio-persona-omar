	                src={primeraPaginaGoogleImage}
	                alt="Primera página en Google"
	                class="absolute inset-0 w-full h-full object-cover opacity-25"
	                loading="lazy"
	                decoding="async"
	                widths={[447, 894, 900]}
	                sizes="(max-width: 768px) 447px, 900px"
	            />
	            <div class="absolute inset-0 bg-black/40"></div>
	            <div class="relative z-10">
	                    <h3 class="text-2xl font-bold mb-2">Primera página en Google</h3>
	                    <p class="text-muted-foreground max-w-sm">SEO técnico + contenido bien estructurado para competir en búsquedas locales.</p>
