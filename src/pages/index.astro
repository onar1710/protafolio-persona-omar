                "@id": `${Astro.site}#organization`
            },
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Cali",
                "addressRegion": "Valle del Cauca",
                "addressCountry": "CO"
            },
            "sameAs": [
                "https://www.linkedin.com/in/omarfuentes052/",
                "https://github.com/onar1710",
                "https://twitter.com/omarfuentes052",
                "https://www.facebook.com/omarfuentes052",
                "https://www.youtube.com/@OmarFuentes052"
