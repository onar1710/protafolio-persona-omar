	                class="absolute inset-0 w-full h-full object-cover opacity-25"
	                loading="lazy"
	                decoding="async"
	                widths={[447, 894]}
	                sizes="447px"
	            />
	            <div class="absolute inset-0 bg-black/40"></div>
	            <div class="relative z-10">
	                <div class="w-12 h-12 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center mx-auto mb-4">
	                    <ShieldCheck className="w-6 h-6" />
