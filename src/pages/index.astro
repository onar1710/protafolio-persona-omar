	                        Ver servicio SEO
	                    </a>
	            </div>
	            <div class="relative z-10 w-32 h-32 shrink-0 bg-linear-to-tr from-purple-950 to-indigo-900 rounded-2xl flex items-center justify-center shadow-lg transform rotate-6 group-hover:rotate-12 transition-transform">
	                <Image
	                    src={googleLogoImage}
	                    alt="Google"
	                    width={96}
	                    height={96}
	                    class="w-24 h-24 object-contain"
	                    loading="lazy"
	                    decoding="async"
	                />
	            </div>
	        </BentoItem>
	    </BentoGrid>
	    </Section>

