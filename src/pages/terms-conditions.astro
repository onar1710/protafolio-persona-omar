---
import Layout from '~/layouts-en/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';

---

<Layout title="Terms and Conditions - Omar Fuentes" description="Terms and Conditions of Use of Jose Omar Fernandez Fuentes. Contracting of web design, SEO, and programming services.">
  
  <PageHeader 
      title="Terms and Conditions of Use"
      description="Last updated: January 28, 2026"
  />

  <Container as="main" class="max-w-4xl mx-auto">
      
      <!-- 1. Acceptance of Terms -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">1. Acceptance of Terms</h2>
          <p class="text-muted-foreground leading-8 mb-6">
              Welcome to the website of <span class="font-semibold text-foreground">Jose Omar Fernandez Fuentes</span>. By accessing and using this website and our
              web design, SEO, and programming services, you agree to comply with these Terms and Conditions. If you do not agree with any part of these
              terms, please do not use our website or our services.
          </p>

          <p class="font-semibold text-foreground mb-4">Service Provider:</p>
          <div class="rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 p-6">
              <dl class="grid gap-4 text-muted-foreground">
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Name</dt>
                      <dd>Jose Omar Fernandez Fuentes</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">NIT</dt>
