      <!-- 20. General Provisions -->
      <section class="mb-16">
          <h2 class="text-2xl font-bold mb-6">20. General Provisions</h2>
          <ul class="grid gap-2 pl-6 text-muted-foreground list-disc">
              <li><span class="font-semibold text-foreground">Divisibility:</span> if any provision is invalid, others remain in effect</li>
              <li><span class="font-semibold text-foreground">Assignment:</span> rights cannot be transferred without written consent</li>
              <li><span class="font-semibold text-foreground">Entire agreement:</span> these terms and specific contract constitute the agreement</li>
              <li><span class="font-semibold text-foreground">Waiver:</span> not exercising a right does not imply waiver of that right</li>
