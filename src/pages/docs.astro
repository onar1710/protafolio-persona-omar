---
import Layout from '../layouts/Layout.astro';

const docs = [
	{
		label: 'PDF',
		title: 'Website Design & Culture',
		description: 'Relación entre cultura y diseño web.',
		href: '/docs/website_design_and_culture.pdf',
	},
	{
		label: 'PDF',
		title: 'Localization of Web Design',
		description: 'Localización aplicada al diseño web.',
		href: '/docs/localization_of_webdesign.pdf',
	},
	{
		label: 'PDF',
		title: 'Emerging Challenges',
		description: 'Retos emergentes en web/localización.',
		href: '/docs/emerging_challenges.pdf',
	},
	{
		label: 'PDF',
		title: 'Cyr 2008: Modelling',
		description: 'Modelado y variables en diseño/localización.',
		href: '/cyr2008_modelling.pdf',
	},
	{
		label: 'PDF',
		title: 'PR: CKNW',
		description: 'Documento PR (CKNW).',
		href: '/docs/pr_cknw.pdf',
	},
];
---

<Layout title="Docs | Omar Fuentes" description="Documentación práctica: problemas reales de indexación y rendimiento en frameworks modernos.">
	<main class="pt-24 pb-20 bg-white">
		<div class="px-6 md:px-8 lg:px-12 mx-auto max-w-5xl">
			<header class="mb-10">
				<h1 class="text-4xl md:text-5xl font-black mb-4">Docs</h1>
				<p class="text-black text-lg max-w-3xl">
					Papers y PDFs en formato de tarjetas para lectura y referencia rápida.
				</p>
			</header>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{docs.map((doc, idx) => {
					const pillClass =
						idx % 2 === 0
							? 'bg-primary-blue text-white group-hover:bg-accent-blue'
							: 'bg-primary-green text-white group-hover:bg-accent-green';

					return (
						<div class="group rounded-2xl border border-gray-200 bg-white shadow-sm p-6 hover:shadow-lg transition-all">
							<div class="rounded-xl bg-gradient-to-r from-primary-blue via-primary-yellow to-primary-green text-white px-4 py-3 mb-4">
								<div class="text-xs font-semibold opacity-90">{doc.label}</div>
								<div class="text-xl font-black">{doc.title}</div>
							</div>
							<div class="text-sm text-gray-700">{doc.description}</div>
							<div class="mt-6 flex flex-wrap gap-3">
								<a
									href={doc.href}
									target="_blank"
									rel="noopener noreferrer"
									class={`inline-flex items-center justify-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold transition-colors ${pillClass}`}
								>
									Abrir
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
									</svg>
								</a>
								<a
									href={doc.href}
									download
									class="inline-flex items-center justify-center gap-2 rounded-full border border-gray-200 bg-white text-black px-5 py-2.5 text-sm font-semibold hover:border-gray-300 hover:bg-gray-50 transition-colors"
								>
									Descargar
								</a>
							</div>
						</div>
					);
				})}
			</div>
		</div>
	</main>
</Layout>
