---
import Layout from '~/layouts/Layout.astro';
import Container from '~/components/ui/Container.astro';
import Grid from '~/components/ui/Grid.astro';
import Button from '~/components/ui/Button.astro';
import LandingQuoteForm from '~/components/islands/LandingQuoteForm.jsx';
import Schema from '~/components/layout/Schema.astro';
import { CheckCircle2, Star, ArrowRight, Zap, ChevronLeft, ChevronRight } from 'lucide-react';
import { siteConfig } from '~/site.config';
import { Image } from 'astro:assets';
import googleLogoImage from '~/assets/images/logo-google.png';

const title = 'Diseñador Web Freelance Colombia: Diseños Rápidos y Baratos | Omar Fuentes';
const description = 'Diseñador web freelance en Colombia. Sitios profesionales con SEO incluido que aumentan ventas y rankean en Google. Trabajo 1-a-1, sin agencias. ¡Cotiza gratis!';
const keywords = 'diseñador web freelance, diseñador web freelance colombia, contratar diseñador web freelance, diseñador web freelance cali, diseñador web freelance bogota, diseñador web freelance medellin, diseñador web freelance barranquilla, freelance diseño web';
const image = '/images/landing-page/diseñadores-web-profesional.png';

const whatsappLink = 'https://wa.me/573107851074?text=Hola%20Omar,%20quiero%20cotizar%20un%20sitio%20web.%20Vengo%20desde%20la%20landing%20de%20Disenador%20Web%20Freelance%20Profesional.';
const emailLink = `mailto:contacto@omarfuentes.com?subject=${encodeURIComponent('Cotización - Diseño Web Profesional')}`;
---

<Layout title={title} description={description} keywords={keywords} image={image}>
    <Fragment slot="head">
        <Schema item={{
            "@context": "https://schema.org",
            "@type": "Person",
            "name": "Omar Fuentes",
            "jobTitle": "Diseñador Web Freelance",
            "description": "Diseñador web freelance en Colombia. Creo sitios profesionales para aumentar tus ventas y tu presencia en Google con SEO incluido que rankean. Trabajo directo 1-a-1, sin agencias.",
            "url": Astro.url,
            "image": new URL(image, Astro.site).toString(),
            "sameAs": [
                "https://wa.me/573107851074",
                "mailto:contacto@omarfuentes.com"
            ],
            "knowsAbout": [
                "Diseño Web Freelance",
                "Diseño Web Freelance Colombia", 
                "Contratar Diseñador Web Freelance",
                "Freelance Diseño Web",
                "SEO Técnico",
                "Desarrollo Web Profesional"
            ],
            "offers": {
                "@type": "Offer",
                "serviceType": "Diseño Web Freelance",
                "description": "Sitios web profesionales con SEO incluido que rankean en Google",
                "priceCurrency": "COP",
                "price": "600000",
                "availability": "https://schema.org/InStock",
                "areaServed": [
                    "Colombia",
                    "Cali",
                    "Bogotá", 
                    "Medellín",
                    "Barranquilla"
                ]
            },
            "contactPoint": {
                "@type": "ContactPoint",
                "telephone": "+57-310-785-1074",
                "contactType": "customer service",
                "email": "contacto@omarfuentes.com",
                "availableLanguage": ["Spanish"]
            }
        }} />
        
        <Schema item={{
            "@context": "https://schema.org",
            "@type": "Service",
            "name": "Diseño Web Freelance en Colombia",
            "description": "Servicio de diseño web freelance para crear sitios profesionales que aumentan ventas y rankean en Google con SEO incluido",
            "provider": {
                "@type": "Person",
                "name": "Omar Fuentes"
            },
            "serviceType": "Diseño Web Profesional",
            "keywords": "diseñador web freelance, diseñador web freelance colombia, contratar diseñador web freelance, freelance diseño web",
            "areaServed": "Colombia",
            "hasOfferCatalog": {
                "@type": "OfferCatalog",
                "name": "Servicios de Diseño Web",
                "itemListElement": [
                    {
                        "@type": "Offer",
                        "itemOffered": {
                            "@type": "Service",
                            "name": "Diseño Web Corporativo",
                            "description": "Sitios profesionales para empresas con SEO técnico completo"
                        }
                    },
                    {
                        "@type": "Offer", 
                        "itemOffered": {
                            "@type": "Service",
                            "name": "Tiendas eCommerce",
                            "description": "Plataformas de venta online optimizadas para conversiones"
                        }
                    },
                    {
                        "@type": "Offer",
                        "itemOffered": {
                            "@type": "Service", 
                            "name": "Landing Pages para Ads",
                            "description": "Páginas de alta conversión optimizadas para Google Ads"
                        }
                    }
                ]
            }
        }} />
    </Fragment>
  <div class="min-h-screen bg-background">
    <section class="relative overflow-hidden pt-28 pb-10">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/15 via-transparent to-purple-500/10"></div>
      <div class="pointer-events-none absolute -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-primary/15 blur-[110px]"></div>
      <div class="pointer-events-none absolute -bottom-48 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-purple-500/10 blur-[110px]"></div>

      <Container as="div" class="relative">
        <Grid cols={2} class="items-center gap-10">
          <div class="order-2 md:order-1">
            <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs text-muted-foreground">
              <Zap className="h-4 w-4 text-primary" />
              Freelance diseño web con entrega en 4-10 días
            </div>

            <h1 class="text-4xl md:text-6xl font-display font-bold leading-tight">
              Diseñador Web Freelance en Colombia
            </h1>

            <p class="mt-5 text-lg md:text-xl text-muted-foreground max-w-xl">
              Soy Omar Fuentes, diseñador web freelance en Colombia especializado en crear sitios optimizados para aumentar tus ventas. Tu marca merece una presencia online profesional que hable por ti. Creo diseños web optimizados para aumentar tu tráfico orgánico con SEO técnico comprobado.
