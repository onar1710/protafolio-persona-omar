            </div>
            
            <!-- React -->
            <div class="w-12 h-12 md:w-24 md:h-24 flex items-center justify-center">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg" alt="React" width="96" height="96" loading="lazy" decoding="async" class="h-10 md:h-16 w-auto object-contain" />
            </div>
            
            <!-- Tailwind CSS -->
