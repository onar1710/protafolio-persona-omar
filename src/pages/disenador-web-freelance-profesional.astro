                  href="#cotizar"
                  class="w-full sm:w-auto justify-center"
                >
                  Cotización Gratis
                  <ArrowRight className="h-4 w-4" />
                </Button>

                <Button
                  variant="outline"
                  size="lg"
                  href={whatsappLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full sm:w-auto justify-center"
                >
                  WhatsApp
                </Button>
              </div>
            </div>

            <div class="mt-8 grid gap-3 text-sm">
              <div class="flex items-start gap-3">
                <CheckCircle2 className="h-5 w-5 text-green-500 mt-0.5" />
                <span><span class="font-semibold text-foreground">20+ proyectos web exitosos entregados en Colombia.</span></span>
              </div>
              <div class="flex items-start gap-3">
                <CheckCircle2 className="h-5 w-5 text-green-500 mt-0.5" />
                <span><span class="font-semibold text-foreground">Especialista en diseños web y conversión de ventas.</span></span>
              </div>
              <div class="flex items-start gap-3">
                <CheckCircle2 className="h-5 w-5 text-green-500 mt-0.5" />
                <span><span class="font-semibold text-foreground">Respuesta en 5 minutos - ¡contrátame ya!</span></span>
              </div>
              <div class="flex items-start gap-3">
                <CheckCircle2 className="h-5 w-5 text-green-500 mt-0.5" />
                <span><span class="font-semibold text-foreground">Entrega 4-10 días (landing, corporativa, ecommerce).</span></span>
              </div>
              <div class="flex items-start gap-3">
                <CheckCircle2 className="h-5 w-5 text-green-500 mt-0.5" />
                <span><span class="font-semibold text-foreground">Soporte post-lanzamiento para ajustes rápidos.</span></span>
              </div>
              <div class="flex items-start gap-3">
                <CheckCircle2 className="h-5 w-5 text-green-500 mt-0.5" />
                <span><span class="font-semibold text-foreground">Hosting gratis 1 año + dominio incluido.</span></span>
