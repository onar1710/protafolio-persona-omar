              <div class="mb-4">
                <h2 class="text-xl font-bold">Contratar diseñador web freelance - Omar Fuentes</h2>
                <p class="mt-1 text-sm text-muted-foreground">
                  4 datos. Respuesta en 5 minutos.
                </p>
              </div>

              <LandingQuoteForm client:load />

              <p class="mt-4 text-xs text-muted-foreground">
