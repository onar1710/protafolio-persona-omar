            </div>
            
            <!-- WooCommerce -->
            <div class="w-12 h-12 md:w-24 md:h-24 flex items-center justify-center">
              <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/woocommerce/woocommerce-original.svg" alt="WooCommerce" width="96" height="96" loading="lazy" decoding="async" class="h-12 md:h-20 w-auto object-contain" />
            </div>
          </div>
      </Container>
    </section>

    <section class="py-10">
      <Container as="div">
        <div class="text-center mb-8">
