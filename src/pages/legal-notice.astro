                      <dd>+57 310 785 1074</dd>
                  </div>
                  <div class="grid gap-1">
                      <dt class="text-sm font-semibold text-foreground">Email</dt>
                      <dd>joseomarfernandez747@gmail.com</dd>
                  </div>
