---
import Layout from '~/layouts-en/Layout.astro';
import { ArrowRight, Star, Users, TrendingUp } from 'lucide-react';

const projects = [
  {
    title: 'LEEXMS SRL',
    description: 'My digital accounting transformation in Dominican Republic. Next.js 14, advanced SEO and legal compliance in 1 week.',
    image: '/images/caso-estudio-web-leexms.png',
    tags: ["Next.js 14", "Advanced SEO", "Professional Services"],
    link: '/en/portfolio/leexms',
    stats: ['15+ pages', '95+ PageSpeed', '1 week development'],
    url: 'https://leexms.com/',
    rel: 'noopener noreferrer nofollow'
  },
  {
    title: 'Ferrarycucina',
    description: 'My flagship remodeling project. Visual portfolio that generates 4-5 weekly quotes in Bogotá.',
    image: '/images/proyecto-imagen-ferrarycucina.png',
    tags: ["Web Design", "Next.js", "Local SEO"],
    link: '/en/portfolio/ferrarycucina',
    stats: ['4-5 quotes/week', 'First page Google']
  },
  {
    title: 'Dog Products',
    description: 'Pet eCommerce store with fast shipping and optimized shopping experience.',
    image: '/images/proyecto-imagen-productosperros.png',
    tags: ["eCommerce", "Logistics", "Marketing"],
    link: '/en/portfolio/productos-para-perros',
    stats: ['Fast shipping', 'Satisfied customers']
  },
  {
    title: 'Gaming World',
    description: 'My converting gaming store: 100+ products, review blog and Amazon Associates.',
    image: '/images/proyecto-imagen-omarytplay.png',
    tags: ["eCommerce", "Next.js", "Amazon Associates"],
    link: '/en/portfolio/mundo-gaming',
    stats: ['100+ products', '15 categories', '95/100 Lighthouse']
  },
  {
    title: 'Aqua Empire Plumbing',
    description: 'Plumbing services in Bogotá. Specialized site with local SEO and Ridgid technology.',
    image: '/images/proyecto-imagen-plemria.png',
    tags: ["Local Services", "Local SEO", "HTML5"],
    link: '/en/portfolio/plomeria',
    stats: ['15+ pages', 'Complete local SEO', '1 week development']
  }
];

const stats = [
  { icon: Users, label: 'Satisfied Clients', value: '50+' },
  { icon: Star, label: 'Completed Projects', value: '100+' },
  { icon: TrendingUp, label: 'Success Rate', value: '98%' }
];

---

<Layout title="Web Projects Portfolio - Omar Fuentes | Web Design USA" description="Successful web projects portfolio in USA: eCommerce, corporate sites and online stores. Real results: +120% organic traffic, first page Google." keywords="web portfolio USA, web projects california, ecommerce new york, websites los angeles, web developer portfolio, web success stories, online stores USA, web page design, ecommerce projects USA">
	<div class="max-w-7xl mx-auto px-6 pt-32 pb-12">
        <!-- Hero Section -->
        <div class="text-center mb-20">
            <h1 class="text-4xl md:text-6xl font-display font-bold mb-6">
                My <span class="text-primary">Projects</span>
            </h1>
            <p class="text-xl text-muted-foreground max-w-3xl mx-auto mb-8">
                As a freelance web developer, I transform ideas into successful digital products. Each project reflects my commitment to technical excellence and user-centered design.
            </p>
            <div class="flex flex-wrap gap-4 justify-center">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-500/10 text-green-700 dark:text-green-300 border border-green-500/20 backdrop-blur-sm">
                    <Star class="w-4 h-4 mr-1" /> Quality Guaranteed
                </span>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-700 dark:text-blue-300 border border-blue-500/20 backdrop-blur-sm">
                    <TrendingUp class="w-4 h-4 mr-1" /> Measurable Results
                </span>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-500/10 text-purple-700 dark:text-purple-300 border border-purple-500/20 backdrop-blur-sm">
                    <Users class="w-4 h-4 mr-1" /> Happy Clients
                </span>
            </div>
        </div>

        <!-- Stats Section -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
            {stats.map((stat) => (
                <div class="text-center p-8 rounded-2xl border border-foreground/10 bg-background hover:border-primary/50 transition-all">
                    <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mx-auto mb-4">
                        <stat.icon class="w-6 h-6" />
                    </div>
                    <div class="text-3xl font-bold text-foreground mb-2">{stat.value}</div>
                    <div class="text-muted-foreground">{stat.label}</div>
                </div>
            ))}
        </div>

        <!-- Projects Grid -->
        <div class="mb-16">
            <h2 class="text-3xl font-bold mb-8">Featured Projects</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {projects.map((project) => (
                    <a href={project.link} class="group block relative overflow-hidden rounded-3xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="aspect-[4/3] w-full overflow-hidden">
                            <img 
                                src={project.image} 
                                alt={project.title} 
                                width="1200"
                                height="900"
                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                loading="lazy"
                                decoding="async"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
                        </div>
                        
                        <div class="absolute bottom-0 left-0 w-full p-8 translate-y-2 group-hover:translate-y-0 transition-transform duration-500 bg-black/50 backdrop-blur-md">
                            <div class="flex flex-wrap gap-2 mb-3 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                                {project.tags.map(tag => (
                                    <span class="text-xs font-medium px-2 py-1 rounded-full bg-white/10 text-white backdrop-blur-sm border border-white/20">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                            
                            <h3 class="text-2xl font-display font-bold text-white mb-2">{project.title}</h3>
                            <p class="text-white/80 text-sm line-clamp-2 group-hover:text-white transition-colors mb-3">
                                {project.description}
                            </p>
                            
                            <div class="flex flex-wrap gap-2">
                                {project.stats.map(stat => (
                                    <span class="text-xs text-green-300 font-medium">
                                        {stat}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>

        <!-- CTA Section -->
        <div class="text-center p-12 rounded-2xl border border-foreground/10 bg-gradient-to-br from-primary/5 to-primary/10">
            <h2 class="text-3xl font-bold mb-4">Ready for your next project?</h2>
            <p class="text-muted-foreground max-w-2xl mx-auto mb-8">
                As your freelance web developer, I transform your vision into reality with modern, fast, and scalable solutions that drive your business.
            </p>
            <a 
                href="https://wa.me/573107851074?text=Hi%20Omar,%20I%20saw%20your%20portfolio%20and%20want%20to%20develop%20my%20project.%20Can%20we%20talk?"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-black rounded-xl hover:bg-primary/90 transition-all text-lg font-semibold shadow-lg shadow-primary/20 hover:shadow-primary/30"
            >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.149-.67.149-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 2.16 3.916c2.359 2.359 4.734 2.359 5.511 2.359.297 0 .644-.074.792-.223.148-.148.671-.671.796-1.263.125-.592.125-1.099.084-1.203-.041-.104-.173-.165-.37-.264z"/>
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                </svg>
                Talk on WhatsApp
            </a>
        </div>
	</div>
</Layout>
