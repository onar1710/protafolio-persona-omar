---
import Layout from '~/layouts-en/Layout.astro';
import { ArrowRight, ExternalLink, Clock, TrendingUp, Users, CheckCircle, Globe, BarChart, Award } from 'lucide-react';

const project = {
  title: 'LEEXMS SRL',
  client: 'LEEXMS SRL',
  category: 'Professional Services',
  location: 'Dominican Republic',
  duration: '1 week',
  technologies: ['Next.js 14', 'Tailwind CSS', 'SEO Advanced', 'Performance Optimization'],
  image: '/images/caso-estudio-web-leexms.png',
  url: 'https://leexms.com/',
  description: 'Digital accounting transformation for a professional services company in Dominican Republic.',
  challenge: 'LEEXMS needed a modern digital presence that would reflect their professional accounting services while complying with local regulations and attracting high-value clients.',
  solution: 'I developed a comprehensive web solution with Next.js 14, implementing advanced SEO strategies, performance optimization, and a professional design that builds trust and credibility.',
  results: [
    { metric: '15+ pages', description: 'Complete website with all services' },
    { metric: '95+ PageSpeed', description: 'Optimized performance score' },
    { metric: '1 week', description: 'Development timeline' },
    { metric: 'First page', description: 'Google ranking for key terms' }
  ]
};
---

<Layout title="LEEXMS Case Study - Professional Services Website | Omar Fuentes" description="Complete digital transformation for LEEXMS accounting firm in Dominican Republic. Next.js 14, advanced SEO, and professional web design delivering 95+ PageSpeed score and first-page Google rankings." keywords="accounting website dominican republic, professional services web design, next.js accounting website, seo for accounting firms, leexms case study, web development santo domingo, professional services digital transformation">
  <div class="max-w-7xl mx-auto px-6 pt-32 pb-20">
    <!-- Hero Section -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary border border-primary/20 mb-6">
        <Globe className="w-4 h-4" />
        <span class="text-sm font-medium">{project.location}</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        {project.title}
      </h1>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto mb-8">
        {project.description}
      </p>
      <div class="flex flex-wrap gap-4 justify-center mb-8">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-700 dark:text-blue-300 border border-blue-500/20">
          {project.category}
        </span>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-500/10 text-green-700 dark:text-green-300 border border-green-500/20">
          <Clock className="w-4 h-4 mr-1" /> {project.duration}
        </span>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-black rounded-xl hover:bg-primary/90 transition-all text-lg font-semibold shadow-lg shadow-primary/20"
        >
          <ExternalLink className="w-5 h-5" />
          Visit Website
        </a>
        <a 
          href="/en/contact"
          class="inline-flex items-center gap-2 px-8 py-4 border border-primary text-primary rounded-xl hover:bg-primary/10 transition-all text-lg font-semibold"
        >
          <ArrowRight className="w-5 h-5" />
          Get Similar Project
        </a>
      </div>
    </div>

    <!-- Project Image -->
    <div class="mb-20">
      <div class="relative rounded-3xl overflow-hidden border border-black/5 dark:border-white/10">
        <img 
          src={project.image}
          alt={project.title}
          width="1200"
          height="800"
          class="w-full h-auto object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
        <div class="absolute bottom-8 left-8 text-white">
          <div class="text-sm opacity-80 mb-2">Live Project</div>
          <div class="text-2xl font-bold">{project.title}</div>
        </div>
      </div>
    </div>

    <!-- Project Details -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-20">
      <div class="lg:col-span-2">
        <h2 class="text-3xl font-bold mb-8">Project Overview</h2>
        
        <div class="mb-12">
          <h3 class="text-xl font-semibold mb-4">The Challenge</h3>
          <p class="text-muted-foreground leading-relaxed">
            {project.challenge}
          </p>
        </div>

        <div class="mb-12">
          <h3 class="text-xl font-semibold mb-4">The Solution</h3>
          <p class="text-muted-foreground leading-relaxed mb-6">
            {project.solution}
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <CheckCircle className="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" />
              <span class="text-muted-foreground">Modern, responsive design optimized for all devices</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle className="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" />
              <span class="text-muted-foreground">Advanced SEO implementation for local market dominance</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle className="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" />
              <span class="text-muted-foreground">Performance optimization achieving 95+ PageSpeed score</span>
            </li>
            <li class="flex items-start gap-3">
              <CheckCircle className="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" />
              <span class="text-muted-foreground">Professional content structure for accounting services</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-xl font-semibold mb-4">Technologies Used</h3>
          <div class="flex flex-wrap gap-2">
            {project.technologies.map(tech => (
              <span class="px-3 py-1 rounded-full bg-primary/10 text-primary border border-primary/20 text-sm">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-3xl font-bold mb-8">Results</h2>
        <div class="space-y-6">
          {project.results.map((result, index) => (
            <div key={index} class="p-6 rounded-2xl border border-black/5 dark:border-white/10 bg-black/5 dark:bg-white/5">
              <div class="text-2xl font-bold text-primary mb-2">{result.metric}</div>
              <div class="text-muted-foreground">{result.description}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="text-center p-12 rounded-2xl border border-foreground/10 bg-gradient-to-br from-primary/5 to-primary/10">
      <h2 class="text-3xl font-bold mb-4">Need a Similar Project?</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto mb-8">
        I can help transform your professional services business with a modern, high-performance website that attracts clients and builds credibility.
      </p>
      <a 
        href="/en/contact"
        class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-black rounded-xl hover:bg-primary/90 transition-all text-lg font-semibold shadow-lg shadow-primary/20"
      >
        <ArrowRight className="w-5 h-5" />
        Start Your Project
      </a>
    </div>
  </div>
</Layout>
