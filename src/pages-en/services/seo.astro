---
import Layout from '~/layouts-en/Layout.astro';
import { ArrowRight } from 'lucide-react';
---

<Layout title="SEO Services - Omar Fuentes" description="Professional SEO services for USA small businesses. Improve your Google rankings and get more customers.">
  
  <div class="max-w-7xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold text-center mb-8">SEO Services</h1>
    <p class="text-xl text-center text-gray-600 mb-12">
      Professional SEO optimization for USA small businesses
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-white p-8 rounded-lg shadow-lg border border-gray-200 flex flex-col h-full">
        <h2 class="text-2xl font-bold mb-4">Local SEO</h2>
        <p class="text-gray-600 mb-6">
          Optimize your website for local search to attract customers in your specific geographic area.
        </p>
        <div class="mt-auto">
          <a href="/en/contact" class="inline-flex items-center justify-center rounded-full bg-blue-600 text-white px-6 py-3 font-semibold hover:bg-blue-700 transition-colors w-full">
            Get Quote
            <ArrowRight className="w-4 h-4 ml-2" />
          </a>
        </div>
      </div>
      
      <div class="bg-white p-8 rounded-lg shadow-lg border border-gray-200 flex flex-col h-full">
        <h2 class="text-2xl font-bold mb-4">Keyword Research</h2>
        <p class="text-gray-600 mb-6">
          Find the best keywords for your business to rank higher and attract qualified traffic.
        </p>
        <div class="mt-auto">
          <a href="/en/contact" class="inline-flex items-center justify-center rounded-full bg-blue-600 text-white px-6 py-3 font-semibold hover:bg-blue-700 transition-colors w-full">
            Get Quote
            <ArrowRight className="w-4 h-4 ml-2" />
          </a>
        </div>
      </div>
      
      <div class="bg-white p-8 rounded-lg shadow-lg border border-gray-200 flex flex-col h-full">
        <h2 class="text-2xl font-bold mb-4">Content Strategy</h2>
        <p class="text-gray-600 mb-6">
          Develop content that ranks well and converts visitors into customers for your business.
        </p>
        <div class="mt-auto">
          <a href="/en/contact" class="inline-flex items-center justify-center rounded-full bg-blue-600 text-white px-6 py-3 font-semibold hover:bg-blue-700 transition-colors w-full">
            Get Quote
            <ArrowRight className="w-4 h-4 ml-2" />
          </a>
        </div>
      </div>
    </div>
  </div>

</Layout>
