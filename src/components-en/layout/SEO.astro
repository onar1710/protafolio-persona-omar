---
interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  article?: boolean;
  noindex?: boolean;
  nofollow?: boolean;
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  type?: string;
  locale?: string;
  siteName?: string;
}

const { 
  title, 
  description, 
  keywords = '',
  image, 
  article = false, 
  noindex = false, 
  nofollow = false,
  author = 'Omar Fuentes',
  publishedTime,
  modifiedTime,
  type = 'website',
  locale = 'en_US',
  siteName = 'Omar Fuentes - Web Design & SEO Company in USA'
 } = Astro.props;
 import { siteConfig } from '~/config-en/site.config';
 
 const pathname = (Astro.url.pathname.replace(/\/$/, '') || '/'); // Keep full path: /en or /en/servicio
 const canonicalURL = new URL(pathname, Astro.site).toString();

 // Detect if this is a blog article (English or Spanish)
 const isBlogArticle = (pathname.startsWith('/blog/') || pathname.startsWith('/en/blog/'))
   && pathname !== '/blog'
   && pathname !== '/en/blog';
 
 // Generate hreflang URLs
 // NOTE: this component can be accidentally used on non-/en routes (shared layouts).
 // Make the logic resilient so hreflang never duplicates the current language URL.
 const currentPath = pathname; // /en/... or /...
 const isEnglishPage = currentPath === '/en' || currentPath.startsWith('/en/');
 const basePath = currentPath.replace(/^\/en/, '') || '/'; // language-neutral path: /, /services, /portfolio/...
 
 // Map English paths to Spanish equivalents
 const pathMappings: Record<string, string> = {
   '/': '/',
   '/services': '/servicios',
   '/pricing': '/precios',
   '/system-design': '/sistema-diseno',
   '/portfolio': '/portafolio',
   '/portfolio/projects': '/portfolio/proyectos',
   '/portfolio/ferrarykitchen': '/portfolio/ferrarycucina',
   '/portfolio/leexms': '/portfolio/leexms',
   '/portfolio/world-games': '/portfolio/mundo-gaming',
   '/portfolio/plumbing': '/portfolio/plomeria',
   '/portfolio/dog-products': '/portfolio/productos-para-perros',
   '/blog': '/blog',
   '/contact': '/contacto',
   '/about': '/sobre-mi',
   '/support': '/soporte',
   '/tools/article-outline-generator': '/herramientas/generador-estructura-articulos',
   '/tools/seo-title-generator': '/herramientas/generador-titulos-seo'
 };
 
 const reversePathMappings: Record<string, string> = Object.fromEntries(
   Object.entries(pathMappings).map(([en, es]) => [es, en])
 );
 
 const englishNeutralPath = basePath;
 const spanishPath = isEnglishPage ? (pathMappings[englishNeutralPath] || englishNeutralPath) : englishNeutralPath;
 const isPortfolioPath = englishNeutralPath === '/portfolio' || englishNeutralPath.startsWith('/portfolio/');
 const englishPath = isEnglishPage
   ? currentPath
   : ((reversePathMappings[englishNeutralPath] || (!isPortfolioPath ? englishNeutralPath : undefined))
       ? `/en${reversePathMappings[englishNeutralPath] || englishNeutralPath}`
       : undefined);
 const xDefaultUrl = isEnglishPage
   ? new URL(currentPath, Astro.site).toString()
   : new URL(spanishPath, Astro.site).toString();
 
 const hreflangUrls = {
   en: englishPath ? new URL(englishPath, Astro.site).toString() : new URL(currentPath, Astro.site).toString(),
   es: new URL(spanishPath, Astro.site).toString(),
   'x-default': xDefaultUrl,
 };

const ogImageUrl = image || siteConfig.ogImage;

function getOgImageType(url: string) {
  const lower = url.toLowerCase();
  if (lower.endsWith('.png')) return 'image/png';
  if (lower.endsWith('.webp')) return 'image/webp';
  if (lower.endsWith('.gif')) return 'image/gif';
  if (lower.endsWith('.jpeg') || lower.endsWith('.jpg')) return 'image/jpeg';
  return 'image/png';
}

const ogImageType = getOgImageType(ogImageUrl);

const robots = [
  noindex ? 'noindex' : 'index',
  nofollow ? 'nofollow' : 'follow'
].join(', ');
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" href={siteConfig.logo.src} />
<link rel="apple-touch-icon" href={siteConfig.logo.src} />
<meta name="generator" content={Astro.generator} />

 <!-- Hreflang Tags for International SEO -->
 <link rel="canonical" href={canonicalURL} />
 {!isBlogArticle && (
   <>
     <link rel="alternate" hreflang="en" href={hreflangUrls.en} />
     {hreflangUrls.es !== hreflangUrls.en && <link rel="alternate" hreflang="es" href={hreflangUrls.es} />}
     <link rel="alternate" hreflang="x-default" href={hreflangUrls['x-default']} />
   </>
 )}
 
 <!-- Robots -->
 <meta name="robots" content={robots} />
 <meta name="googlebot" content={robots} />

<!-- Primary Meta Tags -->
<title set:html={title}></title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={author} />
{keywords && <meta name="keywords" content={keywords} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(ogImageUrl, Astro.site).toString()} />
<meta property="og:image:secure_url" content={new URL(ogImageUrl, Astro.site).toString()} />
<meta property="og:image:type" content={ogImageType} />
<meta property="og:image:width" content="1280" />
<meta property="og:image:height" content="720" />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={locale} />
{article && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{article && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{article && <meta property="article:author" content={author} />}

<!-- Twitter Card -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(ogImageUrl, Astro.site).toString()} />
<meta property="twitter:image:alt" content={title} />
<meta property="twitter:creator" content="@omarfuentes052" />
<meta property="twitter:site" content="@omarfuentes052" />

<!-- LinkedIn Specific -->
<meta property="linkedin:owner" content="omarfuentes052" />
<meta property="linkedin:published_time" content={new Date().toISOString()} />

<!-- Additional Social Media -->
<meta name="image" content={new URL(ogImageUrl, Astro.site).toString()} />
<meta name="image:alt" content={title} />
<meta name="image:width" content="1280" />
<meta name="image:height" content="720" />

<!-- Facebook Specific - For large image display -->
<meta property="fb:app_id" content="" />
<meta name="twitter:image:width" content="1280" />
<meta name="twitter:image:height" content="720" />

<!-- Additional Meta Tags -->
<meta name="theme-color" content="#00008B" />
<meta name="msapplication-TileColor" content="#00008B" />
<meta name="application-name" content={siteName} />
<meta name="apple-mobile-web-app-title" content={siteName} />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />

<!-- Geographic Meta Tags for Local SEO (US) -->
<meta name="geo.region" content="US" />
<meta name="geo.placename" content="United States" />
<meta name="geo.position" content="39.8283;-98.5795" />
<meta name="ICBM" content="39.8283,-98.5795" />

<!-- Language and Region -->
<meta name="language" content="English" />
<meta name="distribution" content="global" />
<meta name="rating" content="general" />
<meta name="revisit-after" content="7 days" />
<meta http-equiv="content-language" content="en" />

<!-- Business Information for Local SEO -->
<meta name="business:contact_data:street_address" content="United States (Remote Services)" />
<meta name="business:contact_data:locality" content="United States" />
<meta name="business:contact_data:region" content="US" />
<meta name="business:contact_data:postal_code" content="00000" />
<meta name="business:contact_data:country_name" content="United States" />
<meta name="business:contact_data:email" content="contact@omarfuentes.com" />
<meta name="business:contact_data:phone_number" content="+57 310 785 1074" />
<meta name="business:contact_data:website" content="https://omarfuentes.com" />
<meta name="business:contact_data:contact_type" content="customer service" />

<!-- Service Information -->
<meta name="service:provider" content="Omar Fuentes" />
<meta name="service:type" content="Web Design, Development, SEO Services" />
<meta name="service:area" content="United States" />
<meta name="service:availability" content="nationwide" />

<!-- Industry Specific -->
<meta name="category" content="Technology, Web Design, SEO, Digital Marketing" />
<meta name="classification" content="Professional Services" />
