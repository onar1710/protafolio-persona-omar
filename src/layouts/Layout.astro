---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/globals.css';

export interface Props {
	title: string;
	description: string;
	keywords?: string;
	image?: string;
	url?: string;
}

const { title, description, keywords, image = "/og-image.webp", url } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
	<BaseHead title={title} description={description} lang="es" keywords={keywords} image={image} canonical={url} />
	<slot name="head" />
</head>
<body>
	<Header lang="es" />
	<slot />
	<Footer />
	<WhatsAppButton />
</body>
</html>
