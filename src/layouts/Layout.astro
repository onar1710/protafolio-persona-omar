---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/globals.css';

export interface Props {
	title: string;
	description: string;
	keywords?: string;
	image?: string;
	url?: string;
}

const { title, description, keywords, image = "/PAGINAS-WEB-BUCARAMAGA.webp", url } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
	<BaseHead title={title} description={description} lang="es" keywords={keywords} image={image} canonical={url} />
	<slot name="head" />
</head>
<body>
	<Header lang="es" />
	<slot />
	<Footer />
	<WhatsAppButton />
	<div
		data-cookie-banner
		class="hidden fixed bottom-4 left-4 right-4 z-[60] max-w-3xl mx-auto rounded-2xl border border-gray-200 bg-white p-5 shadow-2xl"
		style="box-shadow: 0 18px 60px rgba(15, 23, 42, 0.18);"
	>
		<div class="grid gap-3">
			<div class="font-bold text-black text-lg">Cookies</div>
			<p class="text-black text-sm leading-6">
				Usamos cookies para medir rendimiento y, si lo autorizas, mostrar anuncios personalizados. Si rechazas, se
				mostrarán anuncios no personalizados.
			</p>
			<div class="flex flex-wrap gap-3 items-center justify-between">
				<div class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
					<a class="font-semibold hover:underline" href="/politicas-cookies/">Política de Cookies</a>
					<a class="font-semibold hover:underline" href="/politica-privacidad/">Política de Privacidad</a>
				</div>
				<div class="flex flex-wrap gap-3">
					<button
						type="button"
						data-cookie-reject
						class="px-4 py-2 rounded-xl border border-gray-200 font-semibold text-black hover:bg-gray-50"
					>
						Rechazar
					</button>
					<button
						type="button"
						data-cookie-accept
						class="px-4 py-2 rounded-xl font-semibold text-white"
						style="background: var(--primary-blue);"
					>
						Aceptar
					</button>
				</div>
			</div>
		</div>
	</div>
	<script is:inline>
		(() => {
			const key = 'cookie_consent_v1';
			const banner = document.querySelector('[data-cookie-banner]');
			const acceptBtn = document.querySelector('[data-cookie-accept]');
			const rejectBtn = document.querySelector('[data-cookie-reject]');

			const readCookie = (name) => {
				const raw = document.cookie || '';
				const parts = raw.split(';');
				for (const part of parts) {
					const [k, ...rest] = part.trim().split('=');
					if (k === name) return decodeURIComponent(rest.join('=') || '');
				}
				return '';
			};

			const getConsent = () => {
				try {
					const v = localStorage.getItem(key);
					if (v) return v;
				} catch {}
				return readCookie(key) || '';
			};

			const setConsent = (value) => {
				try {
					localStorage.setItem(key, value);
				} catch {}
				const maxAge = 60 * 60 * 24 * 180;
				document.cookie = `${key}=${encodeURIComponent(value)}; Max-Age=${maxAge}; Path=/; SameSite=Lax`;

				const w = window;
				w.adsbygoogle = w.adsbygoogle || [];
				w.adsbygoogle.requestNonPersonalizedAds = value === 'granted' ? 0 : 1;
			};

			const consent = getConsent();
			if (!consent && banner) banner.classList.remove('hidden');

			const close = () => banner && banner.classList.add('hidden');

			if (acceptBtn) {
				acceptBtn.addEventListener('click', () => {
					setConsent('granted');
					close();
					location.reload();
				});
			}

			if (rejectBtn) {
				rejectBtn.addEventListener('click', () => {
					setConsent('denied');
					close();
					location.reload();
				});
			}
		})();
	</script>
</body>
</html>
