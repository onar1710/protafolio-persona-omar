---
import Header from '~/components-en/layout/Header.astro';
import Footer from '~/components-en/layout/Footer.astro';
import Analytics from '~/components/common/Analytics.astro';
import SEO from '~/components-en/layout/SEO.astro';
import Schema from '~/components/layout/Schema.astro';
import CookieConsent from '~/components/common/CookieConsent.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import VercelAnalytics from '@vercel/analytics/astro';
import '../styles/global.css';
import AnnouncementBanner from '~/components/sections/AnnouncementBanner.astro';

interface Props {
	title?: string;
	description?: string;
    keywords?: string;
    image?: string;
    article?: boolean;
    noindex?: boolean;
    nofollow?: boolean;
    children?: any;
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
}

import { siteConfig, ACTION_LINKS } from '~/config-en/site.config';

const { 
    title = siteConfig.name, 
    description = siteConfig.description, 
    keywords = '',
    image, 
    article = false,
    noindex = false,
    nofollow = false,
    publishedTime,
    modifiedTime,
    tags
} = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr" class="dark">
	<head>
        <SEO 
            title={title} 
            description={description} 
            keywords={keywords}
            image={image} 
            article={article} 
            noindex={noindex}
            nofollow={nofollow}
            publishedTime={publishedTime}
            modifiedTime={modifiedTime}
            tags={tags}
        />
        <Schema item={{
            "@context": "https://schema.org",
            "@type": "Organization",
            "@id": `${Astro.site}#organization`,
            "name": siteConfig.name,
            "url": Astro.site,
            "logo": new URL(siteConfig.logo.src, Astro.site).toString(),
            "sameAs": [
                ACTION_LINKS.social?.twitter,
                ACTION_LINKS.social?.github,
                ACTION_LINKS.social?.linkedin,
                ACTION_LINKS.social?.facebook
            ].filter(Boolean)
        }} />
         {Astro.url.pathname !== '/en' && Astro.url.pathname !== '/en/' && (
            <Schema item={{
                "@context": "https://schema.org",
                "@type": "BreadcrumbList",
                "itemListElement": Astro.url.pathname.split('/').filter(Boolean).map((part, index, arr) => ({
                    "@type": "ListItem",
                    "position": index + 1,
                    "name": part.charAt(0).toUpperCase() + part.slice(1).replace(/-/g, ' '),
                    "item": new URL(arr.slice(0, index + 1).join('/'), Astro.site).toString()
                }))
            }} />
        )}
        <style is:global define:vars={{ primary: siteConfig.primaryColor }}>
          :theme {
            --color-primary: var(--primary);
          }

          .skip-link {
            position: absolute;
            top: -40px;
            left: 0;
            background: #000;
            color: #fff;
            padding: 8px 16px;
            z-index: 100;
          }

          .skip-link:focus {
            top: 0;
          }
        </style>
        <Analytics />
        <slot name="head" />
		</head>
		<body class="min-h-screen flex flex-col antialiased bg-background text-foreground selection:bg-primary selection:text-white">
        <a href="#main-content" class="skip-link">Skip to main content</a>
        <div class="fixed inset-0 z-[-1] bg-background"></div>

        <div class="fixed top-0 w-full z-50 flex flex-col items-stretch">
            {siteConfig.announcement?.enabled && (
                <AnnouncementBanner 
                    id={siteConfig.announcement.id}
                    message="Schedule a free quote for your website."
                    link={siteConfig.announcement.link}
                    linkText="Chat on WhatsApp"
                />
            )}
            <Header />
        </div>
		<main id="main-content" tabindex="-1" data-pagefind-body>
			<slot />
		</main>
        <CookieConsent />
		<Footer />
		{import.meta.env.PROD && <SpeedInsights />}
		{import.meta.env.PROD && <VercelAnalytics />}
	</body>
</html>
