# ==========================================
# CONFIGURACIÓN DE APIs DE IA
# ==========================================

# Xiaomi AI
XIAOMI_API_ENDPOINT=https://token-plan-sgp.xiaomimimo.com/v1/chat/completions
XIAOMI_API_KEY=tu_api_key_xiaomi_aqui
XIAOMI_MODEL=mimo-v2.5-pro

# Grok AI (X.AI)
GROK_API_ENDPOINT=https://api.x.ai/v1/chat/completions
GROK_API_KEY=tu_api_key_grok_aqui
GROK_MODEL=grok-beta

# Kimi AI (Moonshot)
KIMI_API_ENDPOINT=https://api.moonshot.cn/v1/chat/completions
KIMI_API_KEY=tu_api_key_kimi_aqui
KIMI_MODEL=moonshot-v1-8k

# ==========================================
# CONFIGURACIÓN DE ENLAZADO
# ==========================================

# IA preferida: xiaomi, grok, kimi, o auto (usa la primera disponible)
PREFERRED_AI=auto

# Número mínimo de enlaces internos por artículo
MIN_LINKS=3

# Número máximo de enlaces internos por artículo
MAX_LINKS=8

# Permitir enlaces cruzados entre ES/EN (true/false)
ALLOW_CROSS_LANG=false

